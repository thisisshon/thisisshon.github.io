---
/**
 * Equity Derivatives (F&O) - /derivatives/
 * Long-form F&O guide. Built entirely from shared design-system components in
 * global.css (hero, .section/.sec-title, .card, .cat-grid, .steps, .product-page_table,
 * .risks, FaqAccordion, .cta-box). Content is the compliance-approved doc, verbatim.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/site/Breadcrumb.astro';
import FaqAccordion from '../components/sections/FaqAccordion.astro';
import { faqPageSchema, breadcrumbSchema, organizationSchema } from '../lib/seo';

// Advantages of Derivatives - numbered list rendered as a cat-grid.
const ADVANTAGES = [
  { h: 'Hedge Portfolio Risk', p: 'You can use derivatives to hedge against market volatility and protect your portfolio from adverse price movements.' },
  { h: 'Price Discovery', p: 'Derivatives reflect market expectations about future prices, helping in better forecasting and informed decision-making.' },
  { h: 'Diversification', p: 'Derivatives help diversify your investments across asset classes and strategies, reducing overall portfolio risk.' },
  { h: 'High Liquidity', p: 'Most derivative contracts are highly liquid, allowing quick entry and exit at competitive prices.' },
  { h: 'Low Transaction Costs', p: 'Trading in derivatives often involves lower transaction costs compared to investing directly in the underlying assets.' },
  { h: 'Access to Multiple Markets', p: 'Derivatives allow traders to gain exposure to a wide range of asset classes, including equities, indices, commodities, and currencies, through a single trading account.' },
];

// Disadvantages of Derivatives - numbered list rendered as a cat-grid.
const DISADVANTAGES = [
  { h: 'Leverage Your Capital', p: 'The same leverage that amplifies profits can multiply losses. A small adverse price move can wipe out your entire margin, and in Futures, losses can even exceed the initial margin deposited.' },
  { h: 'Complex Instruments', p: 'Derivatives, especially multi-leg options strategies, require a solid understanding of pricing models, Greeks (Delta, Theta, Vega), and market dynamics. They are not suitable for beginners without adequate education.' },
  { h: 'Counterparty Risk', p: 'While exchange-traded F&O in India is protected by the clearing corporation, OTC instruments like forwards and swaps carry counterparty default risk.' },
  { h: 'Expiry Pressure', p: 'Derivatives contracts have expiry dates, forcing traders to make quick decisions, which may lead to losses.' },
  { h: 'Margin Calls', p: 'If the market moves against your position, you may face margin calls requiring immediate additional funds. Failure to pay can lead to forced liquidation of your position.' },
  { h: 'Overtrading Risk', p: 'The ease of trading and leverage available in F&O can lead to overtrading, which is a leading cause of losses for retail participants.' },
];

// What are the Risks in Derivative Trading? - six SEBI-disclosed risk categories.
const RISKS = [
  { h: 'Market Risk', p: "Sudden price movements driven by economic data, RBI policy, or global events can rapidly erode your derivative position's value." },
  { h: 'Leverage Risk', p: 'Leverage amplifies both profits and losses. A 1% adverse move in the underlying can result in a 10-20% loss on your margin.' },
  { h: 'Liquidity Risk', p: 'Deep in-the-money(ITM) and out-of-the-money (OTM) options on individual stocks can have low liquidity, leading to wide bid-ask spreads and difficulty exiting at fair prices.' },
  { h: 'Basic Risk', p: "A derivative hedge may not perfectly offset the underlying asset's movement, leaving a residual risk known as basis risk." },
  { h: 'Expiry / Roll-Over Risk', p: 'Futures expire monthly. Maintaining a position beyond expiry requires rolling over, which can add costs - especially in contango markets.' },
  { h: 'Regulatory Risk', p: 'SEBI periodically updates margin requirements, position limits, and contract specs, which can directly impact your existing positions and strategies.' },
];

// Got Questions? - the first 6 FAQs from the compliance doc (display cap; the
// remainder was stripped and can be restored from the doc if needed). Feeds both
// the accordion and the FAQPage JSON-LD, so markup and schema cannot drift.
const FAQS = [
  {
    q: 'What is derivatives trading in India?',
    a: 'Derivatives trading means buying and selling contracts whose value is linked to assets like stocks, commodities, or indices. It allows traders to speculate or hedge without owning the asset directly.',
  },
  {
    q: 'Difference between futures and options?',
    a: 'Futures are binding contracts to buy/sell at a fixed price on a future date. Options give the right, but not the obligation, to buy/sell. Futures carry unlimited risk, while options limit risk to the premium paid.',
  },
  {
    q: 'What is the minimum margin required for F&O trading?',
    a: 'Margins vary by contract and volatility. For example, Nifty futures may require around ₹1.8L. Check to find out the exact requirements before placing trades.',
  },
  {
    q: 'Is derivatives trading risky for beginners?',
    a: 'Yes, because leverage magnifies both profits and losses. Beginners should start small, learn strategies, and use risk‑management tools like stop‑loss orders.',
  },
  {
    q: 'How are derivatives taxed in India?',
    a: 'Profits from F&O trading are treated as business income. They are taxed according to your income slab, and audit requirements may apply if turnover crosses SEBI thresholds.',
  },
  {
    q: 'Do I need a Demat account to trade derivatives?',
    a: 'Yes, a trading account linked with a Demat account is mandatory. This ensures compliance with SEBI regulations and smooth settlement of trades.',
  },
];

const site = Astro.site!.href;

const seo = {
  title: 'F&O Trading - Futures & Options',
  description:
    'Trade futures & options (F&O) on NSE & BSE at flat Rs 100/lot. SEBI-registered F&O advisory and margin guidance from Shriram Financial Services.',
  path: '/derivatives/',
  jsonLd: [
    faqPageSchema(FAQS.map((f) => ({ question: f.q, answer: f.a }))),
    breadcrumbSchema(
      [
        { name: 'Home', path: '/' },
        { name: 'Products', path: '/products/' },
        { name: 'Equity Derivatives', path: '/derivatives/' },
      ],
      site
    ),
    organizationSchema(site),
  ],
};
---

<BaseLayout seo={seo} mainClass="rev-rise-scale">
  <!-- ===== Hero ===== -->
  <section class="hero" id="sec-hero" data-section="hero">
    <Breadcrumb trail={[{ name: 'Products', href: '/products/' }, { name: 'Equity Derivatives' }]} />
    <div class="hero-inner" data-enter>
      <h1>Derivatives Trading in India — Futures &amp; Options Made Simple</h1>
      <p class="lead">Access real-time market data, advanced charts, Option Chain insights, and powerful trading tools to navigate the derivatives market with ease.</p>
      <div class="cta"><a class="btn-gold" href="/open-demat-account/">Start Trading Futures &amp; Options</a></div>
    </div>
  </section>

  <!-- ===== Derivatives Trading: Expand Your Trading Opportunities ===== -->
  <section class="section stack sec-light" id="sec-expand" data-section="expand" data-enter="2" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Derivatives Trading: Expand Your Trading Opportunities</h2>
      <p class="sec-lead">Looking to Trade Beyond Stocks? Expand your market opportunities with derivatives trading. Whether you're aiming to hedge risk, leverage market movements, or diversify your trading strategy, futures and options can help you trade more strategically. With Shriram Financial Services, enjoy a seamless derivatives trading experience powered by advanced tools, real-time market insights, a secure trading platform and advisory support to sharpen your strategy.</p>
      <p class="sec-lead">In India, derivatives are among the most actively traded market instruments, especially through Futures and Options (F&amp;O) contracts listed on stock exchanges.</p>
    </div>
    <div class="card">
      <h4 class="card-h">Example</h4>
      <p class="card-p">Suppose you believe a stock will rise in the coming weeks. Instead of purchasing the stock directly, you may choose a Futures or Options contract linked to that stock and potentially benefit from the anticipated price movement.</p>
    </div>
  </section>

  <!-- ===== How does Derivative Trading Works? ===== -->
  <section class="section stack sec-tint" id="sec-how" data-section="how" style="gap:56px;align-items:center;justify-content:center">
    <div class="stack" style="gap:16px;width:100%">
      <h2 class="sec-title">How does Derivative Trading Works?</h2>
      <p class="sec-lead" style="color:var(--color-text-secondary)">Derivatives trading allows traders to take positions based on the expected price movement of an underlying asset, such as a stock or index.</p>
    </div>
    <div class="steps" data-reveal-row>
      <div class="step">
        <div class="num">1</div>
        <div class="st-body"><h4>Select an instrument</h4><p>Choose a stock or index F&amp;O to trade.</p></div>
      </div>
      <div class="step-div"></div>
      <div class="step">
        <div class="num">2</div>
        <div class="st-body"><h4>Set Contract terms</h4><p>Decide on expiry date, stock price, and a lot size</p></div>
      </div>
      <div class="step-div"></div>
      <div class="step">
        <div class="num">3</div>
        <div class="st-body"><h4>Margin Deposit</h4><p>Pay a fraction of contract value as initial margin.</p></div>
      </div>
      <div class="step-div"></div>
      <div class="step">
        <div class="num">4</div>
        <div class="st-body"><h4>Exit or Settle</h4><p>Contract is settled in cash or via physical delivery</p></div>
      </div>
    </div>
  </section>

  <!-- ===== Types of Derivatives ===== -->
  <section class="section stack sec-light" id="sec-types" data-section="types" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Types of Derivatives</h2>
      <p class="sec-lead">The Indian derivatives market offers four major types of derivative instruments. Each serves a different purpose and is suited to different market participants:</p>
    </div>
    <div class="t-scroll"><div class="product-page_table t4 bordered" style="min-width:720px">
      <div class="cell th"><p>Type</p></div><div class="cell th"><p>What It Is</p></div><div class="cell th"><p>Traded On</p></div><div class="cell th"><p>Who Uses It</p></div>
      <div class="cell tb"><p class="k">Futures</p></div><div class="cell tb"><p class="v">A binding contract to buy or sell an asset at a predetermined price on a future date. Both buyer and seller are obligated to honour the contract.</p></div><div class="cell tb"><p class="v">Exchange (NSE/BSE)</p></div><div class="cell tb"><p class="v">Traders, hedgers</p></div>
      <div class="cell tb"><p class="k">Options</p></div><div class="cell tb"><p class="v">The right — but not the obligation — to buy (Call) or sell (Put) an asset at a set price before or on expiry. The buyer pays a premium for this right.</p></div><div class="cell tb"><p class="v">Exchange (NSE/BSE)</p></div><div class="cell tb"><p class="v">Investors, hedgers, traders</p></div>
    </div></div>
  </section>

  <!-- ===== Advantages of Derivatives ===== -->
  <section class="section stack sec-tint" id="sec-advantages" data-section="advantages" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Advantages of Derivatives</h2>
      <p class="sec-lead" style="color:var(--color-text-secondary)">Discover the key advantages of derivatives, which can be valuable financial instruments for traders and investors looking to manage risk, enhance portfolio efficiency, and capitalise on market opportunities.</p>
    </div>
    <div class="cat-grid cat-grid-3" data-reveal-row>
      {ADVANTAGES.map((c) => (
        <div class="cat"><h4>{c.h}</h4><p>{c.p}</p></div>
      ))}
    </div>
  </section>

  <!-- ===== Disadvantages of Derivatives ===== -->
  <section class="section stack sec-light" id="sec-disadvantages" data-section="disadvantages" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Disadvantages of Derivatives</h2>
      <p class="sec-lead">Derivatives trading comes with certain risks that every trader should understand. Being aware of these limitations can help you make informed decisions and manage your positions more effectively.</p>
    </div>
    <div class="cat-grid cat-grid-3" data-reveal-row>
      {DISADVANTAGES.map((c) => (
        <div class="cat"><h4>{c.h}</h4><p>{c.p}</p></div>
      ))}
    </div>
  </section>

  <!-- ===== How to Start Trading Derivatives? ===== -->
  <section class="section stack sec-tint" id="sec-start" data-section="start" style="gap:56px;align-items:center;justify-content:center">
    <div class="stack" style="gap:16px;width:100%">
      <h2 class="sec-title">How to Start Trading Derivatives?</h2>
      <p class="sec-lead" style="color:var(--color-text-secondary)">A simple step by step journey to start trading Futures and Options.</p>
    </div>
    <div class="steps" data-reveal-row>
      <div class="step">
        <div class="num">1</div>
        <div class="st-body"><h4>Open a Trading &amp; Demat Account</h4><p>Complete your KYC digitally (PAN, Aadhaar, bank details) and select option to activate  F&amp;O trading segment.</p></div>
      </div>
      <div class="step-div"></div>
      <div class="step">
        <div class="num">2</div>
        <div class="st-body"><h4>Complete F&amp;O Activation</h4><p>Submit any of the income proof i.e., latest 6 months Bank statements, latest Salary slip, net worth certificate etc.</p></div>
      </div>
      <div class="step-div"></div>
      <div class="step">
        <div class="num">3</div>
        <div class="st-body"><h4>Fund Your Account</h4><p>Transfer funds via NEFT, RTGS, UPI, or Net Banking to your trading account.</p></div>
      </div>
      <div class="step-div"></div>
      <div class="step">
        <div class="num">4</div>
        <div class="st-body"><h4>Choose Your  contract</h4><p>Select Futures or Options — pick the underlying asset, expiry date, and strike price.</p></div>
      </div>
      <div class="step-div"></div>
      <div class="step">
        <div class="num">5</div>
        <div class="st-body"><h4>Set Order Parameters</h4><p>enter the lot size(Quantity), Price and execute the trade.</p></div>
      </div>
      <div class="step-div"></div>
      <div class="step">
        <div class="num">6</div>
        <div class="st-body"><h4>Monitor &amp; Manage</h4><p>Track positions in real time, set stop-loss orders, and adjust or exit as the market moves.</p></div>
      </div>
      <div class="step-div"></div>
      <div class="step">
        <div class="num">7</div>
        <div class="st-body"><h4>Expiry &amp; Settlement</h4><p>In-the-money(ITM) options are settled on expiry. Futures can be rolled over or cash-settled for index contracts.</p></div>
      </div>
    </div>
    <a class="btn-gold" href="/open-demat-account/" style="align-self:center">Open Demat Account</a>
  </section>

  <!-- ===== Futures Vs Options Comparisons ===== -->
  <section class="section stack sec-light" id="sec-compare" data-section="compare" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Futures Vs Options Comparisons</h2>
    </div>
    <div class="t-scroll"><div class="product-page_table t3 bordered">
      <div class="cell th"><p>Feature</p></div><div class="cell th"><p>Futures</p></div><div class="cell th"><p>Options</p></div>
      <div class="cell tb"><p class="k">Definition</p></div><div class="cell tb"><p class="v">Contract to buy/sell at future price</p></div><div class="cell tb"><p class="v">Right to buy/sell at future price</p></div>
      <div class="cell tb"><p class="k">Obligation</p></div><div class="cell tb"><p class="v">Compulsory for both parties</p></div><div class="cell tb"><p class="v">Only compulsory for Seller</p></div>
      <div class="cell tb"><p class="k">Max Loss</p></div><div class="cell tb"><p class="v">Unlimited</p></div><div class="cell tb"><p class="v">Limited to Premium (for Buyer)</p></div>
      <div class="cell tb"><p class="k">Margin Required</p></div><div class="cell tb"><p class="v">High (Initial + Maintenance/ Exposure)</p></div><div class="cell tb"><p class="v">Low (Premium for Buyer)</p></div>
      <div class="cell tb"><p class="k">Risk Level</p></div><div class="cell tb"><p class="v">Very High</p></div><div class="cell tb"><p class="v">Moderate to High</p></div>
    </div></div>
  </section>

  <!-- ===== What are the Risks in Derivative Trading? ===== -->
  <section class="section stack sec-tint" id="sec-risks" data-section="risks" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">What are the Risks in Derivative Trading?</h2>
      <p class="sec-lead" style="color:var(--color-text-secondary)">SEBI mandates that all brokers disclose risks associated with F&amp;O trading. Every derivative trader should understand these six risk categories before committing capital:</p>
    </div>
    <div class="risks" data-reveal-row>
      {RISKS.map((r) => (
        <div class="risk"><h4>{r.h}</h4><p>{r.p}</p></div>
      ))}
    </div>
  </section>

  <!-- ===== What Is Margin in Derivative Trading? ===== -->
  <section class="section stack sec-light" id="sec-margin" data-section="margin" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">What Is Margin in Derivative Trading?</h2>
      <p class="sec-lead">Margin is the collateral you deposit with your broker to enter and maintain a Futures or Options short (sell) position. In India, margin requirements are set by SEBI and the exchanges (NSE/BSE), and are calculated using the SPAN (Standard Portfolio Analysis of Risk) system.</p>
      <p class="sec-lead">Before placing an F&amp;O trade, it is essential to understand the types of margins involved.</p>
    </div>
    <div class="stack" style="gap:32px">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">Types of Margin in F&amp;O Trading</h3>
      </div>
      <div class="t-scroll"><div class="product-page_table t2 bordered" style="grid-template-columns:repeat(2,minmax(0,1fr));min-width:640px">
        <div class="cell th"><p>Type of Margin</p></div><div class="cell th"><p>What It Is</p></div>
        <div class="cell tb"><p class="k">SPAN Margin</p></div><div class="cell tb"><p class="v">The minimum margin mandated by the exchange based on worst-case scenario analysis. Calculated using the SPAN system developed by the Chicago Mercantile Exchange (CME).</p></div>
        <div class="cell tb"><p class="k">Exposure Margin</p></div><div class="cell tb"><p class="v">An additional margin levied by the exchange over and above SPAN margin to cushion against residual risks.</p></div>
        <div class="cell tb"><p class="k">Total Margin</p></div><div class="cell tb"><p class="v">SPAN Margin + Exposure Margin = Total Initial Margin required to enter a position.</p></div>
        <div class="cell tb"><p class="k">Mark-to-Market (MTM)</p></div><div class="cell tb"><p class="v">Daily settlement of profits and losses on Futures positions basis the last settlement price. Gains are credited and losses are debited from your account daily.</p></div>
        <div class="cell tb"><p class="k">Margin Shortfall</p></div><div class="cell tb"><p class="v">If your account balance falls below the required margin (due to losses), a margin call is triggered. You must top up funds or your position may be squared off.</p></div>
        <div class="cell tb"><p class="k">Peak Margin Rules</p></div><div class="cell tb"><p class="v">SEBI's peak margin reporting requires you to maintain sufficient margin throughout the trading day, not just at end of day.</p></div>
      </div></div>
    </div>
  </section>

  <!-- ===== Got Questions? (General Questions) ===== -->
  <section class="faq-wrap sec-tint" id="sec-faq" data-section="faq">
    <div class="faq-cols">
      <div class="faq-left">
        <h2 class="faq-title">Got Questions?</h2>
        <FaqAccordion faqs={FAQS} />
      </div>
      <div class="faq-side">
        <div class="usr"><img src="/assets/user.svg" alt="" /></div>
        <div class="side-in">
          <div class="side-tx">
            <h3>Need A Clearer Direction?</h3>
            <p>Let's get in touch on a 15-minute call where we can answer any questions you may have. Our advisor will help you understand margins, expiry and risk management so you trade F&amp;O with a plan.</p>
          </div>
          <a class="btn-gold" href="/contact-us/">Book A Discovery Call</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

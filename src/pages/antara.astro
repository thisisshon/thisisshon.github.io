---
/**
 * Explore Antara - /antara/
 * NEW page. Body content is the compliance-approved "Explore Antara Page
 * Content" doc, implemented word-for-word in the shared design system: the
 * standardised olive hero (rule 7), shared section / card / bullets / cat-grid /
 * CTA / FAQ components, and a page-local ".gate" locked card (copied from
 * technical-analysis.astro) for the "Sample locked recommendations" block. Every
 * value binds to a token (rule 9).
 *
 * SEO is DERIVED (the doc carries no meta) - see the "seo" object below; the
 * title/description are flagged unconfirmed in the build report.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/site/Breadcrumb.astro';
import FaqAccordion from '../components/sections/FaqAccordion.astro';
import { faqPageSchema, breadcrumbSchema } from '../lib/seo';

// WHY ANTARA - "Four pillars" (doc verbatim: title + description + 3 bullets each).
const PILLARS = [
  {
    n: '01',
    title: 'Smart dashboards',
    body: 'Your markets, watchlists, positions and portfolio, all organised in one place.',
    bullets: [
      'Live watchlists across segments',
      'Holdings and positions at a glance',
      'Real-time portfolio tracking',
    ],
  },
  {
    n: '02',
    title: 'Plan trades in advance',
    body: 'Set GTT triggers and buy or sell options directly from the option chain.',
    bullets: [
      'GTT triggers valid for up to 365 days',
      'AMO, SL and SL-M orders',
      'Buy or sell options directly from the chain',
    ],
  },
  {
    n: '03',
    title: 'Watchlists, depth & price alerts',
    body: 'Create custom watchlists, monitor real-time market depth, and stay updated with instant price alerts.',
    bullets: [
      'Multiple named watchlists with index tracking',
      'Live market depth for any scrip',
      'Email and SMS price alerts with quick order access',
    ],
  },
  {
    n: '04',
    title: 'IPOs, start to allotment',
    body: 'Discover, apply for and track IPOs seamlessly, all from one place.',
    bullets: [
      'Explore live IPOs',
      'Apply with UPI, no cheques needed',
      'Track application status and allotment',
    ],
  },
];

// Simplify Wealth Creation - "Sample baskets" (doc verbatim: title + meta line).
const BASKETS = [
  { title: 'Diwali Picks 2025', meta: 'Samvat 2082 · Equity · 12 stocks' },
  { title: 'Smart Beta Indices ETFs', meta: 'Factor-based · ETF · 8 stocks' },
  { title: 'Regular Indices ETFs', meta: 'Broad market · ETF · 5 stocks' },
  { title: 'Gold & Silver Basket', meta: 'Precious metals · 4 stocks' },
];

// FAQ - doc verbatim (first item open). Rendered header stays "General
// Questions" (project rule 13); the doc's "FAQ" wording is not adopted.
const FAQS = [
  {
    q: 'Do I need to log in to see recommendations?',
    a: 'Yes. Expert stock recommendations including intraday calls, BTST picks and positional ideas are available only after you log in to your Antara account. A quick OTP login is all it takes.',
  },
  {
    q: 'What is an Investment Box?',
    a: 'An Investment Box is a curated, thematic basket of stocks, such as “Diwali Picks 2025” or “Gold & Silver Basket.” Each basket has a defined risk level and minimum investment and can be scheduled as a recurring SIP with one click.',
  },
  {
    q: 'Which order types does Antara support?',
    a: 'Antara supports Market, Limit, SL, SL-M, After Market Orders (AMO), and Good Till Triggered (GTT) orders valid for up to 365 days.',
  },
  {
    q: 'How is my account kept secure?',
    a: 'Your account is protected by bank-grade encryption, TOTP-based two-factor authentication and SEBI-mandated safety protocols. Trades are settled through NSCCL/ICCL clearing corporations under regulatory oversight.',
  },
];

const site = Astro.site!.href;

// DERIVED SEO (doc carries no meta) - flagged unconfirmed in the build report.
const seo = {
  title: 'Antara Trading App',
  description:
    'Antara is Shriram Financial Services’ app for investing and trading across equities, derivatives, commodities and IPOs, with expert research built in.',
  path: '/antara',
  jsonLd: [
    faqPageSchema(FAQS.map((f) => ({ question: f.q, answer: f.a }))),
    breadcrumbSchema(
      [
        { name: 'Home', path: '/' },
        { name: 'Antara', path: '/antara' },
      ],
      site
    ),
  ],
};
---

<BaseLayout seo={seo} mainClass="rev-rise-scale">
  <!-- ================= HERO (standardised, rule 7) ================= -->
  <section class="hero" id="sec-hero" data-section="hero">
    <Breadcrumb trail={[{ name: 'Antara' }]} />
    <div class="hero-inner" data-enter>
      <p class="an-eyebrow">Invest &amp; trade in one app</p>
      <h1>Smart trading, one powerful app.</h1>
      <p class="lead">Antara is Shriram Financial Services’ app for investing and trading across equities, derivatives, commodities and IPOs, with expert research built in.</p>
      <div class="cta">
        <a class="btn-gold" href="#">Get it on Google Play</a>
        <a class="btn-ghost" href="#">Download on the App Store</a>
      </div>
    </div>
  </section>

  <!-- ================= EXPERT STOCK RECOMMENDATIONS ================= -->
  <section class="section stack sec-light" id="sec-recs" data-section="recs" style="gap:56px;justify-content:center" data-enter="2">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Expert Stock Recommendations</h2>
      <p class="sec-lead">Stop guessing. Start trading with data-backed conviction. Access daily intraday, options, and long-term research calls—complete with entry, target, and potential return metrics</p>
    </div>
    <div class="stack" style="gap:24px;align-items:center;width:100%">
      <div class="card gate">
        <span class="gate-ic" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><rect x="5" y="11" width="14" height="9" rx="2" stroke="currentColor" stroke-width="1.6"></rect><path d="M8 11V8a4 4 0 0 1 8 0v3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path></svg>
        </span>
        <h3>Sample locked recommendations shown:</h3>
        <div class="gate-skel" aria-hidden="true">
          <span class="sk sk-1"></span>
          <span class="sk sk-2"></span>
          <span class="sk sk-3"></span>
        </div>
        <p>Unlock the recommendations — Log in or sign-up to view all expert calls with full target details and potential returns.</p>
        <div class="gate-cta">
          <a class="btn-gold" href="#">Log in/sign-up to view all<svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
        </div>
      </div>
    </div>
  </section>

  <!-- ================= WHY ANTARA ================= -->
  <section class="section stack sec-tint" id="sec-why" data-section="why" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Built for serious traders &amp; investors.</h2>
      <p class="sec-lead" style="color:var(--color-text-secondary)">Four pillars that make Antara a complete trading platform for Indian markets.</p>
    </div>
    <div class="row-2">
      <div class="card">
        <h4 class="card-h">{PILLARS[0].n}. {PILLARS[0].title}</h4>
        <p class="card-p">{PILLARS[0].body}</p>
        <ul class="bullets">{PILLARS[0].bullets.map((b) => <li>{b}</li>)}</ul>
      </div>
      <div class="card">
        <h4 class="card-h">{PILLARS[1].n}. {PILLARS[1].title}</h4>
        <p class="card-p">{PILLARS[1].body}</p>
        <ul class="bullets">{PILLARS[1].bullets.map((b) => <li>{b}</li>)}</ul>
      </div>
    </div>
    <div class="row-2">
      <div class="card">
        <h4 class="card-h">{PILLARS[2].n}. {PILLARS[2].title}</h4>
        <p class="card-p">{PILLARS[2].body}</p>
        <ul class="bullets">{PILLARS[2].bullets.map((b) => <li>{b}</li>)}</ul>
      </div>
      <div class="card">
        <h4 class="card-h">{PILLARS[3].n}. {PILLARS[3].title}</h4>
        <p class="card-p">{PILLARS[3].body}</p>
        <ul class="bullets">{PILLARS[3].bullets.map((b) => <li>{b}</li>)}</ul>
      </div>
    </div>
  </section>

  <!-- ================= SIMPLIFY WEALTH CREATION ================= -->
  <section class="section stack sec-light" id="sec-baskets" data-section="baskets" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Simplify Wealth Creation</h2>
      <p class="sec-lead">Curated thematic baskets</p>
      <p class="sec-lead">Don't just pick stocks; invest in themes. Our curated baskets are designed to match your risk appetite and investment goals.</p>
    </div>
    <ul class="bullets">
      <li>Themed baskets with a clear risk level and minimum investment</li>
      <li>Scheduled SIPs that run automatically</li>
      <li>One-click investment, auto-rebalancing and one-tap exit</li>
    </ul>
    <a class="btn-gold" href="#" style="align-self:flex-start">Explore all baskets<svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
    <div class="stack" style="gap:16px">
      <h3 class="sub-title">Sample baskets:</h3>
    </div>
    <div class="cat-grid" data-reveal-row>
      {BASKETS.map((b) => (
        <div class="cat">
          <h4>{b.title}</h4>
          <p>{b.meta}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ================= CTA BAND ================= -->
  <section class="cta-sec sec-tint" id="sec-cta" data-section="cta">
    <div class="cta-box">
      <div class="ct-tt">
        <h3>Ready to Transform Your Trading Journey</h3>
        <p class="ct-sub">Join a community of successful traders. Backed by 50 years of Shriram trust.</p>
      </div>
      <div class="cta"><a class="btn-gold" href="/open-demat-account">Open Demat Account</a></div>
    </div>
  </section>

  <!-- ================= ANYWHERE YOU ARE ================= -->
  <section class="section stack sec-light" id="sec-platforms" data-section="platforms" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Anywhere you are</h2>
      <p class="sec-lead">Android, iPhone, or the browser.</p>
    </div>
    <div class="cat-grid cat-grid-3" data-reveal-row>
      <div class="cat"><h4>Android</h4><p>Get it on Google Play</p></div>
      <div class="cat"><h4>iPhone &amp; iPad</h4><p>Download on the App Store</p></div>
      <div class="cat"><h4>Web</h4><p>Trade from any browser</p></div>
    </div>
  </section>

  <!-- ================= GENERAL QUESTIONS ================= -->
  <!-- Rendered header stays "General Questions" (project rule 13); the doc's
       "FAQ" wording is intentionally not adopted. -->
  <section class="faq-wrap sec-tint" id="sec-faq" data-section="faq">
    <div class="faq-cols">
      <div class="faq-left">
        <h2 class="faq-title">Got Questions?</h2>
        <FaqAccordion faqs={FAQS} />
      </div>
      <div class="faq-side">
        <div class="usr"><img src="/assets/user.svg" alt="" /></div>
        <div class="side-in">
          <div class="side-tx">
            <h3>Need A Clearer Direction? </h3>
            <p>Let's get in touch on a 15-minute call where we can answer any questions you may have. Our advisor will help map your wealth mix and show what a dedicated advisor would do differently.</p>
          </div>
          <a class="btn-gold" href="/contact-us">Book A Discovery Call</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ===== Explore Antara - page-local styles only. Every value binds to a
     design token. The hero eyebrow mirrors the Karnataka page pattern; the
     ".gate" locked card is copied verbatim from technical-analysis.astro
     (the sanctioned "locked / login to unlock" pattern). ===== */
  .section,
  .cta-sec {
    scroll-margin-top: 96px;
  }

  /* hero eyebrow (mirrors karnataka .kb-eyebrow) */
  .an-eyebrow {
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--color-gold-400);
    margin-bottom: 16px;
    max-width: var(--hero-text-w);
  }

  /* ===== Locked recommendations card (copied from technical-analysis.astro) ===== */
  .gate {
    max-width: 640px; width: 100%; display: flex; flex-direction: column;
    align-items: center; text-align: center; gap: 8px;
  }
  .gate-ic {
    width: 48px; height: 48px; flex: none; border-radius: 999px;
    background: var(--color-text-heading-dark); color: var(--color-white);
    display: inline-flex; align-items: center; justify-content: center; margin-bottom: 16px;
  }
  .gate h3 { font-weight: 500; font-size: 20px; color: var(--color-text-primary); }
  .gate p { font-weight: 400; font-size: 14px; color: var(--color-text-muted); max-width: 400px; }
  .gate-cta { display: flex; gap: 16px; flex-wrap: wrap; justify-content: center; margin-top: 24px; }

  /* skeleton stand-in for the locked sample calls (neutral gray tokens) */
  .gate-skel { width: 100%; max-width: 360px; display: flex; flex-direction: column; gap: 12px; margin: 8px 0; }
  .gate-skel .sk { display: block; height: 8px; border-radius: 999px; background: var(--color-gray-150); }
  .gate-skel .sk-1 { width: 100%; }
  .gate-skel .sk-2 { width: 80%; align-self: center; }
  .gate-skel .sk-3 { width: 60%; align-self: center; }

  @media (max-width: 768px) {
    .gate-cta .btn-gold { width: 100%; }
  }
</style>

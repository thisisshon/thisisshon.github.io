---
/**
 * Technical Research — /technical-analysis/
 * Research sub-page (nested route → imports at ../../ depth). Built to the
 * Figma "Technical Research" wireframe (V4, node 977-6333) but rendered
 * entirely in the shared design system: the standardised olive hero (rule 7),
 * shared section / card / check-list / FAQ components, and page-local styles
 * ONLY for the two genuinely-new blocks — the gated "note" card and the
 * research-report card grid. Every value binds to a token (rule 9).
 *
 * The report grid is DATA-DRIVEN (src-of-truth: REPORTS below) so the same
 * template scales to thousands of report instances — the scale North Star.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import FaqAccordion from '../components/sections/FaqAccordion.astro';
import { faqPageSchema } from '../lib/seo';

// Research reports — verbatim from the wireframe. `kind` maps to a badge tint;
// `locked` gates the card (skeleton + lock overlay + unlock bar); unlocked
// cards show the publisher header + a PDF download instead.
const REPORTS = [
  {
    badge: 'Cautious', kind: 'warn', date: '19 May 2026', pages: '3 pages',
    title: 'Daily EQ Trend — Nifty Recovers from Demand Zone; 24,000 Remains Key Trigger',
    tags: 'Equity | Index', author: 'Brijesh Ail, AVP Research', locked: false,
  },
  {
    badge: 'Positive', kind: 'pos', date: '19 May 2026', pages: '3 pages',
    title: 'Daily Commodity Trend — Gold near 10 DEMA Support; Crude Momentum Positive',
    tags: 'Commodity | MCX', author: 'Brijesh Ail, AVP Research', locked: false,
  },
  {
    badge: 'Range-Bound', kind: 'warn', date: '16 May 2026', pages: '4 pages',
    title: 'Bank Nifty Weekly — 61.8% Fib Support Held; Breakout Above 54,800 Awaited',
    tags: 'Equity | Banking', author: 'Brijesh Ail, AVP Research', locked: true,
  },
  {
    badge: 'Buy', kind: 'info', date: '15 May 2026', pages: '3 pages',
    title: 'MCX Zinc & Crude Oil Trading Strategy — Entry Levels and Stop Loss Zones',
    tags: 'Commodity | Strategy', author: 'Brijesh Ail, AVP Research', locked: true,
  },
  {
    badge: 'Data Report', kind: 'info', date: '14 May 2026', pages: '2 pages',
    title: 'Nifty 50 Pivot Table — Full S1 S2 R1 R2 Levels for All 50 Constituents',
    tags: 'Equity | Pivot Data', author: 'Research Desk', locked: true,
  },
  {
    badge: 'Accumulate', kind: 'pos', date: '13 May 2026', pages: '5 pages',
    title: 'IT Sector Breakout Watch — TechM +4.85%, Infosys +2.38% Lead Sectoral Rally',
    tags: 'Equity | Sectoral', author: 'Brijesh Ail, AVP Research', locked: true,
  },
];

// What Technical Research contains — the checklist (wireframe, verbatim).
const CONTAINS = [
  'Daily support, resistance and pivot levels for key indices and commodities',
  'Candlestick and pattern reads — rounding tops, trend reversals, breakouts',
  'Derivatives strategy notes built for F&O traders',
  'Intraday and positional trade ideas, with entry, target and stop-loss',
  'A level that would make us review the call — stated upfront, not after',
];

// Frequently Asked Questions — first item open (site convention).
const FAQS = [
  {
    q: 'What is Shriram Research?',
    a: 'Shriram Research is the equity and commodity research division of Shriram Financial Services. We publish daily technical trend reports, fundamental stock analysis, and monthly mutual fund industry reviews — all produced by SEBI-registered analysts.',
  },
  {
    q: 'What types of research reports are available?',
    a: 'Technical Research covers daily index and commodity trend notes, weekly derivatives and F&O strategies, pivot tables with support and resistance levels, and sector breakout watches. Each report carries a clear stance, the levels that matter and the trigger that would change the view.',
  },
  {
    q: 'Do I need to login to read the reports?',
    a: 'A short preview of every report is open to everyone. Full reports — with detailed levels, entry, target and stop-loss — unlock when you log in to the Antara app or open a Shriram demat account.',
  },
  {
    q: 'How do I open a demat account to access research?',
    a: 'Opening a Shriram demat account takes only a few minutes online. Submit your PAN, complete KYC with Aadhaar and link your bank account — once verified, every research PDF, pivot table and trade idea is unlocked in full.',
  },
  {
    q: 'Is the research free for clients?',
    a: 'Yes. Once you hold a Shriram demat account you get unlimited access to the full research library — all technical notes, pivot tables and trading ideas — at no extra charge.',
  },
  {
    q: 'How often are reports published?',
    a: 'Daily trend notes for indices and commodities go out before the market opens on every trading day. Weekly derivatives strategies, pivot tables and sector watches are published on a fixed schedule through the week.',
  },
];

const seo = {
  title: 'Technical Research',
  description:
    'Daily technical research from SEBI-registered analysts — support and resistance, pivot levels, candlestick reads and F&O strategy notes across indices, stocks, currencies and commodities.',
  path: '/technical-analysis/',
  jsonLd: [faqPageSchema(FAQS.map((f) => ({ question: f.q, answer: f.a })))],
};
---

<BaseLayout seo={seo}>
  <!-- ================= HERO (standardised, rule 7) ================= -->
  <section class="hero" id="sec-hero" data-section="hero">
    <div class="hero-inner">
      <h1>Technical <span class="g">Research</span></h1>
      <p class="lead">Where price is the only fundamental that matters today. We read the chart — support, resistance and the level that would change the view.</p>
      <div class="cta"><a class="btn-gold" href="/open-demat-account/">Open Demat Account</a></div>
      <div class="hero-feats">
        <div class="feats">
          <div class="feat"><span class="tk" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span><span class="lb">&nbsp;SEBI-registered analysts</span></div>
          <div class="feat"><span class="tk" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span><span class="lb">&nbsp;Daily support &amp; resistance</span></div>
          <div class="feat"><span class="tk" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span><span class="lb">&nbsp;Entry, target &amp; stop-loss</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================= WHAT IS TECHNICAL RESEARCH ================= -->
  <section class="section stack sec-light" id="sec-what" data-section="what" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">What Is Technical Research</h2>
      <p class="sec-lead">Technical Research reads the chart, not the balance sheet — price action, volume, moving averages and the patterns they form, across equity indices, individual stocks, currencies and commodities. The output is short and dated: today's support and resistance, the level that would change the view, and what we're watching the chart for next.</p>
    </div>
  </section>

  <!-- ================= WHAT IT CONTAINS ================= -->
  <section class="section stack sec-tint" id="sec-contains" data-section="contains" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">What Technical Research Contains</h2>
      <p class="sec-lead" style="color:var(--color-text-secondary)">Every desk note is built the same way — actionable levels, the pattern behind them, and the risk stated upfront. Here's what lands in your inbox each trading day.</p>
    </div>
    <div class="card" style="display:flex;flex-direction:column">
      <div class="check-list">
        {CONTAINS.map((item, i) => (
          <>
            {i > 0 && <div class="check-sep"></div>}
            <div class="check-row">
              <span class="ck" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span>
              <p class="tx">{item}</p>
            </div>
          </>
        ))}
      </div>
    </div>
  </section>

  <!-- ================= OPEN DEMAT ACCOUNT — gated daily note ================= -->
  <section class="section stack sec-light" id="sec-note" data-section="note" style="gap:40px;align-items:center;justify-content:center">
    <h2 class="sec-title" style="text-align:center">Open Demat Account</h2>
    <div class="card gate">
      <span class="gate-ic" aria-hidden="true">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><rect x="5" y="11" width="14" height="9" rx="2" stroke="currentColor" stroke-width="1.6"></rect><path d="M8 11V8a4 4 0 0 1 8 0v3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path></svg>
      </span>
      <h3>Today's Technical Note is ready.</h3>
      <p>Log in to read live levels and trade ideas, or open a demat account to get started.</p>
      <div class="gate-cta">
        <a class="btn-ghost" href="#">Login</a>
        <a class="btn-gold" href="/open-demat-account/">Open Demat Account</a>
      </div>
    </div>
  </section>

  <!-- ================= REPORT GRID ================= -->
  <section class="section stack sec-tint" id="sec-notes" data-section="notes" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px;align-items:center;text-align:center">
      <h2 class="sec-title">Technical Research Notes All You Need In One Place</h2>
      <p class="sec-lead" style="color:var(--color-text-secondary);max-width:720px">Daily trend notes, pivot tables and strategy calls — each with a clear stance and the levels that matter. Preview any report; unlock the full PDF with a demat account.</p>
    </div>

    <div class="notes-grid">
      {REPORTS.map((r) => (
        <article class={r.locked ? 'rcard locked' : 'rcard'}>
          <div class="rcard-preview">
            <div class="rcard-skel" aria-hidden="true">
              <div class="rcard-pub">
                <span class="pub-ic"><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M7 3h7l4 4v14H7z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"></path><path d="M14 3v4h4" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"></path></svg></span>
                <span class="pub-tx"><b>SHRIRAM RESEARCH</b><small>SEBI Reg. INH000001384</small></span>
              </div>
              <span class="sk sk-1"></span>
              <span class="sk sk-2"></span>
              <span class="sk-row"><span class="sk sk-a"></span><span class="sk sk-b"></span></span>
              <span class="sk sk-3"></span>
            </div>
            {r.locked && (
              <div class="rcard-lock">
                <span class="lock-ic" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><rect x="5" y="11" width="14" height="9" rx="2" stroke="currentColor" stroke-width="1.6"></rect><path d="M8 11V8a4 4 0 0 1 8 0v3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path></svg></span>
                <span class="lock-tx">Login to Access</span>
              </div>
            )}
            <span class="rcard-pages"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M7 3h7l4 4v14H7z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"></path><path d="M14 3v4h4" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"></path></svg>{r.pages}</span>
          </div>

          <div class="rcard-body">
            <div class="rcard-meta">
              <span class={`rbadge rbadge--${r.kind}`}>{r.badge}</span>
              <span class="rcard-date">{r.date}</span>
            </div>
            <h3 class="rcard-title">{r.title}</h3>
            <div class="rcard-foot">
              <span class="rcard-by">
                <span class="rcard-tags">{r.tags}</span>
                <span class="rcard-author">{r.author}</span>
              </span>
              {r.locked ? (
                <a class="rcard-link" href="#"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"></path><circle cx="12" cy="12" r="2.5" stroke="currentColor" stroke-width="1.5"></circle></svg>Preview</a>
              ) : (
                <a class="rcard-link" href="#"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 4v10m0 0 4-4m-4 4-4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path><path d="M5 19h14" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path></svg>PDF</a>
              )}
            </div>
          </div>

          {r.locked && (
            <a class="rcard-action" href="/open-demat-account/">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="5" y="11" width="14" height="9" rx="2" stroke="currentColor" stroke-width="1.6"></rect><path d="M8 11V8a4 4 0 0 1 8 0v3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path></svg>
              <span>Open Demat to Unlock Full Report</span>
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M2 8h11M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path></svg>
            </a>
          )}
        </article>
      ))}
    </div>

    <!-- Unlock band — the wireframe's blue CTA, rendered in the site's dark
         focus-band palette (blue is functional-only in the token system). -->
    <div class="unlock">
      <div class="unlock-tx">
        <h3>Unlock All Reports + Trading Ideas</h3>
        <p>Open your Shriram demat account and get free, unlimited access to all research PDFs, pivot tables, analyst webinars and model portfolios.</p>
      </div>
      <div class="unlock-cta">
        <a class="btn-gold" href="/open-demat-account/">Open Demat Account — Free</a>
        <a class="btn-outline" href="#">Login to Existing Account</a>
      </div>
    </div>
  </section>

  <!-- ================= FREQUENTLY ASKED QUESTIONS ================= -->
  <!-- Its OWN section, on the lighter surface so it reads as distinct from the
       (tinted) notes section above. Site-standard two-column FAQ: accordion
       left + discovery-call side card right (shared components). -->
  <section class="faq-wrap sec-light" id="sec-faq" data-section="faq">
    <div class="faq-cols">
      <div class="faq-left">
        <h2 class="faq-title">General Questions</h2>
        <FaqAccordion faqs={FAQS} />
      </div>
      <div class="faq-side">
        <div class="usr"><img src="/assets/user.svg" alt="" /></div>
        <div class="side-in">
          <div class="side-tx">
            <h3>Need A Clearer Direction? </h3>
            <p>Let's get in touch on a 15-minute call where we can answer any questions you may have. Our advisor will help map your wealth mix and show what a dedicated research-led plan would do differently.</p>
          </div>
          <a class="btn-gold" href="/contact-us/">Book A Discovery Call</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ================= FINAL CTA ================= -->
  <section class="cta-sec sec-tint" id="sec-final-cta" data-section="final-cta">
    <div class="cta-box">
      <div class="ct-tt">
        <h3>Read the Chart With Us</h3>
        <p class="ct-sub">Open your demat account in minutes and unlock every technical note, pivot table and trade idea.</p>
      </div>
      <a class="btn-gold" href="/open-demat-account/">Open Demat Account</a>
    </div>
  </section>
</BaseLayout>

<style>
  /* ===== Technical Research — page-local components only. Every value binds
     to a design token; the two genuinely-new blocks are the gated note card
     and the research-report grid. Section/hero/card/check-list/FAQ/CTA are all
     shared components from global.css. ===== */
  .section,
  .cta-sec {
    scroll-margin-top: 96px;
  }

  /* The FAQ sits on --sec-light, so the block needs a defined edge: stroke the
     accordion AND the helper side card together (background-dependent rule —
     same as /calculators/sip/). */
  .faq-acc { border: 1px solid var(--color-border-card); padding: 1px; }
  .faq-side { border: 1px solid var(--color-border-card); }

  /* ===== Gated daily-note card ===== */
  .gate {
    max-width: 640px; width: 100%; display: flex; flex-direction: column;
    align-items: center; text-align: center; gap: 8px;
  }
  .gate-ic {
    width: 48px; height: 48px; flex: none; border-radius: 999px;
    background: var(--color-text-heading-dark); color: var(--color-white);
    display: inline-flex; align-items: center; justify-content: center; margin-bottom: 16px;
  }
  .gate h3 { font-weight: 500; font-size: 20px; color: var(--color-text-primary); }
  .gate p { font-weight: 400; font-size: 14px; color: var(--color-text-muted); max-width: 400px; }
  .gate-cta { display: flex; gap: 16px; flex-wrap: wrap; justify-content: center; margin-top: 24px; }

  /* ===== Research-report grid ===== */
  .notes-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 32px; width: 100%; }
  .rcard {
    display: flex; flex-direction: column;
    background: var(--color-surface-card); border: 1px solid var(--color-border-card);
    border-radius: 24px; overflow: hidden;
  }

  /* preview pane (publisher header + skeleton, or lock overlay when gated) */
  .rcard-preview { position: relative; height: 184px; padding: 24px; overflow: hidden; }
  .rcard-skel { display: flex; flex-direction: column; gap: 12px; }
  .rcard.locked .rcard-skel { opacity: 0.45; } /* state dim — sanctioned opacity use (rule 5) */
  .rcard-pub { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; }
  .rcard-pub .pub-ic { width: 24px; height: 24px; flex: none; border-radius: 4px; background: var(--color-surface-section-tint); color: var(--color-text-heading-dark); display: inline-flex; align-items: center; justify-content: center; }
  .rcard-pub .pub-ic svg { width: 16px; height: 16px; }
  .rcard-pub .pub-tx { display: flex; flex-direction: column; }
  .rcard-pub b { font-weight: 700; font-size: 10px; letter-spacing: 1px; color: var(--color-text-heading-dark); }
  .rcard-pub small { font-weight: 400; font-size: 10px; color: var(--color-text-faint); }
  /* skeleton bars — neutral gray tokens standing in for report body text */
  .sk { display: block; height: 8px; border-radius: 999px; background: var(--color-gray-150); }
  .sk-1 { width: 100%; }
  .sk-2 { width: 86%; }
  .sk-3 { width: 72%; }
  .sk-row { display: flex; gap: 8px; }
  .sk-a { flex: 0 0 40%; background: var(--color-gray-200); }
  .sk-b { flex: 1 1 auto; }

  /* lock overlay (gated cards) — blue is the functional link token */
  .rcard-lock { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8px; }
  .rcard-lock .lock-ic { width: 40px; height: 40px; border-radius: 999px; background: var(--color-link); color: var(--color-white); display: inline-flex; align-items: center; justify-content: center; }
  .rcard-lock .lock-tx { font-weight: 600; font-size: 14px; color: var(--color-link); }

  .rcard-pages { position: absolute; right: 16px; bottom: 16px; display: inline-flex; align-items: center; gap: 4px; padding: 4px 8px; border: 1px solid var(--color-border-card); border-radius: 999px; background: var(--color-surface-card); font-weight: 400; font-size: 12px; color: var(--color-text-muted); }
  .rcard-pages svg { width: 16px; height: 16px; flex: none; }

  /* body */
  .rcard-body { flex: 1; display: flex; flex-direction: column; gap: 16px; padding: 24px; border-top: 1px solid var(--color-border-hairline); }
  .rcard-meta { display: flex; align-items: center; justify-content: space-between; gap: 8px; }
  .rbadge { padding: 4px 8px; border-radius: 999px; font-weight: 600; font-size: 12px; text-transform: uppercase; letter-spacing: 0.5px; white-space: nowrap; }
  /* badge tints — all bind to tokens (rule 9). The blue tint is the shared
     --color-surface-info-tint (was a page-local literal). */
  .rbadge--pos { background: var(--color-success-tint); color: var(--color-success-strong); }
  .rbadge--warn { background: var(--color-gold-100); color: var(--color-gold-950); }
  .rbadge--info { background: var(--color-surface-info-tint); color: var(--color-link); }
  .rcard-date { font-weight: 400; font-size: 12px; color: var(--color-text-tertiary); white-space: nowrap; }
  .rcard-title { font-weight: 500; font-size: 18px; color: var(--color-text-primary); }
  .rcard-foot { margin-top: auto; display: flex; align-items: flex-end; justify-content: space-between; gap: 16px; }
  .rcard-by { display: flex; flex-direction: column; gap: 4px; min-width: 0; }
  .rcard-tags { font-weight: 400; font-size: 12px; color: var(--color-text-tertiary); }
  .rcard-author { font-weight: 400; font-size: 12px; color: var(--color-text-muted); }
  .rcard-link { display: inline-flex; align-items: center; gap: 8px; flex: none; font-weight: 500; font-size: 12px; color: var(--color-link); }
  .rcard-link svg { width: 16px; height: 16px; }
  .rcard-link:hover { text-decoration: underline; }

  /* unlock bar at card foot (gated cards) — shared light-blue info tint */
  .rcard-action { display: flex; align-items: center; justify-content: center; gap: 8px; padding: 16px 24px; background: var(--color-surface-info-tint); border-top: 1px solid var(--color-border-hairline); color: var(--color-link); font-weight: 600; font-size: 14px; }
  .rcard-action svg { width: 16px; height: 16px; flex: none; }
  /* nudge the trailing arrow on hover (matches the site's .appr / .pcard language) */
  .rcard-action svg:last-child { transition: transform 0.25s ease; }
  .rcard-action:hover svg:last-child { transform: translateX(4px); }

  /* ===== Unlock band — dark focus band (parity with the site's .rpt pattern);
     the wireframe's saturated blue is remapped to the olive focus palette so
     the page stays inside the one token set. Solid hex only. ===== */
  .unlock {
    width: 100%; border-radius: 24px; padding: 48px var(--container-pad);
    background: radial-gradient(125% 210% at 100% -8%, var(--color-olive-600) 0%, var(--color-olive-800) 50%, var(--color-charcoal-850) 100%);
    display: flex; align-items: center; justify-content: space-between; gap: 32px; flex-wrap: wrap;
  }
  .unlock-tx { display: flex; flex-direction: column; gap: 12px; max-width: 640px; }
  .unlock-tx h3 { font-weight: 500; font-size: 28px; color: var(--color-white); }
  .unlock-tx p { font-weight: 400; font-size: 16px; color: var(--color-text-on-dark-lead); }
  /* .unlock-cta buttons use the shared .btn-gold + .btn-outline (global.css);
     both already size to var(--cta-w), so no width rule is needed here. */
  .unlock-cta { display: flex; gap: 16px; flex-wrap: wrap; }

  /* ===== responsive ===== */
  @media (max-width: 1024px) {
    .notes-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 768px) {
    .unlock-tx h3 { font-size: clamp(22px, 5.6vw, 28px); }
    .rcard-title { font-size: 16px; }
    .unlock-cta { width: 100%; }
    .unlock-cta .btn-gold, .unlock-cta .btn-outline { width: 100%; flex: 1 1 100%; }
    .gate-cta .btn-ghost, .gate-cta .btn-gold { width: 100%; }
    /* bump the publisher badge off 10px for readability on phones —
       raise the pair together so the eyebrow/reg hierarchy is preserved */
    .rcard-pub b, .rcard-pub small { font-size: 12px; }
  }
  @media (max-width: 640px) {
    .notes-grid { grid-template-columns: 1fr; }
  }
</style>

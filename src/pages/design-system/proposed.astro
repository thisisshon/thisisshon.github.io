    toks: [
      { token: 'color-sage-900', role: 'overlay headings / view-all. Absorbs 3 near-dupes' },
      { token: 'color-sage-800', role: 'legacy --ink-2' },
      { token: 'color-sage-700', role: 'secondary text. Absorbs #6d6e6a' },
      { token: 'color-sage-600', role: 'card body text (legacy --muted)' },
      { token: 'color-sage-500', role: 'footer copyright' },
      { token: 'color-sage-450', role: '.appr index, breadcrumb sep. Absorbs #8d8e84' },
      { token: 'color-sage-400', role: 'footer links (legacy --muted-2)' },
      { token: 'color-sage-300', role: 'footer contact / socials' },
      { token: 'color-sage-250', role: 'disabled field ink' },

---
/**
 * Design System — "What is suggested" · /design-system/proposed/
 * THE Figma artifact. The consolidated, duplication-proofed system, rendered
 * LIVE from the tokens in styles.css. Every colour chip / type specimen / spacing
 * bar / component below reads its value from a `var(--token)` — so this doc can
 * never drift from the stylesheet. Internal tooling docs (noindex).
 *
 * INVARIANT: chips MUST use live tokens (style={`background: var(--...)`}) — never
 * a hardcoded hex. Token NAMES + roles below are transcribed from global.css.
 * Values that Tailwind currently tree-shakes out of :root carry a var() FALLBACK
 * via cv() so the live token always wins when present (see the FALLBACK note).
 */
import BaseLayout from '../../layouts/BaseLayout.astro';

const seo = {
  title: 'Design System — What Is Suggested (Live Token Reference)',
  description:
    'The consolidated Shriram design system rendered live from styles.css: primitive → semantic → component colour tokens, the type scale, 8px spacing + radii, shadows, motion and a component gallery — structured to map 1:1 onto Figma variables.',
  path: '/design-system/proposed/',
  noindex: true,
};

/* Tokens global.css does not yet reference get tree-shaken out of :root by
   Tailwind v4, so `var(--token)` would resolve empty. FALLBACK gives those the
   audited literal as a var() fallback — the LIVE token still wins whenever it
   is present, so nothing is hardcoded in place of a live value. Tokens absent
   from this map are live-retained and need no fallback.
   `cv(token)` → `var(--token[, literal])`. */
const FALLBACK: Record<string, string> = {
  // colour primitives global.css doesn't currently paint with
  'color-olive-500': '#4d6710',
  'color-charcoal-825': '#202318',
  'color-gray-250': '#dddddd',
  'color-cream-150': '#fefaf0',
  'color-cream-450': '#fdf4dc',
  // semantic roles not yet painted
  'color-surface-footer-home': '#0a0b07',
  'color-text-on-dark': '#ffffff',
  'color-action-primary-hover': '#d4982a',
  'color-success-tint': '#dbf0e2',
  'color-danger': '#ff3236',
  // type scale (global.css uses raw px in its component layer)
  'text-2xs': '10px', 'text-xs': '12px', 'text-sm': '14px', 'text-base': '16px',
  'text-lg': '18px', 'text-xl': '20px', 'text-2xl': '24px', 'text-3xl': '28px',
  'text-4xl': '32px', 'text-5xl': '40px',
  // weights
  'font-weight-light': '300', 'font-weight-normal': '400', 'font-weight-medium': '500',
  'font-weight-semibold': '600', 'font-weight-bold': '700', 'font-weight-extrabold': '800',
  // radii
  'radius-xs': '2px', 'radius-sm': '4px', 'radius-md': '8px', 'radius-lg': '12px',
  'radius-xl': '16px', 'radius-2xl': '20px', 'radius-3xl': '24px', 'radius-full': '999px',
  // shadows
  'shadow-control': '0 1px 4px rgba(0,0,0,0.18)',
  'shadow-glow-gold': '0 18px 40px -12px rgba(243,184,63,0.3)',
  'shadow-ring-gold': '0 0 0 4px rgba(224,168,46,0.18)',
  'shadow-glass': '0 8px 40px rgba(0,0,0,0.08), inset 0 1px rgba(255,255,255,0.6)',
};
const cv = (token: string): string =>
  FALLBACK[token] ? `var(--${token}, ${FALLBACK[token]})` : `var(--${token})`;

/* ---- Primitive colour families. `token` renders LIVE via var(--token). ---- */
type Tok = { token: string; role: string };

const families: { name: string; tint?: boolean; toks: Tok[] }[] = [
  {
    name: 'Gold — brand primary',
    toks: [
      { token: 'color-gold-100', role: 'warm chip / step-pill bg' },
      { token: 'color-gold-200', role: 'slider accent (sip)' },
      { token: 'color-gold-300', role: 'input focus border (field-bd-active)' },
      { token: 'color-gold-400', role: 'THE brand gold — CTAs, highlights. Absorbs #f2b83f' },
      { token: 'color-gold-500', role: 'step numbers, gradient stop (legacy --gold)' },
      { token: 'color-gold-600', role: 'gold hover. Absorbs #c79a38' },
      { token: 'color-gold-950', role: 'legacy --gold-ink' },
    ],
  },
  {
    name: 'Olive — brand secondary',
    toks: [
      { token: 'color-olive-950', role: 'deep olive — dark cards, .to-top. Absorbs #1a2010' },
      { token: 'color-olive-925', role: 'dark-card hover bg' },
      { token: 'color-olive-900', role: 'THE brand olive — titles, button ink, icons. Absorbs #2d3813' },
      { token: 'color-olive-800', role: 'hero / sidebar gradient middle stop' },
      { token: 'color-olive-700', role: 'dark-card hover border' },
      { token: 'color-olive-600', role: 'hero gradient start, sip invested' },
      { token: 'color-olive-500', role: 'index detail accent' },
      { token: 'color-olive-400', role: 'about muted text / hero-stat dividers' },
    ],
  },
  {
    name: 'Charcoal — dark neutrals ⚠ 12 steps (Tier-2: → ~4)',
    toks: [
      { token: 'color-charcoal-950', role: 'homepage footer bg (home fork)' },
      { token: 'color-charcoal-925', role: 'filled input text (field-ink)' },
      { token: 'color-charcoal-900', role: 'site footer bg' },
      { token: 'color-charcoal-875', role: 'body ink (legacy --ink)' },
      { token: 'color-charcoal-850', role: 'hero gradient end, theme-color' },
      { token: 'color-charcoal-825', role: 'gold-button ink (home fork)' },
      { token: 'color-charcoal-800', role: 'FAQ side text' },
      { token: 'color-charcoal-775', role: 'footer bottom border' },
      { token: 'color-charcoal-750', role: '.btn-ghost bg' },
      { token: 'color-charcoal-700', role: 'nav ink, .btn-dark bg, FAQ q' },

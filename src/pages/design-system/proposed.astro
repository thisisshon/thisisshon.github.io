      { token: 'color-gray-500', role: '.btn-ghost border' },
      { token: 'color-gray-450', role: 'floating field label' },
      { token: 'color-gray-400', role: 'input placeholder' },
      { token: 'color-gray-300', role: 'input border' },
      { token: 'color-gray-250', role: 'home hero-card divider' },
      { token: 'color-gray-200', role: 'disabled field border. Absorbs #e0e0e0' },
      { token: 'color-gray-150', role: 'mobile-menu dividers. Absorbs #ededec' },
      { token: 'color-gray-100', role: 'segmented-control bg (sip)' },
      { token: 'color-gray-75', role: 'disabled field bg' },
      { token: 'color-gray-50', role: 'home n100' },
    ],
  },
  {
    name: 'Warm gray — hairlines on cream',
    tint: true,
    toks: [
      { token: 'color-warmgray-300', role: 'overlay divider' },
      { token: 'color-warmgray-200', role: 'card border (also border-soft)' },
      { token: 'color-warmgray-100', role: 'row hairline (legacy --row-line)' },
    ],
  },
  {
    name: 'Cream — light surfaces ⚠ 9 steps (Tier-2: → ~5)',
    tint: true,
    toks: [
      { token: 'color-cream-50', role: 'card surface (legacy --card)' },
      { token: 'color-cream-100', role: 'homepage body bg (home fork ≠ page bg)' },
      { token: 'color-cream-150', role: 'home brand-pale' },
      { token: 'color-cream-200', role: 'site page bg (legacy --page)' },
      { token: 'color-cream-250', role: 'light section bg (legacy --sec-light)' },
      { token: 'color-cream-300', role: 'product-card hover (legacy --pcard-hover)' },
      { token: 'color-cream-350', role: 'home FAQ / advisory card bg' },
      { token: 'color-cream-400', role: 'tinted section bg (legacy --sec-tint)' },
      { token: 'color-cream-450', role: 'home brand-light' },
    ],
  },
  {
    name: 'Tan — warm borders / accents',
    tint: true,
    toks: [
      { token: 'color-tan-200', role: 'product-card border, overlay gradient start' },
      { token: 'color-tan-300', role: 'home warm border' },
      { token: 'color-tan-400', role: 'product-card hover border' },
      { token: 'color-tan-500', role: 'overlay idle item' },
    ],
  },
  {
    name: 'Functional',
    toks: [
      { token: 'color-white', role: 'white' },
      { token: 'color-blue-500', role: 'login link / verify' },
      { token: 'color-blue-600', role: 'link hover' },
      { token: 'color-green-500', role: 'check ticks / verified (legacy --green)' },
      { token: 'color-green-600', role: 'form success state' },
      { token: 'color-green-100', role: 'success tint bg. Absorbs #daead7' },
      { token: 'color-red-500', role: 'field error (legacy --field-error)' },
    ],
  },
];

/* ---- Semantic tokens (role → primitive). Chip renders the ROLE token live. ---- */
const semantic: { group: string; rows: { role: string; points: string }[] }[] = [
  {
    group: 'Surface',
    rows: [
      { role: 'color-surface-page', points: 'cream-200' },
      { role: 'color-surface-card', points: 'cream-50' },
      { role: 'color-surface-section-light', points: 'cream-250' },
      { role: 'color-surface-section-tint', points: 'cream-400' },
      { role: 'color-surface-footer', points: 'charcoal-950 (V4 footer; was charcoal-900)' },
      { role: 'color-surface-dark-card', points: 'olive-950' },
      { role: 'color-surface-page-home', points: 'cream-100 (home fork)' },
      { role: 'color-surface-footer-home', points: 'charcoal-950 (home fork)' },
    ],
  },
  {
    group: 'Text',
    rows: [
      { role: 'color-text-primary', points: 'charcoal-875' },
      { role: 'color-text-heading-dark', points: 'olive-900' },
      { role: 'color-text-secondary', points: 'sage-800' },
      { role: 'color-text-tertiary', points: 'gray-700' },
      { role: 'color-text-muted', points: 'sage-600' },
      { role: 'color-text-faint', points: 'sage-400' },
      { role: 'color-text-on-dark', points: 'white' },
      { role: 'color-text-on-dark-body', points: 'sage-200' },
      { role: 'color-text-on-dark-lead', points: 'sage-100' },
    ],
  },
  {
    group: 'Border',
    rows: [
      { role: 'color-border-card', points: 'warmgray-200' },
      { role: 'color-border-hairline', points: 'warmgray-100' },
      { role: 'color-border-divider', points: 'warmgray-300' },
      { role: 'color-border-product-card', points: 'tan-200' },
    ],
  },
  {
    group: 'Action',
    rows: [
      { role: 'color-action-primary', points: 'gold-400' },
      { role: 'color-action-primary-hover', points: 'gold-600' },
      { role: 'color-action-primary-ink', points: 'olive-900' },
      { role: 'color-action-dark', points: 'charcoal-700' },
      { role: 'color-link', points: 'blue-500' },
      { role: 'color-link-hover', points: 'blue-600' },
    ],
  },
  {
    group: 'State',
    rows: [
      { role: 'color-success', points: 'green-500' },
      { role: 'color-success-strong', points: 'green-600' },
      { role: 'color-success-tint', points: 'green-100' },
      { role: 'color-danger', points: 'red-500' },
    ],
  },
  {
    group: 'Field (.hf-*)',
    rows: [
      { role: 'color-field-border', points: 'gray-300' },
      { role: 'color-field-border-active', points: 'gold-300' },
      { role: 'color-field-error', points: 'red-500' },
      { role: 'color-field-label', points: 'gray-450' },
      { role: 'color-field-ink', points: 'charcoal-925' },
      { role: 'color-field-placeholder', points: 'gray-400' },
      { role: 'color-field-disabled-bg', points: 'gray-75' },
      { role: 'color-field-disabled-border', points: 'gray-200' },
      { role: 'color-field-disabled-ink', points: 'sage-250' },
    ],
  },
];

/* ---- Type scale — rendered live at real size via var(--text-*) ---- */
const typeScale: { token: string; px: string; use: string }[] = [
  { token: 'text-5xl', px: '40px', use: 'section titles, hero H1' },
  { token: 'text-4xl', px: '32px', use: 'step numbers, overlay headings, home hero title' },
  { token: 'text-3xl', px: '28px', use: 'sip total, mobile-H1 clamp min' },
  { token: 'text-2xl', px: '24px', use: 'sub-titles, overlay items' },
  { token: 'text-xl', px: '20px', use: 'card headings' },
  { token: 'text-lg', px: '18px', use: 'hero lead, cta sub' },
  { token: 'text-base', px: '16px', use: 'body copy' },
  { token: 'text-sm', px: '14px', use: 'nav links, FAQ, footer links, inputs' },
  { token: 'text-xs', px: '12px', use: 'button labels, errors, meta' },
  { token: 'text-2xs', px: '10px', use: 'floating field label, eyebrows' },
];

const weights: { token: string; w: string; use: string }[] = [
  { token: 'font-weight-light', w: '300', use: 'overlay sidebar items only' },
  { token: 'font-weight-normal', w: '400', use: 'body / leads' },
  { token: 'font-weight-medium', w: '500', use: 'headings, labels, CTAs' },
  { token: 'font-weight-semibold', w: '600', use: 'table keys, emphasis' },
  { token: 'font-weight-bold', w: '700', use: 'footer / group headings' },
  { token: 'font-weight-extrabold', w: '800', use: 'loaded, currently unused' },
];

/* ---- Spacing (8px) + radii ---- */
const spacing = ['4px', '8px', '12px', '16px', '24px', '32px', '40px', '48px', '56px', '64px', '72px', '80px', '96px', '144px'];
const radii: { token: string; px: string; use: string }[] = [
  { token: 'radius-xs', px: '2px', use: '' },
  { token: 'radius-sm', px: '4px', use: 'buttons' },
  { token: 'radius-md', px: '8px', use: 'inputs, small tiles' },
  { token: 'radius-lg', px: '12px', use: '' },
  { token: 'radius-xl', px: '16px', use: 'icon tiles' },
  { token: 'radius-2xl', px: '20px', use: '' },
  { token: 'radius-3xl', px: '24px', use: 'THE card radius' },
];

/* ---- Shadows + motion ---- */
const shadows: { token: string; use: string }[] = [
  { token: 'shadow-fab', use: '.to-top FAB' },
  { token: 'shadow-control', use: 'sip controls' },
  { token: 'shadow-glow-gold', use: 'index card glow' },
  { token: 'shadow-ring-gold', use: 'about timeline ring' },
  { token: 'shadow-glass', use: 'home hero card' },
];
const eases = ['--ease-standard · cubic-bezier(0.4,0,0.2,1) — overlay, FAQ, reveals', '--ease-spring · cubic-bezier(0.22,1,0.36,1) — index cards', '--ease-reveal · cubic-bezier(0.2,0.6,0.2,1) — scroll reveal'];
const durs = ['--dur-fast 0.2s', '--dur-base 0.25s', '--dur-slow 0.3s', '--dur-overlay 0.48s', '--dur-reveal 0.6s'];
---

<BaseLayout seo={seo}>
  <!-- ================= HERO ================= -->
  <section class="hero" id="sec-hero" data-section="hero">
    <div class="hero-inner">
      <div class="hero-content">
        <p class="ds-eyebrow">Doc 2 · the Figma artifact</p>
        <h1>What Is <span class="g">Suggested</span></h1>
        <p class="lead">
          The consolidated, duplication-proofed design system. Every value below is a
          <b>live token</b> from <code>styles.css</code> — structured to map 1:1 onto Figma
          variables (primitive → semantic → component) for the round-trip.
        </p>
      </div>
    </div>
  </section>

  <!-- ================= TOKEN TIERS ================= -->
  <section class="section sec-light" id="sec-tiers" data-section="tiers">
    <h2 class="sec-title">How the tokens are structured</h2>
    <div class="tier-cards">
      <div class="tier-card">
        <span class="tier-n">01</span>
        <h3>Primitive</h3>
        <p>Raw palette values — <code>--color-gold-400</code>, <code>--text-5xl</code>. Named by family + numeric step. Nothing binds to a hex directly.</p>
      </div>
      <div class="tier-card">
        <span class="tier-n">02</span>
        <h3>Semantic</h3>
        <p>Role names that point at a primitive — <code>--color-action-primary</code> → <code>gold-400</code>. The layer components bind to.</p>
      </div>
      <div class="tier-card">
        <span class="tier-n">03</span>
        <h3>Component</h3>
        <p>Shared classes (<code>.btn-gold</code>, <code>.hf-field</code>) read semantic tokens only. When values return from Figma, only the primitives change.</p>
      </div>
    </div>
    <div class="policy-note">
      <p>
        <b>Merge policy.</b> <b>Tier 1 (applied):</b> near-duplicates ≤2 RGB points apart are already
        collapsed — imperceptible. <b>Tier 2 (proposed, awaiting sign-off):</b> visible unifications
        the audit flags but this system keeps for pixel parity — the 12→4 charcoal collapse, 15→5
        creams, the button-spec fork, the footer fork, the 4 hero gradients. Steps marked ⚠ are the
        honest current count.
      </p>
    </div>
  </section>

  <!-- ================= COLOUR — PRIMITIVES ================= -->
  <section class="section" id="sec-primitives" data-section="primitives">
    <h2 class="sec-title">Colour tokens — primitives</h2>
    <p class="sec-lead ds-section-lead">
      Each chip’s background is the <b>live token</b> (<code>var(--color-…)</code>), so a swatch can
      never disagree with the stylesheet. Labelled with token name + role and what legacy near-dupes
      it absorbed.
    </p>

    <div class="fam-list">
      {families.map((f) => (
        <div class="fam">
          <h3 class="ds-group-h">{f.name}</h3>
          <div class="tok-grid">
            {f.toks.map((t) => (
              <div class="tok">
                <span class={`tok-chip${f.tint ? ' tok-chip--bordered' : ''}`} style={`background: ${cv(t.token)}`}></span>
                <div class="tok-meta">
                  <code class="tok-name">--{t.token}</code>
                  <span class="tok-role">{t.role}</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ================= COLOUR — SEMANTIC ================= -->
  <section class="section sec-tint" id="sec-semantic" data-section="semantic">
    <h2 class="sec-title">Colour tokens — semantic</h2>
    <p class="sec-lead ds-section-lead">
      Role → primitive. The chip renders the <b>semantic token itself</b> live — proving the pointer
      resolves. Components bind here, never to a primitive or a hex.
    </p>

    <div class="sem-grid">
      {semantic.map((g) => (
        <div class="sem-block">
          <h3 class="sem-h">{g.group}</h3>
          <div class="t-scroll">
            <table class="ds-table ds-table--compact">
              <thead><tr><th></th><th>Role token</th><th>→ primitive</th></tr></thead>
              <tbody>
                {g.rows.map((r) => (
                  <tr>
                    <td class="sem-swatch-cell">
                      <span class="sem-swatch" style={`background: ${cv(r.role)}`}></span>
                    </td>
                    <td><code class="ds-k">--{r.role}</code></td>
                    <td>{r.points}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ================= TYPOGRAPHY ================= -->
  <section class="section" id="sec-type" data-section="type">
    <h2 class="sec-title">Typography</h2>
    <p class="sec-lead ds-section-lead">
      One typeface — <b>Outfit</b>, site-wide, no exceptions — and every text element renders at
      <b>line-height 1.5</b>. Each specimen below is set at its real <code>var(--text-*)</code> size.
    </p>

    <div class="type-list">
      {typeScale.map((t) => (
        <div class="type-row">
          <div class="type-tag">
            <code>--{t.token}</code>
            <span>{t.px}</span>
          </div>
          <p class="type-specimen" style={`font-size: ${cv(t.token)}`}>
            Shriram Financial Services
          </p>
          <span class="type-use">{t.use}</span>
        </div>
      ))}
    </div>

    <h3 class="ds-group-h ds-mt">Weights (Outfit 300–800)</h3>
    <div class="weight-grid">
      {weights.map((w) => (
        <div class="weight-cell">
          <span class="weight-spec" style={`font-weight: ${cv(w.token)}`}>Aa</span>
          <code>--{w.token}</code>
          <span class="weight-n">{w.w}</span>
          <span class="weight-use">{w.use}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- ================= SPACING & RADII ================= -->
  <section class="section sec-light" id="sec-space" data-section="space">
    <h2 class="sec-title">Spacing &amp; radii</h2>
    <p class="sec-lead ds-section-lead">
      Every gap / padding / margin sits on the <b>8px grid</b> (4px worst case). Radii climb to the
      canonical 24px card.
    </p>

    <div class="ds-facts">
      <div class="fact-col">
        <h3 class="ds-group-h">8px spacing scale</h3>
        <div class="space-scale">
          {spacing.map((s) => (
            <div class="space-row">
              <span class="space-label">{s}</span>
              <span class="space-bar" style={`width:${s}`}></span>
            </div>
          ))}
        </div>
      </div>

      <div class="fact-col">
        <h3 class="ds-group-h">Radius scale</h3>
        <div class="radii-grid">
          {radii.map((r) => (
            <div class="radius-cell">
              <span class="radius-box" style={`border-radius: ${cv(r.token)}`}></span>
              <code>--{r.token}</code>
              <span class="radius-px">{r.px}{r.use ? ` · ${r.use}` : ''}</span>
            </div>
          ))}
          <div class="radius-cell">
            <span class="radius-box radius-box--pill" style={`border-radius: ${cv('radius-full')}`}></span>
            <code>--radius-full</code>
            <span class="radius-px">999px · pills</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================= SHADOWS & MOTION ================= -->

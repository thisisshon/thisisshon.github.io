  { px: '19px', count: '1', flag: 'off-scale → 20' },
  { px: '20px', count: '20' },
  { px: '24px', count: '14' },
  { px: '28px', count: '1' },
  { px: '32px', count: '12' },
  { px: '40px', count: '8' },

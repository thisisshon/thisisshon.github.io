---

<BaseLayout seo={seo}>
  <!-- ================= HERO ================= -->
  <section class="hero" id="sec-hero" data-section="hero">
    <div class="hero-inner">
      <div class="hero-content">
        <p class="ds-eyebrow">Doc 1 · the “before”</p>
        <h1>What Is <span class="g">Used</span></h1>
        <p class="lead">
          The honest as-built inventory of the legacy site - what it actually rendered, extracted
          from the full audit. This is the sprawl the token system resolves.
        </p>
      </div>
    </div>
  </section>

  <!-- ================= INTRO ================= -->
  <section class="section sec-light" id="sec-intro" data-section="intro">
    <div class="ds-lead-block">
      <p>
        This is what the legacy site <b>actually rendered</b>, extracted from the full audit
        (<code>docs/legacy-style-audit.md</code>). It shows the sprawl the token system resolves:
        <b>~150 distinct colours</b> for what the proposed system expresses in ~45 primitives,
        <b>two parallel stylesheets</b> (<code>styles.css</code> + a homepage-only
        <code>home.css</code> fork), a mega-nav overlay declared three times, 15 cream backgrounds,
        12 dark charcoals, 4 hero-gradient recipes, and 9 transition durations. Every value on this
        page is a historical literal - this doc records history, not the system.
      </p>
    </div>
  </section>

  <!-- ================= COLOURS AS-FOUND ================= -->
  <section class="section" id="sec-colors" data-section="colors">
    <h2 class="sec-title">Colours as-found</h2>
    <p class="sec-lead ds-section-lead">
      The audit’s colour inventory (§A1), grouped. Chip · hex · occurrence count · example use.
    </p>

    <div class="ds-groups">
      <div class="ds-group">
        <h3 class="ds-group-h">Dark inks / charcoals <span>· 12+ competing “body ink” values</span></h3>
        <div class="sw-grid">
          {darkInks.map((s) => (
            <div class="sw">
              <span class="sw-chip" style={`background:${s.hex}`}></span>
              <div class="sw-meta">
                <code class="sw-hex">{s.hex}</code>
                <span class="sw-count">{s.count}×</span>
                <span class="sw-use">{s.use}</span>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="ds-group">
        <h3 class="ds-group-h">Olive / brand greens</h3>
        <div class="sw-grid">
          {olives.map((s) => (
            <div class="sw">
              <span class="sw-chip" style={`background:${s.hex}`}></span>
              <div class="sw-meta">
                <code class="sw-hex">{s.hex}</code>
                <span class="sw-count">{s.count}×</span>
                <span class="sw-use">{s.use}</span>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="ds-group">
        <h3 class="ds-group-h">Muted grays / sages <span>· ~17 near-neighbours</span></h3>
        <div class="sw-grid">
          {sages.map((s) => (
            <div class="sw">
              <span class="sw-chip" style={`background:${s.hex}`}></span>
              <div class="sw-meta">
                <code class="sw-hex">{s.hex}</code>
                <span class="sw-count">{s.count}×</span>
                <span class="sw-use">{s.use}</span>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="ds-group">
        <h3 class="ds-group-h">Golds</h3>
        <div class="sw-grid">
          {golds.map((s) => (
            <div class="sw">
              <span class="sw-chip" style={`background:${s.hex}`}></span>
              <div class="sw-meta">
                <code class="sw-hex">{s.hex}</code>
                <span class="sw-count">{s.count}×</span>
                <span class="sw-use">{s.use}</span>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="ds-group">
        <h3 class="ds-group-h">Creams <span>· 15 light surfaces</span></h3>
        <div class="sw-grid">
          {creams.map((s) => (
            <div class="sw">
              <span class="sw-chip sw-chip--bordered" style={`background:${s.hex}`}></span>
              <div class="sw-meta">
                <code class="sw-hex">{s.hex}</code>
                <span class="sw-count">{s.count}×</span>
                <span class="sw-use">{s.use}</span>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="ds-group">
        <h3 class="ds-group-h">Neutral grays</h3>
        <div class="sw-grid">
          {neutrals.map((s) => (
            <div class="sw">
              <span class="sw-chip sw-chip--bordered" style={`background:${s.hex}`}></span>
              <div class="sw-meta">
                <code class="sw-hex">{s.hex}</code>
                <span class="sw-count">{s.count}×</span>
                <span class="sw-use">{s.use}</span>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="ds-group">
        <h3 class="ds-group-h">Functional</h3>
        <div class="sw-grid">
          {functional.map((s) => (
            <div class="sw">
              <span class="sw-chip" style={`background:${s.hex}`}></span>
              <div class="sw-meta">
                <code class="sw-hex">{s.hex}</code>
                <span class="sw-count">{s.count}×</span>
                <span class="sw-use">{s.use}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ================= NEAR-DUPLICATE CLUSTERS ================= -->
  <section class="section sec-tint" id="sec-clusters" data-section="clusters">
    <h2 class="sec-title">Near-duplicate clusters</h2>
    <p class="sec-lead ds-section-lead">
      The same visual role expressed by many almost-identical hexes (§A2). Seen side by side, the
      duplication is obvious - each cluster collapses to a small number of tokens.
    </p>

    <div class="ds-clusters">
      {clusters.map((c) => (
        <div class="clu">
          <div class="clu-head">
            <h3>{c.title}</h3>
            <span class="clu-note">{c.note}</span>
          </div>
          <div class="clu-row">
            {c.hexes.map((h) => (
              <div class="clu-chip">
                <span class="clu-swatch" style={`background:${h}`}></span>
                <code>{h}</code>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ================= THE TWO-STYLESHEET FORK ================= -->
  <section class="section" id="sec-fork" data-section="fork">
    <h2 class="sec-title">The two-stylesheet fork</h2>
    <p class="sec-lead ds-section-lead">
      <code>styles.css</code> (12 pages) vs the homepage-only <code>home.css</code> fork (§E2).
      Nav is identical; the footer, buttons and FAQ render visibly differently.
    </p>
    <div class="t-scroll">
      <table class="ds-table">
        <thead>
          <tr><th>Component</th><th><code>styles.css</code></th><th><code>home.css</code> (homepage)</th></tr>
        </thead>
        <tbody>
          {fork.map((r) => (
            <tr><td class="ds-k">{r.comp}</td><td>{r.styles}</td><td>{r.home}</td></tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- ================= TYPE / SPACING / EFFECTS ================= -->
  <section class="section sec-light" id="sec-tokens" data-section="tokens">
    <h2 class="sec-title">Type, spacing &amp; effects as-found</h2>

    <div class="ds-facts">
      <div class="fact-col">
        <h3 class="ds-group-h">Font sizes (px / count)</h3>
        <div class="t-scroll">
          <table class="ds-table ds-table--compact">
            <thead><tr><th>Size</th><th>Count</th><th>Note</th></tr></thead>
            <tbody>
              {typeSizes.map((t) => (
                <tr class={t.flag ? 'is-flag' : ''}>
                  <td class="ds-k">{t.px}</td>
                  <td>{t.count}×</td>
                  <td>{t.flag ?? ''}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="ds-fine">
          Weights 400 (80×) / 500 (92×) / 600 (40×) / 700 (12×) / 300 (2×). Weight 800 loaded but
          unused; weight 300 used on <code>.nps-item</code> yet not loaded on 12 pages → synthesised.
        </p>
      </div>

      <div class="fact-col">
        <h3 class="ds-group-h">Spacing frequency (px / count)</h3>
        <div class="t-scroll">
          <table class="ds-table ds-table--compact">
            <thead><tr><th>Value</th><th>Count</th></tr></thead>
            <tbody>
              {spacing.map((s) => (
                <tr><td class="ds-k">{s.px}</td><td>{s.count}×</td></tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="ds-fine">
          <b>Off-grid:</b> {offGrid.join(' · ')}.
        </p>
      </div>
    </div>

    <div class="ds-facts ds-facts--2">
      <div class="fact-col">
        <h3 class="ds-group-h">Hero-gradient recipes <span>· 4 for one role</span></h3>
        <div class="t-scroll">
          <table class="ds-table ds-table--compact">
            <thead><tr><th>Role</th><th>Recipe</th></tr></thead>
            <tbody>
              {gradients.map((g) => (
                <tr><td class="ds-k">{g.role}</td><td>{g.recipe}</td></tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <div class="fact-col">
        <h3 class="ds-group-h">Transition durations <span>· 9 in use</span></h3>
        <div class="ds-chips">

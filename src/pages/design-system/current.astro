---
/**
 * Design System - "What is used" · /design-system/current/
 * The honest as-built inventory of the legacy static site, extracted from the
 * full audit (docs/legacy-style-audit.md). Values here are HISTORICAL LITERALS
 * - this doc documents the OLD values, so hardcoded hexes are correct here.
 * Internal tooling docs (noindex).
 */
import BaseLayout from '../../layouts/BaseLayout.astro';

const seo = {
  title: 'Design System - What Is Used (Legacy Inventory)',
  description:
    'The honest as-built style inventory of the legacy Shriram site: ~150 colors grouped by near-duplicate cluster, the two-stylesheet fork, and the off-scale type / off-grid spacing / gradient recipes the token system resolves.',
  path: '/design-system/current/',
  noindex: true,
};

/* ---- Colour inventory (audit §A1). Literal legacy hexes - history. ---- */

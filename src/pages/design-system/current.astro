  { title: 'Brand gold', note: '#f3b83f ← #f2b83f; hover #d4982a ← #c79a38 → 1 gold + hover', hexes: ['#f3b83f', '#f2b83f', '#d4982a', '#c79a38', '#e0a82e'] },
  { title: 'Brand olive', note: '#2e3914 ← #2d3813; #1b2010 ← #1a2010 → 2 tokens', hexes: ['#2e3914', '#2d3813', '#1b2010', '#1a2010'] },
  { title: 'Gold-button ink (one role, 3 inks)', note: '→ collapses to 1 token', hexes: ['#202318', '#231a06', '#2e3914'] },
  { title: 'Creams', note: '15 backgrounds → 5 proposed', hexes: ['#fffdf8', '#fffcf3', '#fcf8ef', '#fef8ee', '#f6efe1', '#f8f4e8', '#fefaf0', '#fdf4dc', '#fbf5e8', '#f5f3ed', '#f2f1ea', '#f0efe8', '#f0ede3', '#e6e3da', '#f2eee3'] },
  { title: 'Light sages', note: '~9 within a few points → #bfc1bc + #c9cac7', hexes: ['#bfc1bc', '#c9cac7', '#c4c6c1', '#c9c6ba', '#c9c8c0', '#d7d7cd'] },
  { title: 'Hairlines', note: '~11 → #e1e0db + #efefef', hexes: ['#e1e0db', '#e0ddd8', '#edebe6', '#ededec', '#efefef', '#e6e6e6', '#e0e0e0'] },

const offGrid = ['gap:6', 'padding:10px 12px (.nps-logo)', 'gap:10 ×3', 'gap:14 ×2', 'clamp mins 18 / 14', 'padding-inline-start:21px', 'padding-top:5px', 'padding:7px 20px', 'padding:16px 10px'];

const gradients: { role: string; recipe: string }[] = [
  { role: 'Standard page hero', recipe: 'radial 125% 210% at 100% −8% · #4f583b → #363a2c → #1d1d1d' },
  { role: 'Index hero', recipe: 'distinct olive stops (#3f4733 / #2a2d23 / #3b422c / #282c1e)' },
  { role: 'Index dark band', recipe: '#14160f / #1a1a13 / #23261c / #282c1e stops' },
  { role: 'Products orbit', recipe: '#3a3f30 / #2e3223 / #454430 band' },
];

const durations = ['0.2s (58×)', '0.25s (19×)', '0.3s (17×)', '0.6s (8×)', '0.48s (6×)', '0.35s (5×)', '0.38s (2×)', '0.22s (3×)', '0.15s (3×)'];

/* ---- The two-stylesheet fork (audit §E2) ---- */
const fork: { comp: string; styles: string; home: string }[] = [
  { comp: 'Nav + mobile menu', styles: 'canonical', home: 'byte-identical duplicate' },
  { comp: 'Mega-nav overlay', styles: 'canonical', home: 'exists ×2 (one dead), reconciled by !important pins' },
  { comp: 'Footer', styles: 'bg #15150f, solid grays, 36px socials', home: 'bg #0a0b07, alpha-whites, 32px socials - VISIBLY different' },
  { comp: 'Gold button', styles: '40px, ink #2e3914, radius 4px', home: '48px variant, ink #202318, radius 6px, hover-translateY - 4 specs total' },
  { comp: 'FAQ', styles: 'bg #fffdf8, <button> mechanism', home: 'bg #f8f4e8, <details> + interpolate-size' },

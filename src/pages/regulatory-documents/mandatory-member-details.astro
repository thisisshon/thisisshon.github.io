---
/**
 * Mandatory Member Details — /regulatory-documents/mandatory-member-details/
 * SEBI-mandated member disclosures listed with the shared view/download document
 * card (.doc-grid / .doc-card, global.css) — the same card used by
 * /regulatory-documents/investor-charter/ — then the compliance disclosure band. Standardised olive
 * hero (rule 7). DATA-DRIVEN (DOCS below) so the template scales to any number of
 * member documents — the scale North Star. No page-local component forks (rule 2).
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { organizationSchema } from '../../lib/seo';

// Mandatory member-disclosure documents → one shared .doc-card each.
// Swap the View / Download hrefs for the real PDFs.
const DOCS = [
  'Rights & Obligations of Members, Authorised Persons & Clients',
  'Risk Disclosure Document (RDD)',
  "Guidance Note — Do's & Don'ts for Trading",
  'Policies & Procedures',
  'Additional Risk Disclosure for Derivatives Trading',
  'Investor Charter & Complaints Disclosure',
];

const site = Astro.site!.href;
const seo = {
  title: 'Mandatory Member Details',
  description:
    'All mandatory disclosures, investor rights, grievance mechanisms and compliance documents — in one place. View online or download as PDF.',
  path: '/regulatory-documents/mandatory-member-details/',
  jsonLd: [organizationSchema(site)],
};
---

<BaseLayout seo={seo}>
  <!-- ================= HERO (standardised, rule 7) ================= -->
  <section class="hero" id="sec-hero" data-section="hero">
    <div class="hero-inner">
      <h1><span class="g">Mandatory Member Details</span></h1>
      <p class="lead">
        All mandatory disclosures, investor rights, grievance mechanisms and compliance documents
        — in one place. View online or download as PDF.
      </p>
    </div>
  </section>

  <!-- ================= DOCUMENT LIST (shared .doc-card grid) ================= -->
  <section class="section stack sec-light" id="sec-docs" data-section="docs">
    <div class="stack" style="gap:16px">
      <h2 class="sub-title">Disclosure Documents</h2>
      <p class="sub-lead">
        The mandatory member disclosures required under SEBI and exchange regulations. Read each
        online, or download the signed PDF for your records.
      </p>
    </div>

    <div class="doc-grid">
      {
        DOCS.map((name) => (
          <article class="doc-card">
            <h3 class="nm">{name}</h3>
            <span class="upd">PDF<span class="sep">·</span>Updated Jul 2026</span>
            <div class="doc-links">
              <a class="doc-dl" href="#" aria-label={`View — ${name}`}>View</a>
              <a class="doc-dl" href="#" download aria-label={`Download — ${name}`}>
                Download
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <!-- ================= IMPORTANT DISCLOSURE ================= -->
  <section class="section stack sec-tint" id="sec-disclosure" data-section="disclosure">
    <p class="disc">
      <strong>Important Disclosure:</strong> Investments in securities markets are subject to market
      risks. Read all related documents carefully before investing. Shriram Financial Services
      Limited is registered with SEBI as a Stock Broker (Registration Nos. INB231103833,
      INB011103839), Research Analyst (INH000009624) and CDSL Depository Participant
      (IN-DP-165-2015). AMFI-registered Mutual Fund Distributor: ARN 29483. PFRDA-registered NPS
      Point of Presence. CIN: U65100TN1974PLC006603. Registered Office: Shriram House, No. 4,
      Burkit Road, T. Nagar, Chennai – 600 017.
    </p>
  </section>
</BaseLayout>

<style>
  /* ===== Mandatory Member Details — page-local styles only. The document cards
     use the shared .doc-grid / .doc-card component from global.css; only the
     disclosure fine print is page-specific. ===== */
  .section {
    scroll-margin-top: 96px;
  }

  /* shared .doc-grid, spaced below the section intro (matches /investor-charter/). */
  .doc-grid {
    margin-top: 32px;
  }

  /* compliance disclosure — plain fine print on the tinted band. */
  .disc {
    max-width: 1288px;
    font-weight: 400;
    font-size: 14px;
    color: var(--color-text-tertiary);
    overflow-wrap: anywhere; /* break long reg/CIN numbers so they can't overflow at 320px */
  }
  .disc strong {
    font-weight: 600;
    color: var(--color-text-primary);
  }
</style>

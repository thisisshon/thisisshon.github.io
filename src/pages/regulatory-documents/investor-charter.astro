---
/**
 * Investor Charter - /regulatory-documents/investor-charter/
 * Mandatory-disclosure document listing: investor charters plus grievance,
 * compliance, risk and policy documents. Searchable + filterable by category
 * (shared .doc-toolbar / .doc-chips / .doc-group component from global.css).
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/site/Breadcrumb.astro';

const seo = {
  title:
    'Investor Charter - Rights',
  description:
    'Read the SEBI-mandated Investor Charter outlining your rights, responsibilities and grievance process with Shriram Financial Services.',
  path: '/regulatory-documents/investor-charter/',
};

// Documents grouped by category - feeds the filter chips and the grouped grids.
const CATEGORIES = [
  {
    id: 'investor-charter',
    label: 'Investor Charter',
    docs: [
      { name: 'Investor Charter - Equity & F&O Broking', meta: 'Effective Apr 2025' },
      { name: 'Investor Charter - Depository Participant', meta: 'Effective Apr 2025' },
      { name: 'Investor Charter - Research Analyst', meta: 'Effective Jan 2025' },
      { name: 'Investor Charter - Mutual Fund Distributor', meta: 'Effective Apr 2025' },
    ],
  },
  {
    id: 'grievance-redressal',
    label: 'Grievance Redressal',
    docs: [{ name: 'Grievance Redressal Mechanism', meta: 'Updated Jun 2025' }],
  },
  {
    id: 'annual-compliance',
    label: 'Annual Compliance',
    docs: [{ name: 'Annual Compliance Report - FY 2024–25', meta: 'Published Apr 2025' }],
  },
  {
    id: 'risk-disclosures',
    label: 'Risk Disclosures',
    docs: [{ name: 'Risk Disclosure Document', meta: 'Effective Apr 2025' }],
  },
  {
    id: 'policies',
    label: 'Policies',
    docs: [
      { name: 'Know Your Client (KYC) Policy', meta: 'Updated Jan 2025' },
      { name: 'Anti-Money Laundering (AML) Policy', meta: 'Updated Jan 2025' },
      { name: 'Privacy Policy & Data Protection', meta: 'Updated Mar 2025' },
    ],
  },
];

const TOTAL = CATEGORIES.reduce((n, c) => n + c.docs.length, 0);
---

<BaseLayout seo={seo} mainClass="rev-rise-scale">
  <!-- ================= HERO ================= -->
  <section class="hero" id="sec-hero" data-section="hero">
    <Breadcrumb trail={[{ name: 'Regulatory Documents', href: '/regulatory-documents/' }, { name: 'Investor Charter' }]} />
    <div class="hero-inner" data-enter>
      <h1>Investor <span class="g">Charter</span></h1>
      <p class="lead">
        All mandatory disclosures, investor rights, grievance mechanisms and compliance documents
        - in one place. Search, filter by category, and view online or download as PDF.
      </p>
      <div class="hero-feats">
        <div class="feats">
          <div class="feat">
            <span class="tk" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span>
            <span class="lb">SEBI-mandated</span>
          </div>
          <div class="feat">
            <span class="tk" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span>
            <span class="lb">Search &amp; filter by category</span>
          </div>
          <div class="feat">
            <span class="tk" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span>
            <span class="lb">View or download as PDF</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================= CHARTER & REGULATORY DOCUMENTS ================= -->
  <section class="section stack sec-light" id="sec-charters" data-section="charters" style="gap:40px" data-enter="2">
    <div class="stack" style="gap:16px">
      <h2 class="sub-title">Charter &amp; Regulatory Documents</h2>
      <p class="sub-lead">
        Each document sets out our services, your rights and responsibilities, timelines and the
        grievance-redressal process for that activity. Read online, or download the signed PDF for
        your records.
      </p>
    </div>

    <!-- Search + category chips -->
    <div class="doc-toolbar">
      <div class="doc-search">
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.7"></circle><path d="m20 20-3.2-3.2" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"></path></svg>
        <label class="sr-only" for="doc-q">Search documents</label>
        <input id="doc-q" type="search" placeholder="Search documents" autocomplete="off" />
      </div>
      <div class="doc-chips" role="group" aria-label="Filter by category">
        <button class="doc-chip" type="button" data-cat="all" aria-pressed="true">All ({TOTAL})</button>
        {
          CATEGORIES.map((c) => (
            <button class="doc-chip" type="button" data-cat={c.id} aria-pressed="false">
              {c.label} ({c.docs.length})
            </button>
          ))
        }
      </div>
    </div>

    <p class="doc-empty" id="doc-empty">
      No documents match your search. Try a different term or category.
    </p>

    {
      CATEGORIES.map((c) => (
        <div class="doc-group" data-cat={c.id}>
          <p class="doc-cat">{c.label}</p>
          <div class="doc-grid" data-reveal-row>
            {c.docs.map((d) => (
              <article class="doc-card">
                <h3 class="nm">{d.name}</h3>
                <span class="upd">
                  PDF<span class="sep">·</span>
                  {d.meta}
                </span>
                <div class="doc-links">
                  <a class="doc-dl" href="#" aria-label={`View ${d.name}`}>
                    View
                  </a>
                  <a class="doc-dl" href="#" download aria-label={`Download ${d.name}`}>
                    Download
                  </a>
                </div>
              </article>
            ))}
          </div>
        </div>
      ))
    }
  </section>

  <!-- ================= IMPORTANT DISCLOSURE ================= -->
  <section class="section stack sec-tint" id="sec-disclosure" data-section="disclosure">
    <div class="disc-note">
      <svg class="disc-ico" aria-hidden="true" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6"></circle><path d="M12 7.5v.5M12 11v5.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></path></svg>
      <p>
        <strong>Important Disclosure:</strong> Investments in securities markets are subject to market
        risks. Read all related documents carefully before investing. Shriram Financial Services
        Limited is registered with SEBI as a Stock Broker (Registration Nos. INB231103833,
        INB011103839), Research Analyst (INH000009624) and CDSL Depository Participant
        (IN-DP-165-2015). AMFI-registered Mutual Fund Distributor: ARN 29483. PFRDA-registered NPS
        Point of Presence. CIN: U65100TN1974PLC006603. Registered Office: Shriram House, No. 4,
        Burkit Road, T. Nagar, Chennai – 600 017.
      </p>
    </div>
  </section>
</BaseLayout>

<script>
  /* Investor Charter - client-side search + category-chip filter over the shared
     .doc-group / .doc-card component. Progressive enhancement: with JS off, every
     document is visible (nothing is hidden server-side). */
  (function () {
    var groups = Array.prototype.slice.call(document.querySelectorAll('.doc-group'));
    if (!groups.length) return;
    var chips = Array.prototype.slice.call(document.querySelectorAll('.doc-chip'));
    var qInput = document.getElementById('doc-q');
    var emptyEl = document.getElementById('doc-empty');
    var activeCat = 'all';

    Array.prototype.forEach.call(document.querySelectorAll('.doc-card'), function (card) {
      card.setAttribute('data-name', (card.querySelector('.nm') || {}).textContent || '');
    });

    var applyFilter = function () {
      var q = (qInput ? qInput.value : '').trim().toLowerCase();
      var anyVisible = false;
      groups.forEach(function (g) {
        var catOk = activeCat === 'all' || g.getAttribute('data-cat') === activeCat;
        var groupHasVisible = false;
        Array.prototype.forEach.call(g.querySelectorAll('.doc-card'), function (card) {
          var nameOk = !q || card.getAttribute('data-name').toLowerCase().indexOf(q) !== -1;
          var show = catOk && nameOk;
          card.classList.toggle('hide', !show);
          if (show) groupHasVisible = true;
        });
        g.classList.toggle('hide', !groupHasVisible);
        if (groupHasVisible) anyVisible = true;
      });
      if (emptyEl) emptyEl.classList.toggle('show', !anyVisible);
    };

    if (qInput) qInput.addEventListener('input', applyFilter);
    chips.forEach(function (chip) {
      chip.addEventListener('click', function () {
        activeCat = chip.getAttribute('data-cat');
        chips.forEach(function (c) {
          c.setAttribute('aria-pressed', c === chip ? 'true' : 'false');
        });
        applyFilter();
      });
    });
  })();
</script>

<style>
  /* ===== Investor Charter - page-specific styles. Values reuse shared tokens.
     The document toolbar / chips / groups / cards are the shared component in
     global.css; only the hero disclosure block is unique to this page. ===== */
  .section {
    scroll-margin-top: 96px;
  }

  /* important disclosure block */
  .disc-note {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    background: var(--color-surface-card);
    border: 1px solid var(--color-border-card);
    border-radius: 24px;
    padding: var(--container-pad);
  }
  .disc-note .disc-ico {
    width: 24px;
    height: 24px;
    flex: none;
    margin-top: 2px;
    color: var(--color-gold-400);
  }
  .disc-note p {
    font-weight: 400;
    font-size: 14px;
    color: var(--color-text-tertiary);
    overflow-wrap: anywhere; /* break long reg/CIN numbers so they can't overflow at 320px */
  }
  .disc-note strong {
    font-weight: 600;
    color: var(--color-text-primary);
  }

  @media (max-width: 640px) {
    .disc-note {
      flex-direction: column;
    }
  }
</style>

---
/**
 * Grievance Redressal — /grievance-redressal/
 * How to raise & escalate a complaint. Pixel parity with legacy
 * support/grievance-redressal/index.html.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/site/Breadcrumb.astro';

const seo = {
  title: 'Grievance Redressal Process',
  description:
    'Learn how to raise and track a complaint through the Grievance Redressal Mechanism of Shriram Financial Services.',
  path: '/grievance-redressal/',
  // Page-specific Organization/ContactPoint block (legacy inline JSON-LD).
  jsonLd: [
    {
      '@context': 'https://schema.org',
      '@type': 'Organization',
      name: 'Shriram Financial Services',
      url: 'https://www.shriramsec.in/',
      contactPoint: [
        {
          '@type': 'ContactPoint',
          telephone: '+91-1800-1234567',
          contactType: 'customer support',
          areaServed: 'IN',
          availableLanguage: ['en', 'hi'],
          email: 'support@shriramfs.in',
        },
      ],
    },
  ],
};

// Escalation contacts — one card each, in order.
const ESCALATIONS = [
  {
    num: '01',
    role: 'Customer Care',
    person: 'Jeevana Santosh / Murali K',
    tel: 'tel:08047185579',
    telText: '080-4718 5579, 080-4367 6869',
    ext: 'Extn. 825 / 831',
    email: 'support@way2wealth.com',
  },
  {
    num: '02',
    role: 'Head of Customer Care',
    person: 'Arathinathan J M',
    tel: 'tel:08043676869',
    telText: '080-4367 6869',
    ext: 'Extn. 805',
    email: 'grievance@way2wealth.com',
  },
  {
    num: '03',
    role: 'Compliance Officer',
    person: 'Sandhya',
    tel: 'tel:08043676869',
    telText: '080-4367 6869',
    ext: 'Extn. 874',
    email: 'compliance@way2wealth.com',
  },
  {
    num: '04',
    role: 'CEO',
    person: 'G.S. Shridhar',
    tel: 'tel:08043676869',
    telText: '080-4367 6869',
    ext: null,
    email: 'ceo@way2wealth.com',
  },
];
---

<BaseLayout seo={seo} mainClass="rev-rise-scale">
  <!-- ================= HERO ================= -->
  <section class="hero" id="sec-hero" data-section="hero">
    <Breadcrumb trail={[{ name: 'Grievance Redressal' }]} />
    <div class="hero-inner" data-enter>
      <h1>Grievance <span class="g">Redressal</span></h1>
      <p class="lead">Not satisfied with a product or service? Here's how to raise a complaint — and exactly who to contact at each level until it's resolved.</p>
      <div class="hero-contacts">
        <a class="ct-pill" href="tel:18001234567">
          <svg viewBox="0 0 24 24" fill="none"><path d="M5 4h3l1.5 5-2 1.5a11 11 0 0 0 5 5l1.5-2 5 1.5v3a2 2 0 0 1-2 2A16 16 0 0 1 3 6a2 2 0 0 1 2-2Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"></path></svg>
          1800 1234567 (Toll Free)
        </a>
        <a class="ct-pill" href="mailto:support@shriramfs.in">
          <svg viewBox="0 0 24 24" fill="none"><rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.6"></rect><path d="m4 7 8 6 8-6" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"></path></svg>
          support@shriramfs.in
        </a>
      </div>
    </div>
  </section>

  <!-- ================= HOW TO RAISE A GRIEVANCE ================= -->
  <section class="section stack sec-light" id="sec-policy" data-section="policy" style="gap:56px" data-enter="2">
    <div class="stack" style="gap:24px">
      <h2 class="sub-title">How to Raise a Grievance</h2>
      <p class="sub-lead">Customers who are not satisfied or have a grievance about the products or services provided by the Company can address their complaint to the contacts below. We're here Monday to Saturday, 9 AM – 6 PM.</p>
      <p class="policy-p">The grievance redressal mechanism within the organisation will be explained to every Client so that any dispute can be resolved fairly and without delay. Once a complaint is received, it is acknowledged, logged and assigned to the team best placed to act on it, and the Client is kept informed of the progress until the matter is closed. The mechanism is designed so that all disputes arising out of the decisions of our functionaries are heard and disposed of at least at the next higher level — no concern is left to be settled solely by the person whose decision is being questioned.</p>
      <p class="policy-p">If the applicant or Client is not satisfied with the response received, or does not hear from the Company within the committed timeline, an escalated complaint-handling mechanism is available. The Client may take the issue to the Compliance Officer of the Company at the address below, and, should it remain unresolved, escalate it further to the Head of Customer Care and then to the CEO, in the order set out in the escalation contacts. As a final recourse, a complaint may also be lodged with the relevant regulator through the SEBI SCORES portal.</p>
    </div>

    <div class="policy-card">
      <span class="policy-ico" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8l-5-5Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"></path><path d="M14 3v5h5" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"></path><path d="M12 12v5m0 0 2.5-2.5M12 17l-2.5-2.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path></svg></span>
      <div class="policy-tx">
        <h3>Grievance Redressal Policy</h3>
        <p>PDF · Updated Jun 2026</p>
      </div>
      <a class="btn-gold" href="#" download>Download Policy</a>
    </div>
  </section>

  <!-- ================= ESCALATIONS ================= -->
  <section class="section stack sec-tint" id="sec-escalations" data-section="escalations" style="gap:56px">
    <div class="stack" style="gap:16px">
      <h2 class="sub-title">For Escalations, Contact the Right Team</h2>
      <p class="sub-lead">Complaints are heard and resolved at the next higher level. If you're not satisfied with the response, escalate to the next team in order.</p>
    </div>

    <div class="hours-bar">
      <svg viewBox="0 0 24 24" fill="none"><path d="M12 21s7-5.6 7-11a7 7 0 1 0-14 0c0 5.4 7 11 7 11Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"></path><circle cx="12" cy="10" r="2.5" stroke="currentColor" stroke-width="1.6"></circle></svg>
      All teams: 3rd Floor, Rukmini Towers, #3/1, Sheshadripuram, Bengaluru – 560 020 · Monday to Friday, 9:30 AM – 5:30 PM.
    </div>

    <div class="esc-grid" data-reveal-row>
      {
        ESCALATIONS.map((e) => (
          <article class="esc-card">
            <span class="esc-num" aria-hidden="true">{e.num}</span>
            <h3 class="esc-role">{e.role}</h3>
            <p class="esc-person">{e.person}</p>
            <div class="esc-meta">
              <a href={e.tel}>
                <svg viewBox="0 0 24 24" fill="none"><path d="M5 4h3l1.5 5-2 1.5a11 11 0 0 0 5 5l1.5-2 5 1.5v3a2 2 0 0 1-2 2A16 16 0 0 1 3 6a2 2 0 0 1 2-2Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" />
                </svg>
                {e.telText}
              </a>
              {e.ext && <span class="esc-ext">{e.ext}</span>}
              <a href={`mailto:${e.email}`}>
                <svg viewBox="0 0 24 24" fill="none"><rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.6" /><path d="m4 7 8 6 8-6" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" />
                </svg>
                {e.email}
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <!-- ================= FINAL CTA ================= -->
  <section class="cta-sec sec-light" id="sec-final-cta" data-section="final-cta">
    <div class="cta-box">
      <div class="ct-tt">
        <h3>Still Not Resolved?</h3>
        <p class="ct-sub">If your complaint remains unresolved after escalation, reach our support team directly or escalate to the SEBI SCORES portal.</p>
      </div>
      <a class="btn-gold" href="/contact-us/">Contact Support</a>
    </div>
  </section>
</BaseLayout>

<style>
  /* ===== Grievance Redressal — page-specific components. Every value reuses the shared
     design tokens, radii, container padding and 8px spacing grid. ===== */

  .section,
  .cta-sec {
    scroll-margin-top: 96px;
  }

  /* design-system rule: every font renders at 1.5 line-height. Buttons, inputs, pills and
     links reset to `normal` by default, so restore 1.5 on them explicitly (page-scoped). */
  .ct-pill,
  .btn-gold,
  .btn-dark,
  .policy-card .btn-gold,
  .esc-meta a {
  }

  /* ---------- hero contact pills (mirrors the Contact page hero) ---------- */
  .hero-contacts {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 32px;
    padding-top: 32px;
    border-top: 1px solid #55594e; /* page-local — Tier-2 */
  }
  .ct-pill {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    height: 44px;
    padding: 0 16px;
    border-radius: 999px;
    background: var(--color-sage-900); /* #353731 (Tier-1: absorbed by sage-900) */
    border: 1px solid #4a4c47; /* page-local — Tier-2 */
    color: var(--color-white);
    font-weight: 500;
    font-size: 14px;
    transition: background 0.2s ease, border-color 0.2s ease;
  }
  @media (min-width: 1024px) and (hover: hover) {
    .ct-pill:hover {
    background: #42443e; /* page-local — Tier-2 */
    border-color: var(--color-sage-700); /* #6d6e6a (Tier-1: absorbed by sage-700) */
  }
  }
  .ct-pill svg {
    width: 16px;
    height: 16px;
    flex: none;
    color: var(--color-gold-400);
  }

  /* ---------- policy intro paragraphs + download card.
     Section major blocks are 56px apart (DS rhythm); the two paragraphs are grouped in a
     24px stack so they read as one prose block, not two separated blocks. ---------- */
  .policy-p {
    font-weight: 400;
    font-size: 16px;
    color: var(--color-text-tertiary);
  }

  .policy-card {
    display: flex;
    align-items: center;
    gap: 24px;
    background: var(--color-surface-card);
    border: 1px solid var(--color-border-card);
    border-radius: 24px;
    padding: var(--container-pad);
  }
  .policy-ico {
    width: 48px;
    height: 48px;
    flex: none;
    border-radius: 12px;
    background: var(--color-gold-100); /* #fff0d7 */
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .policy-ico svg {
    width: 24px;
    height: 24px;
    color: var(--color-text-heading-dark);
  }
  .policy-tx {
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex: 1 1 auto;
    min-width: 0;
  }
  .policy-tx h3 {
    font-weight: 500;
    font-size: 18px;
    color: var(--color-text-primary);
  }
  .policy-tx p {
    font-weight: 400;
    font-size: 14px;
    color: var(--color-text-muted);
  }
  .policy-card .btn-gold {
    flex: none;
  }

  /* ---------- shared address / hours bar (mirrors the Contact page) ---------- */
  .hours-bar {
    display: flex;
    align-items: center;
    gap: 12px;
    background: var(--color-surface-card);
    border: 1px solid var(--color-border-card);
    border-radius: 12px;
    padding: 16px 20px;
    font-weight: 500;
    font-size: 14px;
    color: var(--color-text-secondary);
  }
  .hours-bar svg {
    width: 20px;
    height: 20px;
    flex: none;
    color: var(--color-text-heading-dark);
  }

  /* ---------- escalation cards ---------- */
  .esc-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    align-items: stretch;
  }
  .esc-card {
    background: var(--color-surface-card);
    border: 1px solid var(--color-border-card);
    border-radius: 24px;
    padding: var(--container-pad);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .esc-num {
    font-weight: 400;
    font-size: 32px;
    color: var(--color-gold-500);
  }
  .esc-role {
    font-weight: 500;
    font-size: 20px;
    color: var(--color-text-primary);
  }
  .esc-person {
    font-weight: 400;
    font-size: 16px;
    color: var(--color-text-muted);
  }
  .esc-meta {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid var(--color-border-hairline);
  }
  .esc-meta a,
  .esc-meta span {
    display: inline-flex;
    align-items: flex-start;
    gap: 8px;
    font-weight: 500;
    font-size: 14px;
    color: var(--color-text-secondary);
    overflow-wrap: anywhere;
  }
  .esc-meta a {
    transition: color 0.2s ease;
  }
  @media (min-width: 1024px) and (hover: hover) {
    .esc-meta a:hover {
    color: var(--color-text-heading-dark);
  }
  }
  .esc-meta svg {
    width: 16px;
    height: 16px;
    flex: none;
    margin-top: 4px;
    color: var(--color-gold-400);
  }
  .esc-ext {
    color: var(--color-text-muted);
    font-weight: 400;
  }

  /* ---------- responsive ---------- */
  @media (max-width: 1024px) {
    .esc-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 768px) {
    .policy-card {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
    }
  }
  @media (max-width: 560px) {
    .esc-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

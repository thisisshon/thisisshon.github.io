---
/**
 * NPS Calculator — /nps-calculator/
 * Projects the National Pension System corpus at retirement (age 60), the
 * lump-sum you can withdraw and the monthly pension from the annuitised
 * portion. Built on the shared calculator UI in global.css; page carries
 * content + maths. (The NPS *product* page lives at /nps/.)
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import FaqAccordion from '../components/sections/FaqAccordion.astro';
import { faqPageSchema } from '../lib/seo';
import { otherCalculators, calcHref } from '../data/calculators';

const MORE = otherCalculators('nps');

const FAQS = [
  {
    q: 'How does this NPS calculator project my corpus?',
    a: 'It treats your monthly NPS contribution like a SIP that runs until you turn 60. Each contribution compounds at your expected annual rate of return, and the calculator sums them to project the total corpus at retirement, splitting it into the amount you invested and the returns earned.',
  },
  {
    q: 'Why must part of the corpus be used for an annuity?',
    a: 'Under current NPS rules, at retirement you can withdraw up to 60% of your corpus as a tax-free lump sum, but at least 40% must be used to buy an annuity that pays you a regular pension for life. This calculator lets you set the annuitised share (from 40% upward) and estimates the resulting monthly pension.',
  },
  {
    q: 'What annuity rate does the monthly pension assume?',
    a: 'The pension estimate assumes the annuitised amount earns roughly 6% per annum, paid monthly — a typical assumption for illustration. Your actual pension depends on the annuity plan and rates available from the insurer at the time you retire, so treat this figure as an indicative guide.',
  },
  {
    q: 'What rate of return should I expect from NPS?',
    a: 'NPS returns depend on your asset allocation across equity, corporate bonds and government securities. Long-term blended returns have historically fallen in the 8–11% range, but they are market-linked and not guaranteed. Running the calculator with a conservative and an optimistic rate shows the range of possible outcomes.',
  },
  {
    q: 'What are the tax benefits of NPS?',
    a: 'NPS contributions qualify for deductions under Section 80C and an additional dedicated deduction under Section 80CCD(1B), subject to prevailing limits. At retirement the lump-sum withdrawal is tax-free within the allowed share, while the pension income is taxed as per your slab in the year you receive it.',
  },
];

const seo = {
  title: 'NPS Calculator — Estimate Retirement Corpus & Pension',
  description:
    'Free NPS calculator to project your National Pension System corpus at 60, the lump-sum you can withdraw and your expected monthly pension — instant, no sign-up.',
  path: '/nps-calculator/',
  jsonLd: [faqPageSchema(FAQS.map((f) => ({ question: f.q, answer: f.a })))],
};
---

<BaseLayout seo={seo}>
  <!-- ================= HERO ================= -->
  <section class="hero" id="sec-hero" data-section="hero">
    <div class="hero-inner">
      <h1>Plan Your Retirement With The <span class="g">NPS Calculator</span></h1>
      <p class="lead">Project the corpus you'll build by 60, the lump-sum you can withdraw and the monthly pension your annuity could pay.</p>
      <div class="cta"><a class="btn-gold" href="/open-demat-account/">Open Demat Account</a></div>
      <div class="hero-feats">
        <div class="feats">
          <div class="feat"><span class="tk" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span><span class="lb">100% Free</span></div>
          <div class="feat"><span class="tk" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span><span class="lb">Instant Results</span></div>
          <div class="feat"><span class="tk" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span><span class="lb">No Sign-up Required</span></div>
          <div class="feat"><span class="tk" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span><span class="lb">Accurate Projections</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== NPS Calculator ===== -->
  <section class="section stack sec-light" id="sec-calc" data-section="calc" style="gap:24px">
    <h2 class="sec-title">NPS Calculator</h2>
    <p class="calc-hint">Drag the sliders or type your own numbers — results update instantly. Contributions are assumed to run until you turn 60.</p>

    <div class="calc-row">
      <!-- inputs -->
      <div class="card calc-panel">
        <div class="fields">
          <div class="field">
            <div class="field-top">
              <label for="amt">Monthly investment</label>
              <div class="field-val"><span class="pfx">₹</span><input id="amt" type="text" inputmode="numeric" value="5,000" aria-label="Monthly investment in rupees" /></div>
            </div>
            <input class="slider" id="amtR" type="range" min="500" max="150000" step="500" value="5000" aria-label="Monthly investment" />
            <div class="slider-scale"><span>₹500</span><span>₹1,50,000</span></div>
          </div>

          <div class="field">
            <div class="field-top">
              <label for="age">Current age</label>
              <div class="field-val"><input id="age" type="text" inputmode="numeric" value="30" aria-label="Current age in years" /><span class="sfx">Yr</span></div>
            </div>
            <input class="slider" id="ageR" type="range" min="18" max="59" step="1" value="30" aria-label="Current age in years" />
            <div class="slider-scale"><span>18 Yr</span><span>59 Yr</span></div>
          </div>

          <div class="field">
            <div class="field-top">
              <label for="rate">Expected rate of return</label>
              <div class="field-val"><input id="rate" type="text" inputmode="decimal" value="10" aria-label="Expected annual rate of return in percent" /><span class="sfx">%</span></div>
            </div>
            <input class="slider" id="rateR" type="range" min="1" max="15" step="0.5" value="10" aria-label="Expected annual rate of return in percent" />
            <div class="slider-scale"><span>1%</span><span>15%</span></div>
          </div>

          <div class="field">
            <div class="field-top">
              <label for="ann">Annuity purchased</label>
              <div class="field-val"><input id="ann" type="text" inputmode="numeric" value="40" aria-label="Share of corpus used to buy an annuity, in percent" /><span class="sfx">%</span></div>
            </div>
            <input class="slider" id="annR" type="range" min="40" max="100" step="5" value="40" aria-label="Share of corpus used to buy an annuity" />
            <div class="slider-scale"><span>40%</span><span>100%</span></div>
          </div>
        </div>
      </div>

      <!-- results -->
      <div class="calc-results">
        <div class="bar-wrap">
          <div class="bar-top">
            <div class="bar-head">
              <span class="bar-cap">Total Corpus At 60</span>
              <span class="bar-tot" id="d-tot">₹1,13,96,627</span>
            </div>
            <div class="stack-bar" role="img" aria-label="Corpus split between invested amount and interest earned">
              <div class="seg seg-inv" id="seg-inv" style="width:16%"></div>
              <div class="seg seg-ret" id="seg-ret" style="width:84%"></div>
            </div>
          </div>

          <div class="res-cards">
            <div class="res-card">
              <div class="res-top"><span class="dot" style="background:var(--c-inv)"></span>Invested Amount</div>
              <div class="res-val" id="r-inv">₹18,00,000</div>
            </div>
            <div class="res-card">
              <div class="res-top"><span class="dot" style="background:var(--c-ret)"></span>Interest Earned</div>
              <div class="res-val" id="r-ret">₹95,96,627</div>
            </div>
          </div>

          <div class="bar-div" role="presentation"></div>

          <!-- annuitisation outcomes -->
          <div class="res-cards">
            <div class="res-card">
              <div class="res-top">Lump-sum Withdrawal</div>
              <div class="res-val" id="r-lump">₹68,37,976</div>
            </div>
            <div class="res-card">
              <div class="res-top">Expected Monthly Pension</div>
              <div class="res-val" id="r-pen">₹22,793</div>
            </div>
          </div>

          <div class="bar-div" role="presentation"></div>

          <p class="bar-note">Note: Assumes contributions until age 60 and that the annuitised share earns about 6% p.a. Figures are illustrative; NPS returns are market-linked and the actual pension depends on annuity rates at retirement.</p>
        </div>

        <div class="ready-bar">
          <p class="ready-text">Start a <b id="cta-amt">₹5,000/month NPS</b> and secure your retirement</p>
          <a class="ready-btn" href="/open-demat-account/">Open Demat Account</a>
        </div>
      </div>
    </div>

    <p class="sr-only" id="sr-summary" aria-live="polite"></p>
  </section>

  <!-- ===== What Is An NPS Calculator ===== -->
  <section class="section stack sec-tint" id="sec-what" data-section="what" style="gap:24px">
    <h2 class="sec-title">What Is An NPS Calculator?</h2>
    <p class="sec-lead">An NPS calculator is a free online tool that projects the retirement corpus you can build through the National Pension System. By entering your monthly contribution, your current age, an expected annual rate of return and the share of the corpus you plan to annuitise, it estimates the total corpus at 60, the lump sum you can withdraw and the monthly pension your annuity could provide. It turns decades of contributions into a clear, single-screen picture of your retirement.</p>
  </section>

  <!-- ===== How An NPS Calculator Helps You ===== -->
  <section class="section stack sec-light" id="sec-help" data-section="help" style="gap:24px">
    <h2 class="sec-title">How An NPS Calculator Helps You</h2>
    <p class="sec-lead">Retirement is decades away and easy to under-plan. The calculator makes the long horizon tangible:</p>
    <ul class="bullets">
      <li>See the corpus your monthly contribution could grow into by the time you turn 60.</li>
      <li>Understand how much you can take as a lump sum versus what funds your pension.</li>
      <li>Estimate your monthly pension so you can judge whether it meets your retirement needs.</li>
      <li>Test how starting earlier or contributing more changes the outcome — the earlier the bigger.</li>
    </ul>
  </section>

  <!-- ===== How Does An NPS Calculator Work ===== -->
  <section class="section stack sec-tint" id="sec-work" data-section="work" style="gap:24px">
    <h2 class="sec-title">How Does An NPS Calculator Work?</h2>
    <p class="sec-lead">The calculator first works out how many months remain until you turn 60 and compounds each monthly contribution at your expected rate of return over that period — the same future-value logic as a SIP — to arrive at your corpus. It then subtracts your total contributions to show the returns earned. Finally it applies your chosen annuitisation share: the annuitised portion is used to estimate a lifelong monthly pension (assuming roughly a 6% annuity rate), and the remainder is your tax-free lump-sum withdrawal.</p>
  </section>

  <!-- ===== Advantages Of An NPS Calculator ===== -->
  <section class="section stack sec-light" id="sec-adv" data-section="adv" style="gap:24px">
    <h2 class="sec-title">Advantages Of An NPS Calculator</h2>
    <p class="sec-lead">For a decades-long commitment like NPS, seeing the end result in advance changes how you plan:</p>
    <ul class="bullets">
      <li>Instant projection of corpus, lump sum and pension from a single set of inputs.</li>
      <li>Completely free to use, with no sign-up required and results delivered in real time.</li>
      <li>Helps you pick a contribution and annuitisation mix that matches your retirement goals.</li>
      <li>Makes the reward of starting early and staying invested impossible to ignore.</li>
    </ul>
  </section>

  <!-- ===== Explore More ===== -->
  <section class="section stack sec-tint" id="sec-explore" data-section="explore" style="gap:40px">
    <h2 class="sec-title">Explore More</h2>
    <div class="explore-grid">
      {
        MORE.map((c) => (
          <a class="xcard" href={calcHref(c.slug)}>
            <span class="xc-title">{c.title}</span>
            <span class="xc-desc">{c.desc}</span>
            <span class="xc-cta">Calculate Now <span class="arr" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 8h11M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span></span>
          </a>
        ))
      }
    </div>
  </section>

  <!-- ===== General Questions ===== -->
  <section class="faq-wrap sec-light" id="sec-faq" data-section="faq">
    <div class="faq-cols">
      <div class="faq-left">
        <h2 class="faq-title">General Questions</h2>
        <FaqAccordion faqs={FAQS} />
      </div>
      <div class="faq-side">
        <div class="usr"><img src="/assets/user.svg" alt="" /></div>
        <div class="side-in">
          <div class="side-tx">
            <h3>Need A Clearer Direction? </h3>
            <p>Let's get in touch on a 15-Minute call where we would be able to answer any questions you may have. Our Advisor will additionally help map your wealth mix and demonstrate what a dedicated advisor would do differently.</p>
          </div>
          <a class="btn-gold" href="#">Book A Discovery Call</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* NPS calculator — calculator UI is shared in global.css. Page-local:
     General Questions sits on --sec-light, so the accordion + helper side card
     need a defined edge. */
  .faq-acc { border: 1px solid var(--color-border-card); padding: 1px; }
  .faq-side { border: 1px solid var(--color-border-card); }
</style>

<script>
  // NPS calculator — SIP-style corpus to age 60, then annuitisation split.
  const fmt = new Intl.NumberFormat('en-IN', { maximumFractionDigits: 0 });
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const RETIRE_AGE = 60;
  const ANNUITY_RATE = 0.06; // assumed annuity return, p.a.

  const amt = document.getElementById('amt') as HTMLInputElement;
  const amtR = document.getElementById('amtR') as HTMLInputElement;
  const age = document.getElementById('age') as HTMLInputElement;
  const ageR = document.getElementById('ageR') as HTMLInputElement;
  const rate = document.getElementById('rate') as HTMLInputElement;
  const rateR = document.getElementById('rateR') as HTMLInputElement;
  const ann = document.getElementById('ann') as HTMLInputElement;
  const annR = document.getElementById('annR') as HTMLInputElement;

  const segInv = document.getElementById('seg-inv') as HTMLElement;
  const segRet = document.getElementById('seg-ret') as HTMLElement;
  let last = { inv: 0, ret: 0, tot: 0, lump: 0, pen: 0 };

  function digits(s: string) {
    return String(s).replace(/[^0-9.]/g, '');
  }
  function clamp(v: number, mn: number, mx: number) {
    return Math.max(mn, Math.min(mx, v));
  }
  function fillSlider(sl: HTMLInputElement) {
    const p = ((+sl.value - +sl.min) / (+sl.max - +sl.min)) * 100;
    sl.style.background =
      'linear-gradient(90deg, #4f583b 0%, #4f583b ' + p + '%, #f3f3f3 ' + p + '%, #f3f3f3 100%)';
  }
  function countTo(el: HTMLElement, from: number, to: number, fn: (n: number) => string) {
    if (reduce || from === to) {
      el.textContent = fn(to);
      return;
    }
    let t0: number | null = null;
    const d = 350;
    function tick(ts: number) {
      if (t0 === null) t0 = ts;
      const t = Math.min(1, (ts - t0) / d);
      const e = 1 - Math.pow(1 - t, 3);
      el.textContent = fn(from + (to - from) * e);
      if (t < 1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }

  function render(animate: boolean) {
    const monthly = clamp(parseFloat(digits(amt.value)) || 0, +amtR.min, +amtR.max);
    const curAge = clamp(parseFloat(digits(age.value)) || 0, +ageR.min, +ageR.max);
    const ratePct = clamp(parseFloat(digits(rate.value)) || 0, +rateR.min, +rateR.max);
    const annPct = clamp(parseFloat(digits(ann.value)) || 0, +annR.min, +annR.max);

    const months = Math.max(0, (RETIRE_AGE - curAge) * 12);
    const i = ratePct / 100 / 12;
    // future value of a monthly contribution stream (annuity-due)
    const corpus = i > 0 ? monthly * ((Math.pow(1 + i, months) - 1) / i) * (1 + i) : monthly * months;
    const invested = monthly * months;
    const interest = corpus - invested;
    const annuityValue = corpus * (annPct / 100);
    const lump = corpus - annuityValue;
    const pension = (annuityValue * ANNUITY_RATE) / 12;
    const rupee = (v: number) => '₹' + fmt.format(Math.round(v));

    if (animate) {
      countTo(document.getElementById('r-inv') as HTMLElement, last.inv, invested, rupee);
      countTo(document.getElementById('r-ret') as HTMLElement, last.ret, interest, rupee);
      countTo(document.getElementById('d-tot') as HTMLElement, last.tot, corpus, rupee);
      countTo(document.getElementById('r-lump') as HTMLElement, last.lump, lump, rupee);
      countTo(document.getElementById('r-pen') as HTMLElement, last.pen, pension, rupee);
    } else {
      (document.getElementById('r-inv') as HTMLElement).textContent = rupee(invested);
      (document.getElementById('r-ret') as HTMLElement).textContent = rupee(interest);
      (document.getElementById('d-tot') as HTMLElement).textContent = rupee(corpus);
      (document.getElementById('r-lump') as HTMLElement).textContent = rupee(lump);
      (document.getElementById('r-pen') as HTMLElement).textContent = rupee(pension);
    }
    last = { inv: invested, ret: interest, tot: corpus, lump: lump, pen: pension };

    const invPct = corpus > 0 ? (invested / corpus) * 100 : 0;
    segInv.style.width = invPct + '%';
    segRet.style.width = 100 - invPct + '%';

    (document.getElementById('cta-amt') as HTMLElement).textContent = '₹' + fmt.format(monthly) + '/month NPS';
    (document.getElementById('sr-summary') as HTMLElement).textContent =
      'By age 60 your corpus is ' + rupee(corpus) + ', giving a ' + rupee(lump) + ' lump sum and about ' + rupee(pension) + ' monthly pension.';

    updateUrl(monthly, curAge, ratePct, annPct);
    amtR.setAttribute('aria-valuetext', '₹' + fmt.format(monthly));
    ageR.setAttribute('aria-valuetext', curAge + ' years');
    rateR.setAttribute('aria-valuetext', ratePct + ' percent');
    annR.setAttribute('aria-valuetext', annPct + ' percent');
  }

  function updateUrl(monthly: number, curAge: number, ratePct: number, annPct: number) {
    const q = '?amt=' + monthly + '&age=' + curAge + '&rate=' + ratePct + '&ann=' + annPct;
    try {
      history.replaceState(null, '', q);
    } catch (e) {
      /* ignore */
    }
  }

  function pairNumberAndSlider(numEl: HTMLInputElement, slEl: HTMLInputElement, group: boolean) {
    slEl.addEventListener('input', function () {
      numEl.value = group ? fmt.format(+slEl.value) : slEl.value;
      fillSlider(slEl);
      render(false);
    });
    numEl.addEventListener('input', function () {
      const raw = parseFloat(digits(numEl.value)) || 0;
      if (group) numEl.value = raw ? fmt.format(raw) : '';
      slEl.value = String(clamp(raw, +slEl.min, +slEl.max));
      fillSlider(slEl);
      render(false);
    });
    numEl.addEventListener('change', function () {
      const v = clamp(parseFloat(digits(numEl.value)) || +slEl.min, +slEl.min, +slEl.max);
      numEl.value = group ? fmt.format(v) : String(v);
      slEl.value = String(v);
      fillSlider(slEl);
      render(true);
    });
  }
  pairNumberAndSlider(amt, amtR, true);
  pairNumberAndSlider(age, ageR, false);
  pairNumberAndSlider(rate, rateR, false);
  pairNumberAndSlider(ann, annR, false);

  (function initFromUrl() {
    const p = new URLSearchParams(location.search);
    function setNum(el: HTMLInputElement, sl: HTMLInputElement, key: string, group: boolean) {
      if (!p.has(key)) return;
      const v = clamp(parseFloat(p.get(key) || '') || +sl.min, +sl.min, +sl.max);
      sl.value = String(v);
      el.value = group ? fmt.format(v) : String(v);
    }
    setNum(amt, amtR, 'amt', true);
    setNum(age, ageR, 'age', false);
    setNum(rate, rateR, 'rate', false);
    setNum(ann, annR, 'ann', false);
  })();

  [amtR, ageR, rateR, annR].forEach(fillSlider);
  render(true);
</script>

---
/**
 * NPS Calculator - /nps-calculator
 * Projects the National Pension System corpus at retirement, the lump-sum you
 * can withdraw and the monthly pension from the annuitised portion. Built on
 * the shared calculator UI in global.css; page carries content + maths.
 * (The NPS *product* page lives at /nps/.)
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/site/Breadcrumb.astro';
import FaqAccordion from '../components/sections/FaqAccordion.astro';
import { faqPageSchema } from '../lib/seo';

// Got Questions? - the first 6 FAQs from the compliance doc (display cap; the
// remainder was stripped and can be restored from the doc if needed). Feeds both
// the accordion and the FAQPage JSON-LD, so markup and schema cannot drift.
const FAQS = [
  {
    q: 'What is an NPS Calculator?',
    a: 'It is an online tool that estimates your NPS corpus, lump sum withdrawal, annuity amount and monthly pension.',
  },
  {
    q: 'Is NPS safe for retirement savings?',
    a: 'NPS is regulated by the Pension Fund Regulatory and Development Authority (PFRDA) and designed for long-term retirement savings. Returns are market-linked, so they are not guaranteed.',
  },
  {
    q: 'What is the minimum NPS contribution?',
    a: 'For Tier I, the minimum initial contribution is generally ₹500 and the minimum annual contribution is ₹1,000.',
  },
  {
    q: 'What is the maximum age to open an NPS account?',
    a: 'NPS entry age is generally 18 to 70 years for eligible Indian citizens.',
  },
  {
    q: 'What return rate should I assume?',
    a: 'Use a realistic long-term rate based on your asset allocation. Avoid assuming very high returns.',
  },
  {
    q: 'How much corpus can I withdraw as lump sum?',
    a: 'The lump sum amount depends on exit rules, corpus size and subscriber category. Check the latest PFRDA rules before exit.',
  },
];

const seo = {
  title: 'NPS Calculator - Pension',
  description:
    'Estimate your NPS retirement corpus and monthly pension amount with the free NPS calculator from Shriram Financial Services. Plan today.',
  path: '/nps-calculator',
  jsonLd: [faqPageSchema(FAQS.map((f) => ({ question: f.q, answer: f.a })))],
};
---

<BaseLayout seo={seo} mainClass="rev-rise-scale">
  <!-- ================= HERO ================= -->
  <section class="hero hero-compact" id="sec-hero" data-section="hero">
    <Breadcrumb trail={[{ name: 'Calculators', href: '/calculators' }, { name: 'NPS Calculator' }]} />
    <div class="hero-inner" data-enter>
      <h1>NPS Calculator – Estimate Your <span class="g">Retirement Corpus &amp; Monthly Pension</span></h1>
      <p class="lead">Plan your retirement with a quick estimate of your NPS returns.</p>
      <div class="cta"><a class="btn-gold" href="/open-demat-account">Open NPS Account Now</a></div>
    </div>
  </section>

  <!-- ===== NPS Calculator ===== -->
  <section class="section stack sec-light" id="sec-calc" data-section="calc" style="gap:24px" data-enter="2">
    <h2 class="sec-title">NPS Calculator</h2>
    <p class="calc-hint">Drag the sliders or type your own numbers - results update instantly.</p>

    <div class="calc-row">
      <!-- inputs -->
      <div class="card calc-panel">
        <div class="fields">
          <div class="field">
            <div class="field-top">
              <label for="age">Current Age</label>
              <div class="field-val"><input id="age" type="text" inputmode="numeric" value="30" aria-label="Current age in years" /><span class="sfx">yrs</span></div>
            </div>
            <input class="slider" id="ageR" type="range" min="18" max="59" step="1" value="30" aria-label="Current age in years" />
            <div class="slider-scale"><span>18 yrs</span><span>59 yrs</span></div>
          </div>

          <div class="field">
            <div class="field-top">
              <label for="rage">Retirement Age</label>
              <div class="field-val"><input id="rage" type="text" inputmode="numeric" value="60" aria-label="Retirement age in years" /><span class="sfx">yrs</span></div>
            </div>
            <input class="slider" id="rageR" type="range" min="40" max="70" step="1" value="60" aria-label="Retirement age in years" />
            <div class="slider-scale"><span>40 yrs</span><span>70 yrs</span></div>
          </div>

          <div class="field">
            <div class="field-top">
              <label for="amt">Monthly Contribution</label>
              <div class="field-val"><span class="pfx">₹</span><input id="amt" type="text" inputmode="numeric" value="5,000" aria-label="Monthly contribution in rupees" /></div>
            </div>
            <input class="slider" id="amtR" type="range" min="500" max="100000" step="500" value="5000" aria-label="Monthly contribution" />
            <div class="slider-scale"><span>₹500</span><span>₹1,00,000</span></div>
          </div>

          <div class="field">
            <div class="field-top">
              <label for="rate">Expected Return (% p.a.)</label>
              <div class="field-val"><input id="rate" type="text" inputmode="decimal" value="10" aria-label="Expected annual rate of return in percent" /><span class="sfx">%</span></div>
            </div>
            <input class="slider" id="rateR" type="range" min="4" max="15" step="0.5" value="10" aria-label="Expected annual rate of return in percent" />
            <div class="slider-scale"><span>4%</span><span>15%</span></div>
          </div>

          <div class="field">
            <div class="field-top">
              <label for="ann">Annuity Purchase (%)</label>
              <div class="field-val"><input id="ann" type="text" inputmode="numeric" value="40" aria-label="Share of corpus used to buy an annuity, in percent" /><span class="sfx">%</span></div>
            </div>
            <input class="slider" id="annR" type="range" min="40" max="100" step="5" value="40" aria-label="Share of corpus used to buy an annuity" />
            <div class="slider-scale"><span>40%</span><span>100%</span></div>
          </div>

          <div class="field">
            <div class="field-top">
              <label for="arate">Annuity Rate (% p.a.)</label>
              <div class="field-val"><input id="arate" type="text" inputmode="decimal" value="6" aria-label="Expected annuity rate in percent per year" /><span class="sfx">%</span></div>
            </div>
            <input class="slider" id="arateR" type="range" min="4" max="10" step="0.5" value="6" aria-label="Expected annuity rate" />
            <div class="slider-scale"><span>4%</span><span>10%</span></div>
          </div>
        </div>
      </div>

      <!-- results -->
      <div class="calc-results">
        <div class="bar-wrap">
          <div class="bar-top">
            <div class="bar-head">
              <span class="bar-cap">Total Corpus</span>
              <span class="bar-tot" id="d-tot">₹1,13,96,627</span>
            </div>
            <div class="stack-bar" role="img" aria-label="Corpus split between tax-free lump sum and the annuitised portion">
              <div class="seg seg-inv" id="seg-inv" style="width:60%"></div>
              <div class="seg seg-ret" id="seg-ret" style="width:40%"></div>
            </div>
          </div>

          <div class="res-cards" data-reveal-row>
            <div class="res-card">
              <div class="res-top"><span class="dot" style="background:var(--c-inv)"></span>Lump Sum (Tax-Free)</div>
              <div class="res-val" id="r-lump">₹68,37,976</div>
            </div>
            <div class="res-card">
              <div class="res-top"><span class="dot" style="background:var(--c-ret)"></span>Monthly Pension</div>
              <div class="res-val" id="r-pen">₹22,793/mo</div>
            </div>
          </div>

          <div class="bar-div" role="presentation"></div>

          <p class="bar-note">Results are estimates. Actual returns, annuity rates and tax rules may vary.</p>
        </div>

        <div class="ready-bar">
          <p class="ready-text">Put your plan into action - <b>open a free Demat account</b></p>
          <a class="ready-btn" href="/open-demat-account">Open Demat Account</a>
        </div>
      </div>
    </div>

    <p class="sr-only" id="sr-summary" aria-live="polite"></p>
  </section>

  <!-- ===== What Is an NPS Calculator? ===== -->
  <section class="section stack sec-tint" id="sec-what" data-section="what" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">What Is an NPS Calculator?</h2>
      <p class="sec-lead">An NPS Calculator is an online tool that estimates how much retirement corpus you may build through the National Pension System. It also shows how much of the corpus may be available as lump sum and how much monthly pension you may receive through annuity.</p>
    </div>

    <div class="stack" style="gap:16px">
      <h3 class="sub-title">Why use it?</h3>
      <ul class="bullets">
        <li>Estimate your retirement corpus in seconds.</li>
        <li>See your likely lump sum and monthly pension.</li>
        <li>Plan how much to invest every month.</li>
        <li>Compare different return and annuity assumptions.</li>
        <li>Use it anytime, without login.</li>
      </ul>
    </div>

    <div class="card" style="align-self:flex-start">
      <h4 class="card-h">Good to know</h4>
      <p class="card-p">NPS is regulated by the Pension Fund Regulatory and Development Authority (PFRDA). The scheme is designed for long-term retirement savings, not short-term investing.</p>
    </div>
  </section>

  <!-- ===== How Does the NPS Calculator Work? ===== -->
  <section class="section stack sec-light" id="sec-work" data-section="work" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">How Does the NPS Calculator Work?</h2>
      <p class="sec-lead">The calculator works in two simple stages.</p>
    </div>

    <div class="stack" style="gap:32px">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">Stage 1: Corpus accumulation</h3>
        <p class="sub-lead">Your monthly contributions are compounded until retirement. The calculator uses this formula:</p>
        <p class="sub-lead">A = P × [(1 + r/12)^(nt) – 1] / (r/12) × (1 + r/12)</p>
      </div>
      <div class="t-scroll"><div class="product-page_table t2 bordered" style="grid-template-columns:repeat(2,minmax(0,1fr))">
        <div class="cell th"><p>Variable</p></div><div class="cell th"><p>Meaning</p></div>
        <div class="cell tb"><p class="k">A</p></div><div class="cell tb"><p class="v">Estimated corpus at retirement</p></div>
        <div class="cell tb"><p class="k">P</p></div><div class="cell tb"><p class="v">Monthly contribution</p></div>
        <div class="cell tb"><p class="k">r</p></div><div class="cell tb"><p class="v">Expected annual return</p></div>
        <div class="cell tb"><p class="k">n</p></div><div class="cell tb"><p class="v">Compounding frequency, usually 12 for monthly</p></div>
        <div class="cell tb"><p class="k">t</p></div><div class="cell tb"><p class="v">Investment tenure in years</p></div>
      </div></div>
    </div>

    <div class="stack" style="gap:32px">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">Stage 2: Pension conversion</h3>
        <p class="sub-lead">A chosen part of the corpus is used to buy an annuity. This annuity gives regular pension income.</p>
        <p class="sub-lead">Monthly Pension = (Annuity Corpus × Annuity Rate) / 12</p>
      </div>
      <div class="card" style="align-self:flex-start">
        <h4 class="card-h">Example</h4>
        <p class="card-p">If you invest ₹5,000 per month for 30 years at 10% p.a., the estimated corpus is about ₹1.14 crore. If 40% is used for annuity at 6%, the estimated monthly pension is about ₹22,793.</p>
      </div>
    </div>
  </section>

  <!-- ===== How to Use the NPS Calculator ===== -->
  <section class="section stack sec-tint" id="sec-how-to-use" data-section="how-to-use" style="gap:56px;align-items:center;justify-content:center">
    <div class="stack" style="gap:16px;width:100%">
      <h2 class="sec-title">How to Use the NPS Calculator</h2>
      <p class="sec-lead">Use the NPS Calculator to estimate your retirement corpus and potential pension by entering your age, contribution amount, expected returns, and annuity preferences.</p>
    </div>
    <div class="steps" data-reveal-row>
      <div class="step">
        <div class="num">1</div>
        <div class="st-body"><h4>Step 1</h4><p>Enter your current age.</p></div>
      </div>
      <div class="step-div"></div>
      <div class="step">
        <div class="num">2</div>
        <div class="st-body"><h4>Step 2</h4><p>Add your monthly NPS contribution.</p></div>
      </div>
      <div class="step-div"></div>
      <div class="step">
        <div class="num">3</div>
        <div class="st-body"><h4>Step 3</h4><p>Choose your planned retirement age.</p></div>
      </div>
      <div class="step-div"></div>
      <div class="step">
        <div class="num">4</div>
        <div class="st-body"><h4>Step 4</h4><p>Enter your expected annual return.</p></div>
      </div>
      <div class="step-div"></div>
      <div class="step">
        <div class="num">5</div>
        <div class="st-body"><h4>Step 5</h4><p>Select your annuity percentage and expected annuity rate.</p></div>
      </div>
    </div>
    <p class="sec-lead" style="width:100%">The calculator will instantly show your total investment, retirement corpus, lump sum amount, annuity corpus and estimated monthly pension.</p>
    <div class="card" style="align-self:flex-start">
      <h4 class="card-h">Pro tip</h4>
      <p class="card-p">Do not use very high return assumptions. A balanced NPS allocation may include equity, corporate debt and government securities.</p>
    </div>
  </section>

  <!-- ===== Pension Adequacy Indicator ===== -->
  <section class="section stack sec-light" id="sec-adequacy" data-section="adequacy" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Pension Adequacy Indicator</h2>
      <p class="sec-lead">Your pension number is useful only when it is compared with your future lifestyle cost. The Pension Adequacy Indicator helps you check whether the estimated monthly pension may be enough.</p>
    </div>
    <div class="t-scroll"><div class="product-page_table t2 bordered" style="grid-template-columns:repeat(2,minmax(0,1fr))">
      <div class="cell th"><p>Signal</p></div><div class="cell th"><p>Meaning</p></div>
      <div class="cell tb"><p class="k">Green</p></div><div class="cell tb"><p class="v">Estimated pension covers 75% or more of your current monthly expenses.</p></div>
      <div class="cell tb"><p class="k">Amber</p></div><div class="cell tb"><p class="v">Estimated pension covers 40% to 75% of your current monthly expenses.</p></div>
      <div class="cell tb"><p class="k">Red</p></div><div class="cell tb"><p class="v">Estimated pension covers less than 40% of your current monthly expenses. You may need to invest more.</p></div>
    </div></div>
  </section>

  <!-- ===== Benefits of NPS for Retirement Planning ===== -->
  <section class="section stack sec-tint" id="sec-benefits" data-section="benefits" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Benefits of NPS for Retirement Planning</h2>
      <p class="sec-lead">Explore the key benefits of NPS for retirement planning, including tax advantages, market-linked growth, low costs, portability, withdrawal flexibility, and pension income.</p>
    </div>
    <div class="cat-grid cat-grid-3" data-reveal-row>
      <div class="cat"><h4>Tax benefits</h4><p>NPS may provide deductions under Section 80CCD, depending on your tax regime and contribution type.</p></div>
      <div class="cat"><h4>Market-linked growth</h4><p>Your money is invested across approved asset classes such as equity, corporate debt and government securities.</p></div>
      <div class="cat"><h4>Low-cost structure</h4><p>NPS is known for a cost-efficient structure compared with many long-term market-linked products.</p></div>
      <div class="cat"><h4>Portable account</h4><p>Your Permanent Retirement Account Number (PRAN) stays with you even if you change jobs, cities or sectors.</p></div>
      <div class="cat"><h4>Partial withdrawal flexibility</h4><p>Limited withdrawals may be allowed for specified needs, subject to rules.</p></div>
      <div class="cat"><h4>Lifetime pension option</h4><p>The annuity portion can provide regular pension income after retirement.</p></div>
    </div>
  </section>

  <!-- ===== NPS Pension Adequacy Planner ===== -->
  <section class="section stack sec-light" id="sec-planner" data-section="planner" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">NPS Pension Adequacy Planner: Will Your Pension Be Enough?</h2>
      <p class="sec-lead">A future pension can look large, but inflation reduces its value. This planner shows the estimated pension in today’s money.</p>
    </div>
    <div class="t-scroll"><div class="product-page_table t4 bordered" style="grid-template-columns:repeat(4,minmax(0,1fr));min-width:640px">
      <div class="cell th"><p>Monthly contribution</p></div><div class="cell th"><p>Tenure</p></div><div class="cell th"><p>Future monthly pension</p></div><div class="cell th"><p>Value in today’s money*</p></div>
      <div class="cell tb"><p class="k">₹5,000</p></div><div class="cell tb"><p class="v">30 years</p></div><div class="cell tb"><p class="v">₹22,600</p></div><div class="cell tb"><p class="v">₹5,230</p></div>
      <div class="cell tb"><p class="k">₹10,000</p></div><div class="cell tb"><p class="v">30 years</p></div><div class="cell tb"><p class="v">₹45,200</p></div><div class="cell tb"><p class="v">₹10,460</p></div>
      <div class="cell tb"><p class="k">₹15,000</p></div><div class="cell tb"><p class="v">25 years</p></div><div class="cell tb"><p class="v">₹52,800</p></div><div class="cell tb"><p class="v">₹15,580</p></div>
      <div class="cell tb"><p class="k">₹25,000</p></div><div class="cell tb"><p class="v">20 years</p></div><div class="cell tb"><p class="v">₹68,900</p></div><div class="cell tb"><p class="v">₹25,960</p></div>
    </div></div>
    <div class="card" style="align-self:flex-start">
      <h4 class="card-h">Reality check</h4>
      <p class="card-p">A monthly pension of ₹45,000 after 30 years may feel like roughly ₹10,500 today, assuming 5% annual inflation. Plan with real value, not only future value.</p>
    </div>
    <p class="sec-lead">*Illustrative values. Actual inflation and annuity rates may vary.</p>
  </section>

  <!-- ===== Tax Benefits and Taxation on NPS ===== -->
  <section class="section stack sec-tint" id="sec-tax" data-section="tax" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Tax Benefits and Taxation on NPS</h2>
      <p class="sec-lead">NPS tax treatment can differ by contribution type, tax regime and withdrawal stage. Use this as a simple guide and check with a tax adviser before investing.</p>
    </div>
    <div class="t-scroll"><div class="product-page_table t3 bordered" style="min-width:640px">
      <div class="cell th"><p>Stage</p></div><div class="cell th"><p>Treatment</p></div><div class="cell th"><p>Simple rule</p></div>
      <div class="cell tb"><p class="k">Self contribution</p></div><div class="cell tb"><p class="v">Deduction</p></div><div class="cell tb"><p class="v">Up to ₹1.5 lakh under Section 80CCD(1), within the overall 80C limit, generally under the old tax regime.</p></div>
      <div class="cell tb"><p class="k">Additional self contribution</p></div><div class="cell tb"><p class="v">Deduction</p></div><div class="cell tb"><p class="v">Extra deduction up to ₹50,000 under Section 80CCD(1B), generally under the old tax regime.</p></div>
      <div class="cell tb"><p class="k">Employer contribution</p></div><div class="cell tb"><p class="v">Deduction</p></div><div class="cell tb"><p class="v">Available under Section 80CCD(2), subject to salary-based limits.</p></div>
      <div class="cell tb"><p class="k">Lump sum at retirement</p></div><div class="cell tb"><p class="v">Tax treatment</p></div><div class="cell tb"><p class="v">The eligible lump sum withdrawal is generally tax-free, subject to applicable rules.</p></div>
      <div class="cell tb"><p class="k">Annuity purchase</p></div><div class="cell tb"><p class="v">Tax treatment</p></div><div class="cell tb"><p class="v">The amount used to buy annuity is not taxed at purchase.</p></div>
      <div class="cell tb"><p class="k">Monthly pension</p></div><div class="cell tb"><p class="v">Taxable income</p></div><div class="cell tb"><p class="v">Annuity pension is added to income and taxed as per the applicable slab.</p></div>
    </div></div>
    <div class="card" style="align-self:flex-start">
      <h4 class="card-h">Important</h4>
      <p class="card-p">The lump sum withdrawal and the monthly pension are not taxed in the same way. Pension from annuity is taxable as income.</p>
    </div>
  </section>

  <!-- ===== Who Should Invest in NPS? ===== -->
  <section class="section stack sec-light" id="sec-who" data-section="who" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Who Should Invest in NPS?</h2>
    </div>
    <div class="cat-grid cat-grid-2" data-reveal-row>
      <div class="cat"><h4>Salaried employees</h4><p>Useful as an extra retirement layer alongside EPF. Employer contribution may also improve tax efficiency.</p></div>
      <div class="cat"><h4>Government employees</h4><p>NPS is a core retirement asset for many government employees. Employer contribution can be a major benefit.</p></div>
      <div class="cat"><h4>Self-employed people</h4><p>Helpful for disciplined retirement saving when there is no employer-backed pension plan.</p></div>
      <div class="cat"><h4>Young investors</h4><p>Starting early gives contributions more time to compound. A longer tenure can make a meaningful difference.</p></div>
    </div>
  </section>

  <!-- ===== NPS Withdrawal and Exit Rules ===== -->
  <section class="section stack sec-tint" id="sec-exit" data-section="exit" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">NPS Withdrawal and Exit Rules</h2>
      <p class="sec-lead">NPS withdrawal rules depend on the subscriber category, exit age, corpus size and latest PFRDA rules. The table below is a simple content format for the page.</p>
    </div>
    <div class="t-scroll"><div class="product-page_table t3 bordered" style="min-width:640px">
      <div class="cell th"><p>Scenario</p></div><div class="cell th"><p>Lump sum</p></div><div class="cell th"><p>Annuity / condition</p></div>
      <div class="cell tb"><p class="k">At retirement</p></div><div class="cell tb"><p class="v">A portion may be withdrawn as lump sum.</p></div><div class="cell tb"><p class="v">A minimum portion is usually used to buy annuity, unless small-corpus rules apply.</p></div>
      <div class="cell tb"><p class="k">Before retirement</p></div><div class="cell tb"><p class="v">A smaller lump sum may be allowed.</p></div><div class="cell tb"><p class="v">A larger portion may need to be used for annuity.</p></div>
      <div class="cell tb"><p class="k">Partial withdrawal</p></div><div class="cell tb"><p class="v">Limited withdrawals may be allowed.</p></div><div class="cell tb"><p class="v">Usually for specified purposes such as education, illness, marriage or home purchase.</p></div>
    </div></div>
  </section>

  <!-- ===== How to Open an NPS Account Online ===== -->
  <section class="section stack sec-light" id="sec-open" data-section="open" style="gap:56px;align-items:center;justify-content:center">
    <div class="stack" style="gap:16px;width:100%">
      <h2 class="sec-title">How to Open an NPS Account Online</h2>
      <p class="sec-lead">Open an NPS account online by following these simple steps.</p>
    </div>
    <div class="steps" data-reveal-row>
      <div class="step">
        <div class="num">1</div>
        <div class="st-body"><h4>Step 1</h4><p>Visit the NPS portal on the Shriram Financial Services website.</p></div>
      </div>
      <div class="step-div"></div>
      <div class="step">
        <div class="num">2</div>
        <div class="st-body"><h4>Step 2</h4><p>Choose the subscriber type: individual or corporate.</p></div>
      </div>
      <div class="step-div"></div>
      <div class="step">
        <div class="num">3</div>
        <div class="st-body"><h4>Step 3</h4><p>Choose between NSDL or Kfintech</p></div>
      </div>
      <div class="step-div"></div>
      <div class="step">
        <div class="num">4</div>

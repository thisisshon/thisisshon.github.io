---
/**
 * NPS Calculator - /nps-calculator/
 * Projects the National Pension System corpus at retirement (age 60), the
 * lump-sum you can withdraw and the monthly pension from the annuitised
 * portion. Built on the shared calculator UI in global.css; page carries
 * content + maths. (The NPS *product* page lives at /nps/.)
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/site/Breadcrumb.astro';
import FaqAccordion from '../components/sections/FaqAccordion.astro';
import { faqPageSchema } from '../lib/seo';
import { otherCalculators, calcHref } from '../data/calculators';

const MORE = otherCalculators('nps');

const FAQS = [
  {
    q: 'How does this NPS calculator project my corpus?',
    a: 'It treats your monthly NPS contribution like a SIP that runs until your chosen retirement age. Each contribution compounds at your expected annual rate of return, and the calculator sums them to project the total corpus at retirement, then splits it into a tax-free lump sum and the annuitised portion that funds your pension.',
  },
  {
    q: 'Why must part of the corpus be used for an annuity?',
    a: 'Under current NPS rules, at retirement you can withdraw up to 60% of your corpus as a tax-free lump sum, but at least 40% must be used to buy an annuity that pays you a regular pension for life. This calculator lets you set the annuitised share (from 40% upward) and estimates the resulting monthly pension.',
  },
  {
    q: 'What annuity rate does the monthly pension assume?',
    a: 'The pension estimate assumes the annuitised amount earns roughly 6% per annum, paid monthly - a typical assumption for illustration. Your actual pension depends on the annuity plan and rates available from the insurer at the time you retire, so treat this figure as an indicative guide.',
  },
  {
    q: 'What rate of return should I expect from NPS?',
    a: 'NPS returns depend on your asset allocation across equity, corporate bonds and government securities. Long-term blended returns have historically fallen in the 8–11% range, but they are market-linked and not guaranteed. Running the calculator with a conservative and an optimistic rate shows the range of possible outcomes.',
  },
  {
    q: 'What are the tax benefits of NPS?',
    a: 'NPS contributions qualify for deductions under Section 80C and an additional dedicated deduction under Section 80CCD(1B), subject to prevailing limits. At retirement the lump-sum withdrawal is tax-free within the allowed share, while the pension income is taxed as per your slab in the year you receive it.',
  },
];

const seo = {
  title: 'NPS Calculator - Pension',
  description:
    'Estimate your NPS retirement corpus and monthly pension amount with the free NPS calculator from Shriram Financial Services. Plan today.',
  path: '/nps-calculator/',
  jsonLd: [faqPageSchema(FAQS.map((f) => ({ question: f.q, answer: f.a })))],
};
---

<BaseLayout seo={seo} mainClass="rev-rise-scale">
  <!-- ================= HERO ================= -->
  <section class="hero hero-compact" id="sec-hero" data-section="hero">
    <Breadcrumb trail={[{ name: 'Calculators', href: '/calculators/' }, { name: 'NPS Calculator' }]} />
    <div class="hero-inner" data-enter>
      <h1>Plan Your Retirement With The <span class="g">NPS Calculator</span></h1>
      <p class="lead">Project the corpus you'll build by 60, the lump-sum you can withdraw and the monthly pension your annuity could pay.</p>
    </div>
  </section>

  <!-- ===== NPS Calculator ===== -->
  <section class="section stack sec-light" id="sec-calc" data-section="calc" style="gap:24px" data-enter="2">
    <h2 class="sec-title">NPS Calculator</h2>
    <p class="calc-hint">Drag the sliders or type your own numbers - results update instantly.</p>

    <div class="calc-row">
      <!-- inputs -->
      <div class="card calc-panel">
        <div class="fields">
          <div class="field">
            <div class="field-top">
              <label for="age">Current Age</label>
              <div class="field-val"><input id="age" type="text" inputmode="numeric" value="30" aria-label="Current age in years" /><span class="sfx">yrs</span></div>
            </div>
            <input class="slider" id="ageR" type="range" min="18" max="59" step="1" value="30" aria-label="Current age in years" />
            <div class="slider-scale"><span>18 yrs</span><span>59 yrs</span></div>
          </div>

          <div class="field">
            <div class="field-top">
              <label for="rage">Retirement Age</label>
              <div class="field-val"><input id="rage" type="text" inputmode="numeric" value="60" aria-label="Retirement age in years" /><span class="sfx">yrs</span></div>
            </div>
            <input class="slider" id="rageR" type="range" min="40" max="70" step="1" value="60" aria-label="Retirement age in years" />
            <div class="slider-scale"><span>40 yrs</span><span>70 yrs</span></div>
          </div>

          <div class="field">
            <div class="field-top">
              <label for="amt">Monthly Contribution</label>
              <div class="field-val"><span class="pfx">₹</span><input id="amt" type="text" inputmode="numeric" value="5,000" aria-label="Monthly contribution in rupees" /></div>
            </div>
            <input class="slider" id="amtR" type="range" min="500" max="100000" step="500" value="5000" aria-label="Monthly contribution" />
            <div class="slider-scale"><span>₹500</span><span>₹1,00,000</span></div>
          </div>

          <div class="field">
            <div class="field-top">
              <label for="rate">Expected Return (% p.a.)</label>
              <div class="field-val"><input id="rate" type="text" inputmode="decimal" value="10" aria-label="Expected annual rate of return in percent" /><span class="sfx">%</span></div>
            </div>
            <input class="slider" id="rateR" type="range" min="4" max="15" step="0.5" value="10" aria-label="Expected annual rate of return in percent" />
            <div class="slider-scale"><span>4%</span><span>15%</span></div>
          </div>

          <div class="field">
            <div class="field-top">
              <label for="ann">Annuity Purchase (%)</label>
              <div class="field-val"><input id="ann" type="text" inputmode="numeric" value="40" aria-label="Share of corpus used to buy an annuity, in percent" /><span class="sfx">%</span></div>
            </div>
            <input class="slider" id="annR" type="range" min="40" max="100" step="5" value="40" aria-label="Share of corpus used to buy an annuity" />
            <div class="slider-scale"><span>40%</span><span>100%</span></div>
          </div>

          <div class="field">
            <div class="field-top">
              <label for="arate">Annuity Rate (% p.a.)</label>
              <div class="field-val"><input id="arate" type="text" inputmode="decimal" value="6" aria-label="Expected annuity rate in percent per year" /><span class="sfx">%</span></div>
            </div>
            <input class="slider" id="arateR" type="range" min="4" max="10" step="0.5" value="6" aria-label="Expected annuity rate" />
            <div class="slider-scale"><span>4%</span><span>10%</span></div>
          </div>
        </div>
      </div>

      <!-- results -->
      <div class="calc-results">
        <div class="bar-wrap">
          <div class="bar-top">
            <div class="bar-head">
              <span class="bar-cap">Total Corpus</span>
              <span class="bar-tot" id="d-tot">₹1,13,96,627</span>
            </div>
            <div class="stack-bar" role="img" aria-label="Corpus split between tax-free lump sum and the annuitised portion">
              <div class="seg seg-inv" id="seg-inv" style="width:60%"></div>
              <div class="seg seg-ret" id="seg-ret" style="width:40%"></div>
            </div>
          </div>

          <div class="res-cards" data-reveal-row>
            <div class="res-card">
              <div class="res-top"><span class="dot" style="background:var(--c-inv)"></span>Lump Sum (Tax-Free)</div>
              <div class="res-val" id="r-lump">₹68,37,976</div>
            </div>
            <div class="res-card">
              <div class="res-top"><span class="dot" style="background:var(--c-ret)"></span>Monthly Pension</div>
              <div class="res-val" id="r-pen">₹22,793/mo</div>
            </div>
          </div>

          <div class="bar-div" role="presentation"></div>

          <p class="bar-note">A two-stage estimate: the corpus accumulates monthly, then the annuitised portion converts to pension. The lump sum (up to 60%) is tax-free; pension income is taxable.</p>
        </div>

        <div class="ready-bar">
          <p class="ready-text">Put your plan into action - <b>open a free Demat account</b></p>
          <a class="ready-btn" href="/open-demat-account/">Open Demat Account</a>
        </div>
      </div>
    </div>

    <p class="sr-only" id="sr-summary" aria-live="polite"></p>
  </section>

  <!-- ===== What Is An NPS Calculator ===== -->
  <section class="section stack sec-tint" id="sec-what" data-section="what" style="gap:24px">
    <h2 class="sec-title">What Is An NPS Calculator?</h2>
    <p class="sec-lead">An NPS calculator is a free online tool that projects the retirement corpus you can build through the National Pension System. By entering your current and retirement age, your monthly contribution, an expected annual rate of return, the share of the corpus you plan to annuitise and the annuity rate, it estimates the total corpus at retirement, the lump sum you can withdraw and the monthly pension your annuity could provide. It turns decades of contributions into a clear, single-screen picture of your retirement.</p>
  </section>

  <!-- ===== How An NPS Calculator Helps You ===== -->
  <section class="section stack sec-light" id="sec-help" data-section="help" style="gap:24px">
    <h2 class="sec-title">How An NPS Calculator Helps You</h2>
    <p class="sec-lead">Retirement is decades away and easy to under-plan. The calculator makes the long horizon tangible:</p>
    <ul class="bullets">
      <li>See the corpus your monthly contribution could grow into by the time you retire.</li>
      <li>Understand how much you can take as a lump sum versus what funds your pension.</li>
      <li>Estimate your monthly pension so you can judge whether it meets your retirement needs.</li>
      <li>Test how starting earlier or contributing more changes the outcome - the earlier the bigger.</li>
    </ul>
  </section>

  <!-- ===== How Does An NPS Calculator Work ===== -->
  <section class="section stack sec-tint" id="sec-work" data-section="work" style="gap:24px">
    <h2 class="sec-title">How Does An NPS Calculator Work?</h2>
    <p class="sec-lead">The calculator first works out how many months remain until your retirement age and compounds each monthly contribution at your expected rate of return over that period - the same future-value logic as a SIP - to arrive at your corpus. It then applies your chosen annuitisation share: the annuitised portion is converted into a lifelong monthly pension at your chosen annuity rate, and the remainder is your tax-free lump-sum withdrawal.</p>
  </section>

  <!-- ===== Advantages Of An NPS Calculator ===== -->
  <section class="section stack sec-light" id="sec-adv" data-section="adv" style="gap:24px">
    <h2 class="sec-title">Advantages Of An NPS Calculator</h2>
    <p class="sec-lead">For a decades-long commitment like NPS, seeing the end result in advance changes how you plan:</p>
    <ul class="bullets">
      <li>Instant projection of corpus, lump sum and pension from a single set of inputs.</li>
      <li>Completely free to use, with no sign-up required and results delivered in real time.</li>
      <li>Helps you pick a contribution and annuitisation mix that matches your retirement goals.</li>
      <li>Makes the reward of starting early and staying invested impossible to ignore.</li>
    </ul>
  </section>

  <!-- ===== Explore More ===== -->
  <section class="section stack sec-tint" id="sec-explore" data-section="explore" style="gap:40px">
    <h2 class="sec-title">Explore More</h2>
    <div class="explore-grid" data-reveal-row>
      {
        MORE.map((c) => (
          <a class="xcard" href={calcHref(c.slug)}>
            <span class="xc-title">{c.title}</span>
            <span class="xc-desc">{c.desc}</span>
            <span class="xc-cta">Calculate Now <span class="arr" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 8h11M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span></span>
          </a>
        ))
      }
    </div>
  </section>

  <!-- ===== General Questions ===== -->
  <section class="faq-wrap sec-light" id="sec-faq" data-section="faq">
    <div class="faq-cols">
      <div class="faq-left">
        <h2 class="faq-title">General Questions</h2>
        <FaqAccordion faqs={FAQS} />
      </div>
      <div class="faq-side">
        <div class="usr"><img src="/assets/user.svg" alt="" /></div>
        <div class="side-in">
          <div class="side-tx">
            <h3>Need A Clearer Direction? </h3>
            <p>Let's get in touch on a 15-Minute call where we would be able to answer any questions you may have. Our Advisor will additionally help map your wealth mix and demonstrate what a dedicated advisor would do differently.</p>
          </div>
          <a class="btn-gold" href="#">Book A Discovery Call</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* NPS calculator - calculator UI is shared in global.css. Page-local:
     General Questions sits on --sec-light, so the accordion + helper side card
     need a defined edge. */
  .faq-acc { border: 1px solid var(--color-border-card); padding: 1px; }
  .faq-side { border: 1px solid var(--color-border-card); }

  /* NPS has six inputs - lay the sliders out two-across (a 2-column grid) from
     tablet up; phones keep the single-column stack. NPS-only (page-scoped).
     The grid grows to fill the input card and distributes its three rows
     (align-content) so it spans the same vertical extent as the results column
     to its right. Wider 64px column gutter between the two slider columns. */
  @media (min-width: 640px) {
    .fields {
      flex: 1;
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: 64px;
      row-gap: 32px;
      align-content: space-between;
    }
  }
</style>

<script>
  // NPS calculator - SIP-style corpus to retirement, then annuitisation split.
  import { createFlow } from '../scripts/number-flow';

  const fmt = new Intl.NumberFormat('en-IN', { maximumFractionDigits: 0 });
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const age = document.getElementById('age') as HTMLInputElement;
  const ageR = document.getElementById('ageR') as HTMLInputElement;
  const rage = document.getElementById('rage') as HTMLInputElement;
  const rageR = document.getElementById('rageR') as HTMLInputElement;
  const amt = document.getElementById('amt') as HTMLInputElement;
  const amtR = document.getElementById('amtR') as HTMLInputElement;
  const rate = document.getElementById('rate') as HTMLInputElement;
  const rateR = document.getElementById('rateR') as HTMLInputElement;
  const ann = document.getElementById('ann') as HTMLInputElement;
  const annR = document.getElementById('annR') as HTMLInputElement;
  const arate = document.getElementById('arate') as HTMLInputElement;
  const arateR = document.getElementById('arateR') as HTMLInputElement;

  const segInv = document.getElementById('seg-inv') as HTMLElement;
  const segRet = document.getElementById('seg-ret') as HTMLElement;

  // odometer reels for the three result values
  const flowTot = createFlow(document.getElementById('d-tot') as HTMLElement);
  const flowLump = createFlow(document.getElementById('r-lump') as HTMLElement);
  const flowPen = createFlow(document.getElementById('r-pen') as HTMLElement);
  let started = false; // first paint snaps; every change after that rolls

  function digits(s: string) {
    return String(s).replace(/[^0-9.]/g, '');
  }
  function clamp(v: number, mn: number, mx: number) {
    return Math.max(mn, Math.min(mx, v));
  }
  function fillSlider(sl: HTMLInputElement) {
    const p = ((+sl.value - +sl.min) / (+sl.max - +sl.min)) * 100;
    sl.style.background =
      'linear-gradient(90deg, #4f583b 0%, #4f583b ' + p + '%, #f3f3f3 ' + p + '%, #f3f3f3 100%)';
  }

  /* Re-targeting count animation. Reads the start value from what's CURRENTLY
     shown and cancels any in-flight tween on the same element, so rapid slider
     moves roll smoothly toward a moving target instead of restarting from a stale
     value. `read`/`write` adapt it to either a result <span> (textContent) or an
     <input> (value). Snaps instantly under reduced-motion or for sub-unit deltas. */
  const DUR = 300;
  function animateCount(
    el: HTMLElement & { _raf?: number | null },
    to: number,
    read: (el: HTMLElement) => number,
    write: (el: HTMLElement, v: number) => void
  ) {
    const from = read(el);
    if (el._raf) {
      cancelAnimationFrame(el._raf);
      el._raf = null;
    }
    if (reduce || Math.abs(to - from) < 1) {
      write(el, to);
      return;
    }
    let t0: number | null = null;
    function tick(ts: number) {
      if (t0 === null) t0 = ts;
      const t = Math.min(1, (ts - t0) / DUR);
      const e = 1 - Math.pow(1 - t, 3);
      write(el, from + (to - from) * e);
      el._raf = t < 1 ? requestAnimationFrame(tick) : null;
    }
    el._raf = requestAnimationFrame(tick);
  }
  // input value driven by its slider: tween the number the field displays
  function countInput(el: HTMLInputElement, to: number, fn: (n: number) => string) {
    animateCount(el, to, (e) => parseFloat(digits((e as HTMLInputElement).value)) || 0, (e, v) => {
      (e as HTMLInputElement).value = fn(v);
    });
  }

  // Computation reads the RANGE sliders (always the exact current value), never
  // the text fields - those may be mid count-animation and would corrupt the maths.
  function render() {
    const curAge = clamp(+ageR.value, +ageR.min, +ageR.max);
    const retAge = clamp(+rageR.value, +rageR.min, +rageR.max);
    const monthly = clamp(+amtR.value, +amtR.min, +amtR.max);
    const ratePct = clamp(+rateR.value, +rateR.min, +rateR.max);
    const annPct = clamp(+annR.value, +annR.min, +annR.max);
    const annRatePct = clamp(+arateR.value, +arateR.min, +arateR.max);

    const months = Math.max(0, Math.round((retAge - curAge) * 12));
    const i = ratePct / 100 / 12;
    // future value of a monthly contribution stream (annuity-due)
    const corpus = i > 0 ? monthly * ((Math.pow(1 + i, months) - 1) / i) * (1 + i) : monthly * months;
    const annuityValue = corpus * (annPct / 100);
    const lump = corpus - annuityValue;
    const pension = (annuityValue * (annRatePct / 100)) / 12;
    const rupee = (v: number) => '₹' + fmt.format(Math.round(v));
    const perMonth = (v: number) => '₹' + fmt.format(Math.round(v)) + '/mo';

    const roll = started && !reduce;
    flowTot(rupee(corpus), roll);
    flowLump(rupee(lump), roll);
    flowPen(perMonth(pension), roll);
    started = true;

    // dark = tax-free lump sum, gold = annuitised portion
    const lumpPct = corpus > 0 ? (lump / corpus) * 100 : 0;
    segInv.style.width = lumpPct + '%';
    segRet.style.width = 100 - lumpPct + '%';

    (document.getElementById('sr-summary') as HTMLElement).textContent =
      'By age ' + retAge + ' your corpus is ' + rupee(corpus) + ', giving a ' + rupee(lump) + ' tax-free lump sum and about ' + perMonth(pension) + ' pension.';

    updateUrl(curAge, retAge, monthly, ratePct, annPct, annRatePct);
    ageR.setAttribute('aria-valuetext', curAge + ' years');
    rageR.setAttribute('aria-valuetext', retAge + ' years');
    amtR.setAttribute('aria-valuetext', '₹' + fmt.format(monthly));
    rateR.setAttribute('aria-valuetext', ratePct + ' percent');
    annR.setAttribute('aria-valuetext', annPct + ' percent');
    arateR.setAttribute('aria-valuetext', annRatePct + ' percent');
  }

  function updateUrl(curAge: number, retAge: number, monthly: number, ratePct: number, annPct: number, annRatePct: number) {
    const q = '?age=' + curAge + '&rage=' + retAge + '&amt=' + monthly + '&rate=' + ratePct + '&ann=' + annPct + '&arate=' + annRatePct;
    try {
      history.replaceState(null, '', q);
    } catch (e) {
      /* ignore */
    }
  }

  function pairNumberAndSlider(numEl: HTMLInputElement, slEl: HTMLInputElement, group: boolean) {
    // decimals to show for this field, inferred from the slider step (e.g. 0.5 → 1)
    const dec = ((slEl.step || '').split('.')[1] || '').length;
    // money → grouped integer; otherwise round to the step's precision but drop a
    // trailing ".0" so whole numbers read "14", not "14.0".
    const fmtField = (v: number) =>
      group ? fmt.format(Math.round(v)) : String(+v.toFixed(dec));

    // Dragging the slider drives the field - count-animate the field toward the
    // slider value, and let render() count-animate the results. Maths reads the
    // slider, so the trailing field display never affects the computed numbers.
    slEl.addEventListener('input', function () {
      countInput(numEl, +slEl.value, fmtField);
      fillSlider(slEl);
      render();
    });
    // Typing sets the field verbatim (no self-animation) and drives the slider.
    numEl.addEventListener('input', function () {
      const raw = parseFloat(digits(numEl.value)) || 0;
      if (group) numEl.value = raw ? fmt.format(raw) : '';
      slEl.value = String(clamp(raw, +slEl.min, +slEl.max));
      fillSlider(slEl);
      render();
    });
    // On blur, snap the field to the clamped, formatted value.
    numEl.addEventListener('change', function () {
      const v = clamp(parseFloat(digits(numEl.value)) || +slEl.min, +slEl.min, +slEl.max);
      const nf = numEl as HTMLInputElement & { _raf?: number | null };
      if (nf._raf) {
        cancelAnimationFrame(nf._raf);
        nf._raf = null;
      }
      numEl.value = fmtField(v);
      slEl.value = String(v);
      fillSlider(slEl);
      render();
    });
  }
  pairNumberAndSlider(age, ageR, false);
  pairNumberAndSlider(rage, rageR, false);
  pairNumberAndSlider(amt, amtR, true);
  pairNumberAndSlider(rate, rateR, false);
  pairNumberAndSlider(ann, annR, false);
  pairNumberAndSlider(arate, arateR, false);

  (function initFromUrl() {
    const p = new URLSearchParams(location.search);
    function setNum(el: HTMLInputElement, sl: HTMLInputElement, key: string, group: boolean) {
      if (!p.has(key)) return;
      const v = clamp(parseFloat(p.get(key) || '') || +sl.min, +sl.min, +sl.max);
      sl.value = String(v);
      el.value = group ? fmt.format(v) : String(v);
    }
    setNum(age, ageR, 'age', false);
    setNum(rage, rageR, 'rage', false);
    setNum(amt, amtR, 'amt', true);
    setNum(rate, rateR, 'rate', false);
    setNum(ann, annR, 'ann', false);
    setNum(arate, arateR, 'arate', false);
  })();

  [ageR, rageR, amtR, rateR, annR, arateR].forEach(fillSlider);
  render();
</script>

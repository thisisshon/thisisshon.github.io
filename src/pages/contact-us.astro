---
/**
 * Contact Us / Support hub - /contact-us
 * Tabbed page (Customer Care / Branch Locator / Downloads) with a sticky tab
 * bar, a schedule-a-call lead-capture form and an interactive branch map.
 * Pixel parity with legacy support/index.html.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/site/Breadcrumb.astro';

const seo = {
  title: 'Contact & Customer Support',
  description:
    'Get in touch with Shriram Financial Services for account help, trading queries or a free discovery call with a dedicated wealth advisor.',
  path: '/contact-us',
  // Legacy inline ContactPoint block - ported verbatim (NOT the seo.ts
  // organizationSchema helper, which emits a different FinancialService shape).
  jsonLd: [
    {
      '@context': 'https://schema.org',
      '@type': 'Organization',
      name: 'Shriram Financial Services',
      url: 'https://www.shriramsec.in/',
      contactPoint: [
        {
          '@type': 'ContactPoint',
          telephone: '080-47185579 / 080-43676869',
          contactType: 'customer support',
          areaServed: 'IN',
          availableLanguage: ['en', 'hi'],
          email: 'support@shriramfs.com',
        },
      ],
    },
  ],
};
---

<BaseLayout seo={seo} mainClass="rev-rise-scale">
  <!-- ================= HERO ================= -->
  <section class="hero" id="sec-hero" data-section="hero">
    <Breadcrumb trail={[{ name: 'Contact Us' }]} />
    <div class="hero-grid">
      <div class="hero-inner" data-enter>
        <h1>How can we <span class="g">help you?</span></h1>
        <p class="lead">Reach our support team across multiple channels. We are here from Monday to Friday, 8:30am – 5:30pm, Saturday: 10 am to 1pm</p>
        <div class="hero-contacts">
          <a class="ct-pill" href="tel:08047185579">
            <svg viewBox="0 0 24 24" fill="none"><path d="M5 4h3l1.5 5-2 1.5a11 11 0 0 0 5 5l1.5-2 5 1.5v3a2 2 0 0 1-2 2A16 16 0 0 1 3 6a2 2 0 0 1 2-2Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"></path></svg>
            080-47185579 | 080-43676869 Extn.825/831
          </a>
          <a class="ct-pill" href="mailto:support@shriramfs.com">
            <svg viewBox="0 0 24 24" fill="none"><rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.6"></rect><path d="m4 7 8 6 8-6" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"></path></svg>
            support@shriramfs.com
          </a>
        </div>
      </div>

      <!-- schedule-a-call lead-capture card -->
      <form class="hero-form hero-aside reveal" aria-label="Schedule a call with us" onsubmit="return false;">
        <div class="hf-head">
          <h2>Schedule a call with us</h2>
        </div>
        <div class="hf-body">
          <div class="hf-unit">
            <div class="hf-field">
              <div class="hf-field-in">
                <label for="cf-name">Name</label>
                <input id="cf-name" name="name" type="text" autocomplete="name" placeholder="Name" aria-describedby="err-name" required />
              </div>
            </div>
            <p class="hf-err" id="err-name">Please enter your name.</p>
          </div>
          <div class="hf-unit">
            <div class="hf-field">
              <div class="hf-field-in">
                <label for="cf-mobile">Mobile Number</label>
                <input id="cf-mobile" name="mobile" type="tel" inputmode="numeric" autocomplete="tel-national" placeholder="Mobile Number" aria-describedby="err-mobile" required />
              </div>
            </div>
            <p class="hf-err" id="err-mobile">Enter a valid 10-digit mobile number.</p>
          </div>
          <div class="hf-unit">
            <div class="hf-field sel">
              <div class="hf-field-in">
                <label for="cf-city">City</label>
                <select id="cf-city" name="city" aria-describedby="err-city" required>
                  <option value="">City</option>
                  <option>Bengaluru</option>
                  <option>Chennai</option>
                  <option>Coimbatore</option>
                  <option>Hyderabad</option>
                  <option>Kolkata</option>
                  <option>Madurai</option>
                  <option>Mumbai</option>
                  <option>New Delhi</option>
                  <option>Surat</option>
                  <option>Trichy</option>
                  <option>Vijayawada</option>
                  <option>Visakhapatnam</option>
                  <option>Other</option>
                </select>
              </div>
            </div>
            <p class="hf-err" id="err-city">Please select your city.</p>
          </div>
          <div class="hf-unit">
            <div class="hf-field sel">
              <div class="hf-field-in">
                <label for="cf-purpose">Purpose</label>
                <select id="cf-purpose" name="purpose" aria-describedby="err-purpose" required>
                  <option value="">Purpose</option>
                  <option>Product related</option>
                  <option>Service related</option>
                  <option>Demat account related</option>
                  <option>Others</option>
                </select>
              </div>
            </div>
            <p class="hf-err" id="err-purpose">Please select a purpose.</p>
          </div>
        </div>
        <button class="btn btn-primary btn-xl" type="submit">Submit</button>
        <div class="hf-otp" role="group" aria-label="OTP Verification">
          <div class="hf-head">
            <h2>OTP Verification</h2>
            <p>We've sent a 6-digit verification code to your phone number. Please enter it below to submit your message.</p>
          </div>
          <button class="btn btn-primary btn-xl" type="button" id="cf-verify">Verify &amp; Submit</button>
        </div>
        <div class="hf-success" role="status" aria-live="polite">
          <span class="ok" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="m5 13 4 4L19 7" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"></path></svg></span>
          <h3>Thanks for reaching out!</h3>
          <p class="hf-msg">Your message has been successfully sent. Our team is on it, and we'll get back to you within 24 hours.</p>
        </div>
      </form>
    </div>
  </section>

  <!-- ================= TAB BAR ================= -->
  <div class="tabbar">
    <div class="tabbar-inner" role="tablist" aria-label="Contact options">
      <button class="tab" id="tab-care" role="tab" aria-selected="true" aria-controls="panel-care" data-label="Customer Care">Customer Care</button>
      <button class="tab" id="tab-branch" role="tab" aria-selected="false" aria-controls="panel-branch" tabindex="-1" data-label="Branch Locator">Branch Locator</button>
      <button class="tab" id="tab-downloads" role="tab" aria-selected="false" aria-controls="panel-downloads" tabindex="-1" data-label="Downloads">Downloads</button>
    </div>
  </div>

  <!-- ================= PANEL: CUSTOMER CARE ================= -->
  <section class="section stack tabpanel sec-light" id="panel-care" role="tabpanel" aria-labelledby="tab-care"
           data-section="care" style="gap:40px" data-enter="2">
    <div class="stack reveal" style="gap:16px">
      <h2 class="sub-title">Get in touch</h2>
      <p class="sub-lead">Choose the channel that works best for you.</p>
    </div>
    <div class="hours-bar reveal">
      <svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6"></circle><path d="M12 7v5l3.5 2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path></svg>
      Support hours: Monday – Saturday, 8:30 AM to 5:30 PM IST. Closed on public holidays.
    </div>
    <div class="chan-grid reveal" data-reveal-row>
      <div class="chan">
        <span class="chan-ico" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M5 4h3l1.5 5-2 1.5a11 11 0 0 0 5 5l1.5-2 5 1.5v3a2 2 0 0 1-2 2A16 16 0 0 1 3 6a2 2 0 0 1 2-2Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"></path></svg></span>
        <h3>Landline Number</h3>
        <span class="val"><a href="tel:08047185579">080 - 4718 5579</a></span>
        <p>Support hours: Monday to Friday:08:30 AM – 5:30 PM ,Saturday:10 am to 1pm  , Closed on Public Holiday.</p>
      </div>
      <div class="chan">
        <span class="chan-ico" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M5 4h3l1.5 5-2 1.5a11 11 0 0 0 5 5l1.5-2 5 1.5v3a2 2 0 0 1-2 2A16 16 0 0 1 3 6a2 2 0 0 1 2-2Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"></path></svg></span>
        <h3>Alternate Landline</h3>
        <span class="val"><a href="tel:08043676869">080- 4367 6869 Extn. 825/831</a></span>
        <p>Support hours: Monday to Friday:08:30 AM – 5:30 PM ,Saturday:10 am to 1pm,  Closed on Public Holiday.</p>
      </div>
      <div class="chan">
        <span class="chan-ico" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.6"></rect><path d="m4 7 8 6 8-6" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"></path></svg></span>
        <h3>Email support</h3>
        <span class="val"><a href="mailto:support@shriramfs.com">support@shriramfs.com</a></span>
        <p>Response within 24 hours</p>
      </div>
    </div>
    <div class="office reveal">
      <span class="office-ico" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M4 20V8l8-4 8 4v12" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"></path><path d="M4 20h16M9 20v-5h6v5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path><path d="M9 11h.01M15 11h.01" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></path></svg></span>
      <div class="office-tx">
        <h3>Head office</h3>
        <p>3rd Floor, Rukmini Towers, #3/1, Sheshadripuram, Bengaluru-560 020<br/>Monday to Friday: 8:30 AM – 5:30 PM , Saturday:10 am to 1pm, Closed on Public Holiday.</p>
      </div>
    </div>
    <div class="cta-box dark reveal">
      <div class="ct-tt">
        <h3>Open Demat account</h3>
        <p class="ct-sub">In less than 5 minutes</p>
      </div>
      <div class="cta-actions">
        <a class="btn btn-primary" href="/open-demat-account">Open Demat account</a>
      </div>
    </div>
  </section>

  <!-- ================= PANEL: BRANCH LOCATOR ================= -->
  <section class="section stack tabpanel sec-light" id="panel-branch" role="tabpanel" aria-labelledby="tab-branch"
           data-section="branch" hidden style="gap:40px">
    <div class="stack reveal" style="gap:16px">
      <h2 class="sub-title">Find a branch near you</h2>
      <p class="sub-lead">Search by state and city, or browse the list below.</p>
    </div>
    <div class="branch-search reveal">
      <div class="hf-field sel">
        <div class="hf-field-in">
          <label for="bs-state">State</label>
          <select id="bs-state" aria-label="Select State"></select>
        </div>
      </div>
      <div class="hf-field sel">
        <div class="hf-field-in">
          <label for="bs-branch">City</label>
          <select id="bs-branch" aria-label="Select City"></select>
        </div>
      </div>
      <button class="btn btn-primary btn-xl" type="button" id="bs-search">Search</button>
    </div>
    <div class="map-wrap reveal" id="map-wrap">
      <iframe id="branch-map" title="Map view – enter state and city to locate branches" loading="lazy" referrerpolicy="no-referrer-when-downgrade"
        src="https://maps.google.com/maps?q=Shriram%20Financial%20Services%20Pvt%20Ltd%2C%20India&z=5&output=embed"></iframe>
    </div>

    <div class="branch-groups reveal" id="branch-groups"></div>

    <div class="cta-box dark reveal">
      <div class="ct-tt">
        <h3>Open Demat account</h3>
        <p class="ct-sub">In less than 5 minutes</p>
      </div>
      <div class="cta-actions">
        <a class="btn btn-primary" href="/open-demat-account">Open Demat account</a>
      </div>
    </div>
  </section>

  <!-- ================= PANEL: DOWNLOADS ================= -->
  <section class="section stack tabpanel sec-light" id="panel-downloads" role="tabpanel" aria-labelledby="tab-downloads"
           data-section="downloads" hidden style="gap:40px">
    <div class="stack reveal" style="gap:16px">
      <h2 class="sub-title">Forms &amp; documents</h2>
      <p class="sub-lead">Download, fill, and submit at your nearest branch or via email.</p>
    </div>

    <div class="doc-toolbar reveal">
      <div class="doc-search">
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.7"></circle><path d="m20 20-3.2-3.2" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"></path></svg>
        <label class="sr-only" for="doc-q">Search forms</label>
        <input id="doc-q" type="search" placeholder="Search forms &amp; documents" autocomplete="off" />
      </div>
      <div class="doc-chips" role="group" aria-label="Filter by category">
        <button class="doc-chip" type="button" data-cat="all" aria-pressed="true">All</button>
        <button class="doc-chip" type="button" data-cat="grievance" aria-pressed="false">Grievance</button>
        <button class="doc-chip" type="button" data-cat="account-opening" aria-pressed="false">Account Opening</button>
        <button class="doc-chip" type="button" data-cat="kyc" aria-pressed="false">KYC &amp; Compliance</button>
        <button class="doc-chip" type="button" data-cat="dp-demat" aria-pressed="false">DP / Demat</button>
        <button class="doc-chip" type="button" data-cat="funds" aria-pressed="false">Funds &amp; Settlement</button>
      </div>
    </div>
    <p class="doc-empty" id="doc-empty">No forms match your search. Try a different term or category.</p>

    <div class="doc-group reveal" data-cat="grievance">
      <p class="doc-cat">Grievance</p>
      <div class="doc-grid" data-reveal-row>
        <div class="doc-card">
          <span class="nm">Grievance Redressal Policy</span>
          <span class="upd">Updated Jun 2025</span>
          <a class="doc-dl" href="#">Download</a>
        </div>
        <div class="doc-card">
          <span class="nm">Complaint Registration Form</span>
          <span class="upd">Updated Jun 2025</span>
          <a class="doc-dl" href="#">Download</a>
        </div>
      </div>
    </div>

    <div class="doc-group reveal" data-cat="account-opening">
      <p class="doc-cat">Account Opening</p>
      <div class="doc-grid" data-reveal-row>
        <div class="doc-card">
          <span class="nm">Account Opening Form - Individual</span>
          <span class="upd">Updated Apr 2025</span>
          <a class="doc-dl" href="#">Download</a>
        </div>
        <div class="doc-card">
          <span class="nm">Account Opening Form - Non-Individual</span>
          <span class="upd">Updated Apr 2025</span>
          <a class="doc-dl" href="#">Download</a>
        </div>
        <div class="doc-card">
          <span class="nm">Account Closure Form</span>
          <span class="upd">Updated Mar 2025</span>
          <a class="doc-dl" href="#">Download</a>
        </div>
      </div>
    </div>

    <div class="doc-group reveal" data-cat="kyc">
      <p class="doc-cat">KYC &amp; Compliance</p>
      <div class="doc-grid" data-reveal-row>
        <div class="doc-card">
          <span class="nm">KYC Modification Form</span>
          <span class="upd">Updated Jan 2025</span>
          <a class="doc-dl" href="#">Download</a>
        </div>
        <div class="doc-card">
          <span class="nm">Nomination Form - DP &amp; Trading</span>
          <span class="upd">Updated Mar 2025</span>
          <a class="doc-dl" href="#">Download</a>
        </div>
        <div class="doc-card">
          <span class="nm">Power of Attorney - Optional</span>
          <span class="upd">Updated Nov 2024</span>
          <a class="doc-dl" href="#">Download</a>
        </div>
      </div>
    </div>

    <div class="doc-group reveal" data-cat="dp-demat">
      <p class="doc-cat">DP / Demat</p>
      <div class="doc-grid" data-reveal-row>
        <div class="doc-card">
          <span class="nm">DIS (Delivery Instruction Slip)</span>
          <span class="upd">Updated Jan 2025</span>
          <a class="doc-dl" href="#">Download</a>
        </div>
        <div class="doc-card">
          <span class="nm">Demat Account Statement Request</span>
          <span class="upd">Updated Dec 2024</span>
          <a class="doc-dl" href="#">Download</a>
        </div>
      </div>
    </div>

    <div class="doc-group reveal" data-cat="funds">
      <p class="doc-cat">Funds &amp; Settlement</p>
      <div class="doc-grid" data-reveal-row>
        <div class="doc-card">
          <span class="nm">Bank Account Change Request</span>
          <span class="upd">Updated Feb 2025</span>
          <a class="doc-dl" href="#">Download</a>
        </div>
        <div class="doc-card">
          <span class="nm">Funds Withdrawal Request Form</span>
          <span class="upd">Updated Feb 2025</span>
          <a class="doc-dl" href="#">Download</a>
        </div>
      </div>
    </div>

    <div class="cta-box dark reveal">
      <div class="ct-tt">
        <h3>Open Demat account</h3>
        <p class="ct-sub">In less than 5 minutes</p>
      </div>
      <div class="cta-actions">
        <a class="btn btn-primary" href="/open-demat-account">Open Demat account</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ===== Contact Us / Support - page-specific components. Values reuse the
     shared design tokens; page-local literals flagged Tier-2. ===== */

  .section,
  .cta-sec {
    scroll-margin-top: 96px;
  }

  /* design-system rule: every font renders at a 1.5 line-height. Buttons, inputs, pills and
     links reset to `normal` by default, so restore 1.5 on them explicitly (page-scoped). */
  .ct-pill, .tab, .hf-field-in input, .hf-field-in select, .doc-search input,
  .bc-meta a, .doc-dl, .doc-chip {
  }

  /* scroll-reveal (progressive enhancement: only hides when JS is on).
     Page-local system driven by the page tab script (.reveal/.in) - separate
     from BaseLayout's data-reveal/.js-reveal chrome reveal. */
  :global(html.js) .reveal {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.6s cubic-bezier(0.4, 0, 0.2, 1), transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }
  :global(html.js) .reveal.in {
    opacity: 1;
    transform: none;
  }

  /* ---------- hero: contact column + "schedule a call" capture form.
     Layout (.hero-grid / .hero-inner / .hero-aside width + mobile stacking) is canonical in
     global.css - only the pills and the form's own look live here. ---------- */
  .hero-contacts {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 32px;
    padding-top: 32px;
    border-top: 1px solid #4f524a; /* page-local hairline on gradient - Tier-2 candidate */
  }
  .ct-pill {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    height: 48px;
    padding: 0 16px;
    border-radius: 999px;
    background: #363731; /* page-local - Tier-2 candidate (near sage-900) */
    border: 1px solid #4b4c47; /* page-local - Tier-2 candidate */
    color: var(--color-white);
    font-weight: 500;
    font-size: 14px;
    transition: background 0.2s ease, border-color 0.2s ease;
  }
  @media (min-width: 1024px) and (hover: hover) {
    .ct-pill:hover {
    background: #43443e; /* page-local - Tier-2 candidate */
    border-color: var(--color-sage-700); /* #6d6e6a (Tier-1: absorbed by sage-700) */
  }
  }
  .ct-pill svg {
    width: 16px;
    height: 16px;
    flex: none;
    color: var(--color-gold-400);
  }

  /* "Schedule a call with us" lead-capture card (width + flex come from .hero-aside).
     .hf-head/.hf-body/.hf-note/.hf-success appear on 2-3 pages - shared-extraction candidate. */
  .hero-form {
    background: var(--color-cream-350); /* #f8f4e8 */
    border: 1px solid var(--color-tan-300); /* #e1dbc6 */
    border-radius: 24px;
    padding: clamp(24px, 3vw, 40px);
    display: flex;
    flex-direction: column;
    gap: 32px;
  }
  .hf-head {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .hero-form h2 {
    font-weight: 500;
    font-size: clamp(22px, 2.1vw, 26px);
    color: var(--color-olive-600); /* #4f583b */
  }
  .hf-head p {
    font-weight: 400;
    font-size: 14px;
    color: var(--color-sage-700); /* #6b6f5e */
  }
  .hf-body {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  /* Input field (.hf-row/.hf-unit/.hf-field/.hf-field-in/.hf-err) is the shared
     canonical component in global.css - see DESIGN-SYSTEM.md §4.15. Not redefined here. */
  .hero-form .btn-primary {
    width: 100%;
    min-width: 0; /* full-width form submit: exempt from the 220px footprint */
  }
  .hf-note {
    font-weight: 400;
    font-size: 12px;
    color: var(--color-sage-700); /* #6b6f5e */
  }
  /* OTP verification step (between Submit and the thank-you state) */
  .hf-otp {
    display: none;
    flex-direction: column;
    gap: 24px;
  }
  .hf-otp .btn-primary {
    width: 100%;
    min-width: 0; /* full-width form submit: exempt from the 220px footprint */
  }
  .hero-form.otp .hf-body, .hero-form.otp > .btn-primary {
    display: none;
  }
  .hero-form.otp .hf-otp {
    display: flex;
  }
  /* success state */
  .hf-success {
    display: none;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 12px;
    padding: 8px 0;
  }
  .hero-form.done .hf-body, .hero-form.done .hf-actions, .hero-form.done .btn-primary,
  .hero-form.done .hf-note, .hero-form.done .hf-otp {
    display: none;
  }
  .hero-form.done .hf-success {
    display: flex;
  }
  .hf-success .ok {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--color-green-100); /* #daead7 (Tier-1: absorbed by green-100) */
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hf-success .ok svg {
    width: 24px;
    height: 24px;
    color: var(--color-success-strong); /* #067a45 */
  }
  .hf-success h3 {
    font-weight: 600;
    font-size: 20px;
    color: var(--color-olive-900); /* #2e3914 */
  }
  .hf-success p {
    font-weight: 400;
    font-size: 14px;
    color: var(--color-sage-700); /* #6b6f5e */
  }

  /* ---------- tab bar: sticky, pinned to the very top (top:0) on a layer BELOW the nav.
     The bar itself never moves, so it can never float mid-screen. When the nav is showing it
     simply sits on top of the bar; when the nav auto-hides on scroll-down it slides up and out,
     revealing the bar at the top. All the motion comes from the nav's own .35s slide - no
     transform, transition or JS on the bar, and zero chance of a floating gap. ---------- */
  .tabbar {
    background: var(--color-surface-page);
    border-bottom: 1px solid var(--color-border-card);

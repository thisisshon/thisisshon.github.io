          mapFrame.removeEventListener('load', once);
          mapWrap.classList.remove('loading');
        });
        mapFrame.src = mapSrc(b);
        mapFrame.title = 'Map of ' + b.name + ' branch';
        if (scrollToMap) {
          mapWrap.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
      }

      /* populate the State dropdown (alphabetical) */
      states.forEach(function (s) {
        var o = document.createElement('option');
        o.value = s;
        o.textContent = s;
        stateSel.appendChild(o);
      });
      /* rebuild the Branch dropdown for a given state */
      function fillBranches(state) {
        branchSel.innerHTML = '';
        BRANCHES.filter(function (b) {
          return b.state === state;
        }).forEach(function (b) {
          var o = document.createElement('option');
          o.value = b.id;
          o.textContent = b.name;
          branchSel.appendChild(o);
        });
      }

      /* render the state-grouped "All Branches" card grid (states A–Z) */
      var html = '';
      states.forEach(function (s) {
        html += '<div class="branch-group"><p class="branch-gcat">' + esc(s) + '</p><div class="branch-grid">';
        BRANCHES.filter(function (b) {
          return b.state === s;
        }).forEach(function (b) {
          html +=
            '<article class="branch-card" data-id="' + b.id + '">' +
            '<div class="bc-head"><h3>' + esc(b.name) + '</h3></div>' +
            '<p class="bc-addr">' + esc(b.addr) + '</p>' +
            '<div class="bc-meta">' +
            '<a href="' + telHref(b.phone) + '">' + PHONE_SVG + esc(b.phone) + '</a>' +
            '<a href="mailto:' + esc(b.email) + '">' + MAIL_SVG + esc(b.email) + '</a>' +
            '</div>' +
            '<div class="bc-actions">' +
            '<button class="btn btn-secondary bc-map" type="button" data-map="' + b.id + '">' + PIN_SVG + 'View on map</button>' +
            '<a class="btn btn-secondary directions" href="https://maps.google.com/?q=' + encodeURIComponent(b.q) + '" target="_blank" rel="noopener">' + NAV_SVG + 'Directions</a>' +
            '</div>' +
            '</article>';
        });
        html += '</div></div>';
      });
      groupsEl.innerHTML = html;

      /* wire interactions - selecting jumps the map to that branch (no card highlight) */
      stateSel.addEventListener('change', function () {
        fillBranches(stateSel.value);
        if (branchSel.value) {
          zoomTo(byId[branchSel.value], false);
        }
      });
      branchSel.addEventListener('change', function () {
        zoomTo(byId[branchSel.value], false);
      });
      /* explicit "Search" CTA: re-apply the current State/City selection on the map */
      var searchBtn = document.getElementById('bs-search');
      if (searchBtn) {
        searchBtn.addEventListener('click', function () {
          var b = byId[branchSel.value];
          if (b) {
            zoomTo(b, true);
          }
        });
      }
      groupsEl.addEventListener('click', function (e) {
        var btn = e.target.closest && e.target.closest('.bc-map');
        if (btn) {
          var b = byId[btn.getAttribute('data-map')];
          stateSel.value = b.state;
          fillBranches(b.state);
          branchSel.value = b.id;
          zoomTo(b, true);
        }
      });

      /* on load: dropdowns preset to Tamil Nadu / Chennai, map shows every branch */
      stateSel.value = byId.chennai.state;
      fillBranches(byId.chennai.state);
      branchSel.value = 'chennai';
      showAll();
    }

    /* ----- Schedule-a-call: validation + inline errors + success state ----- */
    var form = document.querySelector('.hero-form');
    if (form) {
      var fields = [
        { id: 'cf-name', err: 'err-name', test: function (v) { return v.trim().length >= 2; } },
        { id: 'cf-mobile', err: 'err-mobile', test: function (v) { return v.replace(/\D/g, '').replace(/^91/, '').length === 10; } },
        { id: 'cf-city', err: 'err-city', test: function (v) { return !!v; } },
        { id: 'cf-purpose', err: 'err-purpose', test: function (v) { return !!v; } },
      ];
      var check = function (f, showErr) {
        var input = document.getElementById(f.id),
          errEl = document.getElementById(f.err);
        var ok = f.test(input.value);
        input.closest('.hf-field').classList.toggle('invalid', showErr && !ok);
        errEl.classList.toggle('show', showErr && !ok);
        input.setAttribute('aria-invalid', showErr && !ok ? 'true' : 'false');
        return ok;
      };
      fields.forEach(function (f) {
        var input = document.getElementById(f.id);
        input.addEventListener('input', function () {
          if (input.closest('.hf-field').classList.contains('invalid')) check(f, true);
        });
        input.addEventListener('change', function () {
          check(f, true);
        });
      });
      form.addEventListener('submit', function (e) {
        e.preventDefault();
        var firstBad = null,
          allOk = true;
        fields.forEach(function (f) {
          var ok = check(f, true);
          if (!ok && !firstBad) {
            firstBad = f;
          }
          if (!ok) {
            allOk = false;
          }
        });
        if (!allOk) {
          if (firstBad) {
            document.getElementById(firstBad.id).focus();
          }
          return;
        }
        /* step 1 -> OTP verification screen */
        form.classList.add('otp');
      });
      /* OTP verify -> thank-you screen */
      var verifyBtn = document.getElementById('cf-verify');
      if (verifyBtn) {
        verifyBtn.addEventListener('click', function () {
          form.classList.remove('otp');
          form.classList.add('done');
        });
      }
    }

    /* ----- Downloads: file-type/size meta + search + category-chip filtering ----- */
    var docCards = Array.prototype.slice.call(document.querySelectorAll('.doc-card'));
    if (docCards.length) {
      /* placeholder file sizes (real files TBD), stamped as "PDF · size · Updated …" */
      var SIZES = ['240 KB', '180 KB', '320 KB', '310 KB', '150 KB', '120 KB', '210 KB', '95 KB', '140 KB', '160 KB', '110 KB', '130 KB'];
      docCards.forEach(function (card, i) {
        var upd = card.querySelector('.upd');
        if (upd) {
          upd.textContent = 'PDF · ' + (SIZES[i] || '-') + ' · ' + upd.textContent;
        }
        card.setAttribute('data-name', (card.querySelector('.nm') || {}).textContent || '');
      });

      var groups = Array.prototype.slice.call(document.querySelectorAll('.doc-group'));
      var chips = Array.prototype.slice.call(document.querySelectorAll('.doc-chip'));
      var qInput = document.getElementById('doc-q');
      var emptyEl = document.getElementById('doc-empty');
      var activeCat = 'all';

      var applyFilter = function () {
        var q = (qInput.value || '').trim().toLowerCase();
        var anyVisible = false;
        groups.forEach(function (g) {
          var catOk = activeCat === 'all' || g.getAttribute('data-cat') === activeCat;
          var groupHasVisible = false;
          Array.prototype.forEach.call(g.querySelectorAll('.doc-card'), function (card) {
            var nameOk = !q || card.getAttribute('data-name').toLowerCase().indexOf(q) !== -1;
            var show = catOk && nameOk;
            card.classList.toggle('hide', !show);
            if (show) {
              groupHasVisible = true;
            }
          });
          g.classList.toggle('hide', !groupHasVisible);
          if (groupHasVisible) {
            anyVisible = true;
          }
        });
        emptyEl.classList.toggle('show', !anyVisible);
      };
      if (qInput) {
        qInput.addEventListener('input', applyFilter);
      }
      chips.forEach(function (chip) {
        chip.addEventListener('click', function () {
          activeCat = chip.getAttribute('data-cat');
          chips.forEach(function (c) {
            c.setAttribute('aria-pressed', c === chip ? 'true' : 'false');
          });
          applyFilter();
        });
      });
    }
  })();
</script>

---
/**
 * SIP Calculator - /sip-calculator/
 * Interactive SIP future-value calculator. Pixel parity with legacy
 * calculators/sip/index.html. Nested page → links are root-absolute,
 * shared imports use ../../ depth.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/site/Breadcrumb.astro';
import FaqAccordion from '../components/sections/FaqAccordion.astro';
import { faqPageSchema } from '../lib/seo';

// Got Questions? - the first 6 FAQs from the compliance doc (display cap; the
// remainder was stripped and can be restored from the doc if needed). Feeds both
// the accordion and the FAQPage JSON-LD, so markup and schema cannot drift.
const FAQS = [
  {
    q: 'What is a SIP Calculator?',
    a: 'A SIP Calculator is an online tool that estimates the future value of your monthly SIP investment based on amount, duration, and expected return.',
  },
  {
    q: 'Is the SIP Calculator result guaranteed?',
    a: 'No. SIP Calculator results are estimates. Actual returns depend on market performance and mutual fund scheme performance.',
  },
  {
    q: 'What is the minimum SIP amount in India?',
    a: 'Many mutual funds allow SIPs from ₹500 per month, while some initiatives allow smaller SIP amounts such as ₹250.',
  },
  {
    q: 'Can I use this calculator for ELSS SIP?',
    a: 'Yes. You can use the calculator to estimate ELSS SIP returns. However, keep in mind that ELSS has a 3-year lock-in period.',
  },
  {
    q: 'What return rate should I assume?',
    a: 'Use a realistic return assumption based on the fund category. Equity funds may have higher return potential but also higher volatility.',
  },
  {
    q: 'How does Step-Up SIP affect returns?',
    a: 'Step-Up SIP increases your investment amount periodically. This may help create a larger corpus over time.',
  },
];

const seo = {
  title: 'SIP Calculator Online',
  description:
    'Use the free SIP calculator from Shriram Financial Services to estimate your mutual fund returns based on amount, tenure and expected rate.',
  path: '/sip-calculator/',
  jsonLd: [faqPageSchema(FAQS.map((f) => ({ question: f.q, answer: f.a })))],
};
---

<BaseLayout seo={seo} mainClass="rev-rise-scale">
  <!-- ================= HERO ================= -->
  <section class="hero hero-compact" id="sec-hero" data-section="hero">
    <Breadcrumb trail={[{ name: 'Calculators', href: '/calculators/' }, { name: 'SIP Calculator' }]} />
    <div class="hero-inner" data-enter>
      <h1>SIP Calculator – Estimate Your <span class="g">Mutual Fund Returns Instantly</span></h1>
      <p class="lead">A SIP Calculator estimates the maturity value of your monthly mutual fund investments using compound interest.</p>
      <div class="cta"><a class="btn-gold" href="/open-demat-account/">Start SIP Now</a><a class="btn-ghost" href="/mutual-funds/">Invest in Mutual Funds</a></div>
      <div class="hero-feats">
        <div class="feats">
          <div class="feat"><span class="tk" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span><span class="lb">&nbsp;Trusted by Trader Across India</span></div>
          <div class="feat"><span class="tk" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span><span class="lb">&nbsp;SEBI-registered platform</span></div>
          <div class="feat"><span class="tk" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span><span class="lb">&nbsp;AMFI-compliant mutual fund investing</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SIP Calculator ===== -->
  <section class="section stack sec-light" id="sec-calc" data-section="calc" data-enter="2" style="gap:24px">
    <h2 class="sec-title">SIP Calculator</h2>
    <p class="calc-hint">Drag the sliders or type your own numbers - results update instantly. Switch frequency or add an annual step-up to model a growing SIP.</p>

    <div class="calc-row">
      <!-- inputs + split bar -->
      <div class="card calc-panel">
        <div class="freq-toggle" role="group" aria-label="Investment frequency">
          <button type="button" class="freq-btn is-active" data-freq="12" aria-pressed="true">Monthly</button>
          <button type="button" class="freq-btn" data-freq="4" aria-pressed="false">Quarterly</button>
          <button type="button" class="freq-btn" data-freq="1" aria-pressed="false">Yearly</button>
        </div>

        <div class="fields">
          <div class="field">
            <div class="field-top">
              <label for="amt">SIP amount</label>
              <div class="field-val"><span class="pfx">₹</span><input id="amt" type="text" inputmode="numeric" value="10,000" aria-label="SIP amount in rupees per instalment" /></div>
            </div>
            <input class="slider" id="amtR" type="range" min="500" max="100000" step="500" value="10000" aria-label="SIP amount" />
            <div class="slider-scale"><span>₹500</span><span>₹1,00,000</span></div>
          </div>

          <div class="field">
            <div class="field-top">
              <label for="dur">Investment duration</label>
              <div class="field-val"><input id="dur" type="text" inputmode="numeric" value="10" aria-label="Investment duration in years" /><span class="sfx">Yr</span></div>
            </div>
            <input class="slider" id="durR" type="range" min="1" max="40" step="1" value="10" aria-label="Investment duration in years" />
            <div class="slider-scale"><span>1 Yr</span><span>40 Yr</span></div>
          </div>

          <div class="field">
            <div class="field-top">
              <label for="rate">Expected rate of return</label>
              <div class="field-val"><input id="rate" type="text" inputmode="decimal" value="10" aria-label="Expected annual rate of return in percent" /><span class="sfx">%</span></div>
            </div>
            <input class="slider" id="rateR" type="range" min="1" max="30" step="0.5" value="10" aria-label="Expected annual rate of return in percent" />
            <div class="slider-scale"><span>1%</span><span>30%</span></div>
          </div>

          <div class="field">
            <div class="field-top">
              <label for="step">Annual step-up</label>
              <div class="field-val"><input id="step" type="text" inputmode="decimal" value="0" aria-label="Annual step-up in percent" /><span class="sfx">%</span></div>
            </div>
            <input class="slider" id="stepR" type="range" min="0" max="25" step="1" value="0" aria-label="Annual step-up in percent" />
            <div class="slider-scale"><span>0%</span><span>25%</span></div>
          </div>
        </div>
      </div>

      <!-- results -->
      <div class="calc-results">
        <div class="bar-wrap">
          <div class="bar-top">
            <div class="bar-head">
              <span class="bar-cap">Total Assumed Value</span>
              <span class="bar-tot" id="d-tot">₹20,65,520</span>
            </div>
            <div class="stack-bar" role="img" aria-label="Total assumed value split between invested amount and estimated returns">
              <div class="seg seg-inv" id="seg-inv" style="width:58%"></div>
              <div class="seg seg-ret" id="seg-ret" style="width:42%"></div>
            </div>
          </div>

          <div class="res-cards" data-reveal-row>
            <div class="res-card">
              <div class="res-top"><span class="dot" style="background:var(--c-inv)"></span>Invested Amount</div>
              <div class="res-val" id="r-inv">₹12,00,000</div>
            </div>
            <div class="res-card">
              <div class="res-top"><span class="dot" style="background:var(--c-ret)"></span>Estimated Returns</div>
              <div class="res-val" id="r-ret">₹8,65,520</div>
            </div>
          </div>

          <div class="bar-div" role="presentation"></div>

          <p class="bar-note">Note: Figures are illustrative and assume a constant annual rate of return compounded over the full term; actual mutual-fund returns fluctuate and are not guaranteed.</p>
        </div>

        <!-- ready CTA - sits in the results column, under the results card -->
        <div class="ready-bar">
          <p class="ready-text">Start a <b id="cta-amt">₹10,000/month SIP</b> and build your future</p>
          <a class="ready-btn" href="/open-demat-account/">Open Demat Account</a>
        </div>
      </div>
    </div>

    <!-- live summary for screen readers (not visually shown) -->
    <p class="sr-only" id="sr-summary" aria-live="polite"></p>
  </section>

  <!-- ===== What Is a SIP Calculator? ===== -->
  <section class="section stack sec-tint" id="sec-what" data-section="what" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">What Is a SIP Calculator?</h2>
      <p class="sec-lead">A SIP Calculator is a simple online tool that helps you estimate how much your mutual fund investments could grow over time. It calculates based on your monthly investment amount, expected returns, and investment period.</p>
    </div>
  </section>

  <!-- ===== Benefits of using a SIP Calculator ===== -->
  <section class="section stack sec-light" id="sec-benefits" data-section="benefits" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Benefits of using a SIP Calculator</h2>
    </div>
    <ul class="bullets">
      <li>Quick estimate: You can get an instant view of how much your SIP investment could grow over time based on your inputs.</li>
      <li>No calculations: The calculator automatically does the math, saving you time and effort.</li>
      <li>Compare options: Adjust the investment amount, duration, or expected return to compare different outcomes.</li>
      <li>Plan goals: Estimate the SIP amount needed to work towards financial goals such as retirement, education, or wealth creation.</li>
      <li>Free to use: Use can use the calculator anytime, as often as you need, without incurring any charges.</li>
    </ul>
    <p class="sec-lead">Note: A SIP Calculator provides only an estimate. Actual returns may vary based on market performance and fund performance.</p>
  </section>

  <!-- ===== How Does the SIP Calculator Work? ===== -->
  <section class="section stack sec-tint" id="sec-work" data-section="work" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">How Does the SIP Calculator Work?</h2>
      <p class="sec-lead">A SIP Calculator estimates how your monthly investments can grow over time through compounding, based on your investment amount, duration, and expected returns.</p>
    </div>

    <div class="stack" style="gap:32px">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">SIP Formula</h3>
        <p class="sub-lead">FV = P × (((1+i)^n – 1) / i) × (1+i)</p>
      </div>
      <div class="t-scroll"><div class="product-page_table t2 bordered" style="grid-template-columns:repeat(2,minmax(0,1fr))">
        <div class="cell th"><p>Variable</p></div><div class="cell th"><p>Meaning</p></div>
        <div class="cell tb"><p class="k">FV</p></div><div class="cell tb"><p class="v">Future value or estimated maturity amount</p></div>
        <div class="cell tb"><p class="k">P</p></div><div class="cell tb"><p class="v">Monthly SIP amount</p></div>
        <div class="cell tb"><p class="k">I</p></div><div class="cell tb"><p class="v">Monthly rate of return</p></div>
        <div class="cell tb"><p class="k">N</p></div><div class="cell tb"><p class="v">Total number of SIP instalments</p></div>
      </div></div>
      <p class="sub-lead">For example, if you invest ₹5,000 per month for 10 years at an expected return of 12% p.a., your estimated maturity value may be around ₹11.6 lakh.</p>
    </div>

    <div class="stack" style="gap:32px">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">Step-by-step example</h3>
      </div>
      <div class="t-scroll"><div class="product-page_table t2 bordered" style="grid-template-columns:repeat(2,minmax(0,1fr))">
        <div class="cell th"><p>Input</p></div><div class="cell th"><p>Value</p></div>
        <div class="cell tb"><p class="k">Monthly SIP</p></div><div class="cell tb"><p class="v">₹5,000</p></div>
        <div class="cell tb"><p class="k">Duration</p></div><div class="cell tb"><p class="v">10 years</p></div>
        <div class="cell tb"><p class="k">Expected Return</p></div><div class="cell tb"><p class="v">12% p.a.</p></div>
        <div class="cell tb"><p class="k">Total Invested</p></div><div class="cell tb"><p class="v">₹6,00,000</p></div>
        <div class="cell tb"><p class="k">Estimated Returns</p></div><div class="cell tb"><p class="v">₹5,61,695</p></div>
        <div class="cell tb"><p class="k">Estimated Total Value</p></div><div class="cell tb"><p class="v">₹11,61,695</p></div>
      </div></div>
      <p class="sub-lead">The calculator performs this calculation automatically, so you only need to enter your SIP amount, tenure, and expected return.</p>
    </div>
    <a class="btn-gold" href="#sec-calc" style="align-self:center">Try the Calculator Above</a>
  </section>

  <!-- ===== SIP Returns – Illustrative Scenarios ===== -->
  <section class="section stack sec-light" id="sec-scenarios" data-section="scenarios" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">SIP Returns – Illustrative Scenarios</h2>
      <p class="sec-lead">The table below shows sample SIP returns at an assumed annual return of 12% p.a. These figures are for illustration only and are not guaranteed.</p>
    </div>
    <div class="t-scroll"><div class="product-page_table t5 bordered" style="grid-template-columns:repeat(5,minmax(0,1fr));min-width:640px">
      <div class="cell th"><p>Monthly SIP</p></div><div class="cell th"><p>Duration</p></div><div class="cell th"><p>Expected Return</p></div><div class="cell th"><p>Invested Amount</p></div><div class="cell th"><p>Estimated Maturity Value</p></div>
      <div class="cell tb"><p class="k">₹500</p></div><div class="cell tb"><p class="v">5 years</p></div><div class="cell tb"><p class="v">12% p.a.</p></div><div class="cell tb"><p class="v">₹30,000</p></div><div class="cell tb"><p class="v">₹41,243</p></div>
      <div class="cell tb"><p class="k">₹1,000</p></div><div class="cell tb"><p class="v">10 years</p></div><div class="cell tb"><p class="v">12% p.a.</p></div><div class="cell tb"><p class="v">₹1,20,000</p></div><div class="cell tb"><p class="v">₹2,32,339</p></div>
      <div class="cell tb"><p class="k">₹5,000</p></div><div class="cell tb"><p class="v">15 years</p></div><div class="cell tb"><p class="v">12% p.a.</p></div><div class="cell tb"><p class="v">₹9,00,000</p></div><div class="cell tb"><p class="v">₹25,22,880</p></div>
      <div class="cell tb"><p class="k">₹10,000</p></div><div class="cell tb"><p class="v">20 years</p></div><div class="cell tb"><p class="v">12% p.a.</p></div><div class="cell tb"><p class="v">₹24,00,000</p></div><div class="cell tb"><p class="v">₹99,91,479</p></div>
      <div class="cell tb"><p class="k">₹25,000</p></div><div class="cell tb"><p class="v">25 years</p></div><div class="cell tb"><p class="v">12% p.a.</p></div><div class="cell tb"><p class="v">₹75,00,000</p></div><div class="cell tb"><p class="v">₹4,74,40,877</p></div>
    </div></div>
    <p class="sec-lead">Disclaimer: These values are illustrative. Mutual fund returns are market-linked and not guaranteed.</p>
    <a class="btn-gold" href="/open-demat-account/" style="align-self:center">Start Your SIP</a>
  </section>

  <!-- ===== How to Use the SIP Calculator ===== -->
  <section class="section stack sec-tint" id="sec-how-to-use" data-section="how-to-use" style="gap:56px;align-items:center;justify-content:center">
    <div class="stack" style="gap:16px;width:100%">
      <h2 class="sec-title">How to Use the SIP Calculator</h2>
      <p class="sec-lead">Follow these simple steps to estimate your SIP returns:</p>
    </div>
    <div class="steps" data-reveal-row>
      <div class="step">
        <div class="num">1</div>
        <div class="st-body"><h4>Enter your monthly SIP amount</h4><p>Add the amount you plan to invest every month.</p></div>
      </div>
      <div class="step-div"></div>
      <div class="step">
        <div class="num">2</div>
        <div class="st-body"><h4>Choose your investment duration</h4><p>Select how long you want to continue your SIP.</p></div>
      </div>
      <div class="step-div"></div>
      <div class="step">
        <div class="num">3</div>
        <div class="st-body"><h4>Enter expected annual return</h4><p>Use a realistic return assumption based on the mutual fund category.</p></div>
      </div>
      <div class="step-div"></div>
      <div class="step">
        <div class="num">4</div>
        <div class="st-body"><h4>View your estimated corpus</h4><p>The calculator shows your invested amount, estimated returns, and maturity value.</p></div>
      </div>
      <div class="step-div"></div>
      <div class="step">
        <div class="num">5</div>
        <div class="st-body"><h4>Compare different scenarios</h4><p>Increase or decrease the SIP amount, tenure, or return rate to plan better.</p></div>
      </div>
    </div>
    <p class="sec-lead" style="width:100%">Pro Tip: Use conservative return assumptions when planning important goals. Kindly note that equity mutual funds can deliver higher long-term growth but also carry higher short-term volatility.</p>
  </section>

  <!-- ===== Step-Up SIP Calculator ===== -->
  <section class="section stack sec-light" id="sec-stepup" data-section="stepup" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Step-Up SIP Calculator</h2>
      <p class="sec-lead">A Step-Up SIP lets you increase your SIP amount every year. This can help align your investments with salary hikes, income growth, and rising financial goals.</p>
      <p class="sec-lead">For example, compare a flat SIP of ₹5,000 per month with a SIP that increases by 10% every year.</p>
    </div>
    <div class="t-scroll"><div class="product-page_table t5 bordered" style="grid-template-columns:repeat(5,minmax(0,1fr));min-width:640px">
      <div class="cell th"><p>SIP Type</p></div><div class="cell th"><p>Duration</p></div><div class="cell th"><p>Expected Return</p></div><div class="cell th"><p>Total Invested</p></div><div class="cell th"><p>Estimated Value</p></div>
      <div class="cell tb"><p class="k">Flat SIP</p></div><div class="cell tb"><p class="v">10 years</p></div><div class="cell tb"><p class="v">12% p.a.</p></div><div class="cell tb"><p class="v">₹6,00,000</p></div><div class="cell tb"><p class="v">₹11,61,695</p></div>
      <div class="cell tb"><p class="k">10% Step-Up SIP</p></div><div class="cell tb"><p class="v">10 years</p></div><div class="cell tb"><p class="v">12% p.a.</p></div><div class="cell tb"><p class="v">₹9,56,245</p></div><div class="cell tb"><p class="v">₹16,87,163</p></div>
    </div></div>
    <p class="sec-lead">A Step-Up SIP can create a larger corpus because both your investment amount and compounding base increase over time.</p>
    <a class="btn-gold" href="#sec-calc" style="align-self:center">Calculate Step-Up SIP</a>
  </section>

  <!-- ===== Benefits of Investing via SIP ===== -->
  <section class="section stack sec-tint" id="sec-sip-benefits" data-section="sip-benefits" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Benefits of Investing via SIP</h2>
    </div>
    <div class="cat-grid" data-reveal-row>
      <div class="cat"><h4>Rupee Cost Averaging</h4><p>SIPs invest a fixed amount regularly. You may buy more units when prices are low and fewer when prices are high. As a result, it helps reduce the impact of market fluctuations.</p></div>
      <div class="cat"><h4>Power of Compounding</h4><p>Returns earned on your investments can generate additional returns over time. The earlier you start, the more time your money has to grow.</p></div>
      <div class="cat"><h4>Disciplined Saving</h4><p>SIPs encourage regular investing through fixed monthly contributions. This helps build a consistent saving and investing habit.</p></div>
      <div class="cat"><h4>Flexibility</h4><p>Most SIPs can be increased, reduced, paused, or stopped when needed. Thus, giving you the flexibility to invest according to your goals and budget.</p></div>
      <div class="cat"><h4>Low Minimum Investment</h4><p>You can start a SIP with a small monthly amount, making mutual fund investing accessible even for first-time investors.</p></div>
      <div class="cat"><h4>Diversification</h4><p>Mutual funds invest across multiple securities, helping spread risk and providing exposure to different asset classes and sectors.</p></div>
    </div>
  </section>

  <!-- ===== SIP vs Lumpsum – Key Differences ===== -->
  <section class="section stack sec-light" id="sec-vs-lumpsum" data-section="vs-lumpsum" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">SIP vs Lumpsum – Key Differences</h2>
    </div>
    <div class="t-scroll"><div class="product-page_table t3 bordered">
      <div class="cell th"><p>Parameter</p></div><div class="cell th"><p>SIP</p></div><div class="cell th"><p>Lumpsum</p></div>
      <div class="cell tb"><p class="k">Investment mode</p></div><div class="cell tb"><p class="v">Monthly or periodic</p></div><div class="cell tb"><p class="v">One-time investment</p></div>
      <div class="cell tb"><p class="k">Market timing</p></div><div class="cell tb"><p class="v">Less important</p></div><div class="cell tb"><p class="v">More important</p></div>
      <div class="cell tb"><p class="k">Risk impact</p></div><div class="cell tb"><p class="v">Spread across time</p></div><div class="cell tb"><p class="v">Invested at one market level</p></div>
      <div class="cell tb"><p class="k">Suitable for</p></div><div class="cell tb"><p class="v">Salaried or regular-income investors</p></div><div class="cell tb"><p class="v">Bonus, windfall, or surplus cash</p></div>
      <div class="cell tb"><p class="k">Minimum amount</p></div><div class="cell tb"><p class="v">Often starts from small amounts</p></div><div class="cell tb"><p class="v">Usually higher than SIP</p></div>
      <div class="cell tb"><p class="k">Best use case</p></div><div class="cell tb"><p class="v">Goal-based disciplined investing</p></div><div class="cell tb"><p class="v">Deploying idle capital</p></div>
    </div></div>
    <div class="stack" style="gap:32px">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">Which is better: SIP or lumpsum?</h3>
        <p class="sub-lead">SIP may be better for investors who want to invest gradually and reduce the pressure of market timing. Lumpsum investing may suit investors who already have surplus funds and a long investment horizon. The better choice depends on your cash flow, risk appetite, and goal timeline.</p>
      </div>
    </div>
  </section>

  <!-- ===== Types of SIP in India ===== -->
  <section class="section stack sec-tint" id="sec-types" data-section="types" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Types of SIP in India</h2>
    </div>
    <div class="row-2">
      <div class="card"><h4 class="card-h">Regular SIP</h4><p class="card-p">A Regular SIP allows you to invest a fixed amount on a fixed date. It is best for salaried investors who want a simple monthly investing habit. Best for: First-time investors and salaried professionals.</p></div>
      <div class="card"><h4 class="card-h">Flexible SIP</h4><p class="card-p">A Flexible SIP allows you to change the SIP amount based on your income, expenses, or market conditions. Best for: Investors with variable income.</p></div>
    </div>
    <div class="row-2">
      <div class="card"><h4 class="card-h">Step-Up SIP</h4><p class="card-p">A Step-Up SIP increases your monthly investment amount periodically, usually every year. Best for: Investors expecting income growth.</p></div>

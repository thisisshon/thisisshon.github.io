---
/**
 * SIP Calculator — /sip-calculator/
 * Interactive SIP future-value calculator. Pixel parity with legacy
 * calculators/sip/index.html. Nested page → links are root-absolute,
 * shared imports use ../../ depth.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/site/Breadcrumb.astro';
import FaqAccordion from '../components/sections/FaqAccordion.astro';
import { faqPageSchema } from '../lib/seo';
import { otherCalculators, calcHref } from '../data/calculators';

// "Explore More" rail — the four other calculators, from the shared dataset.
const MORE = otherCalculators('sip');

// General-Questions FAQ — legacy content verbatim, same order.
const FAQS = [
  {
    q: 'What is a SIP and how is it different from a lumpsum investment?',
    a: 'A Systematic Investment Plan (SIP) lets you invest a fixed amount at regular intervals — usually monthly — rather than committing a large sum all at once. This spreads your entry points across market cycles, averages out your purchase cost over time (rupee-cost averaging) and makes investing more affordable and disciplined. A lumpsum, by contrast, is a single one-time investment.',
  },
  {
    q: 'How accurate are the results from this SIP calculator?',
    a: 'The calculator applies the standard SIP future-value formula precisely to the inputs you provide. However, the expected rate of return is an assumption — real market returns fluctuate year to year. Treat the output as a well-grounded estimate for planning purposes rather than a guaranteed outcome.',
  },
  {
    q: 'Can I change or stop my SIP amount later?',
    a: 'Yes. SIPs are flexible — you can increase, decrease, pause or stop your contributions at any time, and many investors use a step-up SIP to raise their instalment each year as their income grows. There is typically no penalty for modifying or stopping a SIP.',
  },
  {
    q: 'What is a realistic rate of return to assume?',
    a: 'For equity-oriented funds, investors often use a long-term assumption in the range of 10–12% per annum, while debt-oriented funds are usually modelled lower. The right figure depends on your fund choice and risk appetite — it is wise to run the calculator with both an optimistic and a conservative rate to understand the range of possible outcomes.',
  },
  {
    q: 'Is there a minimum amount required to start a SIP?',
    a: 'Many funds let you start a SIP with as little as ₹500 per month, making it accessible to almost every investor. You can always increase your contribution as your savings capacity grows.',
  },
];

const seo = {
  title: 'SIP Calculator Online',
  description:
    'Use the free SIP calculator from Shriram Financial Services to estimate your mutual fund returns based on amount, tenure and expected rate.',
  path: '/sip-calculator/',
  jsonLd: [faqPageSchema(FAQS.map((f) => ({ question: f.q, answer: f.a })))],
};
---

<BaseLayout seo={seo} mainClass="rev-rise-scale">
  <!-- ================= HERO ================= -->
  <section class="hero hero-compact" id="sec-hero" data-section="hero">
    <Breadcrumb trail={[{ name: 'Calculators', href: '/calculators/' }, { name: 'SIP Calculator' }]} />
    <div class="hero-inner" data-enter>
      <h1>Plan Smarter With The <span class="g">SIP Calculator</span></h1>
      <p class="lead">Estimate your future wealth instantly by adjusting your monthly SIP amount, duration, and return rate.</p>
    </div>
  </section>

  <!-- ===== SIP Calculator ===== -->
  <section class="section stack sec-light" id="sec-calc" data-section="calc" data-enter="2" style="gap:24px">
    <h2 class="sec-title">SIP Calculator</h2>
    <p class="calc-hint">Drag the sliders or type your own numbers — results update instantly. Switch frequency or add an annual step-up to model a growing SIP.</p>

    <div class="calc-row">
      <!-- inputs + split bar -->
      <div class="card calc-panel">
        <div class="freq-toggle" role="group" aria-label="Investment frequency">
          <button type="button" class="freq-btn is-active" data-freq="12" aria-pressed="true">Monthly</button>
          <button type="button" class="freq-btn" data-freq="4" aria-pressed="false">Quarterly</button>
          <button type="button" class="freq-btn" data-freq="1" aria-pressed="false">Yearly</button>
        </div>

        <div class="fields">
          <div class="field">
            <div class="field-top">
              <label for="amt">SIP amount</label>
              <div class="field-val"><span class="pfx">₹</span><input id="amt" type="text" inputmode="numeric" value="10,000" aria-label="SIP amount in rupees per instalment" /></div>
            </div>
            <input class="slider" id="amtR" type="range" min="500" max="100000" step="500" value="10000" aria-label="SIP amount" />
            <div class="slider-scale"><span>₹500</span><span>₹1,00,000</span></div>
          </div>

          <div class="field">
            <div class="field-top">
              <label for="dur">Investment duration</label>
              <div class="field-val"><input id="dur" type="text" inputmode="numeric" value="10" aria-label="Investment duration in years" /><span class="sfx">Yr</span></div>
            </div>
            <input class="slider" id="durR" type="range" min="1" max="40" step="1" value="10" aria-label="Investment duration in years" />
            <div class="slider-scale"><span>1 Yr</span><span>40 Yr</span></div>
          </div>

          <div class="field">
            <div class="field-top">
              <label for="rate">Expected rate of return</label>
              <div class="field-val"><input id="rate" type="text" inputmode="decimal" value="10" aria-label="Expected annual rate of return in percent" /><span class="sfx">%</span></div>
            </div>
            <input class="slider" id="rateR" type="range" min="1" max="30" step="0.5" value="10" aria-label="Expected annual rate of return in percent" />
            <div class="slider-scale"><span>1%</span><span>30%</span></div>
          </div>

          <div class="field">
            <div class="field-top">
              <label for="step">Annual step-up</label>
              <div class="field-val"><input id="step" type="text" inputmode="decimal" value="0" aria-label="Annual step-up in percent" /><span class="sfx">%</span></div>
            </div>
            <input class="slider" id="stepR" type="range" min="0" max="25" step="1" value="0" aria-label="Annual step-up in percent" />
            <div class="slider-scale"><span>0%</span><span>25%</span></div>
          </div>
        </div>
      </div>

      <!-- results -->
      <div class="calc-results">
        <div class="bar-wrap">
          <div class="bar-top">
            <div class="bar-head">
              <span class="bar-cap">Total Assumed Value</span>
              <span class="bar-tot" id="d-tot">₹20,65,520</span>
            </div>
            <div class="stack-bar" role="img" aria-label="Total assumed value split between invested amount and estimated returns">
              <div class="seg seg-inv" id="seg-inv" style="width:58%"></div>
              <div class="seg seg-ret" id="seg-ret" style="width:42%"></div>
            </div>
          </div>

          <div class="res-cards" data-reveal-row>
            <div class="res-card">
              <div class="res-top"><span class="dot" style="background:var(--c-inv)"></span>Invested Amount</div>
              <div class="res-val" id="r-inv">₹12,00,000</div>
            </div>
            <div class="res-card">
              <div class="res-top"><span class="dot" style="background:var(--c-ret)"></span>Estimated Returns</div>
              <div class="res-val" id="r-ret">₹8,65,520</div>
            </div>
          </div>

          <div class="bar-div" role="presentation"></div>

          <p class="bar-note">Note: Figures are illustrative and assume a constant annual rate of return compounded over the full term; actual mutual-fund returns fluctuate and are not guaranteed.</p>
        </div>

        <!-- ready CTA — sits in the results column, under the results card -->
        <div class="ready-bar">
          <p class="ready-text">Start a <b id="cta-amt">₹10,000/month SIP</b> and build your future</p>
          <a class="ready-btn" href="/open-demat-account/">Open Demat Account</a>
        </div>
      </div>
    </div>

    <!-- live summary for screen readers (not visually shown) -->
    <p class="sr-only" id="sr-summary" aria-live="polite"></p>
  </section>

  <!-- ===== What Is A SIP Calculator ===== -->
  <section class="section stack sec-tint" id="sec-what" data-section="what" style="gap:24px">
    <h2 class="sec-title">What Is A SIP Calculator?</h2>
    <p class="sec-lead">A SIP calculator is a free online tool that estimates the maturity value of your Systematic Investment Plan. By entering your monthly contribution, the length of time you plan to stay invested and an expected annual rate of return, it projects how much wealth you could accumulate. It removes the guesswork from financial planning, giving you an instant, data-backed picture of your investment journey so you can set realistic goals and invest with confidence.</p>
  </section>

  <!-- ===== How A SIP Calculator Helps You ===== -->
  <section class="section stack sec-light" id="sec-help" data-section="help" style="gap:24px">
    <h2 class="sec-title">How A SIP Calculator Helps You</h2>
    <p class="sec-lead">Planning your investments by hand is tedious and error-prone. A SIP calculator does the heavy lifting in seconds, so you can focus on the decisions that matter:</p>
    <ul class="bullets">
      <li>Instantly estimate the future value of your monthly investments without complex manual calculations.</li>
      <li>Compare different scenarios by changing your contribution, duration or expected return to find what fits your goals.</li>
      <li>Understand how much of your final corpus comes from invested capital versus estimated returns.</li>
      <li>Set realistic, time-bound financial goals — be it a home, education, or retirement — and track progress toward them.</li>
    </ul>
  </section>

  <!-- ===== How Does A SIP Calculator Work ===== -->
  <section class="section stack sec-tint" id="sec-work" data-section="work" style="gap:24px">
    <h2 class="sec-title">How Does A SIP Calculator Work?</h2>
    <p class="sec-lead">The calculator uses the standard future-value formula for a series of regular investments: M = P × ({'{'}[1 + i]ⁿ − 1{'}'} ÷ i) × (1 + i), where P is your periodic investment, i is the periodic rate of return (your annual rate divided by the number of instalments per year) and n is the total number of instalments. It compounds each contribution over the remaining investment period and sums them to arrive at your projected maturity value. Because every instalment earns returns for a different length of time, the tool captures the true effect of compounding far more accurately than a simple multiplication ever could. When you add an annual step-up, each year's instalment is increased before the next year's compounding begins.</p>
  </section>

  <!-- ===== Advantages Of A SIP Calculator ===== -->
  <section class="section stack sec-light" id="sec-adv" data-section="adv" style="gap:24px">
    <h2 class="sec-title">Advantages Of A SIP Calculator</h2>
    <p class="sec-lead">Whether you are a first-time investor or a seasoned one, a SIP calculator brings clarity and discipline to your planning:</p>
    <ul class="bullets">
      <li>Accurate, instant projections that account for compounding across the entire investment horizon.</li>
      <li>Completely free to use, with no sign-up required and results delivered in real time.</li>
      <li>Helps you decide a comfortable monthly amount that aligns with your income and goals.</li>
      <li>Encourages consistent, disciplined investing by making the long-term payoff easy to visualise.</li>
    </ul>
  </section>

  <!-- ===== Explore More ===== -->
  <section class="section stack sec-tint" id="sec-explore" data-section="explore" style="gap:40px">
    <h2 class="sec-title">Explore More</h2>
    <div class="explore-grid" data-reveal-row>
      {
        MORE.map((c) => (
          <a class="xcard" href={calcHref(c.slug)}>
            <span class="xc-title">{c.title}</span>
            <span class="xc-desc">{c.desc}</span>
            <span class="xc-cta">Calculate Now <span class="arr" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 8h11M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span></span>
          </a>
        ))
      }
    </div>
  </section>

  <!-- ===== General Questions ===== -->
  <section class="faq-wrap sec-light" id="sec-faq" data-section="faq">
    <div class="faq-cols">
      <div class="faq-left">
        <h2 class="faq-title">General Questions</h2>
        <FaqAccordion faqs={FAQS} />
      </div>
      <div class="faq-side">
        <div class="usr"><img src="/assets/user.svg" alt="" /></div>
        <div class="side-in">
          <div class="side-tx">
            <h3>Need A Clearer Direction? </h3>
            <p>Let's get in touch on a 15-Minute call where we would be able to answer any questions you may have. Our Advisor will additionally help map your wealth mix and demonstrate what a dedicated advisor would do differently.</p>
          </div>
          <a class="btn-gold" href="#">Book A Discovery Call</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* SIP calculator — all calculator UI now lives in global.css (.calc-* / .field
     / .slider / .bar-* / .res-* / .ready-* / .bullets / .explore-grid). Only the
     page-local FAQ border remains: General Questions sits on --sec-light here, so
     the accordion + helper side card need a defined edge. */
  .faq-acc { border: 1px solid var(--color-border-card); padding: 1px; }
  .faq-side { border: 1px solid var(--color-border-card); }
</style>

<script>
  // SIP calculator — ported verbatim from legacy inline script (var → const/let,
  // behaviour identical). Astro <script> is a deferred module at end of body,
  // so the DOM is ready when it runs.
  const fmt = new Intl.NumberFormat('en-IN', { maximumFractionDigits: 0 });
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const amt = document.getElementById('amt') as HTMLInputElement;
  const amtR = document.getElementById('amtR') as HTMLInputElement;
  const dur = document.getElementById('dur') as HTMLInputElement;
  const durR = document.getElementById('durR') as HTMLInputElement;
  const rate = document.getElementById('rate') as HTMLInputElement;
  const rateR = document.getElementById('rateR') as HTMLInputElement;
  const step = document.getElementById('step') as HTMLInputElement;
  const stepR = document.getElementById('stepR') as HTMLInputElement;
  let freq = 12;

  const segInv = document.getElementById('seg-inv') as HTMLElement;
  const segRet = document.getElementById('seg-ret') as HTMLElement;
  let last = { inv: 0, ret: 0, tot: 0 };

  function digits(s: string) {
    return String(s).replace(/[^0-9.]/g, '');
  }
  function clamp(v: number, mn: number, mx: number) {
    return Math.max(mn, Math.min(mx, v));
  }

  function fillSlider(sl: HTMLInputElement) {
    const p = ((+sl.value - +sl.min) / (+sl.max - +sl.min)) * 100;
    sl.style.background =
      'linear-gradient(90deg, #4f583b 0%, #4f583b ' + p + '%, #f3f3f3 ' + p + '%, #f3f3f3 100%) center / 100% 6px no-repeat';
  }
  /* core SIP maths, period-by-period so step-up & frequency are exact */
  function compute(amount: number, years: number, ratePct: number, stepPct: number, perYear: number) {
    const n = Math.round(years * perYear);
    const i = ratePct / 100 / perYear;
    let contribution = amount;
    let balance = 0;
    let invested = 0;
    const rows: { year: number; invested: number; value: number }[] = [];
    for (let p = 1; p <= n; p++) {
      if (p > 1 && (p - 1) % perYear === 0) contribution *= 1 + stepPct / 100;
      balance = (balance + contribution) * (1 + i);
      invested += contribution;
      if (p % perYear === 0) rows.push({ year: p / perYear, invested: invested, value: balance });
    }
    return { fv: balance, invested: invested, returns: balance - invested, rows: rows };
  }

  function countTo(el: HTMLElement, from: number, to: number, fn: (n: number) => string) {
    if (reduce || from === to) {
      el.textContent = fn(to);
      return;
    }
    let t0: number | null = null;
    const dur = 350;
    function tick(ts: number) {
      if (t0 === null) t0 = ts;
      const t = Math.min(1, (ts - t0) / dur);
      const e = 1 - Math.pow(1 - t, 3);
      el.textContent = fn(from + (to - from) * e);
      if (t < 1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }

  function freqWord() {
    return freq === 12 ? 'month' : freq === 4 ? 'quarter' : 'year';
  }

  function render(animate: boolean) {
    const amount = clamp(parseFloat(digits(amt.value)) || 0, +amtR.min, +amtR.max);
    const years = clamp(parseFloat(digits(dur.value)) || 0, +durR.min, +durR.max);
    const ratePct = clamp(parseFloat(digits(rate.value)) || 0, +rateR.min, +rateR.max);
    const stepPct = clamp(parseFloat(digits(step.value)) || 0, +stepR.min, +stepR.max);

    const r = compute(amount, years, ratePct, stepPct, freq);
    const rupee = function (v: number) {
      return '₹' + fmt.format(Math.round(v));
    };

    if (animate) {
      countTo(document.getElementById('r-inv') as HTMLElement, last.inv, r.invested, rupee);
      countTo(document.getElementById('r-ret') as HTMLElement, last.ret, r.returns, rupee);
      countTo(document.getElementById('d-tot') as HTMLElement, last.tot, r.fv, rupee);
    } else {
      (document.getElementById('r-inv') as HTMLElement).textContent = rupee(r.invested);
      (document.getElementById('r-ret') as HTMLElement).textContent = rupee(r.returns);
      (document.getElementById('d-tot') as HTMLElement).textContent = rupee(r.fv);
    }
    last = { inv: r.invested, ret: r.returns, tot: r.fv };

    /* horizontally stacked split bar */
    const invPct = r.fv > 0 ? (r.invested / r.fv) * 100 : 0;
    segInv.style.width = invPct + '%';
    segRet.style.width = 100 - invPct + '%';

    /* contextual CTA + screen-reader summary */
    (document.getElementById('cta-amt') as HTMLElement).textContent =
      '₹' + fmt.format(amount) + '/' + freqWord() + ' SIP';
    (document.getElementById('sr-summary') as HTMLElement).textContent =
      'Projected total value ' +
      rupee(r.fv) +
      ' from ' +
      rupee(r.invested) +
      ' invested over ' +
      years +
      ' years.';

    updateUrl(amount, years, ratePct, stepPct);

    /* slider aria-valuetext mirrors the visible value */
    amtR.setAttribute('aria-valuetext', '₹' + fmt.format(amount));
    durR.setAttribute('aria-valuetext', years + ' years');
    rateR.setAttribute('aria-valuetext', ratePct + ' percent');
    stepR.setAttribute('aria-valuetext', stepPct + ' percent');
  }

  function updateUrl(amount: number, years: number, ratePct: number, stepPct: number) {
    const q =
      '?amt=' + amount + '&dur=' + years + '&rate=' + ratePct + '&step=' + stepPct + '&freq=' + freq;
    try {
      history.replaceState(null, '', q);
    } catch (e) {
      /* ignore (e.g. file://) */
    }
  }

  /* ----- input <-> slider wiring ----- */
  function pairNumberAndSlider(numEl: HTMLInputElement, slEl: HTMLInputElement, group: boolean) {
    slEl.addEventListener('input', function () {
      numEl.value = group ? fmt.format(+slEl.value) : slEl.value;
      fillSlider(slEl);
      render(false);
    });
    numEl.addEventListener('input', function () {
      const raw = parseFloat(digits(numEl.value)) || 0;
      if (group) {
        numEl.value = raw ? fmt.format(raw) : '';
      }
      slEl.value = String(clamp(raw, +slEl.min, +slEl.max));
      fillSlider(slEl);
      render(false);
    });
    numEl.addEventListener('change', function () {
      const v = clamp(parseFloat(digits(numEl.value)) || +slEl.min, +slEl.min, +slEl.max);
      numEl.value = group ? fmt.format(v) : String(v);
      slEl.value = String(v);
      fillSlider(slEl);
      render(true);
    });
  }
  pairNumberAndSlider(amt, amtR, true);
  pairNumberAndSlider(dur, durR, false);
  pairNumberAndSlider(rate, rateR, false);
  pairNumberAndSlider(step, stepR, false);

  /* frequency segmented control */
  document.querySelectorAll('.freq-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      freq = parseInt(btn.getAttribute('data-freq') || '12', 10);
      document.querySelectorAll('.freq-btn').forEach(function (b) {
        const on = b === btn;
        b.classList.toggle('is-active', on);
        b.setAttribute('aria-pressed', on ? 'true' : 'false');
      });
      render(true);
    });
  });

  /* ----- read state from the URL on load ----- */
  (function initFromUrl() {
    const p = new URLSearchParams(location.search);
    function setNum(el: HTMLInputElement, sl: HTMLInputElement, key: string, group: boolean) {
      if (!p.has(key)) return;
      const v = clamp(parseFloat(p.get(key) || '') || +sl.min, +sl.min, +sl.max);
      sl.value = String(v);
      el.value = group ? fmt.format(v) : String(v);
    }
    setNum(amt, amtR, 'amt', true);
    setNum(dur, durR, 'dur', false);
    setNum(rate, rateR, 'rate', false);
    setNum(step, stepR, 'step', false);
    if (p.has('freq')) {
      const f = parseInt(p.get('freq') || '', 10);
      if (f === 12 || f === 4 || f === 1) {
        freq = f;
        document.querySelectorAll('.freq-btn').forEach(function (b) {
          const on = parseInt(b.getAttribute('data-freq') || '', 10) === f;
          b.classList.toggle('is-active', on);
          b.setAttribute('aria-pressed', on ? 'true' : 'false');
        });
      }
    }
  })();

  [amtR, durR, rateR, stepR].forEach(fillSlider);
  render(true);
</script>

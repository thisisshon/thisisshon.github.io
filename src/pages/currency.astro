---
/**
 * Currency - /currency/
 * Product long-form page. Net-new page built entirely from the shared design
 * system (tokens + component classes in global.css); structural sibling of
 * products/equity.astro and products/mutual-funds.astro.
 *
 * Page-unique scoped block below holds only two things not (yet) in the system:
 *  - .vsteps - a 7-step vertical numbered flow (shared .steps is 4-wide horizontal)
 *  - .stat   - legal/restricted status pills (token-bound to success/danger)
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/site/Breadcrumb.astro';
import FaqAccordion from '../components/sections/FaqAccordion.astro';
import { faqPageSchema } from '../lib/seo';

// Got Questions? - the first 6 FAQs from the compliance doc (display cap; the
// remainder was stripped and can be restored from the doc if needed). Feeds both
// the accordion and the FAQPage JSON-LD, so markup and schema cannot drift.
const FAQS = [
  {
    q: 'What is currency trading in India?',
    a: 'Currency trading involves buying and selling exchange-traded currency derivative contracts on recognised exchanges such as NSE and BSE.',
  },
  {
    q: 'Is currency trading legal in India?',
    a: 'Yes. Currency trading is legal when conducted through SEBI-regulated brokers and approved exchanges.',
  },
  {
    q: 'Which currency pairs can be traded in India?',
    a: 'USD/INR, EUR/INR, GBP/INR, JPY/INR, and select cross-currency pairs are available for trading.',
  },
  {
    q: 'How much money is required to start currency trading?',
    a: 'The amount depends on the contract, margin requirements, and trading strategy.',
  },
  {
    q: 'What is the most traded currency pair in India?',
    a: 'USD/INR is the most actively traded currency pair in India.',
  },
  {
    q: 'What are currency futures?',
    a: 'Currency futures are contracts to buy or sell a currency pair at a predetermined price on a future date.',
  },
];

const seo = {
  title: 'Currency Trading - Forex Pairs',
  description:
    'Trade USD/INR, EUR/INR & other currency pairs online with competitive spreads and real-time insights from Shriram Financial Services. Start today.',
  path: '/currency',
  jsonLd: [faqPageSchema(FAQS.map((f) => ({ question: f.q, answer: f.a })))],
};
---

<BaseLayout seo={seo} mainClass="rev-rise-scale">
  <section class="hero" id="sec-hero" data-section="hero">
    <Breadcrumb trail={[{ name: 'Products', href: '/products' }, { name: 'Currency' }]} />
    <div class="hero-inner" data-enter>
      <h1>Currency Trading in India</h1>
      <p class="lead">Shriram Financial Services offers SEBI‑regulated access to currency derivatives on NSE/BSE. Trade major currency pairs — USD/INR, EUR/INR, GBP/INR, and JPY/INR — with transparent pricing, low margins, and trusted settlement.</p>
      <div class="cta"><a class="btn-gold" href="/open-demat-account">Open Demat Account</a></div>
    </div>
  </section>

  <!-- ===== Currency Trading: Explore Global Market Opportunities ===== -->
  <section class="section stack sec-light" id="sec-about" data-section="about" data-enter="2" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Currency Trading: Explore Global Market Opportunities</h2>
      <p class="sec-lead">Tap into global market movements with currency trading, one of the world’s most actively traded financial markets. By trading currency pairs, you can participate in opportunities created by changes in exchange rates and global economic trends. With Shriram Financial Services, everything you need for currency trading, from a seamless platform to real-time market insights to dedicated advisory guidance —is in one place.</p>
    </div>
  </section>

  <!-- ===== How Does Currency Trading Work (NSE & BSE)? ===== -->
  <section class="section stack sec-tint" id="sec-how" data-section="how" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">How Does Currency Trading Work (NSE &amp; BSE)?</h2>
      <p class="sec-lead" style="color:var(--color-text-secondary)">Every trade moves through three layers: the exchange that matches orders, the clearing corporation that guarantees settlement, and your broker that holds the margin.</p>
    </div>
    <div class="stack" style="gap:32px">
      <div class="row-2" data-reveal-row>
        <div class="card">
          <h4 class="card-h">Exchange</h4>
          <p class="card-p">NSE and BSE run separate currency derivatives segments. Prices are quoted and matched electronically, the same order book mechanism used for equity futures.</p>
        </div>
        <div class="card">
          <h4 class="card-h">Clearing Corporation</h4>
          <p class="card-p">Once a trade is matched, the clearing corporation becomes the counterparty to both sides. It collects margin from both buyer and seller and guarantees settlement even if one party defaults.</p>
        </div>
      </div>
      <div class="row-2" data-reveal-row>
        <div class="card">
          <h4 class="card-h">Daily Settlement</h4>
          <p class="card-p">Open Daily Settlement positions are marked to market every trading day. Gains are credited and losses are debited from your margin account daily, rather than waiting until the contract expires.</p>
        </div>
        <div class="card">
          <h4 class="card-h">Expiry and Settlement</h4>
          <p class="card-p">Most contracts expire on the last working day of the month, two days prior to the last business day. Final settlement uses the RBI's reference rate, and the difference is paid in rupees — no foreign currency changes hands.</p>
        </div>
      </div>
    </div>
    <p class="sec-lead" style="color:var(--color-text-secondary)">Trading hours on the currency segment generally run from 9:00 AM to 5:00 PM IST, longer than the equity cash market, which lets traders react to global cues from European and early US sessions before the local market close.</p>
  </section>

  <!-- ===== Currency Pairs Available for Trading in India ===== -->
  <section class="section stack sec-light" id="sec-pairs" data-section="pairs" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Currency Pairs Available for Trading in India</h2>
      <p class="sec-lead">Currency trading in India is currently permitted in selected currency pairs approved by regulators. These contracts are available on recognised exchanges and provide exposure to both domestic and international currency movements.</p>
      <p class="sec-lead">The most actively traded currency pair in India is USD/INR, which reflects the exchange rate between the US Dollar and the Indian Rupee.</p>
    </div>
    <div class="stack" style="gap:32px">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">Major Currency Pairs</h3>
      </div>
      <div class="row-2" data-reveal-row>
        <div class="card">
          <h4 class="card-h">USD/INR</h4>
          <p class="card-p">USD/INR is the most liquid and widely traded currency pair in India. It is influenced by factors such as interest rates, inflation, crude oil prices, RBI policies, and US economic data.</p>
        </div>
        <div class="card">
          <h4 class="card-h">EUR/INR</h4>
          <p class="card-p">EUR/INR tracks the exchange rate between the Euro and the Indian Rupee. It is influenced by economic developments in the Eurozone and India.</p>
        </div>
      </div>
      <div class="row-2" data-reveal-row>
        <div class="card">
          <h4 class="card-h">GBP/INR</h4>
          <p class="card-p">GBP/INR reflects the value of the British Pound against the Indian Rupee and is often impacted by UK economic data and global market sentiment.</p>
        </div>
        <div class="card">
          <h4 class="card-h">JPY/INR</h4>
          <p class="card-p">JPY/INR represents the Japanese Yen against the Indian Rupee and is often considered sensitive to global risk sentiment.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Currency Futures Vs Currency Options ===== -->
  <section class="section stack sec-tint" id="sec-fvo" data-section="fvo" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Currency Futures Vs Currency Options</h2>
      <p class="sec-lead" style="color:var(--color-text-secondary)">Currency derivatives are primarily traded through Futures and Options contracts. While both allow traders to participate in currency market movements, they differ in terms of risk, capital requirements, and trading flexibility. Futures obligate both parties to settle at a future date; options give the buyer the right — but not the obligation — to buy or sell at a predetermined price.</p>
    </div>
    <div class="t-scroll"><div class="product-page_table t3 bordered">
      <div class="cell th"><p>Features</p></div><div class="cell th"><p>Currency Futures</p></div><div class="cell th"><p>Currency Options</p></div>
      <div class="cell tb"><p class="k">Obligation</p></div><div class="cell tb"><p class="v">Buyer and seller both obligated to settle</p></div><div class="cell tb"><p class="v">Buyer has a right, not an obligation; seller is obligated</p></div>
      <div class="cell tb"><p class="k">Upfront cost</p></div><div class="cell tb"><p class="v">Margin only, no premium</p></div><div class="cell tb"><p class="v">Buyer pays a premium; seller receives it and posts margin</p></div>
      <div class="cell tb"><p class="k">Maximum loss (buyer)</p></div><div class="cell tb"><p class="v">Theoretically unlimited if the market moves against you</p></div><div class="cell tb"><p class="v">Capped at the premium paid</p></div>
      <div class="cell tb"><p class="k">Leverage</p></div><div class="cell tb"><p class="v">High — small margin controls a full lot</p></div><div class="cell tb"><p class="v">Premium cost is small relative to lot value</p></div>
      <div class="cell tb"><p class="k">Typical use</p></div><div class="cell tb"><p class="v">Directional trades, hedging known exposure</p></div><div class="cell tb"><p class="v">Defined-risk speculation, hedging with optionality</p></div>
      <div class="cell tb"><p class="k">Expiry cycle</p></div><div class="cell tb"><p class="v">Monthly contracts, several months listed at once</p></div><div class="cell tb"><p class="v">Monthly expiry, generally on USD/INR, EUR/INR, GBP/INR, JPY/INR</p></div>
      <div class="cell tb"><p class="k">Obligation</p></div><div class="cell tb"><p class="v">Buyer and seller both obligated to settle</p></div><div class="cell tb"><p class="v">Buyer has a right, not an obligation; seller is obligated</p></div>
    </div></div>
    <div class="stack" style="gap:16px">
      <h3 class="sub-title">What is a Call Option vs a Put Option in Currency Trading?</h3>
      <p class="sub-lead" style="color:var(--color-text-secondary)">A Call Option gives the buyer the right to buy a currency pair at a predetermined strike price before expiry, while a Put Option gives the right to sell. Traders buy calls when they expect the currency pair to rise. Traders buy puts when they expect the pair to fall.</p>
      <p class="sub-lead" style="color:var(--color-text-secondary)">As expiry approaches, options can lose value due to time decay, making option buying and option selling suitable for different risk and reward objectives. Option buyers benefit from early directional moves; option sellers profit from time decay when markets stay range-bound.</p>
    </div>
    <a class="btn-gold" href="/open-demat-account" style="align-self:center">Start Options Trading</a>
  </section>

  <!-- ===== Is Currency Trading Legal in India? ===== -->
  <section class="section stack sec-light" id="sec-legal" data-section="legal" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Is Currency Trading Legal in India?</h2>
      <p class="sec-lead">Yes, currency trading is legal in India if it is regulated and permitted through recognised exchanges and authorised intermediaries. Understanding the legal framework can help traders participate confidently while avoiding unregulated forex platforms.</p>
    </div>
    <div class="row-2" data-reveal-row>
      <div class="card">
        <span class="stat ok">Legal Currency Trading in India</span>
        <p class="card-p">Currency trading is legal in India when conducted through a SEBI-registered broker on recognised exchanges such as NSE and BSE. Currency futures and options are regulated, exchange-traded, and settled through authorised clearing corporations.</p>
      </div>
      <div class="card">
        <span class="stat no">Restricted Currency Trading Activities</span>
        <p class="card-p">Trading forex through offshore or unregulated platforms is not permitted under Indian regulations. Under FEMA guidelines, currency transactions are allowed only within the prescribed regulatory framework, and speculative forex trading through overseas brokers is generally restricted.</p>
      </div>
    </div>
    <div class="stack" style="gap:24px">
      <p class="sec-lead">Currency derivatives trading is governed by:</p>
      <div class="cat-grid cat-grid-3" data-reveal-row>
        <div class="cat"><h4>Securities and Exchange Board of India (SEBI)</h4><p>Regulates brokers, stock exchanges, and currency derivative trading activities to ensure transparent market practices and investor protection.</p></div>
        <div class="cat"><h4>Reserve Bank of India (RBI)</h4><p>Oversees India's foreign exchange framework under FEMA and plays a key role in currency market regulation and exchange rate management.</p></div>
        <div class="cat"><h4>Foreign Exchange Management Act (FEMA)</h4><p>Provides the legal framework governing foreign exchange transactions and defines the permitted currency trading activities for Indian residents and businesses.</p></div>
      </div>
    </div>
  </section>

  <!-- ===== Taxation on Trading Account ===== -->
  <section class="section stack sec-tint" id="sec-tax" data-section="tax" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Taxation on Trading Account</h2>
      <p class="sec-lead" style="color:var(--color-text-secondary)">Profits from exchange-traded currency futures and options are classified as non-speculative business income and are taxed according to your applicable income tax slab rate. Unlike traditional capital gains, currency trading tax rules allow traders to claim business expenses and carry forward trading losses to offset future business income. Understanding these tax implications on your trading account is essential for maximising your net returns and staying compliant with prevailing tax regulations.</p>
    </div>
  </section>

  <!-- ===== How to start currency trading? ===== -->
  <section class="section stack sec-light" id="sec-howstart" data-section="howstart" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">How to start currency trading?</h2>
      <p class="sec-lead">Starting currency trading in India is a straightforward process. Getting started with currency trading is simple when you follow a structured approach. Here are the key steps to begin trading currency futures and options on recognised exchanges such as NSE and BSE.</p>
    </div>
    <div class="stack" style="gap:32px">
      <div class="vsteps" data-reveal-row>
        <div class="vstep">
          <div class="vnum">1</div>
          <div class="vbody"><h4>Open a Trading and Demat Account</h4><p>Open a trading and Demat account with a SEBI-registered broker. If you already have an account, you can use the same account to access the currency derivatives segment.</p></div>
        </div>
        <div class="vstep">
          <div class="vnum">2</div>
          <div class="vbody"><h4>Activate the Currency Trading Segment</h4><p>Enable the currency derivatives segment through your broker's platform. This may require completing additional KYC formalities and submitting income proof, as applicable.</p></div>
        </div>
        <div class="vstep">
          <div class="vnum">3</div>
          <div class="vbody"><h4>Add Funds to Your Trading Account</h4><p>Transfer funds to your trading account. Currency derivatives in India are traded and settled in Indian Rupees (INR), so there is no need to hold foreign currency.</p></div>
        </div>
        <div class="vstep">
          <div class="vnum">4</div>
          <div class="vbody"><h4>Choose a Currency Pair</h4><p>Select a currency pair such as USD/INR, EUR/INR, GBP/INR, or JPY/INR. Beginners often start with USD/INR due to its high liquidity and trading volume.</p></div>
        </div>
        <div class="vstep">
          <div class="vnum">5</div>
          <div class="vbody"><h4>Place Your Trade</h4><p>Choose between currency futures or options, select the contract details, enter the quantity, and place your order through the trading platform.</p></div>
        </div>
        <div class="vstep">
          <div class="vnum">6</div>
          <div class="vbody"><h4>Monitor and Manage Your Position</h4><p>Track market movements, monitor your positions regularly, and manage risk using appropriate trading strategies and stop-loss orders.</p></div>
        </div>
        <div class="vstep">
          <div class="vnum">7</div>
          <div class="vbody"><h4>Exit or Settle Your Trade</h4><p>You can square off your position before expiry or allow the contract to be settled as per exchange regulations, you can begin participating in the regulated currency derivatives market.</p></div>
        </div>
      </div>
    </div>
    <a class="btn-gold" href="/open-demat-account" style="align-self:center">Start Currency Trading</a>
  </section>

  <!-- ===== Currency Trading Strategies for Beginners ===== -->
  <section class="section stack sec-tint" id="sec-strategies" data-section="strategies" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Currency Trading Strategies for Beginners</h2>
      <p class="sec-lead">Many beginner-friendly currency trading strategies combine technical indicators with disciplined risk management rule. Rather than relying solely on market predictions, successful traders focus on identifying trends, managing position sizes, and following a consistent trading plan. Below are the widely used technical indicators in the Indian currency market.</p>
    </div>
    <div class="stack" style="gap:32px">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">Technical Indicators Used in Currency Trading</h3>
        <p class="sub-lead">Technical indicators can help traders analyse price movements, identify trends, and make more informed trading decisions. While no indicator guarantees success, they are widely used as part of a structured currency trading strategy.</p>
      </div>
      <div class="row-2" data-reveal-row>
        <div class="card">
          <h4 class="card-h">Relative Strength Index (RSI)</h4>
          <p class="card-p">The Relative Strength Index (RSI) is a popular momentum indicator that helps identify overbought and oversold market conditions. It can assist traders in spotting potential entry and exit opportunities, particularly during short-term price movements in currency pairs such as USD/INR.</p>
        </div>
        <div class="card">
          <h4 class="card-h">Moving Average Convergence Divergence (MACD)</h4>
          <p class="card-p">MACD is a trend-following indicator that measures the relationship between two moving averages. Traders use MACD to identify changes in momentum, confirm emerging trends, and evaluate potential buy or sell signals in the currency market.</p>
        </div>
      </div>
      <div class="row-2" data-reveal-row>
        <div class="card">
          <h4 class="card-h">Pivot Points</h4>
          <p class="card-p">Pivot Points are technical levels calculated using the previous trading session's high, low, and closing prices. They help traders identify potential support and resistance levels, making them a commonly used tool for intraday currency trading strategies.</p>
        </div>
        <div class="card">
          <h4 class="card-h">Moving Averages</h4>
          <p class="card-p">Moving Averages smooth out short-term price fluctuations and help traders identify the overall market trend. Commonly used averages, such as the 20-period and 50-period Moving Average, can indicate whether a currency pair is trending upward, downward, or moving sideways.</p>
        </div>
      </div>
    </div>
    <div class="stack" style="gap:32px">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">Essential Risk Management Rules for Beginners</h3>
        <p class="sub-lead">No trading strategy is complete without proper risk management. Consider these best practices:</p>
      </div>
      <ul class="rmr" data-reveal-row>
        <li class="rmr-item"><span class="ck" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span><p>Always use a stop-loss order.</p></li>
        <li class="rmr-item"><span class="ck" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span><p>Avoid overleveraging your positions.</p></li>
        <li class="rmr-item"><span class="ck" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span><p>Trade only with capital you can afford to risk.</p></li>
        <li class="rmr-item"><span class="ck" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span><p>Follow a trading plan and avoid emotional decisions.</p></li>
        <li class="rmr-item"><span class="ck" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span><p>Start with smaller positions while learning.</p></li>
      </ul>
    </div>
  </section>

  <!-- ===== Got Questions? (General Questions) ===== -->
  <section class="faq-wrap sec-light" id="sec-faq" data-section="faq">
    <div class="faq-cols">
      <div class="faq-left">
        <h2 class="faq-title">Got Questions?</h2>
        <FaqAccordion faqs={FAQS} />
      </div>
      <div class="faq-side">
        <div class="usr"><img src="/assets/user.svg" alt="" /></div>
        <div class="side-in">
          <div class="side-tx">
            <h3>Need A Clearer Direction? </h3>
            <p>Let's get in touch on a 15-Minute call where we would be able to answer any questions you may have. Our Advisor will additionally help map your wealth mix and demonstrate what a dedicated advisor would do differently.</p>
          </div>
          <a class="btn-gold" href="/contact-us">Book A Discovery Call</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Page-unique: vertical numbered flow (shared .steps is 4-wide horizontal). */
  .vsteps { background: var(--color-surface-card); border: 1px solid var(--color-border-card); border-radius: 24px; overflow: hidden; display: flex; flex-direction: column; }
  .vstep { display: flex; gap: 24px; align-items: flex-start; padding: var(--container-pad); border-bottom: 1px solid var(--color-border-card); }
  .vstep:last-child { border-bottom: 0; }
  .vstep .vnum { flex: none; width: 48px; height: 48px; border-radius: 9999px; border: 1px solid var(--color-border-card); display: flex; align-items: center; justify-content: center; font-weight: 400; font-size: 20px; color: var(--color-gold-500); }
  .vstep .vbody { display: flex; flex-direction: column; gap: 12px; }
  .vstep h4 { font-weight: 500; font-size: 20px; color: var(--color-text-primary); }
  .vstep p { font-weight: 400; font-size: 16px; color: var(--color-text-tertiary); }

  /* Page-unique: legal/restricted status pills, token-bound to the state roles. */
  .stat { align-self: flex-start; display: inline-flex; align-items: center; padding: 4px 12px; border-radius: 8px; font-weight: 500; font-size: 14px; }
  .stat.ok { background: var(--color-success-tint); color: var(--color-success-strong); }
  .stat.no { background: var(--color-danger-tint); color: var(--color-danger); }

  /* Risk-management rules - a compact 2-col checklist inside a shared card
     container (surface / border / 24px radius, like .card). Replaces the tall
     divider-row card: five short rules read faster as an even two-up grid with
     just a success tick per line. Collapses to one column on mweb. */
  .rmr { list-style: none; margin: 0; padding: var(--container-pad); background: var(--color-surface-card); border: 1px solid var(--color-border-card); border-radius: 24px; display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16px 40px; }
  .rmr-item { display: flex; gap: 12px; align-items: flex-start; }
  .rmr-item .ck { flex: none; width: 16px; height: 1.5em; display: flex; align-items: center; justify-content: center; color: var(--color-success); }
  .rmr-item .ck svg { display: block; width: 16px; height: 16px; }
  .rmr-item p { font-weight: 400; font-size: 16px; color: var(--color-text-tertiary); }

  @media (max-width: 768px) {
    .rmr { grid-template-columns: 1fr; gap: 16px; }
    .rmr-item p { font-size: 14px; }
  }
  @media (max-width: 640px) {
    .vstep p { font-size: 14px; }
  }
</style>

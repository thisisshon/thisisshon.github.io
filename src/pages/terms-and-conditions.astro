---
/**
 * Terms & Conditions - /terms-and-conditions/
 * Legal long-form page. Mirrors privacy-policy.astro structure and shared styles.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/site/Breadcrumb.astro';

const seo = {
  title: 'Terms & Conditions',
  description:
    "Read the Terms & Conditions governing the use of Shriram Financial Services' trading, investment & related services.",
  path: '/terms-and-conditions/',
};
---

<BaseLayout seo={seo} mainClass="rev-rise-scale">
  <!-- ================= HERO ================= -->
  <section class="hero" id="sec-hero" data-section="hero">
    <Breadcrumb trail={[{ name: 'Terms & Conditions' }]} />
    <div class="hero-inner" data-enter>
      <div class="hero-content">
        <h1>Terms &amp; <span class="g">Conditions</span></h1>
        <p class="lead">
          The terms that govern your use of the Shriram Financial Services website, trading
          platforms and investment services. Please read them carefully before you register or
          transact.
        </p>
        <div class="hero-feats">
          <div class="feats">
            <div class="feat">
              <span class="tk" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg>
              </span>
              <span class="lb">SEBI-regulated</span>
            </div>
            <div class="feat">
              <span class="tk" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg>
              </span>
              <span class="lb">Transparent fees</span>
            </div>
            <div class="feat">
              <span class="tk" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg>
              </span>
              <span class="lb">Governed by Indian law</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================= ACCEPTANCE + ELIGIBILITY + REGISTRATION ================= -->
  <section class="section sec-light" id="sec-intro" data-section="intro" data-enter="2">
    <div class="legal">
      <div class="policy">
        <p class="updated">Last updated: 6 July 2026</p>
        <h2 class="sub-title">Acceptance of Terms</h2>
        <p>
          These Terms &amp; Conditions (&ldquo;Terms&rdquo;) constitute a binding agreement between
          you and Shriram Financial Services (&ldquo;Shriram&rdquo;, &ldquo;we&rdquo;,
          &ldquo;us&rdquo; or &ldquo;our&rdquo;). By accessing our website, opening an account, or
          using any of our trading, Demat, research or advisory services, you confirm that you have
          read, understood and agreed to be bound by these Terms and by our Privacy Policy.
        </p>
        <p>
          If you do not agree with any part of these Terms, you must not use our website or
          services. Your continued use following any revision constitutes acceptance of the updated
          Terms then in force.
        </p>
      </div>

      <div class="policy">
        <h2 class="sub-title">Eligibility</h2>
        <p>
          To open an account and use our services, you must be a resident of India, at least 18
          years of age, of sound mind, and competent to contract under the Indian Contract Act,
          1872. You must not be a person barred from accessing the securities markets by the
          Securities and Exchange Board of India (SEBI) or any other regulatory authority.
        </p>
        <p>
          Non-resident Indians and other categories of investors may transact only where expressly
          permitted, and subject to the additional conditions and documentation required under the
          Foreign Exchange Management Act, 1999 and applicable regulations.
        </p>
      </div>

      <div class="policy">
        <h2 class="sub-title">Account Registration &amp; KYC</h2>
        <p>
          Opening an account requires you to complete the Know Your Customer (KYC) process mandated
          by SEBI and the depositories. You agree to provide accurate, current and complete
          information and to keep it updated. You are responsible for the confidentiality of your
          login credentials, passwords and one-time passwords, and for all activity that occurs
          under your account.
        </p>
        <ul class="legal-list">
          <li>
            <b>Accurate details</b> - you warrant that all identity, PAN, bank and contact
            information you submit is true and belongs to you.
          </li>
          <li>
            <b>Verification</b> - we may verify, suspend or reject any account where
            information cannot be confirmed or appears fraudulent.
          </li>
          <li>
            <b>Security</b> - you must notify us immediately of any unauthorised use of your
            account or breach of security.
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ================= USE OF SERVICES + FEES + RISK ================= -->
  <section class="section sec-tint" id="sec-use" data-section="use">
    <div class="legal">
      <div class="policy">
        <h2 class="sub-title">Use of Services</h2>
        <p>
          You agree to use our website and services only for lawful purposes and in accordance with
          these Terms, the rules of the stock exchanges, and all applicable SEBI regulations. You
          must not attempt to gain unauthorised access to our systems, interfere with the platform,
          engage in market manipulation, or use the services to launder money or finance any
          unlawful activity.
        </p>
        <p>
          Orders placed through our platforms are subject to acceptance, market conditions,
          exchange rules and applicable limits. We may decline, cancel or modify any order, or
          restrict access to the platform, where required by law or to protect the integrity of the
          market or your account.
        </p>
      </div>

      <div class="policy">
        <h2 class="sub-title">Fees &amp; Charges</h2>
        <p>
          Brokerage, statutory levies, depository charges, transaction fees and other applicable
          costs will be disclosed in our schedule of charges, which forms part of these Terms. You
          agree to pay all fees, taxes and duties associated with your transactions, including
          Securities Transaction Tax, GST, stamp duty and exchange charges.
        </p>
        <p>
          We may revise our fees from time to time; any change will be communicated in advance
          through our website or by other reasonable means, and will apply prospectively to
          transactions carried out after the effective date.
        </p>
      </div>

      <div class="policy">
        <h2 class="sub-title">Risk Disclosure</h2>
        <p>
          Investments in securities are subject to market risks, and the value of your investments
          may rise or fall. Past performance is not indicative of future results. Research reports,
          recommendations and tools provided through our platforms are for information only and do
          not constitute a guarantee of returns or an offer or solicitation to buy or sell any
          security.
        </p>
        <p>
          You are solely responsible for evaluating the merits and risks of each transaction and
          should seek independent professional advice where appropriate. Please read all
          scheme-related and risk-disclosure documents carefully before investing.
        </p>
      </div>
    </div>
  </section>

  <!-- ================= IP + LIABILITY + LAW + AMENDMENTS ================= -->
  <section class="section sec-light" id="sec-legal" data-section="legal">
    <div class="legal">
      <div class="policy">
        <h2 class="sub-title">Intellectual Property</h2>
        <p>
          All content on our website and platforms - including text, graphics, logos, icons,
          research, software and the Shriram name and marks - is owned by or licensed to
          Shriram and is protected by applicable intellectual-property laws. You may access and use
          the content for your personal, non-commercial use only.
        </p>
        <p>
          You must not copy, reproduce, distribute, republish or create derivative works from any
          part of the platform without our prior written consent.
        </p>
      </div>

      <div class="policy">
        <h2 class="sub-title">Limitation of Liability</h2>
        <p>
          To the maximum extent permitted by law, Shriram shall not be liable for any indirect,
          incidental, special or consequential loss, or for any loss of profits, arising from your
          use of - or inability to use - the website or services, including losses
          caused by delays, system outages, network failures or events beyond our reasonable
          control.
        </p>
        <p>
          Nothing in these Terms excludes or limits any liability that cannot lawfully be excluded
          under applicable Indian law, including the regulations of SEBI and the stock exchanges.
        </p>
      </div>

      <div class="policy">
        <h2 class="sub-title">Governing Law &amp; Jurisdiction</h2>
        <p>
          These Terms are governed by and construed in accordance with the laws of India. Any
          dispute arising out of or in connection with these Terms or your use of the services
          shall be subject to the exclusive jurisdiction of the competent courts, and to the
          arbitration and grievance-redressal mechanisms prescribed by SEBI and the exchanges.
        </p>
      </div>

      <div class="policy">
        <h2 class="sub-title">Amendments</h2>
        <p>
          We may amend these Terms at any time to reflect changes in regulation, our services or our
          business. The &ldquo;last updated&rdquo; date above always reflects the version currently
          in force. For questions about these Terms, contact us at
          <a href="mailto:support@shriramsecurities.com">support@shriramsecurities.com</a> or
          <a href="tel:18001031212">1800 103 1212</a>.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ===== Terms & Conditions - page-specific styles. Values reuse the shared tokens. ===== */
  .section {
    scroll-margin-top: 96px;
  }

  /* legal document column - constrained measure for long-form reading */
  .legal {
    display: flex;
    flex-direction: column;
    gap: 56px;
  }
  .policy {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .policy p {
    font-weight: 400;
    font-size: 16px;
    color: var(--color-text-tertiary);
    overflow-wrap: anywhere; /* break long emails/URLs so they can't overflow at 320px */
  }
  .policy p b {
    font-weight: 600;
    color: var(--color-text-primary);
  }
  .policy a {
    color: var(--color-link);
  }
  .policy p.updated {
    font-weight: 500;
    font-size: 14px;
    color: var(--color-text-muted);
  }

  /* bulleted list - olive-green markers */
  .legal-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .legal-list li {
    position: relative;
    padding-left: 24px;
    font-weight: 400;
    font-size: 16px;
    color: var(--color-text-tertiary);
  }
  .legal-list li::before {
    content: '';
    position: absolute;
    left: 8px;
    top: 9px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-text-heading-dark);
  }
  .legal-list li b {
    font-weight: 600;
    color: var(--color-text-primary);
  }

  @media (max-width: 768px) {
    .legal {
      gap: 48px;
    }
    .policy p,
    .legal-list li {
      font-size: 14px;
    }
  }
</style>

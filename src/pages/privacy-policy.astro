---
/**
 * Privacy Policy — /privacy-policy/
 * Legal long-form page. Pixel parity with legacy privacy.html.
 */
import BaseLayout from '../layouts/BaseLayout.astro';

const seo = {
  title: 'Privacy Policy — How We Collect, Use & Protect Your Data',
  description:
    'Read the Shriram Financial Services Privacy Policy — what personal and KYC information we collect, how it is disclosed to SEBI, NSE, BSE and CDSL, how long we retain it, and the security safeguards that protect it.',
  path: '/privacy-policy/',
};
---

<BaseLayout seo={seo}>
  <!-- ================= HERO ================= -->
  <section class="hero" id="sec-hero" data-section="hero">
    <div class="hero-inner">
      <div class="hero-content">
        <h1>Privacy <span class="g">Policy</span></h1>
        <p class="lead">
          How Shriram Financial Services collects, uses, protects and shares your personal
          information across our website, trading platforms and services.
        </p>
        <div class="hero-feats">
          <div class="feats">
            <div class="feat">
              <span class="tk" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg>
              </span>
              <span class="lb">SEBI-compliant</span>
            </div>
            <div class="feat">
              <span class="tk" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg>
              </span>
              <span class="lb">Encrypted &amp; secured</span>
            </div>
            <div class="feat">
              <span class="tk" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg>
              </span>
              <span class="lb">Never sold to third parties</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================= INTRODUCTION + DISCLOSURE ================= -->
  <section class="section sec-light" id="sec-intro" data-section="intro">
    <div class="legal">
      <div class="policy">
        <p class="updated">Last updated: 26 June 2026</p>
        <h2 class="sub-title">Introduction</h2>
        <p>
          Shriram Financial Services (&ldquo;Shriram&rdquo;, &ldquo;we&rdquo;, &ldquo;us&rdquo; or
          &ldquo;our&rdquo;) is committed to protecting the privacy of every customer, visitor and
          partner. This Privacy Policy explains what information we collect when you browse our
          website, open a Demat or trading account, or use our research and advisory services
          &mdash; and how that information is stored, used and safeguarded.
        </p>
        <p>
          By accessing our website or using our services, you consent to the practices described in
          this policy. We may update it from time to time to reflect changes in regulation or in
          our services; the &ldquo;last updated&rdquo; date above always reflects the version
          currently in force.
        </p>
      </div>

      <div class="policy">
        <h2 class="sub-title">Disclosure of Personal Information</h2>
        <p>
          We collect personal information that you provide to us directly, as well as information
          generated as you use our platforms. <b>We do not sell your personal information.</b> We
          disclose it only in the limited circumstances described below:
        </p>
        <ul class="legal-list">
          <li>
            <b>Identity &amp; KYC details</b> &mdash; name, PAN, Aadhaar reference, date of birth
            and photograph, collected to satisfy SEBI and depository (CDSL) account-opening
            requirements.
          </li>
          <li>
            <b>Contact &amp; financial details</b> &mdash; address, email, mobile number, bank
            account and income band, used to operate and service your account.
          </li>
          <li>
            <b>Usage &amp; device data</b> &mdash; pages visited, device type, IP address and
            cookies, used to secure, maintain and improve the platform.
          </li>
          <li>
            <b>Regulators &amp; depositories</b> &mdash; information shared with SEBI, NSE, BSE and
            CDSL where required by law or to clear and settle your trades.
          </li>
          <li>
            <b>Service providers</b> &mdash; KYC registration agencies, payment partners and IT
            vendors who process data on our behalf under strict confidentiality obligations.
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ================= SUPPLEMENTAL + SECURITY ================= -->
  <section class="section sec-tint" id="sec-security" data-section="security">
    <div class="legal">
      <div class="policy">
        <h2 class="sub-title">Supplemental Information</h2>
        <p>
          Where you interact with us through third-party channels &mdash; such as WhatsApp, our
          partner referral network or social media &mdash; those platforms may also collect
          information about you under their own privacy policies, which we encourage you to review
          separately.
        </p>
        <p>
          We retain your personal information for as long as your account is active, and thereafter
          for the period mandated by SEBI, the Income Tax Act and other applicable laws. You may
          request access to, correction of, or deletion of your information at any time, subject to
          the records we are legally required to retain.
        </p>
      </div>

      <div class="policy">
        <h2 class="sub-title">Security Policy</h2>
        <p>
          We apply industry-standard safeguards &mdash; encryption in transit and at rest,
          role-based access controls, OTP-based authentication and continuous monitoring &mdash; to
          protect your information against unauthorised access, alteration or disclosure.
        </p>
        <p>
          While we work hard to protect your data, no method of transmission over the internet is
          completely secure, and we cannot guarantee absolute security. If you believe your account
          has been compromised, or if you have any questions about this policy, contact us
          immediately at <a href="mailto:support@shriramsecurities.com">support@shriramsecurities.com</a>
          or <a href="tel:18001031212">1800 103 1212</a>.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ===== Privacy — page-specific styles. Values reuse the shared tokens. ===== */
  .section {
    scroll-margin-top: 96px;
  }

  /* legal document column — constrained measure for long-form reading */
  .legal {
    display: flex;
    flex-direction: column;
    gap: 56px;
  }
  .policy {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .policy p {
    font-weight: 400;
    font-size: 16px;
    color: var(--color-text-tertiary);
    overflow-wrap: anywhere; /* break long emails/URLs so they can't overflow at 320px */
  }
  .policy p b {
    font-weight: 600;
    color: var(--color-text-primary);
  }
  .policy a {
    color: var(--color-link);
  }
  .policy p.updated {
    font-weight: 500;
    font-size: 14px;
    color: var(--color-text-muted);
  }

  /* bulleted list — olive-green markers */
  .legal-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .legal-list li {
    position: relative;
    padding-left: 24px;
    font-weight: 400;
    font-size: 16px;
    color: var(--color-text-tertiary);
  }
  .legal-list li::before {
    content: '';
    position: absolute;
    left: 8px;
    top: 9px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-text-heading-dark);
  }
  .legal-list li b {
    font-weight: 600;
    color: var(--color-text-primary);
  }

  @media (max-width: 768px) {
    .legal {
      gap: 48px;
    }
    .policy p,
    .legal-list li {
      font-size: 14px;
    }
  }
</style>

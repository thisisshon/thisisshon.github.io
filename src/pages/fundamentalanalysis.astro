---
/**
 * Fundamental Research - /fundamentalanalysis
 * Research sub-page (root route → BaseLayout / component imports at ../ depth).
 * Body content is the compliance-approved "Fundamental Research Page Content"
 * doc, implemented word-for-word in the shared design system: the standardised
 * olive hero (rule 7), shared section / card / check-list / gated-note / unlock
 * band / FAQ / CTA components (mirrors technical-analysis.astro). Every value
 * binds to a token (rule 9).
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/site/Breadcrumb.astro';
import FaqAccordion from '../components/sections/FaqAccordion.astro';
import { faqPageSchema } from '../lib/seo';

// "What Fundamental Research Contains" - the checklist (doc verbatim).
const CONTAINS = [
  'Quarterly earnings reviews with our take on revenue growth, margins and management’s guidance',
  'Stock-specific notes with a fair value range, target price and the holding period we have in mind',
  'Sector and thematic reports comparing companies on growth, debt and return ratios',
  'Mutual fund and portfolio reviews for investors who’d rather hold a basket than pick single names',
  'A clearly stated risk - the one thing that, if it happens, changes our call',
];

// Frequently Asked Questions (doc verbatim; first item open). The rendered
// header stays "General Questions" (project rule 13).
const FAQS = [
  {
    q: 'What is fundamental research?',
    a: 'Fundamental research looks at a company’s actual business — its earnings, debt, margins and growth — to work out what the stock is worth, rather than reading price charts. It’s the analysis behind a buy, hold or sell call.',
  },
  {
    q: 'How is this different from technical research?',
    a: 'Technical research tells you when a stock might move, based on price and volume patterns. Fundamental research tells you whether the company is worth owning in the first place, based on its financials and business outlook. Most serious investors use both.',
  },
  {
    q: 'Do I need to log in to read the reports?',
    a: 'You can preview the headline and rating on every report without logging in. Reading the full note — including our target price, valuation working and risk view — needs a demat account with us.',
  },
  {
    q: 'How do I open a demat account to access research?',
    a: 'Tap \'Open Demat Account\' on this page and complete the KYC process online — it takes a few minutes with your PAN and Aadhaar. Once your account is active, every fundamental report unlocks automatically.',
  },
  {
    q: 'Is the research free for clients?',
    a: 'Yes. All fundamental and technical reports, sector notes, and mutual fund reviews are free for anyone with a Shriram demat account — there’s no separate subscription.',
  },
  {
    q: 'How often are reports published?',
    a: 'Technical research are more frequent than the Fundamental. Sector reports and mutual fund reviews are published monthly, and we flag any rating change the same day it happens.',
  },
];

const seo = {
  title: 'Fundamental Research Reports',
  description:
    'Access in-depth company analysis, financial modelling and valuation reports to assess a stock\'s true worth with Shriram Financial Services.',
  path: '/fundamentalanalysis',
  jsonLd: [faqPageSchema(FAQS.map((f) => ({ question: f.q, answer: f.a })))],
};
---

<BaseLayout seo={seo} mainClass="rev-rise-scale">
  <!-- ================= HERO (standardised, rule 7) ================= -->
  <section class="hero" id="sec-hero" data-section="hero">
    <Breadcrumb trail={[{ name: 'Research Centre', href: '/researchhub' }, { name: 'Fundamental Research' }]} />
    <div class="hero-inner" data-enter>
      <h1>Fundamental <span class="g">Research</span></h1>
      <p class="lead">We look past the candle and into the company — earnings, debt, margins, and what management is actually telling shareholders.</p>
      <div class="cta"><a class="btn-gold" href="/opendemataccount">Open Demat Account</a></div>
    </div>
  </section>

  <!-- ================= WHAT IS FUNDAMENTAL RESEARCH ================= -->
  <section class="section stack sec-light" id="sec-what" data-section="what" style="gap:56px;justify-content:center" data-enter="2">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">What is Fundamental Research</h2>
      <p class="sec-lead">Fundamental Research is how we check whether a company is actually as good — or as cheap — as its share price suggests. We go through the balance sheet, the profit and loss account and the cash flow statement to see how the business is really doing, not just how the stock is trading. Ratios like price-to-earnings come into it too, alongside a look at the sector the company sits in and how it stacks up against peers.</p>
      <p class="sec-lead">None of this is about predicting tomorrow’s price move. It’s about arriving at what a stock is genuinely worth — its intrinsic value — and comparing that to what the market is charging for it today. If the gap is wide enough, that’s a stock worth a second look, whether it’s trading above or below where the numbers say it should be.</p>
      <p class="sec-lead">We publish that thinking as stock-specific notes, sector deep-dives and periodic portfolio reviews, written by SEBI-registered analysts who put a number on paper and stand behind it.</p>
    </div>
  </section>

  <!-- ================= WHAT FUNDAMENTAL RESEARCH CONTAINS ================= -->
  <section class="section stack sec-tint" id="sec-contains" data-section="contains" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">What Fundamental Research Contains</h2>
      <p class="sec-lead" style="color:var(--color-text-secondary)">Every fundamental note follows the same discipline — what changed, why it matters, and what we’d watch next. Here’s what you’ll find inside:</p>
    </div>
    <div class="card" style="display:flex;flex-direction:column">
      <div class="check-list">
        {CONTAINS.map((item, i) => (
          <>
            {i > 0 && <div class="check-sep"></div>}
            <div class="check-row">
              <span class="ck" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span>
              <p class="tx">{item}</p>
            </div>
          </>
        ))}
      </div>
    </div>
    <div style="display:flex"><a class="btn-gold" href="/opendemataccount">Open Demat Account</a></div>
  </section>

  <!-- ================= TODAY'S FUNDAMENTAL NOTE - gated ================= -->
  <section class="section stack sec-light" id="sec-note" data-section="note" style="gap:40px;align-items:center;justify-content:center">
    <div class="card gate">
      <span class="gate-ic" aria-hidden="true">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><rect x="5" y="11" width="14" height="9" rx="2" stroke="currentColor" stroke-width="1.6"></rect><path d="M8 11V8a4 4 0 0 1 8 0v3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path></svg>
      </span>
      <h3>Today’s Fundamental Note is ready.</h3>
      <p>Log in to read the full report and analyst rating, or open a demat account to get started.</p>
      <div class="gate-cta">
        <a class="btn-ghost" href="#">Login</a>
        <a class="btn-gold" href="/opendemataccount">Open Demat Account</a>
      </div>
    </div>
  </section>

  <!-- ================= ALL REPORTS IN ONE PLACE + UNLOCK BAND ================= -->
  <section class="section stack sec-tint" id="sec-notes" data-section="notes" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px;align-items:center;text-align:center">
      <h2 class="sec-title">Fundamental Research notes all you need in one place</h2>
      <p class="sec-lead" style="color:var(--color-text-secondary);max-width:720px">Every report we publish, from single earnings note to a full sector study, lives here as soon as it’s out. Log in to read the full working, rating and target price.</p>
    </div>

    <!-- Unlock band - the doc's CTA, rendered in the site's dark focus-band
         palette (parity with technical-analysis.astro's .unlock). -->
    <div class="unlock">
      <div class="unlock-tx">
        <h3>Unlock All Reports + Stock Ratings</h3>
        <p>Open your Demat account and get free, unlimited access to every fundamental report, analyst rating and model portfolio we publish.</p>
      </div>
      <div class="unlock-cta">
        <a class="btn-gold" href="/opendemataccount">Open Demat Account</a>
        <a class="btn-outline" href="#">Login to Existing Account</a>
      </div>
    </div>
  </section>

  <!-- ================= FREQUENTLY ASKED QUESTIONS ================= -->
  <!-- On the lighter surface so it reads as distinct from the tinted section
       above. Site-standard two-column FAQ: accordion left + discovery-call side
       card right (shared components). -->
  <section class="faq-wrap sec-light" id="sec-faq" data-section="faq">
    <div class="faq-cols">
      <div class="faq-left">
        <h2 class="faq-title">Got Questions?</h2>
        <FaqAccordion faqs={FAQS} />
      </div>
      <div class="faq-side">
        <div class="usr"><img src="/assets/user.svg" alt="" /></div>
        <div class="side-in">
          <div class="side-tx">
            <h3>Need A Clearer Direction? </h3>
            <p>Let’s get in touch on a 15-minute call where we can answer any questions you may have. Our advisor will help map your wealth mix and show what a dedicated research-led plan would do differently.</p>
          </div>
          <a class="btn-gold" href="/contactus">Book A Discovery Call</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ===== Fundamental Research - page-local components only. Every value binds
     to a design token; the genuinely-new blocks are the gated note card and the
     unlock band (mirrored from technical-analysis.astro). Section/hero/card/
     check-list/FAQ are all shared components from global.css. ===== */
  .section,
  .cta-sec {
    scroll-margin-top: 96px;
  }

  /* The FAQ sits on --sec-light, so the block needs a defined edge: stroke the
     accordion AND the helper side card together (background-dependent rule -
     same as research/technical). */
  .faq-acc { border: 1px solid var(--color-border-card); padding: 1px; }
  .faq-side { border: 1px solid var(--color-border-card); }

  /* ===== Gated daily-note card ===== */
  .gate {
    max-width: 640px; width: 100%; display: flex; flex-direction: column;
    align-items: center; text-align: center; gap: 8px;
  }
  .gate-ic {
    width: 48px; height: 48px; flex: none; border-radius: 999px;
    background: var(--color-text-heading-dark); color: var(--color-white);
    display: inline-flex; align-items: center; justify-content: center; margin-bottom: 16px;
  }
  .gate h3 { font-weight: 500; font-size: 20px; color: var(--color-text-primary); }
  .gate p { font-weight: 400; font-size: 14px; color: var(--color-text-muted); max-width: 400px; }
  .gate-cta { display: flex; gap: 16px; flex-wrap: wrap; justify-content: center; margin-top: 24px; }

  /* ===== Unlock band - dark focus band (parity with the site's .unlock pattern);
     the doc's CTA banner is rendered in the olive focus palette so the page stays
     inside the one token set. Solid hex only. ===== */
  .unlock {
    width: 100%; border-radius: 24px; padding: 48px var(--container-pad);
    background: radial-gradient(125% 210% at 100% -8%, var(--color-olive-600) 0%, var(--color-olive-800) 50%, var(--color-charcoal-850) 100%);
    display: flex; align-items: center; justify-content: space-between; gap: 32px; flex-wrap: wrap;
  }
  .unlock-tx { display: flex; flex-direction: column; gap: 12px; max-width: 640px; }
  .unlock-tx h3 { font-weight: 500; font-size: 28px; color: var(--color-white); }
  .unlock-tx p { font-weight: 400; font-size: 16px; color: var(--color-text-on-dark-lead); }
  /* .unlock-cta buttons use the shared .btn-gold + .btn-outline (global.css). */
  .unlock-cta { display: flex; gap: 16px; flex-wrap: wrap; }

  /* white-outline button on the dark band (matches the fill so it reads as an
     outline). Auto width to fit the longer label. */
  .btn-outline {
    display: inline-flex; align-items: center; justify-content: center;
    height: 40px; padding: 8px 24px; border-radius: 4px;
    background: transparent; border: 1px solid var(--color-white); color: var(--color-white);
    font-weight: 500; font-size: 12px; white-space: nowrap; transition: background 0.25s ease, color 0.25s ease;
  }
  @media (min-width: 1024px) and (hover: hover) {
    .btn-outline:hover { background: var(--color-white); color: var(--color-text-heading-dark); }
  }

  /* ===== responsive ===== */
  @media (max-width: 768px) {
    .unlock-tx h3 { font-size: clamp(22px, 5.6vw, 28px); }
    .unlock-cta { width: 100%; }
    .unlock-cta .btn-gold, .unlock-cta .btn-outline { width: 100%; flex: 1 1 100%; }
    .gate-cta .btn-ghost, .gate-cta .btn-gold { width: 100%; }
  }
</style>

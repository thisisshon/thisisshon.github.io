---
/**
 * Open a Demat Account - campaign 1 - /open-demat-campaign1
 *
 * ISOLATED, single-screen lead-capture landing page for paid campaigns. It
 * deliberately omits the shared site chrome (Header / MegaNav / Footer) via
 * BaseLayout's `chrome={false}` + `footer="custom"` seam - the same sanctioned
 * mechanism the Proofkit dashboards use - so the page is a focused conversion
 * funnel: logo-only bar -> hero (persuasion + form) -> disclaimer strip.
 *
 * Built 100% from the design system: the shared <Hero> two-column `aside`
 * layout (rule 18), the shared `.hf-field` input (rule 8), the global button
 * system (rule 17), Outfit (rule 3) and colour tokens (rule 9). The content
 * derives from a green-chart wireframe variation; NONE of that wireframe's
 * styling (its own green palette, Nunito Sans, bespoke spacing) is used.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';

const seo = {
  title: 'Open a Demat Account Online',
  description:
    'One good call changes everything. Open a fully digital Demat account with Shriram Financial Services using just your mobile number - 100% paperless and SEBI-regulated.',
  path: '/open-demat-campaign1',
  // Paid-campaign variant of /open-demat-account - keep it out of the index so
  // it never competes with the canonical page for the same intent. (No effect
  // while BaseLayout force-noindexes the whole pre-launch site; takes over once
  // that sitewide block is lifted and per-page `seo.noindex` gating is restored.)
  noindex: true,
};
---

<BaseLayout seo={seo} chrome={false} footer="custom" mainClass="lp-main">
  <!-- ===== logo-only bar (isolated: no mega-nav) ===== -->
  <header class="lp-nav">
    <a href="/" class="nav-logo-link" aria-label="Shriram Financial Services - home">
      <div class="logo-box">
        <div class="logo-crop">
          <img src="/assets/logo.svg" alt="Shriram Financial Services" width="128" height="52" />
        </div>
      </div>
    </a>
  </header>

  <!-- ===== HERO: persuasion column + lead-capture card ===== -->
  <Hero id="sec-hero" dataSection="lp-hero">
    <Fragment slot="title">One Good Call<br /><span class="g">Changes Everything.</span></Fragment>
    <Fragment slot="lead">
      Get expert-backed market insights from Shriram Financial Services - start
      with a fully digital Demat account.
    </Fragment>

    <!-- trust bullets (default slot -> inside .hero-inner, under the lead) -->
    <ul class="lp-bullets">
      <li class="lp-bullet">
        <span class="lp-bullet-ico" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <rect x="4" y="2" width="16" height="20" rx="2" /><path d="M8 7h8M8 11h8M8 15h5" />
          </svg>
        </span>
        <span class="lp-bullet-tx">100% Paperless Process</span>
      </li>
      <li class="lp-bullet">
        <span class="lp-bullet-ico" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3l7 3v5c0 4.4-3 7.6-7 9-4-1.4-7-4.6-7-9V6l7-3Z" /><path d="M9 12l2 2 4-4" />
          </svg>
        </span>
        <span class="lp-bullet-tx">SEBI Regulated</span>
      </li>
    </ul>

    <!-- lead-capture card (aside slot -> right column via .hero-grid) -->
    <form class="lp-form hero-aside" slot="aside" aria-label="Open a Demat account" onsubmit="return false;">
      <div class="lp-form-head">
        <span class="lp-form-ico" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3l7 3v5c0 4.4-3 7.6-7 9-4-1.4-7-4.6-7-9V6l7-3Z" /><path d="M9.5 12l1.8 1.8L15 10" />
          </svg>
        </span>
        <div>
          <h2 class="lp-form-title">Get Started Now</h2>
          <p class="lp-form-sub">Create a Demat account with your mobile number and explore Shriram Financial Services.</p>
        </div>
      </div>

      <div class="lp-form-rule"></div>

      <div class="hf-field">
        <span class="lp-flag" aria-hidden="true"></span>
        <span class="lp-sep" aria-hidden="true"></span>
        <div class="hf-field-in">
          <label for="lp-mobile">Mobile Number</label>
          <input id="lp-mobile" name="mobile" type="tel" inputmode="numeric" autocomplete="tel-national" placeholder="+91 00000 00000" required />
        </div>
      </div>

      <label class="lp-tc">
        <input type="checkbox" name="terms" required />
        <span>I&rsquo;ve read and accept the <a href="/terms-and-conditions">Terms &amp; Conditions</a>.</span>
      </label>

      <div class="lp-actions">
        <button class="btn btn-primary btn-xl" type="submit">Open Demat Account</button>
        <p class="lp-login">Already have an account? <a href="#">Login now.</a></p>
      </div>
    </form>
  </Hero>

  <!-- ===== disclaimer strip (custom footer) ===== -->
  <footer class="lp-disclaimer">
    <div class="lp-disclaimer-in">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 3l7 3v5c0 4.4-3 7.6-7 9-4-1.4-7-4.6-7-9V6l7-3Z" /><path d="M9 12l2 2 4-4" />
      </svg>
      <p class="lp-disc-text">
        <strong>Disclaimer:</strong> Investment in the securities market is subject to market risk. Read all related documents carefully before investing. The securities are quoted as an example and not as a recommendation.
        <a href="https://bit.ly/4y00xWN" target="_blank" rel="noopener">https://bit.ly/4y00xWN</a>
      </p>
    </div>
  </footer>
</BaseLayout>

<style>
  /* ===== Campaign LP - page-scoped layout only. All colour via tokens,
     all type on the shared scale, spacing on the 8px grid. The input is the
     shared .hf-field (global.css); only the card + strip chrome live here. ===== */

  /* Single-screen funnel: bar (fixed) -> hero (grows) -> disclaimer (fixed).
     `main` is rendered by BaseLayout and `.hero` by the Hero component, so these
     cross-component rules are :global (scoped to this page via the unique
     `main.lp-main` anchor - no other page uses that class). */
  :global(main.lp-main) {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }
  :global(main.lp-main > .hero) {
    flex: 1;
  }

  /* ---- logo-only bar ---- */
  .lp-nav {
    flex: none;
    height: 72px;
    padding: 0 var(--pad);
    background: var(--color-white);
    border-bottom: 1px solid var(--color-border-card);
    display: flex;
    align-items: center;
  }
  .nav-logo-link { display: inline-flex; text-decoration: none; }

  /* ---- trust bullets (on the dark hero) ---- */
  .lp-bullets {
    margin-top: 40px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    list-style: none;
  }
  .lp-bullet { display: flex; align-items: center; gap: 12px; }
  .lp-bullet-ico {
    width: 40px;
    height: 40px;
    flex: none;
    border-radius: 50%;
    border: 1px solid var(--color-gold-400);
    color: var(--color-gold-400);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .lp-bullet-tx {
    font-weight: 600;
    font-size: 16px;
    color: var(--color-white);
  }

  /* ---- lead-capture card (width + flex come from shared .hero-aside) ---- */
  .lp-form {
    background: var(--color-white);
    border: 1px solid var(--color-border-card);
    border-radius: 24px;
    padding: clamp(28px, 3vw, 40px);
    display: flex;
    flex-direction: column;
    gap: 24px;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.22); /* sanctioned translucency: shadow only */
  }
  .lp-form-head { display: flex; align-items: flex-start; gap: 12px; }
  .lp-form-ico {
    width: 44px;
    height: 44px;
    flex: none;
    border-radius: 12px;
    background: var(--color-gold-100);
    color: var(--color-olive-900);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .lp-form-title { font-weight: 600; font-size: 20px; color: var(--color-text-primary); }
  .lp-form-sub { margin-top: 4px; font-weight: 400; font-size: 14px; color: var(--color-text-muted); }
  .lp-form-rule { height: 1px; background: var(--color-border-card); }

  /* India-flag prefix + separator inside the shared .hf-field. The
     #ff9933/#138808 are flag illustration content (per the demat page), not
     brand tokens - kept verbatim, no alpha. */
  .lp-flag {
    width: 16px;
    height: 16px;
    flex: none;
    border-radius: 50%;
    border: 1px solid var(--color-border-card);
    background: linear-gradient(180deg, #ff9933 33%, #fff 33% 66%, #138808 66%);
  }
  .lp-sep { width: 1px; height: 24px; flex: none; background: var(--color-border-card); }

  /* terms checkbox - the whole label is the (larger) hit area; glyph stays 16px */
  .lp-tc { display: flex; align-items: flex-start; gap: 8px; cursor: pointer; }
  .lp-tc input {
    width: 16px;
    height: 16px;
    margin-top: 2px;
    flex: none;
    accent-color: var(--color-olive-900);
    cursor: pointer;
  }
  .lp-tc span { font-weight: 400; font-size: 12px; line-height: 1.5; color: var(--color-text-muted); }
  .lp-tc a { color: var(--color-link); font-weight: 500; text-decoration: underline; }

  .lp-actions { display: flex; flex-direction: column; gap: 16px; }
  .lp-form .btn-primary { width: 100%; min-width: 0; } /* full-width submit: exempt from the 220px footprint */
  .lp-login { text-align: center; font-weight: 400; font-size: 12px; color: var(--color-text-muted); }
  .lp-login a { color: var(--color-link); font-weight: 500; }

  /* ---- disclaimer strip ---- */
  .lp-disclaimer {
    flex: none;
    padding: 16px var(--pad);
    background: var(--color-white);
    border-top: 1px solid var(--color-border-card);
  }
  .lp-disclaimer-in { display: flex; align-items: flex-start; gap: 12px; }
  .lp-disclaimer-in svg { flex: none; margin-top: 1px; color: var(--color-olive-900); }
  .lp-disc-text { font-weight: 400; font-size: 12px; line-height: 1.5; color: var(--color-text-muted); }
  .lp-disc-text strong { font-weight: 600; color: var(--color-text-secondary); }
  .lp-disc-text a { color: var(--color-link); text-decoration: underline; margin-left: 8px; }

  @media (max-width: 767px) {
    .lp-nav { height: 60px; }
    .lp-bullets { margin-top: 32px; }
  }
</style>

<script>
  /* Digit-group the hero mobile field (+91 XXXXX XXXXX). Mirrors the demat page. */
  const mob = document.getElementById('lp-mobile') as HTMLInputElement | null;
  if (mob) {
    mob.addEventListener('input', () => {
      let d = mob.value.replace(/\D/g, '');
      if (d.slice(0, 2) === '91') d = d.slice(2);
      d = d.slice(0, 10);
      mob.value = d ? '+91 ' + (d.length > 5 ? d.slice(0, 5) + ' ' + d.slice(5) : d) : '';
    });
  }
</script>

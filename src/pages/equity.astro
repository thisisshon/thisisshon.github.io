---
/**
 * Equity - /equity/
 * Product long-form page. Pixel parity with legacy products/equity/index.html.
 * Nested route → BaseLayout / component imports at ../../ depth.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/site/Breadcrumb.astro';
import FaqAccordion from '../components/sections/FaqAccordion.astro';
import { faqPageSchema, breadcrumbSchema } from '../lib/seo';

// General Questions - doc content verbatim, same order (first item open).
const FAQS = [
  {
    q: 'What are equity stocks?',
    a: "Equity stocks are shares that represent ownership in a company. When you buy equity stocks, you become a shareholder and can benefit from the company's growth through share price appreciation and dividends.",
  },
  {
    q: 'How do I start investing in stocks in India?',
    a: 'To start investing, open a Demat and Trading Account, complete your KYC, add funds, research stocks, and place your first order through a SEBI-registered broker.',
  },
  {
    q: 'What is a Demat account and why is it required?',
    a: 'A Demat account holds your shares electronically and is mandatory for buying and selling stocks on Indian stock exchanges.',
  },
  {
    q: 'What is the minimum amount required to invest in stocks?',
    a: 'There is no fixed minimum investment amount. You can start with the price of a single share, making stock investing accessible even with a small budget.',
  },
  {
    q: 'What is the difference between NSE and BSE?',
    a: "NSE (National Stock Exchange) is India's largest exchange by trading volume and operates the NIFTY 50 index. BSE (Bombay Stock Exchange) is Asia's oldest stock exchange and operates the SENSEX index.",
  },
  {
    q: 'What are large-cap, mid-cap, and small-cap stocks?',
    a: 'Large-cap stocks belong to the top 100 companies by market capitalisation, mid-cap stocks rank between 101 and 250, while small-cap stocks are smaller companies with higher growth potential and higher risk.',
  },
  {
    q: 'What are blue-chip stocks?',
    a: 'Blue-chip stocks are shares of well-established companies with strong financial performance, stable earnings, and a long track record of growth.',
  },
  {
    q: 'How are profits from equity stocks taxed?',
    a: 'Short-Term Capital Gains (STCG) and Long-Term Capital Gains (LTCG) on equity investments are taxed as per prevailing tax regulations. Tax treatment depends on the holding period and gains earned.',
  },
  {
    q: 'Is equity investing better than mutual funds?',
    a: 'Both have advantages. Equity investing offers direct ownership and potentially higher returns, while mutual funds provide professional management and diversification, making them suitable for beginners.',
  },
  {
    q: 'What are dividends in stocks?',
    a: "Dividends are a portion of a company's profits distributed to shareholders. Not all companies pay dividends, but dividend-paying stocks can provide an additional income stream.",
  },
  {
    q: 'What are the risks of investing in equity stocks?',
    a: 'Equity investments are subject to market risk, price volatility, company-specific risks, and investor behaviour risks. Diversification and long-term investing can help manage these risks.',
  },
  {
    q: 'Can NRIs invest in Indian equity stocks?',
    a: 'Yes. NRIs can invest in Indian stocks through eligible Demat and Trading Accounts linked to NRE or NRO bank accounts, subject to applicable regulations.',
  },
  {
    q: 'How do I choose the right stocks to invest in?',
    a: "Investors should evaluate a company's financial performance, business model, growth potential, valuation, management quality, and industry outlook before investing.",
  },
  {
    q: 'Can I lose money in the stock market?',
    a: 'Yes. Stock prices can move up or down depending on market conditions and company performance. Investing with a long-term perspective and proper research can help reduce risks.',
  },
  {
    q: 'Why invest in equity stocks through Shriram Financial Services?',
    a: 'Shriram Financial Services offers a seamless investing experience with expert-backed research, market insights, dedicated support, and access to a trusted SEBI-registered stockbroking platform.',
  },
];

const site = Astro.site!.href;

const seo = {
  title: 'Buy Equity Stocks - NSE & BSE',
  description:
    'Buy equity stocks online on NSE & BSE with SEBI-registered research, real-time market data & expert insights from Shriram Financial Services.',
  path: '/equity/',
  jsonLd: [
    faqPageSchema(FAQS.map((f) => ({ question: f.q, answer: f.a }))),
    breadcrumbSchema(
      [
        { name: 'Home', path: '/' },
        { name: 'Products', path: '/products/' },
        { name: 'Equity', path: '/equity/' },
      ],
      site
    ),
  ],
};
---

<BaseLayout seo={seo} mainClass="rev-rise-scale">
  <section class="hero" id="sec-hero" data-section="hero">
    <Breadcrumb trail={[{ name: 'Products', href: '/products/' }, { name: 'Equity' }]} />
    <div class="hero-inner" data-enter>
      <h1>Equity Investing and trading Made Simpler, Smart, and Secure</h1>
      <p class="lead">Own a part of India's leading companies and grow your wealth over time. Invest in equity stocks in India with Shriram Financial Services, a SEBI-registered broker trusted by clients for 25+ years. Access research, live market insights, and a seamless investing experience.</p>
      <div class="cta"><a class="btn-gold" href="/open-demat-account/">Open Demat Account</a></div>
      <div class="hero-feats">
        <div class="feats">
          <div class="feat" style="left:0"><span class="tk" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span><span class="lb">&nbsp;SEBI-registered</span></div>
          <div class="feat" style="left:165px"><span class="tk" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span><span class="lb">&nbsp;100% Digital</span></div>
          <div class="feat" style="left:312.73px"><span class="tk" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span><span class="lb">&nbsp;Research-led</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== What Are Equity Stocks ===== -->
  <section class="section stack sec-light" id="sec-about" data-section="about" data-enter="2" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">What Are Equity Stocks?</h2>
      <p class="sec-lead">Equity stocks also known as equity shares, represent ownership in a company. When you buy equity shares in India, you become a shareholder and participate in the company's growth through potential capital appreciation and dividends.</p>
      <p class="sec-lead">Equity shares are traded on National Stock Exchange (NSE) and the Bombay Stock Exchange (BSE) under Securities and Exchange Board of India regulation (SEBI).</p>
    </div>
    <div class="stack" style="gap:32px">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">Where Equity Stocks Trade</h3>
        <p class="sub-lead">In India, this marketplace is mainly run through two exchanges — NSE and BSE. Both are regulated by SEBI (Securities and Exchange Board of India) to keep trading fair and transparent.</p>
      </div>
      <div class="row-2">
        <div class="card" style="border-color:var(--color-border-card)">
          <h4 class="card-h">National Stock Exchange (NSE)</h4>
          <p class="card-p">NSE, started in 1992, which is India's largest stock exchange by trading volume. It's known for its modern, technology-driven system where trades happen quickly and transparently. NSE runs the NIFTY 50 index, which shows how the top 50 companies in India are performing.</p>
        </div>
        <div class="card" style="border-color:var(--color-border-card)">
          <h4 class="card-h">Bombay Stock Exchange (BSE)</h4>
          <p class="card-p">BSE, founded in 1875, is the Asia's oldest stock exchange. It lists over 5,000 companies, making it the exchange with the widest coverage. BSE runs the famous SENSEX index, which tracks the top 30 companies in India.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Types of Equity Stocks ===== -->
  <section class="section stack sec-tint" id="sec-types" data-section="types" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Types of Equity Shares</h2>
      <p class="sec-lead">Stocks are grouped two ways — by the rights they carry, and by the size and style of the company behind them.</p>
    </div>
    <div class="stack" style="gap:32px">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">By Shareholder Rights</h3>
        <p class="sub-lead">Companies issue different classes of shares, each carrying its own rights to voting, dividends and profits.</p>
      </div>
      <div class="row-2">
        <div class="card">
          <h4 class="card-h">Common Equity Shares</h4>
          <p class="card-p">These are mostly traded shares. Investors receive voting rights and a slice of profits via dividends and price appreciation. Includes stable Blue chip India stocks.</p>
        </div>
        <div class="card">
          <h4 class="card-h">Preferred Equity Shares</h4>
          <p class="card-p">Preferred shareholders receive priority in dividend payments, over common shareholders but limited voting rights and lower volatility.</p>
        </div>
      </div>
    </div>
    <div class="stack" style="gap:32px">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">By Size and Style</h3>
        <p class="sub-lead">The main categories investors use to classify and compare stocks.</p>
      </div>
      <div class="cat-grid" data-reveal-row>
        <div class="cat"><h4>Large-Cap</h4><p>Top 100 biggest companies. Highly stable, lower risk, ideal for long-term safety.</p></div>
        <div class="cat"><h4>Mid-Cap</h4><p>Companies ranked 101–250. Balanced mix of growth and stability.</p></div>
        <div class="cat"><h4>Small-Cap</h4><p>Companies ranked beyond 250. High growth potential but highly volatile.</p></div>
        <div class="cat"><h4>Blue Chip</h4><p>Established, financially sound companies with a history of reliable performance.</p></div>
        <div class="cat"><h4>Growth vs. Value</h4><p>Growth stocks reinvest profits to expand fast. Value stocks are bargain shares trading below their actual worth.</p></div>
        <div class="cat"><h4>Dividend Stocks</h4><p>Reliable companies that pay regular cash rewards to shareholders.</p></div>
        <div class="cat"><h4>Value Stocks</h4><p>Undervalued companies trading below intrinsic value. Suitable for patient investors.</p></div>
        <div class="cat"><h4>Penny Stocks</h4><p>Low-priced, small company shares. High risk and high reward — for experienced traders only.</p></div>
      </div>
    </div>
    <a class="btn-gold" href="/open-demat-account/" style="align-self:center">Open Demat Account</a>
  </section>

  <!-- ===== How to Start Investing ===== -->
  <section class="section stack sec-light" id="sec-getting-started" data-section="getting-started" style="gap:56px;align-items:center;justify-content:center">
    <div class="stack" style="gap:16px;width:100%">
      <h2 class="sec-title">How to Start Investing</h2>
      <p class="sec-lead">Get started in just four simple steps—from account setup to placing your first trade.</p>
    </div>
    <div class="steps" data-reveal-row>
      <div class="step">
        <div class="num">1</div>
        <div class="st-body"><h4>Open Demat + Trading Account</h4><p>Register online with Shriram platform and link your existing Demat account or open a new one— quick and paperless.</p></div>
      </div>
      <div class="step-div"></div>
      <div class="step">
        <div class="num">2</div>
        <div class="st-body"><h4>Complete PAN / KYC / Bank Linking</h4><p>Submit PAN, complete e-KYC via Aadhaar OTP, and link your bank account.</p></div>
      </div>
      <div class="step-div"></div>
      <div class="step">
        <div class="num">3</div>
        <div class="st-body"><h4>Search &amp; Analyse Stocks</h4><p>Use our research tools and SEBI-registered analyst insights.</p></div>
      </div>
      <div class="step-div"></div>
      <div class="step">
        <div class="num">4</div>
        <div class="st-body"><h4>Buy, Hold, Sell &amp; Track</h4><p>Trade on NSE/BSE and monitor your portfolio in real time via the Antara app.</p></div>
      </div>
    </div>
    <div class="stack" style="gap:32px;width:100%">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">Who Can Invest in Equity Stocks in India?</h3>
        <p class="sub-lead">To invest in equity stocks India, you just need to check the eligibility criteria and keep a few documents ready.</p>
      </div>
      <div class="row-2">
        <div class="card check-card">
          <h4 class="ch-title">Eligibility Criteria</h4>
          <div class="check-list">
            <div class="check-row"><span class="ck" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span><p class="tx">Must be an Indian resident aged 18+.</p></div>
            <div class="check-sep"></div>
            <div class="check-row"><span class="ck" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span><p class="tx">Minors can invest if a guardian opens the account. Guardian's PAN and signature are required.</p></div>
            <div class="check-sep"></div>
            <div class="check-row"><span class="ck" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span><p class="tx">NRIs can invest via an RBI-approved broker with NRE/NRO bank accounts.</p></div>
            <div class="check-sep"></div>
            <div class="check-row"><span class="ck" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span><p class="tx">PAN card is mandatory.</p></div>
            <div class="check-sep"></div>
            <div class="check-row"><span class="ck" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span><p class="tx">KYC compliance required under SEBI rules.</p></div>
          </div>
        </div>
        <div class="card check-card">
          <h4 class="ch-title">Documents Required</h4>
          <div class="check-list">
            <div class="check-row"><span class="ck" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span><p class="tx">PAN card / Form 60 (for NRIs).</p></div>
            <div class="check-sep"></div>
            <div class="check-row"><span class="ck" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span><p class="tx">Address proof (Aadhaar, Passport, Driver's Licence, Utility Bill).</p></div>
            <div class="check-sep"></div>
            <div class="check-row"><span class="ck" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span><p class="tx">Bank details (cancelled cheque or statement).</p></div>
          </div>
        </div>
      </div>
    </div>
    <a class="btn-gold" href="/open-demat-account/" style="align-self:center">Open Demat Account</a>
  </section>

  <!-- ===== Costs & Taxes ===== -->
  <section class="section stack sec-tint" id="sec-costs" data-section="costs" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Costs &amp; Taxes</h2>
      <p class="sec-lead" style="color:var(--color-text-secondary)">What you pay to trade, and how your gains are taxed — with no hidden costs.</p>
    </div>

    <div class="stack" style="gap:32px">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">Brokerage &amp; Charges</h3>
      </div>
      <div class="t-scroll"><div class="product-page_table t3">
        <div class="cell th"><p>Charge Type</p></div><div class="cell th"><p>Delivery Equity</p></div><div class="cell th"><p>Intraday</p></div>
        <div class="cell tb"><p class="k">Brokerage</p></div><div class="cell tb"><p class="v">₹0.50paise</p></div><div class="cell tb"><p class="v">0.05%</p></div>
        <div class="cell tb"><p class="k">STT</p></div><div class="cell tb"><p class="v">0.1% on sell side</p></div><div class="cell tb"><p class="v">0.025% on buy &amp; sell side</p></div>
        <div class="cell tb"><p class="k">GST</p></div><div class="cell tb"><p class="v">18% on brokerage + exchange charges</p></div><div class="cell tb"><p class="v">18% on brokerage + exchange charges</p></div>
        <div class="cell tb"><p class="k">DP Charges</p></div><div class="cell tb"><p class="v">₹25 per  debit</p></div><div class="cell tb"><p class="v">N/A</p></div>
        <div class="cell tb"><p class="k">Exchange Charges</p></div><div class="cell tb"><p class="v">0.00345% (NSE) / 0.00375% (BSE)</p></div><div class="cell tb"><p class="v">0.00345% (NSE) / 0.00375% (BSE)</p></div>
      </div></div>
    </div>

    <div class="stack" style="gap:32px">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">Tax on Equity Stocks: LTCG &amp; STCG</h3>
        <p class="sub-lead" style="color:var(--color-text-secondary)">Understanding capital gains tax helps you plan your exit strategy and keep more of your returns.</p>
      </div>
      <div class="t-scroll"><div class="product-page_table t3">
        <div class="cell th"><p>Feature</p></div><div class="cell th"><p>Short Term (STCG)</p></div><div class="cell th"><p>Long Term (LTCG)</p></div>
        <div class="cell tb"><p class="k">Holding Period</p></div><div class="cell tb"><p class="v">Up to 12 months</p></div><div class="cell tb"><p class="v">More than 12 months</p></div>
        <div class="cell tb"><p class="k">Tax Rate</p></div><div class="cell tb"><p class="v">20% Flat</p></div><div class="cell tb"><p class="v">12.5%</p></div>
        <div class="cell tb"><p class="k">Tax-Free Limit</p></div><div class="cell tb"><p class="v">Nil (taxed from ₹1)</p></div><div class="cell tb"><p class="v">Up to ₹1.25 Lakh per year</p></div>
        <div class="cell tb"><p class="k">Indexation Benefit</p></div><div class="cell tb"><p class="v">Not Applicable</p></div><div class="cell tb"><p class="v">Not Applicable</p></div>
        <div class="cell tb"><p class="k">Applicable Section</p></div><div class="cell tb"><p class="v">Section 70A</p></div><div class="cell tb"><p class="v">Section 70A</p></div>
      </div></div>
    </div>
  </section>

  <!-- ===== Analyse and Decide ===== -->
  <section class="section stack sec-light" id="sec-analyse" data-section="analyse" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Analyse and Decide</h2>
      <p class="sec-lead" style="color:var(--color-text-secondary)">How to research a stock, choose a strategy, compare your options and weigh the risks?</p>
    </div>

    <div class="stack" style="gap:32px">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">Research Approaches</h3>
        <p class="sub-lead" style="color:var(--color-text-secondary)">Two complementary approaches, backed by data-driven insights and research-led ideas.</p>
      </div>
      <div class="approaches">
        <a class="appr" href="/fundamental-analysis/">
          <div class="appr-main">
            <p class="idx">Approach 01</p>
            <div class="appr-tt"><h4>Fundamental Research</h4><p>In-depth company analysis, financial modelling, and valuation reports to help you pick stocks with strong long-term potential.</p></div>
          </div>
          <div class="explore"><span>Explore&nbsp;</span><span aria-hidden="true"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 8h11M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span></div>
        </a>
        <a class="appr" href="/technical-analysis/">
          <div class="appr-main">
            <p class="idx">Approach 02</p>
            <div class="appr-tt"><h4>Technical Research</h4><p>Chart patterns, price action, and technical indicators to identify optimal entry and exit points for your trades.</p></div>
          </div>
          <div class="explore"><span>Explore&nbsp;</span><span aria-hidden="true"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 8h11M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span></div>
        </a>
      </div>
    </div>

    <div class="stack" style="gap:32px">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">Top Trading Strategies for Indian Investors</h3>
        <p class="sub-lead" style="color:var(--color-text-secondary)">Choose an investment strategy that aligns with your financial goals, time horizon, and risk appetite.</p>
      </div>
      <div class="t-scroll"><div class="product-page_table t4 bordered">
        <div class="cell th"><p>Parameter</p></div><div class="cell th"><p>Intraday Trading</p></div><div class="cell th"><p>Swing Trading</p></div><div class="cell th"><p>Long-Term Investing</p></div>
        <div class="cell tb"><p class="k">Investment Horizon</p></div><div class="cell tb"><p class="v">Same Day</p></div><div class="cell tb"><p class="v">Days to Weeks</p></div><div class="cell tb"><p class="v">Years</p></div>
        <div class="cell tb"><p class="k">Time Commitment</p></div><div class="cell tb"><p class="v">High</p></div><div class="cell tb"><p class="v">Moderate</p></div><div class="cell tb"><p class="v">Low</p></div>
        <div class="cell tb"><p class="k">Skill Level</p></div><div class="cell tb"><p class="v">Advanced</p></div><div class="cell tb"><p class="v">Intermediate</p></div><div class="cell tb"><p class="v">Beginner-Friendly</p></div>
        <div class="cell tb"><p class="k">Risk Level</p></div><div class="cell tb"><p class="v">High</p></div><div class="cell tb"><p class="v">Moderate</p></div><div class="cell tb"><p class="v">Moderate to Low</p></div>
        <div class="cell tb"><p class="k">Best Suited For</p></div><div class="cell tb"><p class="v">Active Traders</p></div><div class="cell tb"><p class="v">Trend-Based Traders</p></div><div class="cell tb"><p class="v">Long-Term Wealth Creation</p></div>
      </div></div>
    </div>

    <div class="stack" style="gap:32px">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">Equity Stocks Vs Mutual Funds – Know how?</h3>
        <p class="sub-lead" style="color:var(--color-text-secondary)">Both are great wealth-building tools — the right choice depends on your goals, expertise, and time horizon.</p>
      </div>
      <div class="t-scroll"><div class="product-page_table t3 bordered">
        <div class="cell th"><p>Feature</p></div><div class="cell th"><p>Equity Stocks</p></div><div class="cell th"><p>Mutual Funds</p></div>
        <div class="cell tb"><p class="k">Control</p></div><div class="cell tb"><p class="v">Full control over stock selection</p></div><div class="cell tb"><p class="v">Fund manager decides</p></div>
        <div class="cell tb"><p class="k">Returns</p></div><div class="cell tb"><p class="v">Potentially higher (and lower)</p></div><div class="cell tb"><p class="v">Moderate, diversified</p></div>
        <div class="cell tb"><p class="k">Risk</p></div><div class="cell tb"><p class="v">Higher (concentrated positions)</p></div><div class="cell tb"><p class="v">Lower (diversified)</p></div>

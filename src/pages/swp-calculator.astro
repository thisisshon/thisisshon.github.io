<style>
  /* SWP calculator - calculator UI is shared in global.css. Page-local:
     General Questions sits on --sec-light, so the accordion + helper side card
     need a defined edge. */
  .faq-acc { border: 1px solid var(--color-border-card); padding: 1px; }
  .faq-side { border: 1px solid var(--color-border-card); }
</style>

<script>
  // SWP calculator - month-by-month drawdown of a growing lumpsum.
  const fmt = new Intl.NumberFormat('en-IN', { maximumFractionDigits: 0 });
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const amt = document.getElementById('amt') as HTMLInputElement;
  const amtR = document.getElementById('amtR') as HTMLInputElement;
  const wd = document.getElementById('wd') as HTMLInputElement;
  const wdR = document.getElementById('wdR') as HTMLInputElement;
  const rate = document.getElementById('rate') as HTMLInputElement;
  const rateR = document.getElementById('rateR') as HTMLInputElement;

  const segInv = document.getElementById('seg-inv') as HTMLElement;
  const segRet = document.getElementById('seg-ret') as HTMLElement;
  let last = { wd: 0, rem: 0 };

  function digits(s: string) {
    return String(s).replace(/[^0-9.]/g, '');
  }
  function clamp(v: number, mn: number, mx: number) {
    return Math.max(mn, Math.min(mx, v));
  }
  function fillSlider(sl: HTMLInputElement) {
    const p = ((+sl.value - +sl.min) / (+sl.max - +sl.min)) * 100;
    sl.style.background =
      'linear-gradient(90deg, #4f583b 0%, #4f583b ' + p + '%, #f3f3f3 ' + p + '%, #f3f3f3 100%)';
  }
  function countTo(el: HTMLElement, from: number, to: number, fn: (n: number) => string) {
    if (reduce || from === to) {
      el.textContent = fn(to);
      return;
    }
    let t0: number | null = null;
    const d = 350;
    function tick(ts: number) {
      if (t0 === null) t0 = ts;
      const t = Math.min(1, (ts - t0) / d);
      const e = 1 - Math.pow(1 - t, 3);
      el.textContent = fn(from + (to - from) * e);
      if (t < 1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }

  /* month-by-month drawdown until the corpus empties, capped at 50 years. Each
     month the balance earns a return, then the withdrawal is taken. If monthly
     growth outpaces the withdrawal the corpus survives the cap (lasts indefinitely). */
  const CAP_MONTHS = 600; // 50-year horizon
  function compute(corpus: number, monthly: number, ratePct: number) {
    const i = ratePct / 100 / 12;
    let balance = corpus;
    let withdrawn = 0;
    let months = 0;
    for (let m = 1; m <= CAP_MONTHS; m++) {
      balance = balance * (1 + i);
      months = m;
      if (balance >= monthly) {
        balance -= monthly;
        withdrawn += monthly;
      } else {
        withdrawn += balance; // partial final withdrawal empties the corpus
        balance = 0;
        break;
      }
    }
    const indefinite = balance > 0; // still solvent at the cap
    return { months: months, withdrawn: withdrawn, remaining: balance, indefinite: indefinite };
  }

  function render(animate: boolean) {
    const corpus = clamp(parseFloat(digits(amt.value)) || 0, +amtR.min, +amtR.max);
    const monthly = clamp(parseFloat(digits(wd.value)) || 0, +wdR.min, +wdR.max);
    const ratePct = clamp(parseFloat(digits(rate.value)) || 0, +rateR.min, +rateR.max);

    const r = compute(corpus, monthly, ratePct);
    const rupee = (v: number) => '₹' + fmt.format(Math.round(v));
    const durText = r.indefinite ? '50+ yrs' : (r.months / 12).toFixed(1) + ' yrs';

    // headline is a formatted duration string, not a running number
    (document.getElementById('d-tot') as HTMLElement).textContent = durText;

    if (animate) {
      countTo(document.getElementById('r-wd') as HTMLElement, last.wd, r.withdrawn, rupee);
      countTo(document.getElementById('r-rem') as HTMLElement, last.rem, r.remaining, rupee);
    } else {
      (document.getElementById('r-wd') as HTMLElement).textContent = rupee(r.withdrawn);
      (document.getElementById('r-rem') as HTMLElement).textContent = rupee(r.remaining);
    }
    last = { wd: r.withdrawn, rem: r.remaining };

    // dark = share withdrawn, gold = share remaining (fully dark once depleted)
    const total = r.withdrawn + r.remaining;
    const wdPct = total > 0 ? (r.withdrawn / total) * 100 : 100;
    segInv.style.width = wdPct + '%';
    segRet.style.width = 100 - wdPct + '%';

    (document.getElementById('sr-summary') as HTMLElement).textContent =
      'A ₹' + fmt.format(corpus) + ' corpus with ₹' + fmt.format(monthly) + ' monthly withdrawals lasts ' + durText + ', withdrawing ' + rupee(r.withdrawn) + ' in total.';

    updateUrl(corpus, monthly, ratePct);
    amtR.setAttribute('aria-valuetext', '₹' + fmt.format(corpus));
    wdR.setAttribute('aria-valuetext', '₹' + fmt.format(monthly));
    rateR.setAttribute('aria-valuetext', ratePct + ' percent');
  }

  function updateUrl(corpus: number, monthly: number, ratePct: number) {
    const q = '?amt=' + corpus + '&wd=' + monthly + '&rate=' + ratePct;
    try {
      history.replaceState(null, '', q);
    } catch (e) {
      /* ignore */
    }
  }

  function pairNumberAndSlider(numEl: HTMLInputElement, slEl: HTMLInputElement, group: boolean) {
    slEl.addEventListener('input', function () {
      numEl.value = group ? fmt.format(+slEl.value) : slEl.value;
      fillSlider(slEl);
      render(false);
    });
    numEl.addEventListener('input', function () {
      const raw = parseFloat(digits(numEl.value)) || 0;
      if (group) numEl.value = raw ? fmt.format(raw) : '';
      slEl.value = String(clamp(raw, +slEl.min, +slEl.max));
      fillSlider(slEl);
      render(false);
    });
    numEl.addEventListener('change', function () {
      const v = clamp(parseFloat(digits(numEl.value)) || +slEl.min, +slEl.min, +slEl.max);
      numEl.value = group ? fmt.format(v) : String(v);
      slEl.value = String(v);
      fillSlider(slEl);
      render(true);
    });
  }
  pairNumberAndSlider(amt, amtR, true);
  pairNumberAndSlider(wd, wdR, true);
  pairNumberAndSlider(rate, rateR, false);

  (function initFromUrl() {
    const p = new URLSearchParams(location.search);
    function setNum(el: HTMLInputElement, sl: HTMLInputElement, key: string, group: boolean) {
      if (!p.has(key)) return;
      const v = clamp(parseFloat(p.get(key) || '') || +sl.min, +sl.min, +sl.max);
      sl.value = String(v);
      el.value = group ? fmt.format(v) : String(v);
    }
    setNum(amt, amtR, 'amt', true);
    setNum(wd, wdR, 'wd', true);
    setNum(rate, rateR, 'rate', false);
  })();

  [amtR, wdR, rateR].forEach(fillSlider);
  render(true);
</script>

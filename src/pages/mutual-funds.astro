---
/**
 * Mutual Funds - /mutual-funds/
 * Product long-form page. Net-new page built entirely from the shared design
 * system (tokens + component classes in global.css); structural sibling of
 * products/equity.astro. Content is the compliance-approved Mutual Fund doc, verbatim.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/site/Breadcrumb.astro';
import FaqAccordion from '../components/sections/FaqAccordion.astro';
import { faqPageSchema } from '../lib/seo';
import { calcHref } from '../data/calculators';

// The three mutual-fund-relevant calculators. Blurbs are this page's own copy;
// hrefs resolve through the calculators data layer so the links cannot rot.
const CALC_TOOLS = [
  { slug: 'sip', title: 'SIP Calculator', desc: 'Estimate monthly SIP returns over time at varying rates.' },
  { slug: 'lumpsum', title: 'Lump Sum Calculator', desc: 'Project lump sum growth with CAGR assumptions.' },
  { slug: 'swp', title: 'SWP Calculator', desc: 'Plan monthly withdrawals without depleting the corpus.' },
];

// SEBI's six Riskometer bands, in order. Scheme examples are indicative, not advice.
const RISK_BANDS = [
  { h: 'Low', p: 'Principal at low risk. Typically overnight and liquid funds.' },
  { h: 'Low to Moderate', p: 'Principal at low to moderate risk. Typically ultra-short duration and money-market funds.' },
  { h: 'Moderate', p: 'Principal at moderate risk. Typically short-duration and conservative hybrid funds.' },
  { h: 'Moderately High', p: 'Principal at moderately high risk. Typically balanced-advantage and large-cap funds.' },
  { h: 'High', p: 'Principal at high risk. Typically mid-cap and multi-cap equity funds.' },
  { h: 'Very High', p: 'Principal at very high risk. Typically small-cap, sectoral and thematic funds.' },
];

// Got Questions? - the first 6 FAQs from the compliance doc (display cap; the
// remainder was stripped and can be restored from the doc if needed). Feeds both
// the accordion and the FAQPage JSON-LD, so markup and schema cannot drift.
const FAQS = [
  {
    q: 'What is a mutual fund, and how does it work?',
    a: 'A mutual fund is a pooled investment vehicle regulated by SEBI that collects capital from multiple investors and deploys it across a diversified portfolio of securities managed by a professional fund manager. Each investor holds units proportional to their contribution, and the value of these units (Net Asset Value) fluctuates based on the performance of the underlying portfolio.',
  },
  {
    q: 'Is investing in mutual funds safe in India?',
    a: 'Mutual funds offer significant investor protection, including mandatory disclosures, independent trustee oversight, and daily NAV transparency. However, returns are not guaranteed, and fund values are subject to market risk. The safety of an investment depends on the fund category; for example, liquid funds are considered low-risk, whereas small-cap equity funds are more volatile. Selecting funds aligned with your risk profile is key.',
  },
  {
    q: 'What is NAV in a mutual fund?',
    a: "NAV, or Net Asset Value, is the per-unit price of a mutual fund scheme. It is calculated daily by dividing the total market value of the fund's portfolio (minus liabilities) by the total number of outstanding units. A rising NAV indicates that the fund's portfolio has appreciated in value.",
  },
  {
    q: 'What is the minimum amount to invest in a mutual fund?',
    a: 'Most mutual fund schemes in India allow investments starting from as low as ₹100 via SIP and lump sum payment. Some schemes have slightly higher minimums, while index funds and ETFs can be purchased for the price of a single unit on a stock exchange.',
  },
  {
    q: 'How does SIP differ from a lump sum investment?',
    a: 'A SIP (Systematic Investment Plan) involves investing a fixed amount at regular intervals, benefiting from Rupee Cost Averaging and investment discipline. A lump sum is a single, one-time investment of the full amount. SIPs are generally better suited for regular income earners, while lump sum investments may be more effective when markets are at a significant low for investors with surplus capital.',
  },
  {
    q: 'What is ELSS, and how does it help in tax saving?',
    a: 'ELSS (Equity-Linked Savings Scheme) is a category of equity mutual fund that qualifies for a deduction of up to ₹1.5 lakh per year under Section 80C of the Income Tax Act. It has a mandatory lock-in period of 3 years, the shortest among all 80C instruments, and invests predominantly in equities, offering the dual benefit of tax savings and potential long-term capital appreciation.',
  },
];

const seo = {
  title: 'Invest in Mutual Funds Online',
  description:
    'Compare 3,000+ mutual funds and invest in Regular and Direct Plans. Start a SIP from Rs 100/month with Shriram Financial Services.',
  path: '/mutual-funds/',
  jsonLd: [faqPageSchema(FAQS.map((f) => ({ question: f.q, answer: f.a })))],
};
---

<BaseLayout seo={seo} mainClass="rev-rise-scale">
  <section class="hero" id="sec-hero" data-section="hero">
    <Breadcrumb trail={[{ name: 'Products', href: '/products/' }, { name: 'Mutual Funds' }]} />
    <div class="hero-inner" data-enter>
      <h1>Mutual Funds: A Smarter Way to Build <span class="g">Long-Term Wealth</span></h1>
      <p class="lead">Whether you are starting your first SIP, planning for retirement, building wealth, or seeking tax-efficient investment options, Shriram Financial Services offers a wide range of mutual fund solutions through a trusted investment experience.</p>
      <div class="cta"><a class="btn-gold" href="/open-demat-account/">Start SIP</a></div>
    </div>
  </section>

  <!-- ===== Expert-Managed Portfolios ===== -->
  <section class="section stack sec-light" id="sec-about" data-section="about" style="gap:56px;justify-content:center" data-enter="2">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Mutual Funds: Expert-Managed Portfolios Built for Your Goals</h2>
      <p class="sec-lead">Invest in mutual funds with Shriram Financial Services and put your money into professionally managed portfolios built for your goals.  Whether you are investing for wealth creation, income, or long-term financial milestones, Shriram Financial Services gives you access to a wide range of mutual fund schemes from leading asset management companies. Compare them side by side and start investing online in just a few clicks.</p>
    </div>
  </section>

  <!-- ===== How Mutual Funds Work ===== -->
  <section class="section stack sec-tint" id="sec-how" data-section="how" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">How Mutual Funds Work — NAV, AUM, and Fund Manager</h2>
      <p class="sec-lead">When you invest, you purchase units of a fund at the current Net Asset Value (NAV). The NAV changes daily based on the market value of underlying securities.</p>
    </div>
    <div class="steps" data-reveal-row>
      <div class="step">
        <div class="num">1</div>
        <div class="st-body"><h4>You invest money</h4><p>Transfer funds via SIP or as a lump sum. Your money is pooled with other investors.</p></div>
      </div>
      <div class="step-div"></div>
      <div class="step">
        <div class="num">2</div>
        <div class="st-body"><h4>Fund manager invests</h4><p>Buys equities, bonds, or other instruments in line with the fund's stated mandate and SEBI category.</p></div>
      </div>
      <div class="step-div"></div>
      <div class="step">
        <div class="num">3</div>
        <div class="st-body"><h4>NAV is calculated daily</h4><p>Total assets minus liabilities, divided by outstanding units = today's NAV.</p></div>
      </div>
      <div class="step-div"></div>
      <div class="step">
        <div class="num">4</div>
        <div class="st-body"><h4>You redeem at NAV</h4><p>Units are redeemed at the current NAV. Gains or losses are credited to your account.</p></div>
      </div>
    </div>
    <div class="t-scroll"><div class="product-page_table t2" style="grid-template-columns:repeat(2,minmax(0,1fr))">
      <div class="cell th"><p>Term</p></div><div class="cell th"><p>Meaning</p></div>
      <div class="cell tb"><p class="k">NAV</p></div><div class="cell tb"><p class="v">Price per unit of a fund, calculated daily</p></div>
      <div class="cell tb"><p class="k">AUM</p></div><div class="cell tb"><p class="v">Total market value of assets managed by the fund</p></div>
      <div class="cell tb"><p class="k">Expense ratio</p></div><div class="cell tb"><p class="v">Annual fee charged by the fund (% of AUM)</p></div>
      <div class="cell tb"><p class="k">Exit load</p></div><div class="cell tb"><p class="v">Fee on redemption before a specified period</p></div>
      <div class="cell tb"><p class="k">Units</p></div><div class="cell tb"><p class="v">Portions of the fund you own after investing</p></div>
    </div></div>
    <a class="btn-gold" href="/open-demat-account/" style="align-self:center">Start Investing</a>
  </section>

  <!-- ===== Types of Mutual Funds in India ===== -->
  <section class="section stack sec-light" id="sec-types" data-section="types" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Types of Mutual Funds in India</h2>
      <p class="sec-lead">SEBI classifies mutual funds into well-defined categories, making it easier for investors to align fund selection with their financial goals, risk appetite, and investment horizon. Here is an overview of the key types of mutual funds in India:</p>
    </div>
    <div class="t-scroll"><div class="product-page_table t5" style="grid-template-columns:repeat(5,minmax(0,1fr));min-width:820px">
      <div class="cell th"><p>Category</p></div><div class="cell th"><p>Sub-types</p></div><div class="cell th"><p>Ideal for</p></div><div class="cell th"><p>Risk level</p></div><div class="cell th"><p>Horizon</p></div>
      <div class="cell tb"><p class="k">Equity</p></div><div class="cell tb"><p class="v">Large cap, Mid cap, Small cap, Flexi cap, ELSS</p></div><div class="cell tb"><p class="v">Long-term wealth creation</p></div><div class="cell tb"><p class="v">High</p></div><div class="cell tb"><p class="v">3+ years</p></div>
      <div class="cell tb"><p class="k">Debt</p></div><div class="cell tb"><p class="v">Liquid, Short-term, Gilt, Corporate bond</p></div><div class="cell tb"><p class="v">Capital preservation, income</p></div><div class="cell tb"><p class="v">Low</p></div><div class="cell tb"><p class="v">1 day–3 years</p></div>
      <div class="cell tb"><p class="k">Hybrid</p></div><div class="cell tb"><p class="v">Balanced advantage, Aggressive, Conservative</p></div><div class="cell tb"><p class="v">Moderate risk, balanced growth</p></div><div class="cell tb"><p class="v">Moderate</p></div><div class="cell tb"><p class="v">3–5 years</p></div>
      <div class="cell tb"><p class="k">Solution-oriented</p></div><div class="cell tb"><p class="v">Retirement, Children's fund</p></div><div class="cell tb"><p class="v">Specific life goals</p></div><div class="cell tb"><p class="v">Moderate</p></div><div class="cell tb"><p class="v">5+ years</p></div>
      <div class="cell tb"><p class="k">Other / Index</p></div><div class="cell tb"><p class="v">Index funds, ETFs, Fund of funds</p></div><div class="cell tb"><p class="v">Passive, low-cost investing</p></div><div class="cell tb"><p class="v">Moderate</p></div><div class="cell tb"><p class="v">3+ years</p></div>
      <div class="cell tb"><p class="k">ELSS Funds</p></div><div class="cell tb"><p class="v">Equity-Linked Savings Scheme</p></div><div class="cell tb"><p class="v">Tax saving under Section 80C + wealth creation</p></div><div class="cell tb"><p class="v">High</p></div><div class="cell tb"><p class="v">3+ years (mandatory lock-in period)</p></div>
      <div class="cell tb"><p class="k">Open-Ended</p></div><div class="cell tb"><p class="v">Any of the above (entry/exit anytime)</p></div><div class="cell tb"><p class="v">Flexible investment horizon</p></div><div class="cell tb"><p class="v">Varies</p></div><div class="cell tb"><p class="v">Flexible</p></div>
      <div class="cell tb"><p class="k">Close-Ended</p></div><div class="cell tb"><p class="v">Fixed Maturity Plans (FMPs)</p></div><div class="cell tb"><p class="v">Defined maturity with predictable returns</p></div><div class="cell tb"><p class="v">Low to Moderate</p></div><div class="cell tb"><p class="v">Fixed (typically 3–5 years, until maturity)</p></div>
    </div></div>
  </section>

  <!-- ===== Mutual Fund Calculators and Tools ===== -->
  <section class="section stack sec-tint" id="sec-calculators" data-section="calculators" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Mutual Fund Calculators and Tools</h2>
      <p class="sec-lead">Sound investment decisions begin with precise planning. Our free mutual fund calculator tools enable you to model scenarios, set realistic return expectations, and determine the right investment amount for your goals — before you invest a single rupee.</p>
    </div>
    <div class="cat-grid cat-grid-3" data-reveal-row>
      {CALC_TOOLS.map((c) => (
        <a class="cat cat-link" href={calcHref(c.slug)}>
          <h4>{c.title}</h4>
          <p>{c.desc}</p>
          <div class="cat-go">
            <span>Open&nbsp;</span>
            <span aria-hidden="true"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 8h11M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- ===== Mutual Fund Risks & Riskometer ===== -->
  <section class="section stack sec-light" id="sec-risks" data-section="risks" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Mutual Fund Risks &amp; Riskometer</h2>
      <p class="sec-lead">Every investment carries risk, and mutual funds are no exception. However, informed investors know that risk is not something to avoid; it is something to understand, measure, and manage. SEBI mandates all mutual fund schemes in India to carry a Riskometer — a standardised visual rating that classifies each fund's risk level across six categories.</p>
    </div>
    <div class="cat-grid cat-grid-3" data-reveal-row>
      {RISK_BANDS.map((r) => (
        <div class="cat"><h4>{r.h}</h4><p>{r.p}</p></div>
      ))}
    </div>
    <p class="sec-lead">Every scheme discloses its Riskometer in the scheme document and reviews it monthly. Check the band before you invest, and match it to your own horizon and tolerance rather than to past returns.</p>
  </section>

  <!-- ===== Tax Benefits of Mutual Funds ===== -->
  <section class="section stack sec-tint" id="sec-tax" data-section="tax" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Tax Benefits of Mutual Funds</h2>
      <p class="sec-lead">One of the most compelling advantages of mutual fund investing in India is the potential for significant tax efficiency. From the Section 80C deduction available through ELSS funds to the concessional Long-Term Capital Gains (LTCG) tax treatment on equity holdings, mutual funds are among the most tax-smart instruments available to Indian investors in 2026.</p>
    </div>
    <div class="stack" style="gap:32px">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">Mutual Fund Taxation – At a Glance</h3>
      </div>
      <div class="t-scroll"><div class="product-page_table t5" style="grid-template-columns:repeat(5,minmax(0,1fr));min-width:860px">
        <div class="cell th"><p>Fund Type</p></div><div class="cell th"><p>Holding Period</p></div><div class="cell th"><p>Tax Type</p></div><div class="cell th"><p>Tax Rate</p></div><div class="cell th"><p>80C Benefit</p></div>
        <div class="cell tb"><p class="k">Equity &amp; Equity-Oriented</p></div><div class="cell tb"><p class="v">&lt; 1 Year</p></div><div class="cell tb"><p class="v">STCG</p></div><div class="cell tb"><p class="v">20%</p></div><div class="cell tb"><p class="v">Applicable only if invested through ELSS schemes</p></div>
        <div class="cell tb"><p class="k">Equity &amp; Equity-Oriented</p></div><div class="cell tb"><p class="v">&gt; 1 Year</p></div><div class="cell tb"><p class="v">LTCG</p></div><div class="cell tb"><p class="v">12.5% (above ₹1.25 lakh gains)</p></div><div class="cell tb"><p class="v">Applicable only if invested through ELSS schemes</p></div>
        <div class="cell tb"><p class="k">Debt Funds (post Apr 2023 investments)</p></div><div class="cell tb"><p class="v">Any</p></div><div class="cell tb"><p class="v">Added to income</p></div><div class="cell tb"><p class="v">As per income tax slab</p></div><div class="cell tb"><p class="v">Not applicable</p></div>
        <div class="cell tb"><p class="k">Hybrid Funds (Equity-Oriented)</p></div><div class="cell tb"><p class="v">&lt; 1 Year</p></div><div class="cell tb"><p class="v">STCG</p></div><div class="cell tb"><p class="v">20%</p></div><div class="cell tb"><p class="v">Not applicable</p></div>
        <div class="cell tb"><p class="k">Hybrid Funds (Equity-Oriented)</p></div><div class="cell tb"><p class="v">&gt; 1 Year</p></div><div class="cell tb"><p class="v">LTCG</p></div><div class="cell tb"><p class="v">12.5% (above ₹1.25 lakh gains)</p></div><div class="cell tb"><p class="v">Not applicable</p></div>
      </div></div>
      <p class="sec-lead">Note: Tax rules are subject to change as per Union Budget announcements. Always consult a tax advisor for personalised guidance.</p>
    </div>
  </section>

  <!-- ===== What is a Systematic Investment Plan ===== -->
  <section class="section stack sec-light" id="sec-sip" data-section="sip" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">What is a Systematic Investment Plan in Mutual Funds?</h2>
      <p class="sec-lead">A Systematic Investment Plan (SIP) allows you to invest a fixed amount into a mutual fund at regular intervals — weekly, monthly, or quarterly, rather than committing a large amount upfront. SIP investment is the preferred route for salaried individuals and first-time investors because it instils financial discipline while harnessing the power of compounding.</p>
    </div>
    <div class="t-scroll"><div class="product-page_table t3 bordered">
      <div class="cell th"><p>Criteria</p></div><div class="cell th"><p>SIP</p></div><div class="cell th"><p>Lump Sum</p></div>
      <div class="cell tb"><p class="k">Minimum amount</p></div><div class="cell tb"><p class="v">₹100</p></div><div class="cell tb"><p class="v">₹100</p></div>
      <div class="cell tb"><p class="k">Market timing</p></div><div class="cell tb"><p class="v">Not needed</p></div><div class="cell tb"><p class="v">Critical</p></div>
      <div class="cell tb"><p class="k">Avg. cost</p></div><div class="cell tb"><p class="v">Rupee-cost averaging</p></div><div class="cell tb"><p class="v">Single price</p></div>
      <div class="cell tb"><p class="k">Best for</p></div><div class="cell tb"><p class="v">Salaried investors</p></div><div class="cell tb"><p class="v">Lump-sum surplus</p></div>
      <div class="cell tb"><p class="k">Tax</p></div><div class="cell tb"><p class="v">Each SIP = new investment</p></div><div class="cell tb"><p class="v">One holding date</p></div>
    </div></div>
    <div class="t-scroll"><div class="product-page_table t2" style="grid-template-columns:repeat(2,minmax(0,1fr))">
      <div class="cell th"><p>Metric</p></div><div class="cell th"><p>Value</p></div>
      <div class="cell tb"><p class="k">Monthly SIP</p></div><div class="cell tb"><p class="v">₹5,000</p></div>
      <div class="cell tb"><p class="k">Expected p.a.</p></div><div class="cell tb"><p class="v">12%</p></div>
      <div class="cell tb"><p class="k">Invested (20 years)</p></div><div class="cell tb"><p class="v">₹12L</p></div>
      <div class="cell tb"><p class="k">Estimated Returns</p></div><div class="cell tb"><p class="v">₹ 46 L (approx.)</p></div>
    </div></div>
    <a class="btn-gold" href="/sip-calculator/" style="align-self:center">Calculate Now</a>
  </section>

  <!-- ===== SWP, STP, and Lump Sum ===== -->
  <section class="section stack sec-tint" id="sec-modes" data-section="modes" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">SWP, STP, and Lump Sum - Other Mutual Fund Investment Modes</h2>
      <p class="sec-lead">Beyond SIP, mutual fund investors in India have access to additional investment and withdrawal strategies that offer greater control over cash flows and portfolio rebalancing. Understanding these modes enables you to tailor your investment journey to your life stage and income needs.</p>
    </div>
    <div class="t-scroll"><div class="product-page_table t4 bordered" style="min-width:760px">
      <div class="cell th"><p>Mode</p></div><div class="cell th"><p>Full Form</p></div><div class="cell th"><p>How It Works</p></div><div class="cell th"><p>Ideal For</p></div>
      <div class="cell tb"><p class="k">SWP</p></div><div class="cell tb"><p class="v">Systematic Withdrawal Plan</p></div><div class="cell tb"><p class="v">Withdraw a fixed amount at regular intervals from your mutual fund corpus</p></div><div class="cell tb"><p class="v">Retirees; passive income seekers; post-goal cash flow</p></div>
      <div class="cell tb"><p class="k">STP</p></div><div class="cell tb"><p class="v">Systematic Transfer Plan</p></div><div class="cell tb"><p class="v">Transfer a fixed sum periodically from one mutual fund to another within the same AMC</p></div><div class="cell tb"><p class="v">Gradual equity deployment; risk management during volatility</p></div>
      <div class="cell tb"><p class="k">Lump Sum</p></div><div class="cell tb"><p class="v">—</p></div><div class="cell tb"><p class="v">Invest the entire amount at once in a mutual fund scheme</p></div><div class="cell tb"><p class="v">Investors with idle surplus; deploying bonuses or windfalls</p></div>
      <div class="cell tb"><p class="k">Switch</p></div><div class="cell tb"><p class="v">—</p></div><div class="cell tb"><p class="v">Move your investment from one scheme to another within the same AMC, such as between plans, options, or fund categories</p></div><div class="cell tb"><p class="v">Investors rebalancing portfolios, moving between direct and regular plans, or realigning with changing financial goals</p></div>
      <div class="cell tb"><p class="k">NFO</p></div><div class="cell tb"><p class="v">New Fund Offer</p></div><div class="cell tb"><p class="v">Subscribe to a new mutual fund scheme during its initial offer period, typically launched at a fixed unit price before it reopens for ongoing purchase and sale</p></div><div class="cell tb"><p class="v">Investors seeking early entry into a new theme or strategy; those comfortable investing without a prior performance track record</p></div>
    </div></div>
  </section>

  <!-- ===== General Questions (doc "Got Questions?") ===== -->
  <section class="faq-wrap sec-light" id="sec-faq" data-section="faq">
    <div class="faq-cols">
      <div class="faq-left">
        <h2 class="faq-title">Got Questions?</h2>
        <FaqAccordion faqs={FAQS} />
      </div>
      <div class="faq-side">
        <div class="usr"><img src="/assets/user.svg" alt="" /></div>
        <div class="side-in">
          <div class="side-tx">
            <h3>Need A Clearer Direction? </h3>
            <p>Let's get in touch on a 15-Minute call where we would be able to answer any questions you may have. Our Advisor will additionally help map your wealth mix and demonstrate what a dedicated advisor would do differently.</p>
          </div>
          <a class="btn-gold" href="/contact-us/">Book A Discovery Call</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

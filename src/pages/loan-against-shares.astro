---
/**
 * Loan Against Securities (LAS) - /loan-against-shares
 * Long-form product page. Built entirely from the shared design-system
 * components in global.css (hero, .section/.sec-title, .card, .cat-grid,
 * .steps, .product-page_table, .check-card, .risks, .bullets, FaqAccordion,
 * .cta-box). Content is the compliance-approved LAS product doc, verbatim.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/site/Breadcrumb.astro';
import FaqAccordion from '../components/sections/FaqAccordion.astro';
import { faqPageSchema, breadcrumbSchema, organizationSchema } from '../lib/seo';

// Got Questions? - the first 6 FAQs from the compliance doc (display cap; the
// remainder was stripped and can be restored from the doc if needed). Feeds both
// the accordion and the FAQPage JSON-LD, so markup and schema cannot drift.
const FAQS = [
  {
    q: 'What is a Loan Against Shares (LAS)?',
    a: 'A Loan Against Shares is a secured credit facility that allows you to borrow funds by pledging eligible shares and securities while continuing to retain ownership of your investments.',
  },
  {
    q: 'How much loan can I get against my shares?',
    a: 'The loan amount depends on the market value of the pledged securities and the applicable Loan-to-Value (LTV) ratio. Typically, lenders may offer funding of up to 50% of the value of eligible shares, subject to prevailing regulations.',
  },
  {
    q: 'Do I lose ownership of my shares after pledging them?',
    a: 'No. You continue to remain the owner of the pledged shares and may continue to receive corporate benefits such as dividends, bonus issues, and rights entitlements, subject to applicable terms.',
  },
  {
    q: 'Which shares are eligible for a Loan Against Shares?',
    a: 'Only shares approved by the lender and meeting regulatory eligibility criteria can be pledged. Eligible securities are generally selected based on liquidity, market capitalisation, and risk parameters.',
  },
  {
    q: 'What is the Loan-to-Value (LTV) ratio in LAS?',
    a: 'LTV represents the percentage of the pledged portfolio value that can be availed as a loan. The applicable LTV varies depending on the type of security and regulatory guidelines.',
  },
  {
    q: 'What happens if the value of my pledged shares falls?',
    a: 'If the value of pledged shares declines significantly, the lender may issue a margin call asking you to pledge additional securities or repay a portion of the outstanding loan to maintain the required margin.',
  },
];

const site = Astro.site!.href;

const seo = {
  title: 'Loan Against Shares (LAS)',
  description:
    'Borrow against your equity portfolio at competitive interest rates while your shares stay invested. Apply for LAS with Shriram Financial Services.',
  path: '/loan-against-shares',
  jsonLd: [
    faqPageSchema(FAQS.map((f) => ({ question: f.q, answer: f.a }))),
    breadcrumbSchema(
      [
        { name: 'Home', path: '/' },
        { name: 'Products', path: '/products' },
        { name: 'Loan Against Securities', path: '/loan-against-shares' },
      ],
      site
    ),
    organizationSchema(site),
  ],
};
---

<BaseLayout seo={seo} mainClass="rev-rise-scale">
  <!-- ===== Hero ===== -->
  <section class="hero" id="sec-hero" data-section="hero">
    <Breadcrumb trail={[{ name: 'Products', href: '/products' }, { name: 'Loan Against Securities' }]} />
    <div class="hero-inner" data-enter>
      <h1>Loan Against Shares – Unlock Liquidity Without Selling a Single Share</h1>
      <p class="lead">Need quick funds for short‑term expenses? A Loan Against Shares lets you access money instantly while keeping your investments intact. With Shriram Financial Services, you can get credit against your shares — currently available for Demat accounts with NSDL.</p>
      <div class="t-scroll"><div class="product-page_table t5" style="grid-template-columns:repeat(5,minmax(0,1fr));min-width:640px">
        <div class="cell th"><p>Interest Rate</p></div><div class="cell th"><p>Max LTV</p></div><div class="cell th"><p>Disbursal</p></div><div class="cell th"><p>Approved Scrips</p></div><div class="cell th"><p>Foreclosure</p></div>
        <div class="cell tb"><p class="v">From  12% p.a.</p></div><div class="cell tb"><p class="v">Up to 50%</p></div><div class="cell tb"><p class="v">12-24 hrs</p></div><div class="cell tb"><p class="v">800 +</p></div><div class="cell tb"><p class="v">Zero charges</p></div>
      </div></div>
      <div class="cta"><a class="btn-gold" href="/open-demat-account">Apply Now</a><a class="btn-ghost" href="/open-demat-account">Check Eligibility</a><a class="btn-ghost" href="/contact-us">Talk to an Expert</a></div>
    </div>
  </section>

  <!-- ===== Borrow Funds without Selling Investments ===== -->
  <section class="section stack sec-light" id="sec-about" data-section="about" style="gap:56px;justify-content:center" data-enter="2">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Loan Against Shares: Borrow Funds without Selling Investments</h2>
      <p class="sec-lead">Unlock the value of your share portfolio with a Loan Against Shares. Access funds by pledging your eligible shares while continuing to stay invested in the market. With Shriram Financial Services, enjoy a simple application process, competitive interest rates, and quick access to funds without disrupting your long-term investment goals.</p>
    </div>
    <div class="stack" style="gap:32px;width:100%">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">How It Works — 3-Step Process</h3>
      </div>
      <div class="steps" data-reveal-row>
        <div class="step"><div class="num">1</div><div class="st-body"><p>You pledge approved shares from your Demat account</p></div></div>
        <div class="step-div"></div>
        <div class="step"><div class="num">2</div><div class="st-body"><p>Lender assigns a credit limit based on LTV (up to 50% of share value)</p></div></div>
        <div class="step-div"></div>
        <div class="step"><div class="num">3</div><div class="st-body"><p>Withdraw funds as needed; pay interest only on amount used.</p></div></div>
      </div>
    </div>
  </section>

  <!-- ===== How the LAS Process Works ===== -->
  <section class="section stack sec-tint" id="sec-how" data-section="how" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">How the LAS Process Works?</h2>
      <p class="sec-lead" style="color:var(--color-text-secondary)">With Shriram Financial Services, the Loan Against Shares journey is transparent and digital‑first. From valuation, Pledging to unpledging, every step is secure, regulated, and hassle‑free.</p>
    </div>
    <div class="stack" style="gap:32px;width:100%">
      <div class="steps" data-reveal-row>
        <div class="step"><div class="num">1</div><div class="st-body"><h4>Valuation &amp; Eligibility</h4><p>When you apply,  Only approved shares of Shriram Credit (RE), are eligible to be pledged. The lender evaluates your portfolio and confirms the Loan to Value (LTV).</p></div></div>
        <div class="step-div"></div>
        <div class="step"><div class="num">2</div><div class="st-body"><h4>Loan‑to‑Value (LTV)</h4><p>Based on the market value of your shares, the lender sanctions a credit limit. This is usually between 30% and 50% of your portfolio’s worth. For example, if your shares are worth ₹10 lakh, you may be eligible for a loan of up to ₹5 lakh.</p></div></div>
        <div class="step-div"></div>
        <div class="step"><div class="num">3</div><div class="st-body"><h4>Lien Marking</h4><p>To secure the loan, a lien is placed on your pledged shares through the NSDL system. You authorise this digitally via OTP. Once pledged, you would not be able to liquidate or transfer those lien marked shares until the loan is fully repaid.</p></div></div>
      </div>
      <div class="steps" data-reveal-row>
        <div class="step"><div class="num">4</div><div class="st-body"><h4>Repayment &amp; Interest</h4><p>You are given a credit line, similar to an overdraft. You only pay interest on the amount you actually withdraw, not on the full sanctioned limit. Interest is calculated daily, making it cost‑efficient if you use the facility for short periods.</p></div></div>
        <div class="step-div"></div>
        <div class="step"><div class="num">5</div><div class="st-body"><h4>Unpledge</h4><p>Once you repay the borrowed amount fully the lien is removed. Your shares are “unpledged” and returned to your Demat account, restoring full control over your portfolio.</p></div></div>
      </div>
    </div>
  </section>

  <!-- ===== Features and Benefits ===== -->
  <section class="section stack sec-light" id="sec-features" data-section="features" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">What are the Features and Benefits of LAS?</h2>
      <p class="sec-lead">A Loan Against Shares is more than just a credit facility - it’s a flexible way to unlock liquidity while keeping your portfolio intact. Here are the standout benefits you enjoy with Shriram Financial Services:</p>
    </div>
    <div class="cat-grid cat-grid-3" data-reveal-row>
      <div class="cat"><h4>Pay Interest Only on Amount Used</h4><p>Think of it like an overdraft. You’re billed daily only on the balance you actually withdraw, not on the full sanctioned limit. This keeps borrowing costs low and transparent.</p></div>
      <div class="cat"><h4>Retain Ownership of Shares</h4><p>Your shares remain yours. Even while pledged, you continue to all corporate benefits like earn dividends, bonuses, and benefit from stock splits etc. — so your portfolio keeps growing.</p></div>
      <div class="cat"><h4>Flexible Withdrawal &amp; Repayment</h4><p>Draw funds whenever you need them and repay at your convenience. There are no rigid EMI schedules, you can choose your EMI date as per your convenience giving you complete control over cash flow.</p></div>
      <div class="cat"><h4>Competitive LTV</h4><p>Borrow up to 50% of your approved equity shares’ value, in line with RBI guidelines. This ensures both safety and maximised liquidity.</p></div>
      <div class="cat"><h4>Digital Pledge Process</h4><p>No paperwork, no branch visits. Authorise pledges instantly via NSDL.e‑pledge with OTP verification — a secure, digital‑first experience.</p></div>
      <div class="cat"><h4>Share Swap Facility</h4><p>Replace pledged shares with other approved securities anytime. This flexibility helps you optimise your portfolio without breaking the loan arrangement.</p></div>
    </div>
  </section>

  <!-- ===== Eligible Securities & Approved Scrip List ===== -->
  <section class="section stack sec-tint" id="sec-securities" data-section="securities" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Eligible Securities &amp; Approved Scrip List</h2>
      <p class="sec-lead" style="color:var(--color-text-secondary)">RBI mandates that only exchange-listed, liquid, and independently-valued securities can be pledged. Below are the four main asset classes accepted, with their respective LTV ratios. Here’s a clear breakdown:</p>
    </div>
    <div class="t-scroll"><div class="product-page_table t3 bordered">
      <div class="cell th"><p>Security Type</p></div><div class="cell th"><p>LTV (Loan‑to‑Value)</p></div><div class="cell th"><p>Notes</p></div>
      <div class="cell tb"><p class="k">BSE/NSE Listed Large Cap</p></div><div class="cell tb"><p class="v">Up to 50%</p></div><div class="cell tb"><p class="v">NIFTY 50, BSE 100 constituent stocks</p></div>
      <div class="cell tb"><p class="k">Mid-Cap Equities</p></div><div class="cell tb"><p class="v">Up to 50 %</p></div><div class="cell tb"><p class="v">NIFTY Midcap 150 constituents (SEBI approved)</p></div>
      <div class="cell tb"><p class="k">Exchange-Traded Funds (ETFs)</p></div><div class="cell tb"><p class="v">Up to 50%</p></div><div class="cell tb"><p class="v">NIFTY 50 ETF, Liquid BeES,</p></div>
      <div class="cell tb"><p class="k">Sovereign Gold Bonds (SGBs) and G-Sec</p></div><div class="cell tb"><p class="v">Up to 50%</p></div><div class="cell tb"><p class="v">RBI-issued SGBs held in demat form</p></div>
    </div></div>
  </section>

  <!-- ===== Interest Rates & Fees ===== -->
  <section class="section stack sec-light" id="sec-charges" data-section="charges" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">What are the Interest Rates &amp; Fees for LAS?</h2>
      <p class="sec-lead">Understanding the applicable interest rates and charges is important before availing a Loan Against Shares (LAS). The overall cost of borrowing depends on factors such as the sanctioned limit, utilisation amount, loan tenure, and applicable fees &amp; charges</p>
      <p class="sec-lead">A key advantage of LAS is that interest is generally charged only on the amount utilised, not the entire sanctioned limit, making it a flexible financing option.</p>
    </div>
    <div class="t-scroll"><div class="product-page_table t2 bordered" style="grid-template-columns:repeat(2,minmax(0,1fr))">
      <div class="cell th"><p>Component</p></div><div class="cell th"><p>Details</p></div>
      <div class="cell tb"><p class="k">Interest Rate</p></div><div class="cell tb"><p class="v">From &lt;12% p.a.&gt; (interest charged only on the utilised amount)</p></div>
      <div class="cell tb"><p class="k">Processing Fee</p></div><div class="cell tb"><p class="v">&lt;1%&gt; of sanctioned limit + applicable taxes</p></div>
      <div class="cell tb"><p class="k">Account Maintenance Charges</p></div><div class="cell tb"><p class="v">₹ NIL per quarter / annum</p></div>
      <div class="cell tb"><p class="k">Renewal Fee</p></div><div class="cell tb"><p class="v">₹NIL per annum</p></div>
      <div class="cell tb"><p class="k">Penal Interest</p></div><div class="cell tb"><p class="v">&lt;3% X% p.a.&gt; on overdue or overdrawn amounts</p></div>
      <div class="cell tb"><p class="k">Foreclosure Charges</p></div><div class="cell tb"><p class="v">Nil</p></div>
      <div class="cell tb"><p class="k">Swap Charges</p></div><div class="cell tb"><p class="v">₹ 2000 per request</p></div>
    </div></div>
    <a class="btn-gold" href="/open-demat-account" style="align-self:center">Apply for Loan</a>
  </section>

  <!-- ===== Loan-to-Value (LTV) Ratio Explained ===== -->
  <section class="section stack sec-tint" id="sec-ltv" data-section="ltv" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Loan-to-Value (LTV) Ratio Explained</h2>
      <p class="sec-lead" style="color:var(--color-text-secondary)">The Loan-to-Value (LTV) ratio determines the maximum loan amount you can avail against the market value of your pledged shares.</p>
      <p class="sec-lead" style="color:var(--color-text-secondary)">The higher the value of your eligible securities, the higher the loan amount you may be able to access, subject to applicable regulatory guidelines.</p>
    </div>
    <div class="stack" style="gap:32px;width:100%">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">What is the LTV Ratio?</h3>
        <p class="sub-lead" style="color:var(--color-text-secondary)">The Loan-to-Value ratio measures the loan amount as a percentage of the market value of the pledged shares.</p>
        <p class="sub-lead" style="color:var(--color-text-secondary)">Formula: LTV = Loan Amount ÷ Market Value of Shares × 100 Example: ₹10L portfolio → maximum loan eligible = ₹5L .Formula: LTV = Loan Amount ÷ Market Value of Shares × 100 Example: ₹10L portfolio → maximum loan eligible = ₹5L .</p>
      </div>
    </div>
    <div class="stack" style="gap:32px;width:100%">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">Why LTV Matters?</h3>
        <p class="sub-lead" style="color:var(--color-text-secondary)">The LTV ratio helps manage risk for both borrowers and lenders. If the value of pledged shares falls significantly, the LTV ratio may  Increase beyond the permitted limit, which could trigger a margin call.</p>
      </div>
    </div>
    <div class="stack" style="gap:32px;width:100%">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">Tips to Maintain a Healthy LTV Ratio</h3>
      </div>
      <div class="card check-card">
        <div class="check-list">
          <div class="check-row"><span class="ck" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span><p class="tx">Avoid borrowing the maximum available limit.</p></div>
          <div class="check-sep"></div>
          <div class="check-row"><span class="ck" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span><p class="tx">Maintain a safety buffer for market fluctuations.</p></div>
          <div class="check-sep"></div>
          <div class="check-row"><span class="ck" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span><p class="tx">Diversify your pledged portfolio across sectors and stocks.</p></div>
          <div class="check-sep"></div>
          <div class="check-row"><span class="ck" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span><p class="tx">Regularly monitor the value of pledged securities.</p></div>
          <div class="check-sep"></div>
          <div class="check-row"><span class="ck" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span><p class="tx">Respond promptly to any margin call notifications.</p></div>
        </div>
      </div>
      <p class="sub-lead" style="color:var(--color-text-secondary)">A lower LTV ratio provides greater flexibility and protection during market volatility. Maintaining a comfortable margin buffer can help you manage your Loan Against Shares more effectively and reduce the risk of margin calls.</p>
    </div>
  </section>

  <!-- ===== Margin Call ===== -->
  <section class="section stack sec-light" id="sec-margin" data-section="margin" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Margin Call: What It Is &amp; How to Handle It?</h2>
      <p class="sec-lead">A margin call is a standard risk-management mechanism designed to protect both the borrower and the lender when market values decline. Since share prices fluctuate on real time basis, the value of your pledged collateral can decrease over time, and if it falls significantly to push your LTV below the permitted limit of 90%, the lender may issue a margin call asking you to restore the required margin within a set timeframe.</p>
    </div>
    <div class="stack" style="gap:32px;width:100%">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">What Triggers a Margin Call?</h3>
        <p class="sub-lead">A margin call may occur when:</p>
      </div>
      <ul class="bullets">
        <li>The market value of pledged shares declines substantially.</li>
        <li>The approved LTV ratio exceeds the permissible limit.</li>
        <li>Portfolio concentration or volatility increases the risk profile of the pledged securities.</li>
      </ul>
    </div>
    <div class="stack" style="gap:32px;width:100%">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">How Can You Respond to a Margin Call?</h3>
        <p class="sub-lead">There are several ways to restore the required margin and continue enjoying your credit facility:</p>
      </div>
      <div class="steps" data-reveal-row>
        <div class="step"><div class="num">1</div><div class="st-body"><h4>Pledge Additional Eligible Shares</h4><p>You can pledge additional approved securities to increase the collateral value and bring the LTV ratio back within the permitted range.</p></div></div>
        <div class="step-div"></div>
        <div class="step"><div class="num">2</div><div class="st-body"><h4>Make a Partial Loan Repayment</h4><p>Reducing the outstanding loan amount can help restore the required margin and lower your LTV ratio.</p></div></div>
        <div class="step-div"></div>
        <div class="step"><div class="num">3</div><div class="st-body"><h4>Replace Existing Securities</h4><p>Subject to lender approval, you may swap certain pledged securities with eligible shares that have a higher market value.</p></div></div>
      </div>
    </div>
    <div class="stack" style="gap:32px;width:100%">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">What Happens If You Do Not Respond?</h3>
        <p class="sub-lead">If the margin shortfall is not addressed within the specified period, the lender may invoke the pledge and sell a portion of the pledged securities to recover the shortfall and restore the required margin levels. In the event of invocation of the pledged securities, such number of shares as are required to recover the total outstanding loan amount, as on the date of invocation, shall be sold. Upon realization and appropriation of the sale proceeds towards settlement of the lender's outstanding dues, the loan account shall stand closed, and any remaining pledged shares shall be released and returned to the customer after revocation of the pledge thereon.</p>
      </div>
    </div>
    <div class="stack" style="gap:32px;width:100%">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">How to Avoid Margin Calls?</h3>
        <p class="sub-lead">While market fluctuations cannot be predicted, the following practices may help reduce the likelihood of a margin call:</p>
      </div>
    </div>
  </section>

  <!-- ===== Eligibility Criteria ===== -->
  <section class="section stack sec-tint" id="sec-eligibility" data-section="eligibility" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Eligibility Criteria for a Loan Against Shares</h2>
      <p class="sec-lead" style="color:var(--color-text-secondary)">Before applying for a Loan Against Shares, it is important to ensure that you meet the basic eligibility requirements. Eligibility for LAS is typically based on factors such as your residency status, age, Demat holdings, and the value of the securities being offer to be pledged.</p>
    </div>
    <div class="row-2" data-reveal-row>
      <div class="card check-card">
        <h4 class="ch-title">Who Can Apply for a Loan Against Shares?</h4>
        <p class="card-p" style="margin-bottom:16px">You may be eligible to apply if you meet the following criteria:</p>
        <div class="check-list">
          <div class="check-row"><span class="ck" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span><p class="tx">Indian resident individual — Salaried / Self-employed / Professional / Business owner</p></div>
          <div class="check-sep"></div>
          <div class="check-row"><span class="ck" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span><p class="tx">Age: 21–70years</p></div>
          <div class="check-sep"></div>
          <div class="check-row"><span class="ck" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span><p class="tx">Active Demat account ( or NSDL)</p></div>
          <div class="check-sep"></div>
          <div class="check-row"><span class="ck" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span><p class="tx">Approved shares with minimum portfolio value of ₹[XX] lakh – Min value of 50K and having atleast 3 scrips to be offered for pledge.</p></div>
          <div class="check-sep"></div>
          <div class="check-row"><span class="ck" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span><p class="tx">CIBIL score: 400+ preferred</p></div>
          <div class="check-sep"></div>
          <div class="check-row"><span class="ck" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span><p class="tx">Valid KYC: Aadhaar + PAN</p></div>
        </div>
      </div>
      <div class="card check-card">
        <h4 class="ch-title">Who May Not Be Eligible?</h4>
        <p class="card-p" style="margin-bottom:16px">The following applicants may not qualify for a standard Loan Against Shares facility:</p>
        <div class="check-list">

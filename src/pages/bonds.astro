---
/**
 * Bonds - /bonds/
 * Long-form bond-investing guide. Built entirely from the shared design-system
 * components in global.css (hero, .section/.sec-title, .card, .product-page_table,
 * .risks, .steps, FaqAccordion, .cta-box). The only page-scoped CSS is a generic
 * responsive card grid (.bond-cards) and a glossary list (.gloss) - both token-bound.
 * Content implemented verbatim from the compliance-approved doc (V3, July 06).
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/site/Breadcrumb.astro';
import FaqAccordion from '../components/sections/FaqAccordion.astro';
import { faqPageSchema, breadcrumbSchema, organizationSchema } from '../lib/seo';

// Key terms to know - term + definition (verbatim).
const TERMS = [
  {
    t: 'Face Value',
    d: 'The principal amount of the bond, typically ₹1,000 per bond for Indian retail bonds, which is repaid to the investor at maturity.',
  },
  {
    t: 'Coupon Rate',
    d: 'The annual interest rate the issuer pays, expressed as a percentage of the face value. A 7% coupon on a ₹1,000 bond pays ₹70 per year.',
  },
  {
    t: 'Maturity Date',
    d: 'The date on which the bond expires and the issuer repays the principal. Bond tenures in India range from a few months to 40+ years (G-Secs).',
  },
  {
    t: 'Yield to Maturity (YTM)',
    d: 'The total annualised return you earn if you hold the bond to maturity, accounting for coupon payments and any difference between purchase price and face value.',
  },
  {
    t: 'Credit Rating',
    d: "Assigned by agencies such as CRISIL, ICRA, or CARE, it indicates the issuer's ability to repay. AAA is the highest (lowest risk); D denotes default.",
  },
];

// Types of bonds in India (verbatim).
const TYPES = [
  {
    h: 'Government Bonds (G-Secs)',
    p: 'Issued by the central government, these are generally considered among the lower-risk bond options in India because they carry sovereign backing.',
  },
  {
    h: 'Treasury Bills (T-Bills)',
    p: 'These are short-term government securities issued at a discount and redeemed at face value on maturity. Since they do not usually pay periodic coupon interest, the return comes from the difference between the purchase price and the redemption value.',
  },
  {
    h: 'Corporate Bonds',
    p: 'These are issued by companies to raise capital. These can vary widely in credit quality, coupon structure, and tenure.',
  },
  {
    h: 'Non-Convertible Debentures (NCDs)',
    p: 'These are debt instruments issued by companies with a fixed maturity and interest payout structure. They should be assessed carefully for issuer quality, rating, and liquidity.',
  },
  {
    h: 'Municipal bonds and PSU bonds',
    p: 'Municipal bonds are issued by urban local bodies for public infrastructure funding, while PSU bonds are issued by public sector undertakings.',
  },
  {
    h: 'State Development Loans (SDLs)',
    p: 'Issued by state governments, these have slightly higher yields than central G-Secs, with quasi-sovereign backing.',
  },
  {
    h: 'Infrastructure Bonds (54EC)',
    p: 'These are issued by organisations such as NHAI and REC and can help investors save tax on long-term capital gains from the sale of property.',
  },
  {
    h: 'Floating Rate Bonds',
    p: 'Bonds where the interest (coupon) rate is not fixed, but changes periodically based on a predetermined benchmark market rate. RBI issues floating rate savings bonds for retail investors.',
  },
  {
    h: 'Bond ETFs',
    p: 'These are exchange-traded funds that invest in a basket of bonds. They offer a simple way to access the bond market without buying individual bonds.',
  },
  {
    h: 'Debt Mutual Funds',
    p: 'These invest in debt instruments such as government securities, corporate bonds and treasury bills. They can be suitable for investors looking for diversified fixed income exposure.',
  },
];

// Risk factors table - risk / meaning / mitigation (verbatim).
const RISK_ROWS = [
  {
    k: 'Interest Rate Risk',
    m: 'Bond prices may fall when interest rates rise and may increase when rates decline. Longer-duration bonds are generally more sensitive to interest rate changes.',
    x: 'Prefer shorter-duration bonds in rising-rate environments.',
  },
  {
    k: 'Credit or Default Risk',
    m: "The issuer may delay interest payments or fail to repay the principal on time. Credit rating agencies can help assess the issuer's creditworthiness.",
    x: 'Stick to AAA/AA-rated bonds; check CRISIL/ICRA ratings before investing.',
  },
  {
    k: 'Liquidity Risk',
    m: 'Some bonds may be difficult to buy or sell quickly at a fair market price.',
    x: 'Invest via liquid bond mutual funds or buy bonds you are comfortable holding to maturity.',
  },
  {
    k: 'Inflation Risk',
    m: "Rising inflation can reduce the real value of a bond's returns over time.",
    x: 'Consider inflation-indexed bonds or floating rate bonds to hedge inflation risk.',
  },
];

// How to evaluate a bond - four parameters (verbatim).
const EVALUATE = [
  {
    h: 'Credit Rating and Issuer Profile',
    p: "Check the latest CRISIL/ICRA/CARE rating to understand the issuer's business strength, debt servicing ability, profitability, leverage, and any recent developments that may affect repayment capacity. If the bond has protective terms such as covenants, investors should understand what those conditions mean and how they may influence risk.",
  },
  {
    h: 'Yield Metrics',
    p: 'The coupon rate alone does not show the full return picture. Investors should look at current yield, which relates the annual coupon to the current market price, and yield to maturity (YTM), which captures the total return if the bond is held until maturity and all payments are made as scheduled.',
  },
  {
    h: 'Tenor or Maturity Period',
    p: "A bond with a longer tenor may offer a different risk-return profile than a shorter-term bond. Investors should align the bond's maturity with their cash flow needs, rate outlook, and overall asset allocation strategy.",
  },
  {
    h: 'Callable and Puttable Features',
    p: 'A callable bond gives the issuer the right to repay the bond before maturity, which may affect return expectations if rates fall. A puttable bond gives the investor the right to sell the bond back to the issuer under specified conditions, which may add flexibility in some cases.',
  },
];

// Six-step process to invest via the secondary market (verbatim).
const STEPS = [
  { h: 'Download and Register on the app', p: 'Download Shriram Financial Services’ “Antara” app and get registered.' },
  { h: 'Complete KYC', p: 'Complete the eKYC formalities as per the instructions shared in the app.' },
  { h: 'Activate your trading account', p: 'Link your bank account and demat account.' },
  { h: 'Browse available bonds on the platform', p: 'Explore Government Securities, listed corporate NCDs, SGBs, and tax-free bonds by issuer, tenure, and yield.' },
  { h: 'Place a buy order', p: 'For listed bonds, place a market or limit order on NSE/BSE.' },
  { h: 'Track coupon payments and maturity via the app', p: 'Monitor coupon credits to your bank account and upcoming maturity dates in the dashboard.' },
];

// Bond investment strategies (verbatim).
const STRATEGIES = [
  {
    h: 'Bond Laddering',
    p: 'Bond laddering involves investing in bonds with different maturity dates instead of putting all your money into one. As bonds mature over time, the proceeds can be reinvested, helping manage liquidity and interest rate risk.',
  },
  {
    h: 'Barbell Strategy',
    p: 'A barbell strategy splits investments between short-term and long-term bonds, with limited allocation to medium-term bonds. This can help balance liquidity from shorter-term holdings with return potential from longer-duration bonds.',
  },
  {
    h: 'Bullet Strategy',
    p: 'A bullet strategy focuses on investing in bonds that mature around the same time or within a narrow maturity range. It can be useful for investors planning for a specific financial goal or cash requirement in the future.',
  },
  {
    h: 'Income-focused and Total-return Strategy',
    p: 'An income-focused strategy prioritises regular coupon payouts and relatively steady cash flows. A total-return strategy looks at both interest income and price appreciation opportunities based on market movements.',
  },
  {
    h: 'Duration Management',
    p: "Duration management helps investors adjust their portfolio's sensitivity to interest rate changes. Shorter-duration bonds may help reduce volatility in a rising-rate environment, while longer-duration bonds may benefit more when rates decline.",
  },
];

// Risks and warning signs in bonds (verbatim).
const WARNINGS = [
  {
    h: 'Rating Downgrade',
    p: "If a company's financial health weakens, its bond rating may be revised downward by rating agencies. A downgrade can affect investor confidence, reduce demand for the bond, and lead to price declines in the secondary market. Monitoring issuer announcements, financial results, and rating updates is therefore important for ongoing bond review.",
  },
  {
    h: 'Liquidity and Exit Risk',
    p: 'In stressed market conditions, even bonds from known issuers may become difficult to sell at the expected price. Lower secondary market depth can widen spreads and reduce exit flexibility, especially in lower-rated or less frequently traded bonds.',
  },
  {
    h: 'High Coupon Rates',
    p: "A very high coupon almost always signals higher credit risk. Do not chase yield without verifying the issuer's rating, financial health, and repayment track record. Several high-yield NCDs have defaulted in the past.",
  },
  {
    h: 'Capital Loss Risk',
    p: 'If a bond is bought above its face value, the actual return may be lower than the coupon rate. This is why Yield to Maturity (YTM) is a better measure of returns than the coupon alone.',
  },
  {
    h: 'Promoter background and financials',
    p: "For corporate NCDs, read the issuer's latest annual report and credit rating rationale. Verify debt-to-equity, interest coverage, and cash flow; these are the key signals of a bond issuer's ability to repay.",
  },
  {
    h: 'Warning Signs to Watch in Bond Issuers',
    p: 'Investors should also watch for signs such as a sudden increase in borrowing, deteriorating cash flows, weak interest coverage, delayed disclosures, governance concerns, or repeated refinancing pressure at the issuer level.',
  },
];

// Got Questions? - the first 6 FAQs from the compliance doc (display cap; the
// remainder was stripped and can be restored from the doc if needed). Feeds both
// the accordion and the FAQPage JSON-LD, so markup and schema cannot drift.
const FAQS = [
  {
    q: 'What is a bond?',
    a: 'A bond is a debt instrument through which you lend money to a government body or company for a fixed period. In return, the issuer may pay periodic interest and repay the principal on maturity.',
  },
  {
    q: 'How do bonds generate returns?',
    a: 'Bonds can generate returns through periodic coupon payments and, in some cases, through price appreciation if the bond is sold in the secondary market at a higher price than the purchase price.',
  },
  {
    q: 'What is the difference between coupon rate and yield to maturity?',
    a: "The coupon rate is the fixed interest rate on the bond's face value. Yield to maturity, or YTM, is a broader return measure that considers the bond's market price, coupon payments, and redemption value if held till maturity.",
  },
  {
    q: 'What are the main types of bonds in India?',
    a: 'Common bond categories in India include government bonds, treasury bills, sovereign gold bonds, corporate bonds, PSU bonds, municipal bonds, and NCDs. Investors can also access debt exposure through Bond ETFs and debt mutual funds.',
  },
  {
    q: 'Are government bonds safer than corporate bonds?',
    a: 'Government bonds are generally viewed as lower-risk because they are backed by the sovereign issuer. Corporate bonds may offer different return opportunities but typically require closer evaluation of credit quality and issuer strength.',
  },
  {
    q: 'How can I invest in bonds in India?',
    a: 'You can invest in bonds through the secondary market, approved investing platforms, brokers, and demat-linked channels. You may also invest indirectly through debt mutual funds and Bond ETFs.',
  },
];

const site = Astro.site!.href;

const seo = {
  title: 'Invest in Bonds & Debentures',
  description:
    'Invest in government and corporate bonds for stable, predictable fixed-income returns with lower risk, via Shriram Financial Services.',
  path: '/bonds/',
  jsonLd: [
    faqPageSchema(FAQS.map((f) => ({ question: f.q, answer: f.a }))),
    breadcrumbSchema(
      [
        { name: 'Home', path: '/' },
        { name: 'Products', path: '/products/' },
        { name: 'Bonds', path: '/bonds/' },
      ],
      site
    ),
    organizationSchema(site),
  ],
};
---

<BaseLayout seo={seo} mainClass="rev-rise-scale">
  <!-- ===== Hero ===== -->
  <section class="hero" id="sec-hero" data-section="hero">
    <Breadcrumb trail={[{ name: 'Products', href: '/products/' }, { name: 'Bonds' }]} />
    <div class="hero-inner" data-enter>
      <h1>Grow Your Wealth Steadily with <span class="g">Bonds</span></h1>
      <p class="lead">Understand bond types, returns, risks and investment strategies to make informed fixed-income decisions.</p>
      <div class="cta"><a class="btn-gold" href="/open-demat-account/">Open Demat Account</a></div>
    </div>
  </section>

  <!-- ===== Bonds: Balance Growth with Stability ===== -->
  <section class="section stack sec-light" id="sec-about" data-section="about" data-enter="2" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Bonds: Balance Growth with Stability</h2>
      <p class="sec-lead">Bonds offer a disciplined way to diversify your portfolio while earning predictable income across different investment options. Shriram Financial Services gives you access to explore government securities, PSU and corporate bonds, and tax-free instruments, each with transparent yield and rating information laid out before you commit. It is fixed income investing built for people who already know what they want and simply need a faster, cleaner way to get there.</p>
    </div>
    <div class="stack" style="gap:32px">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">Key terms to know:</h3>
      </div>
      <div class="card">
        <dl class="gloss">
          {TERMS.map((t) => (
            <div><dt>{t.t}</dt><dd>{t.d}</dd></div>
          ))}
        </dl>
      </div>
    </div>
  </section>

  <!-- ===== Types of Bonds in India ===== -->
  <section class="section stack sec-tint" id="sec-types" data-section="types" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Types of Bonds in India</h2>
      <p class="sec-lead" style="color:var(--color-text-secondary)">The Indian bond market offers multiple fixed income instruments for different investment needs, risk profiles, and time horizons. Here are a few:</p>
    </div>
    <div class="bond-cards cols-2" data-reveal-row>
      {TYPES.map((c) => (
        <div class="card"><h4 class="card-h">{c.h}</h4><p class="card-p">{c.p}</p></div>
      ))}
    </div>
    <a class="btn-gold" href="/open-demat-account/" style="align-self:center">Open Demat Account</a>
  </section>

  <!-- ===== Risk Factors in Bonds ===== -->
  <section class="section stack sec-light" id="sec-risks" data-section="risks" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Risk Factors in Bonds</h2>
      <p class="sec-lead">As with any investment option, bonds also involve risks. Understanding these is important for anyone investing in bonds in India.</p>
    </div>
    <div class="t-scroll"><div class="product-page_table t3 bordered">
      <div class="cell th"><p>Risk Factors</p></div><div class="cell th"><p>What It Means</p></div><div class="cell th"><p>Mitigation Approach</p></div>
      {RISK_ROWS.map((r) => (
        <>
          <div class="cell tb"><p class="k">{r.k}</p></div>
          <div class="cell tb"><p class="v">{r.m}</p></div>
          <div class="cell tb"><p class="v">{r.x}</p></div>
        </>
      ))}
    </div></div>
  </section>

  <!-- ===== How to Evaluate a Bond? ===== -->
  <section class="section stack sec-tint" id="sec-evaluate" data-section="evaluate" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">How to Evaluate a Bond?</h2>
      <p class="sec-lead" style="color:var(--color-text-secondary)">Before investing, it is important to evaluate a bond beyond its coupon rate. Here are four parameters to evaluate a bond:</p>
    </div>
    <div class="risks" data-reveal-row>
      {EVALUATE.map((e) => (
        <div class="risk"><h4>{e.h}</h4><p>{e.p}</p></div>
      ))}
    </div>
  </section>

  <!-- ===== How to Invest in Bonds in India? ===== -->
  <section class="section stack sec-light" id="sec-invest" data-section="invest" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">How to Invest in Bonds in India?</h2>
      <p class="sec-lead">Investment in bonds in the secondary market through Shriram Financial Services can be completed in a few steps, which are:</p>
    </div>
    <div class="stack" style="gap:32px;width:100%">
      <div class="steps" data-reveal-row>
        {STEPS.slice(0, 3).map((s, i) => (
          <>
            {i > 0 && <div class="step-div" />}
            <div class="step"><div class="num">{i + 1}</div><div class="st-body"><h4>{s.h}</h4><p>{s.p}</p></div></div>
          </>
        ))}
      </div>
      <div class="steps" data-reveal-row>
        {STEPS.slice(3).map((s, i) => (
          <>
            {i > 0 && <div class="step-div" />}
            <div class="step"><div class="num">{i + 4}</div><div class="st-body"><h4>{s.h}</h4><p>{s.p}</p></div></div>
          </>
        ))}
      </div>
    </div>
    <a class="btn-gold" href="/open-demat-account/" style="align-self:center">Start Investing in Bonds</a>
  </section>

  <!-- ===== Bond Investment Strategies ===== -->
  <section class="section stack sec-tint" id="sec-strategies" data-section="strategies" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Bond Investment Strategies</h2>
      <p class="sec-lead" style="color:var(--color-text-secondary)">A bond portfolio works best when it is aligned with your investment horizon, cash flow needs, and interest-rate outlook. Instead of buying bonds randomly, investors can use structured bond investment strategies, such as the ones listed below, to manage risk and improve portfolio efficiency.</p>
    </div>
    <div class="bond-cards" data-reveal-row>
      {STRATEGIES.map((s) => (
        <div class="card"><h4 class="card-h">{s.h}</h4><p class="card-p">{s.p}</p></div>
      ))}
    </div>
  </section>

  <!-- ===== What are the Risks and Warning Signs in Bonds? ===== -->
  <section class="section stack sec-light" id="sec-warnings" data-section="warnings" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">What are the Risks and Warning Signs in Bonds?</h2>
    </div>
    <div class="bond-cards" data-reveal-row>
      {WARNINGS.map((w) => (
        <div class="card"><h4 class="card-h">{w.h}</h4><p class="card-p">{w.p}</p></div>
      ))}
    </div>
    <p class="sec-lead">The right approach is to treat bonds as instruments that still require research, diversification, and periodic monitoring. A bond portfolio should be built with attention to credit quality, duration, liquidity, and suitability for your financial goals.</p>
  </section>

  <!-- ===== Got Questions? (General Questions) ===== -->
  <section class="faq-wrap sec-tint" id="sec-faq" data-section="faq">
    <div class="faq-cols">
      <div class="faq-left">
        <h2 class="faq-title">Got Questions?</h2>
        <FaqAccordion faqs={FAQS} />
      </div>
      <div class="faq-side">
        <div class="usr"><img src="/assets/user.svg" alt="" /></div>
        <div class="side-in">
          <div class="side-tx">
            <h3>Need A Clearer Direction?</h3>
            <p>Let's get in touch on a 15-minute call where we can answer any questions you may have. Our advisor will help map your wealth mix and show what a dedicated, research-led plan would do differently.</p>
          </div>
          <a class="btn-gold" href="/contact-us/">Book A Discovery Call</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ===== bonds - page-specific only ===== */

  /* Generic responsive card grid for the types / strategies / warning-sign
     card sets (the shared .row-2 is 2-up and .cat-grid's border math is tuned
     for 8 cells; this handles arbitrary counts). Values are on the 8px grid. */
  .bond-cards {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 24px;
    align-items: stretch;
  }
  .bond-cards .card {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  /* Two-column variant - `.bond-cards cols-2` (Types of Bonds). Only the desktop
     template differs; tablet already reflows to 2-up. Note the mobile reset below:
     this selector (0,2,0) outranks the bare `.bond-cards` (0,1,0) in the 560px
     query, so without it the grid would refuse to stack. */
  .bond-cards.cols-2 {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  /* Key-terms glossary - a definition list inside a shared .card. */
  .gloss {
    margin: 0;
    display: flex;
    flex-direction: column;
  }
  .gloss > div {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 24px 0;
    border-top: 1px solid var(--color-border-hairline);
  }
  .gloss > div:first-child {
    padding-top: 0;
    /* The row separator is a border-top on every row; the first row has no row
       above it, so its border would paint a stray hairline across the card. */
    border-top: 0;
  }
  .gloss > div:last-child {
    padding-bottom: 0;
  }
  .gloss dt {
    font-weight: 500;
    font-size: 16px;
    color: var(--color-text-primary);
  }
  .gloss dd {
    margin: 0;
    font-weight: 400;
    font-size: 16px;
    color: var(--color-text-tertiary);
  }

  @media (max-width: 1024px) {
    .bond-cards {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  @media (max-width: 768px) {
    .gloss dt,
    .gloss dd {
      font-size: 14px;
    }
  }
  @media (max-width: 560px) {
    .bond-cards,
    .bond-cards.cols-2 {
      grid-template-columns: 1fr;
    }
  }
</style>

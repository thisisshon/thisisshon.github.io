---
/**
 * Commodities - /commodities/
 * Long-form commodity-trading guide. Built entirely from the shared design-system
 * components in global.css (hero, .section/.sec-title, .card, .cat-grid, .bullets,
 * .product-page_table, .steps, .approaches, FaqAccordion, .cta-box). The only
 * page-scoped CSS is a generic responsive card grid (.comm-cards) - token-bound.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/site/Breadcrumb.astro';
import FaqAccordion from '../components/sections/FaqAccordion.astro';
import { faqPageSchema, breadcrumbSchema, organizationSchema } from '../lib/seo';

// Got Questions? - the first 6 FAQs from the compliance doc (display cap; the
// remainder was stripped and can be restored from the doc if needed). Feeds both
// the accordion and the FAQPage JSON-LD, so markup and schema cannot drift.
const FAQS = [
  {
    q: 'What is commodity trading in India?',
    a: 'Commodity trading involves buying and selling contracts linked to commodities such as gold, silver, crude oil, natural gas, copper etc on recognised exchanges like MCX and NCDEX. Traders seek to benefit from price movements without necessarily taking physical delivery of the commodity.',
  },
  {
    q: 'Is commodity trading legal in India?',
    a: 'Yes. Commodity trading is completely legal in India when conducted through SEBI-regulated brokers and recognised exchanges such as MCX and NCDEX.',
  },
  {
    q: 'How much money do I need to start commodity trading?',
    a: 'The capital required depends on the commodity and contract size. Some commodity contracts may require margins starting from a few thousand rupees, while larger contracts may require higher margins.',
  },
  {
    q: 'Which commodities are most commonly traded in India?',
    a: 'Gold, silver, crude oil, natural gas, copper, zinc, aluminium and cotton commodities are among the most actively traded commodities in India.',
  },
  {
    q: 'What is the difference between commodity futures and options?',
    a: 'A futures contract creates an obligation to buy or sell a commodity at a future date, while an options contract gives the buyer the right, but not the obligation, to buy or sell the commodity.',
  },
  {
    q: 'Can beginners trade commodities?',
    a: 'Yes. Beginners can start with liquid commodities such as gold and silver while learning market fundamentals and using proper risk-management techniques.',
  },
];

const site = Astro.site!.href;

const seo = {
  title: 'Commodity Trading - MCX',
  description:
    'Trade gold, silver & crude oil on MCX with live commodity prices, expert insights and secure execution with Shriram Financial Services',
  path: '/commodities',
  jsonLd: [
    faqPageSchema(FAQS.map((f) => ({ question: f.q, answer: f.a }))),
    breadcrumbSchema(
      [
        { name: 'Home', path: '/' },
        { name: 'Products', path: '/products' },
        { name: 'Commodities', path: '/commodities' },
      ],
      site
    ),
    organizationSchema(site),
  ],
};
---

<BaseLayout seo={seo} mainClass="rev-rise-scale">
  <!-- ===== Hero ===== -->
  <section class="hero" id="sec-hero" data-section="hero">
    <Breadcrumb trail={[{ name: 'Products', href: '/products' }, { name: 'Commodities' }]} />
    <div class="hero-inner" data-enter>
      <h1>Trade Commodities with Confidence — Gold, Silver, Crude &amp; More</h1>
      <p class="lead">Trade India's top commodities like gold, silver, crude oil, and other products on trusted MCX exchanges — diversify your portfolio, hedge inflation, and capture market opportunities.</p>
      <div class="cta"><a class="btn-gold" href="/opendemataccount">Open Demat Account</a></div>
    </div>
  </section>

  <!-- ===== Commodities: A Smart Trading choice ===== -->
  <section class="section stack sec-light" id="sec-about" data-section="about" data-enter="2" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Commodities: A Smart Trading choice</h2>
      <p class="sec-lead">Commodity trading lets you trade in assets like gold, silver, crude oil and more while benefiting from market price movements. It can also help hedge against inflation and market volatility. With Shriram Financial Services, you can trade commodities seamlessly using a secure platform, real-time market insights, advanced trading tools and advisory support to guide your positions.</p>
    </div>
  </section>

  <!-- ===== Types of Commodity in India ===== -->
  <section class="section stack sec-tint" id="sec-types" data-section="types" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Types of Commodity in India</h2>
      <p class="sec-lead" style="color:var(--color-text-secondary)">India's commodity markets span five major categories traded across MCX. Each segment has distinct exchanges, lot sizes, and price drivers. The main type of commodity is :</p>
    </div>
    <div class="stack" style="gap:32px">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">Hard Commodities</h3>
        <p class="sub-lead" style="color:var(--color-text-secondary)">Hard commodities are natural resources such as metals and energy products that are mined or extracted from the earth, including gold, silver, copper, crude oil, and natural gas.</p>
      </div>
      <div class="comm-cards" data-reveal-row>
        <div class="card">
          <h4 class="card-h">Industrial Metals</h4>
          <p class="card-p">Metals used in construction, manufacturing, engineering, and other industries.</p>
          <p class="card-p">Examples: Copper, Aluminium, Zinc, Lead, Nickel</p>
        </div>
        <div class="card">
          <h4 class="card-h">Precious Metals</h4>
          <p class="card-p">Rare and highly valuable metals used as a store of value and in jewellery.</p>
          <p class="card-p">Examples: Gold, Silver, Platinum, Palladium</p>
        </div>
        <div class="card">
          <h4 class="card-h">Energy</h4>
          <p class="card-p">Fuel and energy resources that power industries and economies.</p>
          <p class="card-p">Examples: Crude Oil, Natural Gas.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Why Should You Invest in Commodity? ===== -->
  <section class="section stack sec-light" id="sec-why" data-section="why" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Why Should You Invest in Commodity?</h2>
      <p class="sec-lead">Investors choose commodities for diversification, inflation hedge, global exposure, leverage opportunities, and volatility benefits. Learn the key benefits of adding commodities to your investment portfolio.</p>
    </div>
    <div class="cat-grid cat-grid-3" data-reveal-row>
      <div class="cat"><h4>Portfolio Diversification</h4><p>Low correlation with other asset classes helps reduce overall portfolio risk and volatility.</p></div>
      <div class="cat"><h4>Inflation Hedge</h4><p>Commodity prices tend to rise during inflation, protecting your purchasing power.</p></div>
      <div class="cat"><h4>Global Exposure</h4><p>Gain exposure to worldwide demand across industries and benefit from global market trends.</p></div>
      <div class="cat"><h4>Trading Opportunities</h4><p>Frequent price fluctuations create opportunities to generate returns in the short term.</p></div>
      <div class="cat"><h4>Leverage Efficiency</h4><p>Use margin to control larger positions with smaller capital, enhancing potential returns.</p></div>
      <div class="cat"><h4>Risk Balancing</h4><p>Commodities can offset losses in other asset classes during uncertain market conditions.</p></div>
    </div>
    <a class="btn-gold" href="/opendemataccount" style="align-self:center">Open Commodity Trading Account</a>
  </section>

  <!-- ===== Advantages of Commodity Trading ===== -->
  <section class="section stack sec-tint" id="sec-advantages" data-section="advantages" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Advantages of Commodity Trading</h2>
      <p class="sec-lead" style="color:var(--color-text-secondary)">Commodity trading offers a range of benefits, providing traders and investors with opportunities to participate in diverse market segments through a regulated and transparent trading environment.</p>
    </div>
    <div class="cat-grid cat-grid-3" data-reveal-row>
      <div class="cat"><h4>High Liquidity</h4><p>High trading volumes in major commodities ensure easy entry and exit.</p></div>
      <div class="cat"><h4>Transparent Pricing</h4><p>Prices are determined by global demand and supply, ensuring fairness and transparency.</p></div>
      <div class="cat"><h4>Standardised Contracts</h4><p>Exchange-traded contracts are uniform, reducing complexity in execution.</p></div>
      <div class="cat"><h4>Real Asset Backing</h4><p>Commodities are tangible assets with intrinsic value like gold, oil, and metals.</p></div>
      <div class="cat"><h4>Wide Market Access</h4><p>Trade a wide range of commodities across reputable exchanges such as MCX.</p></div>
      <div class="cat"><h4>Regulated Trading</h4><p>Trading on regulated exchanges ensures safety, compliance, and transparency.</p></div>
    </div>
    <a class="btn-gold" href="/opendemataccount" style="align-self:center">Start Commodity Trading</a>
  </section>

  <!-- ===== Disadvantages of Commodity Trading ===== -->
  <section class="section stack sec-light" id="sec-disadvantages" data-section="disadvantages" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Disadvantages of Commodity Trading</h2>
      <p class="sec-lead">While commodity trading offers numerous opportunities, it also carries certain risks that traders should understand before participating in the market.</p>
    </div>
    <div class="cat-grid cat-grid-3" data-reveal-row>
      <div class="cat"><h4>Price Volatility</h4><p>Commodity prices can fluctuate significantly due to changes in global demand and supply, geopolitical events, weather conditions, and economic developments.</p></div>
      <div class="cat"><h4>Leverage Risk</h4><p>Commodity trading often involves margin-based trading, where a small price movement can result in substantial gains or losses.</p></div>
      <div class="cat"><h4>Market Complexity</h4><p>Commodity markets are influenced by multiple factors, including international events, inventory levels, currency movements, and government policies, making them challenging for inexperienced traders.</p></div>
      <div class="cat"><h4>Margin Calls</h4><p>If the market moves against your position, you may be required to deposit additional funds to maintain the trade, failing which your position may be squared off.</p></div>
      <div class="cat"><h4>Global Event Sensitivity</h4><p>Commodity prices can react sharply to geopolitical tensions, natural disasters, production disruptions, and policy changes across the world.</p></div>
      <div class="cat"><h4>Limited Knowledge Risk</h4><p>Trading without a proper understanding of commodity markets, contract specifications, and risk management strategies can increase the likelihood of losses.</p></div>
    </div>
  </section>

  <!-- ===== How does Commodity Trading Works? ===== -->
  <section class="section stack sec-tint" id="sec-how-works" data-section="how-works" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">How does Commodity Trading Works?</h2>
      <p class="sec-lead" style="color:var(--color-text-secondary)">Commodity trading facilitates the exchange of physical goods such as metals and energy resources. It operates through structured platforms and mechanisms such as MCX, offering investment opportunities while managing market risks.</p>
      <p class="sec-lead" style="color:var(--color-text-secondary)">Commodity trading in India happens through exchange-traded futures and options contracts. When you buy a crude oil futures contract on MCX, you agree to buy a fixed quantity (100 barrels) at a predetermined price on a specific expiry date. Most retail traders square off positions before expiry, settling in cash rather than taking physical delivery.</p>
    </div>
    <div class="stack" style="gap:32px">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">Multi Commodity Exchange (MCX)</h3>
        <p class="sub-lead" style="color:var(--color-text-secondary)">MCX (Multi Commodity Exchange) is an electronic platform where traders and investors buy and sell commodity derivative contracts (such as futures and options), rather than the physical commodities themselves. It is primarily used for metals (gold, silver), energy (crude oil, natural gas). Trading runs from 9:00 AM to 11:55 PM IST, also 9:00am – 11:30pm (for 6 months) mirroring international market hours including the US trading session.</p>
      </div>
    </div>
  </section>

  <!-- ===== Commodity Futures Vs Options — Key Differences ===== -->
  <section class="section stack sec-light" id="sec-futures-options" data-section="futures-options" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Commodity Futures Vs Options — Key Differences</h2>
      <p class="sec-lead">Commodity derivatives are primarily traded through Futures and Options contracts. While both allow traders to participate in commodity price movements without owning the physical commodity, they work differently and serve different trading objectives.</p>
      <p class="sec-lead">Understanding the difference between Commodity Futures and Commodity Options can help you choose the right instrument based on your trading style, risk appetite, and market outlook.</p>
    </div>
    <div class="t-scroll"><div class="product-page_table t3 bordered" style="min-width:640px">
      <div class="cell th"><p>Feature</p></div><div class="cell th"><p>Commodity Futures</p></div><div class="cell th"><p>Commodity Options</p></div>
      <div class="cell tb"><p class="k">Contract Nature</p></div><div class="cell tb"><p class="v">Obligation to buy or sell</p></div><div class="cell tb"><p class="v">Right, not obligation</p></div>
      <div class="cell tb"><p class="k">Upfront Cost</p></div><div class="cell tb"><p class="v">Margin required</p></div><div class="cell tb"><p class="v">Premium paid</p></div>
      <div class="cell tb"><p class="k">Risk for Buyer</p></div><div class="cell tb"><p class="v">Potentially unlimited</p></div><div class="cell tb"><p class="v">Limited to premium paid</p></div>
      <div class="cell tb"><p class="k">Profit Potential</p></div><div class="cell tb"><p class="v">Unlimited</p></div><div class="cell tb"><p class="v">Significant but dependent on premium and time value</p></div>
      <div class="cell tb"><p class="k">Leverage</p></div><div class="cell tb"><p class="v">High</p></div><div class="cell tb"><p class="v">Moderate to High</p></div>
      <div class="cell tb"><p class="k">Time Decay</p></div><div class="cell tb"><p class="v">Not applicable</p></div><div class="cell tb"><p class="v">Option value declines as expiry approaches</p></div>
      <div class="cell tb"><p class="k">Complexity</p></div><div class="cell tb"><p class="v">Relatively straightforward</p></div><div class="cell tb"><p class="v">Requires understanding of strike prices and premiums</p></div>
      <div class="cell tb"><p class="k">Suitable For</p></div><div class="cell tb"><p class="v">Active traders and hedgers</p></div><div class="cell tb"><p class="v">Beginners, hedgers, and strategy traders</p></div>
      <div class="cell tb"><p class="k">Settlement</p></div><div class="cell tb"><p class="v">Mandatory settlement at expiry</p></div><div class="cell tb"><p class="v">Exercise only if beneficial</p></div>
      <div class="cell tb"><p class="k">Capital Requirement</p></div><div class="cell tb"><p class="v">Higher</p></div><div class="cell tb"><p class="v">Lower</p></div>
    </div></div>
  </section>

  <!-- ===== How to Start Trading with Commodities? ===== -->
  <section class="section stack sec-tint" id="sec-start" data-section="start" style="gap:56px;align-items:center;justify-content:center">
    <div class="stack" style="gap:16px;width:100%">
      <h2 class="sec-title">How to Start Trading with Commodities?</h2>
      <p class="sec-lead" style="color:var(--color-text-secondary)">To start trading with commodities, follow these 5 easy steps to open your account, activate the commodity segment, and begin trading on regulated exchanges.</p>
    </div>
    <div class="steps" data-reveal-row>
      <div class="step">
        <div class="num">1</div>
        <div class="st-body"><h4>Open Account Online</h4><p>Fill in your basic details through “Open an account” link. No paperwork or branch visit required.</p></div>
      </div>
      <div class="step-div"></div>
      <div class="step">
        <div class="num">2</div>
        <div class="st-body"><h4>Complete KYC</h4><p>Upload PAN, Aadhaar, and a cancelled cheque. Video-based in-person verification (IPV) is done instantly.</p></div>
      </div>
      <div class="step-div"></div>
      <div class="step">
        <div class="num">3</div>
        <div class="st-body"><h4>Activate MCX</h4><p>Request commodity segment activation from your client dashboard.</p></div>
      </div>
      <div class="step-div"></div>
      <div class="step">
        <div class="num">4</div>
        <div class="st-body"><h4>Add Funds</h4><p>Transfer money via UPI, NEFT, or net banking.</p></div>
      </div>
      <div class="step-div"></div>
      <div class="step">
        <div class="num">5</div>
        <div class="st-body"><h4>Place First Trade</h4><p>Search for a commodity contract, check margin requirements, and place a buy or sell futures order.</p></div>
      </div>
    </div>
    <a class="btn-gold" href="/opendemataccount" style="align-self:center">Open Demat Account</a>
  </section>

  <!-- ===== SEBI Rules & Regulations ===== -->
  <section class="section stack sec-light" id="sec-sebi" data-section="sebi" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">SEBI Rules &amp; Regulations for Commodity Trading in India</h2>
    </div>
    <div class="cat-grid cat-grid-3" data-reveal-row>
      <div class="cat"><h4>SEBI Regulation</h4><p>Commodity trading is regulated by SEBI, ensuring fair, transparent, and safe market practices.</p></div>
      <div class="cat"><h4>KYC &amp; PAN Mandatory</h4><p>Every trader must complete KYC verification and provide a valid PAN card before opening an account.</p></div>
      <div class="cat"><h4>Position Limits</h4><p>SEBI restricts the number of contracts a trader can hold to prevent excessive speculation and maintain market stability.</p></div>
      <div class="cat"><h4>Margin Requirements</h4><p>Traders must maintain initial margins and mark-to-market (MTM) margins to manage risk and ensure smooth settlement.</p></div>
      <div class="cat"><h4>Risk Disclosure</h4><p>Brokers are required to clearly inform investors about the risks involved in commodity trading before they begin.</p></div>
      <div class="cat"><h4>Market Surveillance</h4><p>SEBI continuously monitors trading activity to detect manipulation, fraud, or unfair practices.</p></div>
    </div>
  </section>

  <!-- ===== Taxation on Commodity Trading Profits ===== -->
  <section class="section stack sec-tint" id="sec-tax" data-section="tax" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Taxation on Commodity Trading Profits</h2>
      <p class="sec-lead" style="color:var(--color-text-secondary)">Commodity trading profits are subject to specific tax regulations in India. Traders should understand how different commodity transactions are taxed to ensure net profits are added to your total annual income and taxed according to your applicable income tax slab rate (whether under the old or new tax regime). Profits from commodity trading in India are taxed as business income – not capital gains.</p>
    </div>
    <div class="row-2" data-reveal-row>
      <div class="card">
        <h4 class="card-h">Non-Agricultural Commodity Futures (MCX)</h4>
        <ul class="bullets">
          <li>Profits from MCX contracts (gold, silver, crude oil, copper, etc.) are treated as non-speculative business income.</li>
          <li>Taxed at your applicable income tax slab rate.</li>
          <li>Losses can be carried forward for up to 8 assessment years and offset against other business income.</li>
        </ul>
      </div>
      <div class="card">
        <h4 class="card-h">GST on Brokerage &amp; ITR Filing</h4>
        <ul class="bullets">
          <li>18% GST is levied on brokerage charged by SFS.</li>
          <li>GST cannot be claimed as a trading loss but is deductible as a business expense.</li>
          <li>Commodity traders should file ITR-3 and maintain a trade-wise P&amp;L statement.</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ===== Commodity Trading Strategy for Beginners ===== -->
  <section class="section stack sec-light" id="sec-strategy" data-section="strategy" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Commodity Trading Strategy for Beginners</h2>
      <p class="sec-lead">Getting started with commodity trading is easier when you have a clear strategy. These widely used approaches can help beginners understand market trends, manage risk, and trade with greater confidence.</p>
    </div>
    <div class="comm-cards" data-reveal-row>
      <div class="card">
        <h4 class="card-h">1. Trend Following</h4>
        <ul class="bullets">
          <li>Track the direction of a commodity's price using moving averages</li>
          <li>Go long in an uptrend, short in a downtrend.</li>
          <li>Works well on MCX gold and crude oil due to strong global macro influences.</li>
        </ul>
      </div>
      <div class="card">
        <h4 class="card-h">2. Intraday Scalping</h4>
        <ul class="bullets">
          <li>Place multiple trades within the same day to capture small price moves, though it may carry a higher level of risk.</li>
          <li>Popular in MCX crude oil because of high liquidity and volatility.</li>
          <li>Requires quick execution, strict stop-losses, and squaring off before market close</li>
        </ul>
      </div>
      <div class="card">
        <h4 class="card-h">3. Commodity Hedging</h4>
        <ul class="bullets">
          <li>Used by businesses and large investors to lock in prices and reduce risk.</li>
          <li>Example: A jeweller holding gold inventory can short MCX gold futures to protect against falling prices.</li>
          <li>Focused on risk management, not profit-seeking.</li>
        </ul>
      </div>
      <div class="card">
        <h4 class="card-h">4. RSI Divergence Trading</h4>
        <ul class="bullets">
          <li>A bearish RSI divergence on MCX silver or gold may signal a trend reversal.</li>
          <li>Always confirm with trading volume before entering positions.</li>
        </ul>
      </div>
      <div class="card">
        <h4 class="card-h">5. Pivot Point Trading</h4>
        <ul class="bullets">
          <li>Calculate daily pivot points (classic or Camarilla) for MCX contracts.</li>
          <li>Buy near support levels with stop-loss below; sell near resistance levels.</li>
          <li>Widely used by professional traders for intraday range trading.</li>
        </ul>
      </div>
      <div class="card">
        <h4 class="card-h">6. Calendar Spread Trading</h4>
        <ul class="bullets">
          <li>Buy and sell two related contracts simultaneously (e.g., near-month vs far-month crude oil futures).</li>
          <li>Profit from changes in the price spread between contracts.</li>
          <li>Requires lower capital and carries less directional risk compared to outright positions.</li>
        </ul>
      </div>
    </div>
    <div class="stack" style="gap:32px">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">Essential Rules for Risk Management</h3>
        <p class="sub-lead">Effective risk management is essential for long-term success in commodity trading. Following these basic rules can help beginners protect their capital and trade more confidently.</p>
      </div>
      <div class="steps" data-reveal-row>
        <div class="step">
          <div class="num">1</div>
          <div class="st-body"><h4>Always Use a Stop-Loss</h4><p>Set a stop-loss for every trade to limit potential losses and protect your trading capital from unexpected market movements.</p></div>
        </div>
        <div class="step-div"></div>
        <div class="step">
          <div class="num">2</div>
          <div class="st-body"><h4>Avoid Overleveraging</h4><p>Trade within your financial capacity and avoid taking excessively large positions that can amplify losses.</p></div>
        </div>
        <div class="step-div"></div>
        <div class="step">
          <div class="num">3</div>
          <div class="st-body"><h4>Diversify Your Trades</h4><p>Avoid concentrating all your capital in a single commodity. Diversification can help reduce overall portfolio risk.</p></div>
        </div>
        <div class="step-div"></div>
        <div class="step">
          <div class="num">4</div>
          <div class="st-body"><h4>Risk Only What You Can Afford to Lose</h4><p>Allocate only a small portion of your trading capital to each trade and never invest money meant for essential expenses.</p></div>
        </div>
        <div class="step-div"></div>
        <div class="step">
          <div class="num">5</div>
          <div class="st-body"><h4>Follow a Trading Plan</h4><p>Enter trades with predefined entry, target, and exit levels, and avoid making emotional decisions based on short-term market fluctuations.</p></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== General Questions ===== -->
  <section class="faq-wrap sec-tint" id="sec-faq" data-section="faq">
    <div class="faq-cols">
      <div class="faq-left">
        <h2 class="faq-title">Got Questions?</h2>
        <FaqAccordion faqs={FAQS} />
      </div>
      <div class="faq-side">
        <div class="usr"><img src="/assets/user.svg" alt="" /></div>
        <div class="side-in">
          <div class="side-tx">
            <h3>Need A Clearer Direction?</h3>
            <p>Let's get in touch on a 15-minute call where we can answer any questions you may have. Our advisor will help map your wealth mix and show what a dedicated, research-led plan would do differently.</p>
          </div>
          <a class="btn-gold" href="/contactus">Book A Discovery Call</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ===== commodities - page-specific only ===== */

  /* Generic responsive card grid for the multi-card sets (the shared .row-2 is
     2-up and .cat-grid's border math is tuned for text cells; this handles the
     3-up Hard-Commodities sub-group and 6-up strategy card sets). Values are on
     the 8px grid. */
  .comm-cards {
    display: grid;

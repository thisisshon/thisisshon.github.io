---
/**
 * Commodities — /products/commodities/
 * Long-form commodity-trading guide. Built entirely from the shared design-system
 * components in global.css (hero, .section/.sec-title, .card, .cat-grid,
 * .product-page_table, .approaches, .risks, FaqAccordion, .cta-box). The only
 * page-scoped CSS is a generic responsive card grid (.comm-cards) — token-bound.
 * Nested route → BaseLayout / component imports at ../../ depth.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import FaqAccordion from '../../components/sections/FaqAccordion.astro';
import { faqPageSchema, breadcrumbSchema, organizationSchema } from '../../lib/seo';

// The four commodity groups traded on MCX and NCDEX.
const GROUPS = [
  {
    h: 'Bullion',
    p: 'Precious metals — gold and silver — traded on the MCX. Popular as an inflation hedge and a store of value, with contracts sized for both large and retail participants (Gold Mini, Silver Micro).',
  },
  {
    h: 'Energy',
    p: 'Crude oil and natural gas contracts on the MCX track global energy benchmarks. Highly liquid and sensitive to OPEC decisions, inventory data and geopolitical events.',
  },
  {
    h: 'Base Metals',
    p: 'Industrial metals such as copper, zinc, aluminium, lead and nickel trade on the MCX. Their prices move with global demand, LME benchmarks and the industrial cycle.',
  },
  {
    h: 'Agricultural',
    p: 'Farm commodities — cotton, guar seed, guar gum, cumin (jeera), soybean and more — trade mainly on the NCDEX, driven by monsoon, sowing, harvest and export demand.',
  },
];

// A quick MCX/NCDEX contract reference — commodity / exchange / lot / typical margin.
const CONTRACTS = [
  { c: 'Gold (1 kg)', e: 'MCX', l: '1 kg', m: '≈ 6–8%' },
  { c: 'Gold Mini', e: 'MCX', l: '100 g', m: '≈ 6–8%' },
  { c: 'Silver', e: 'MCX', l: '30 kg', m: '≈ 8–10%' },
  { c: 'Crude Oil', e: 'MCX', l: '100 barrels', m: '≈ 10–12%' },
  { c: 'Natural Gas', e: 'MCX', l: '1,250 mmBtu', m: '≈ 12–15%' },
  { c: 'Copper', e: 'MCX', l: '2,500 kg', m: '≈ 8–10%' },
  { c: 'Cotton', e: 'MCX', l: '25 bales', m: '≈ 6–8%' },
  { c: 'Guar Seed', e: 'NCDEX', l: '10 MT', m: '≈ 8–10%' },
];

// Trading strategies — approach cards.
const STRATEGIES = [
  {
    h: 'Hedging',
    p: 'Producers, jewellers and manufacturers take an offsetting futures position to lock in a price and protect against adverse moves in the physical market.',
  },
  {
    h: 'Speculation',
    p: 'Traders take a directional view on price using leverage, aiming to profit from expected moves. Higher return potential comes with higher risk.',
  },
];

// Risk factors — risk cards.
const RISKS = [
  {
    h: 'Price Volatility',
    p: 'Commodity prices can swing sharply on supply shocks, weather, inventory data and demand surprises — often faster than equities.',
  },
  {
    h: 'Leverage Risk',
    p: 'Low margins amplify both gains and losses. A small adverse move can wipe out a large part of your margin, triggering margin calls.',
  },
  {
    h: 'Global Factors',
    p: 'Crude, bullion and base metals track global benchmarks — OPEC decisions, US inventory, the dollar and geopolitics all move Indian prices.',
  },
  {
    h: 'Roll-Over & Storage',
    p: 'Physically-settled contracts require you to square off or roll over before expiry, or take delivery — with associated warehouse and quality costs.',
  },
];

// General Questions — plain-text answers, shared with the FAQPage schema.
const FAQS = [
  {
    q: 'What is commodity trading in India?',
    a: 'Commodity trading is the buying and selling of commodity futures and options — such as gold, silver, crude oil, copper and agricultural produce — on regulated exchanges. In India the main venues are the MCX for bullion, energy and metals, and the NCDEX for agricultural commodities, all overseen by SEBI.',
  },
  {
    q: 'What is the difference between MCX and NCDEX?',
    a: 'The MCX (Multi Commodity Exchange) is the leading exchange for bullion, energy and base metals such as gold, silver, crude oil and copper. The NCDEX (National Commodity & Derivatives Exchange) specialises in agricultural commodities like guar, cotton, soybean and cumin. Both are SEBI-regulated electronic exchanges.',
  },
  {
    q: 'Do I need a separate account to trade commodities?',
    a: 'You trade commodities through a trading account with a SEBI-registered broker that is a member of the MCX/NCDEX. If you already have a Shriram trading account, commodity segment activation is a simple online step — no separate demat is needed as most contracts are cash-settled.',
  },
  {
    q: 'How does leverage work in commodity futures?',
    a: 'Commodity futures are traded on margin — you deposit a fraction of the contract value (typically 6–15%) to take a position. This leverage magnifies both profits and losses, so a small price move can have a large effect on your margin.',
  },
  {
    q: 'How is income from commodity trading taxed?',
    a: 'Income from trading commodity derivatives on a recognised exchange is generally treated as non-speculative business income, not as capital gains. It is added to your total income and taxed at your applicable slab rate, and losses can be set off against other business income subject to the rules.',
  },
  {
    q: 'What is Commodities Transaction Tax (CTT)?',
    a: 'CTT is a small tax levied on the sell side of non-agricultural commodity derivative transactions (such as bullion, energy and metals). Agricultural commodities are exempt. It is charged automatically on eligible trades, similar to how STT applies to equities.',
  },
  {
    q: 'Are commodities suitable for portfolio diversification?',
    a: 'Commodities often move differently from equities and bonds, so a measured allocation — for example to gold — can help diversify a portfolio and hedge against inflation. Suitability depends on your goals, risk appetite and time horizon, and leverage should be used carefully.',
  },
];

const site = Astro.site!.href;

const seo = {
  title: 'Commodity Trading — Trade Gold, Crude & Metals on MCX & NCDEX | Shriram Financial Services',
  description:
    'Learn how to trade commodities in India — bullion, energy, base metals and agri on MCX & NCDEX, with lot sizes, margins, costs, taxes, strategies and risks, with Shriram.',
  path: '/products/commodities/',
  jsonLd: [
    faqPageSchema(FAQS.map((f) => ({ question: f.q, answer: f.a }))),
    breadcrumbSchema(
      [
        { name: 'Home', path: '/' },
        { name: 'Products', path: '/products/' },
        { name: 'Commodities', path: '/products/commodities/' },
      ],
      site
    ),
    organizationSchema(site),
  ],
};
---

<BaseLayout seo={seo}>
  <!-- ===== Hero ===== -->
  <section class="hero" id="sec-hero" data-section="hero">
    <div class="hero-inner">
      <h1>Trade <span class="g">Commodities</span> on MCX &amp; NCDEX</h1>
      <p class="lead">Buy and sell gold, silver, crude oil, base metals and agricultural futures with low margins, live market data and research-led guidance from Shriram.</p>
      <div class="cta"><a class="btn-gold" href="/demat/">Open Demat Account</a></div>
      <div class="hero-feats">
        <div class="feats">
          <div class="feat"><span class="tk" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span><span class="lb">&nbsp;MCX &amp; NCDEX</span></div>
          <div class="feat"><span class="tk" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span><span class="lb">&nbsp;SEBI-regulated</span></div>
          <div class="feat"><span class="tk" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span><span class="lb">&nbsp;Low margins</span></div>
          <div class="feat"><span class="tk" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span><span class="lb">&nbsp;Research-led</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== What Is Commodity Trading ===== -->
  <section class="section stack sec-light" id="sec-about" data-section="about" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">What Is Commodity Trading?</h2>
      <p class="sec-lead">Commodity trading is the buying and selling of raw materials — precious metals, energy, industrial metals and farm produce — through standardised futures and options contracts. Rather than holding the physical asset, you trade a contract whose value tracks the underlying commodity. In India these contracts trade electronically on two SEBI-regulated exchanges, giving investors a transparent, well-supervised marketplace to speculate on prices, hedge exposure or diversify a portfolio.</p>
    </div>
    <div class="stack" style="gap:32px">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">Where Commodities Trade</h3>
        <p class="sub-lead">Two major exchanges enable transparent, electronic trading across the commodity segment:</p>
      </div>
      <div class="row-2">
        <div class="card" style="border-color:var(--color-border-card)">
          <h4 class="card-h">Multi Commodity Exchange (MCX)</h4>
          <p class="card-p">India's largest commodity exchange, where bullion, energy and base metals such as gold, silver, crude oil and copper trade with deep liquidity and transparent price discovery.</p>
        </div>
        <div class="card" style="border-color:var(--color-border-card)">
          <h4 class="card-h">National Commodity &amp; Derivatives Exchange (NCDEX)</h4>
          <p class="card-p">The leading exchange for agricultural commodities — guar, cotton, soybean, cumin and more — offering farmers, traders and investors a regulated venue for price discovery and hedging.</p>
        </div>
      </div>
    </div>
    <div class="stack" style="gap:32px">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">Futures &amp; Options</h3>
        <p class="sub-lead">Commodities are traded through two kinds of derivative contracts, each with its own risk profile.</p>
      </div>
      <div class="row-2">
        <div class="card">
          <h4 class="card-h">Commodity Futures</h4>
          <p class="card-p">An agreement to buy or sell a fixed quantity of a commodity at a set price on a future date. Traded on margin, with a defined lot size and monthly expiry.</p>
        </div>
        <div class="card">
          <h4 class="card-h">Commodity Options</h4>
          <p class="card-p">Give the right — but not the obligation — to buy or sell the underlying futures at a strike price. Buyers pay a premium and cap their downside to that premium.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Types of Commodities ===== -->
  <section class="section stack sec-tint" id="sec-types" data-section="types" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Types of Commodities</h2>
      <p class="sec-lead" style="color:var(--color-text-secondary)">Commodities fall into four broad groups, each traded on its primary exchange and driven by its own set of price factors.</p>
    </div>
    <div class="comm-cards">
      {GROUPS.map((g) => (
        <div class="card"><h4 class="card-h">{g.h}</h4><p class="card-p">{g.p}</p></div>
      ))}
    </div>
    <div class="stack" style="gap:32px">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">Commonly Traded Commodities</h3>
        <p class="sub-lead" style="color:var(--color-text-secondary)">A snapshot of the most actively traded contracts across the four groups.</p>
      </div>
      <div class="cat-grid">
        <div class="cat"><h4>Gold</h4><p>The benchmark bullion contract — a classic inflation hedge and safe-haven asset.</p></div>
        <div class="cat"><h4>Silver</h4><p>A precious and industrial metal, more volatile than gold with strong demand cycles.</p></div>
        <div class="cat"><h4>Crude Oil</h4><p>Highly liquid energy contract tracking global benchmarks and inventory data.</p></div>
        <div class="cat"><h4>Natural Gas</h4><p>An energy contract sensitive to weather, storage and seasonal demand.</p></div>
        <div class="cat"><h4>Copper</h4><p>A base metal seen as a barometer of global industrial and economic health.</p></div>
        <div class="cat"><h4>Zinc &amp; Aluminium</h4><p>Industrial base metals driven by construction, manufacturing and global demand.</p></div>
        <div class="cat"><h4>Cotton</h4><p>An agri contract shaped by monsoon, sowing, harvest and textile export demand.</p></div>
        <div class="cat"><h4>Guar Seed &amp; Gum</h4><p>NCDEX agri staples influenced by rainfall, acreage and oil-drilling demand.</p></div>
      </div>
    </div>
    <a class="btn-gold" href="/demat/" style="align-self:center">Open Demat Account</a>
  </section>

  <!-- ===== How Commodity Futures Work ===== -->
  <section class="section stack sec-light" id="sec-mechanics" data-section="mechanics" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">How Commodity Futures Work: Lot Sizes, Margins &amp; Expiry</h2>
      <p class="sec-lead">Every futures contract is standardised — a fixed lot size, a margin requirement and a monthly expiry. You deposit only a fraction of the contract value as margin, which is what gives commodity trading its leverage. Positions must be squared off or rolled over before expiry, or settled as per the contract specification.</p>
    </div>
    <div class="stack" style="gap:32px">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">Contract Specifications</h3>
        <p class="sub-lead">An indicative reference of lot sizes and typical margins across popular contracts. Exact values are set by the exchange and vary with volatility.</p>
      </div>
      <div class="t-scroll"><div class="product-page_table t4 bordered">
        <div class="cell th"><p>Commodity</p></div><div class="cell th"><p>Exchange</p></div><div class="cell th"><p>Lot Size</p></div><div class="cell th"><p>Typical Margin</p></div>
        {CONTRACTS.map((c) => (
          <>
            <div class="cell tb"><p class="k">{c.c}</p></div>
            <div class="cell tb"><p class="v">{c.e}</p></div>
            <div class="cell tb"><p class="v">{c.l}</p></div>
            <div class="cell tb"><p class="v">{c.m}</p></div>
          </>
        ))}
      </div></div>
    </div>
  </section>

  <!-- ===== Costs & Taxes ===== -->
  <section class="section stack sec-tint" id="sec-costs" data-section="costs" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Costs &amp; Taxes</h2>
      <p class="sec-lead" style="color:var(--color-text-secondary)">What you pay to trade commodities, and how the income is treated for tax — transparently, with no hidden costs.</p>
    </div>
    <div class="stack" style="gap:32px">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">Brokerage &amp; Charges</h3>
        <p class="sub-lead" style="color:var(--color-text-secondary)">A clear breakdown of the charges that apply to commodity futures trades.</p>
      </div>
      <div class="t-scroll"><div class="product-page_table t3">
        <div class="cell th"><p>Charge Type</p></div><div class="cell th"><p>Rate</p></div><div class="cell th"><p>Applies To</p></div>
        <div class="cell tb"><p class="k">Brokerage</p></div><div class="cell tb"><p class="v">Flat ₹20 per executed order</p></div><div class="cell tb"><p class="v">All commodity futures</p></div>
        <div class="cell tb"><p class="k">CTT</p></div><div class="cell tb"><p class="v">0.01% on sell side</p></div><div class="cell tb"><p class="v">Non-agri (bullion, energy, metals)</p></div>
        <div class="cell tb"><p class="k">GST</p></div><div class="cell tb"><p class="v">18% on brokerage &amp; charges</p></div><div class="cell tb"><p class="v">All trades</p></div>
        <div class="cell tb"><p class="k">Exchange Transaction Charge</p></div><div class="cell tb"><p class="v">≈ 0.0026% of turnover</p></div><div class="cell tb"><p class="v">Varies by commodity</p></div>
        <div class="cell tb"><p class="k">SEBI Turnover Fee</p></div><div class="cell tb"><p class="v">₹10 per crore of turnover</p></div><div class="cell tb"><p class="v">All trades</p></div>
        <div class="cell tb"><p class="k">Stamp Duty</p></div><div class="cell tb"><p class="v">0.002% on buy side</p></div><div class="cell tb"><p class="v">All trades</p></div>
      </div></div>
    </div>
    <div class="stack" style="gap:32px">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">Tax on Commodity Trading</h3>
        <p class="sub-lead" style="color:var(--color-text-secondary)">How gains from commodity derivatives are treated under Indian income-tax rules.</p>
      </div>
      <div class="card">
        <p class="card-p">Income from trading commodity derivatives on a recognised exchange is generally treated as <strong>non-speculative business income</strong> — not as capital gains. It is added to your total income and taxed at your applicable slab rate, and business-related losses can be set off against other income subject to the prevailing rules. Because the treatment is business income, maintaining trade records and, where applicable, meeting audit requirements is important. This is general information, not tax advice — consult a qualified tax adviser for your situation.</p>
      </div>
    </div>
    <a class="btn-gold" href="/demat/" style="align-self:center">Open Demat Account</a>
  </section>

  <!-- ===== Trading Strategies ===== -->
  <section class="section stack sec-light" id="sec-strategies" data-section="strategies" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Trading Strategies</h2>
      <p class="sec-lead">Traders use commodities for different reasons — to protect a physical position, to profit from a directional view, or to exploit price differences across markets. Match the approach to your goal, capital and risk appetite.</p>
    </div>
    <div class="approaches">
      {STRATEGIES.map((s, i) => (
        <a class="appr" href="#">
          <div class="appr-main">
            <p class="idx">Strategy 0{i + 1}</p>
            <div class="appr-tt"><h4>{s.h}</h4><p>{s.p}</p></div>
          </div>
          <div class="explore"><span>Explore&nbsp;</span><span aria-hidden="true"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 8h11M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span></div>
        </a>
      ))}
    </div>
    <div class="stack" style="gap:32px">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">Arbitrage</h3>
        <p class="sub-lead">A lower-risk approach that seeks to profit from price differences of the same commodity.</p>
      </div>
      <div class="card">
        <p class="card-p">Arbitrage involves simultaneously buying and selling the same commodity across different markets, contracts or maturities to capture a price gap — for example, between a near-month and far-month futures contract, or between the spot and futures price. The positions largely offset each other, so the strategy targets small, relatively low-risk gains rather than directional bets, though execution speed and transaction costs matter.</p>
      </div>
    </div>
  </section>

  <!-- ===== Risks to Weigh ===== -->
  <section class="section stack sec-tint" id="sec-risks" data-section="risks" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Risks to Weigh</h2>
      <p class="sec-lead" style="color:var(--color-text-secondary)">Commodity trading offers real opportunity, but leverage and global sensitivity make it high-risk. Understand what can move against you before you commit capital.</p>
    </div>
    <div class="risks">
      {RISKS.map((r) => (
        <div class="risk"><h4>{r.h}</h4><p>{r.p}</p></div>
      ))}
    </div>
  </section>

  <!-- ===== General Questions ===== -->
  <section class="faq-wrap sec-tint" id="sec-faq" data-section="faq">
    <div class="faq-cols">
      <div class="faq-left">
        <h2 class="faq-title">General Questions</h2>
        <FaqAccordion faqs={FAQS} />
      </div>
      <div class="faq-side">
        <div class="usr"><img src="/assets/user.svg" alt="" /></div>
        <div class="side-in">
          <div class="side-tx">
            <h3>Need A Clearer Direction?</h3>
            <p>Let's get in touch on a 15-minute call where we can answer any questions you may have. Our advisor will help map your wealth mix and show what a dedicated, research-led plan would do differently.</p>
          </div>
          <a class="btn-gold" href="/support/">Book A Discovery Call</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Final CTA ===== -->
  <section class="cta-sec sec-light" id="sec-final-cta" data-section="final-cta">
    <div class="cta-box">
      <div class="ct-tt">
        <h3>Start Trading Commodities Within Minutes</h3>
        <p class="ct-sub">Open your Demat account and activate the commodity segment — with zero paperwork.</p>
      </div>
      <a class="btn-gold" href="/demat/">Open Demat Account</a>
    </div>
  </section>
</BaseLayout>

<style>
  /* ===== commodities — page-specific only ===== */

  /* Generic responsive card grid for the commodity-group card set (the shared
     .row-2 is 2-up and .cat-grid's border math is tuned for 8 cells; this
     handles the 4 group cards). Values are on the 8px grid. */
  .comm-cards {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px;
    align-items: stretch;
  }
  .comm-cards .card {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  @media (max-width: 560px) {
    .comm-cards {
      grid-template-columns: 1fr;
    }
  }
</style>

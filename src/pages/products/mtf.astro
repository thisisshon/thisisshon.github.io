---
/**
 * Margin Trading Facility (MTF) — /products/mtf/
 * Long-form MTF guide. Built entirely from shared design-system components in
 * global.css (hero, .section/.sec-title, .card, .steps, .check-card,
 * .product-page_table, .risks, FaqAccordion, .cta-box). Frontmatter data arrays
 * feed the card/step/table maps. Nested route → imports at ../../ depth.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import FaqAccordion from '../../components/sections/FaqAccordion.astro';
import { faqPageSchema, breadcrumbSchema, organizationSchema } from '../../lib/seo';

// How MTF works, step by step.
const STEPS = [
  { h: 'Fund Your Share of the Trade', p: 'You pay an initial margin — a portion of the total order value — from your own funds.' },
  { h: 'The Broker Funds the Rest', p: 'Shriram funds the balance so you can buy more shares than your cash alone would allow.' },
  { h: 'Pledge the Shares as Collateral', p: 'The shares you buy are pledged with the depository as collateral against the funded amount.' },
  { h: 'Pay Interest on the Funded Amount', p: 'A daily interest is charged only on the amount funded by the broker, for as long as the position is open.' },
  { h: 'Hold, Then Square Off', p: 'Hold the position within the allowed period, then sell to book gains and repay the funded amount, or top up margin if required.' },
];

// Approved-security eligibility checklist (check-card).
const APPROVED = [
  'Stocks appear on the exchange-approved MTF list',
  'Sufficient liquidity and trading volume in the scrip',
  'Applicable margin percentage set by the broker and exchange',
  'Meets SEBI and exchange norms for margin funding',
  'Not under any surveillance measure (e.g. ASM/GSM) that restricts MTF',
];

// Investor eligibility checklist (check-card).
const ELIGIBLE = [
  'An active trading and Demat account with Shriram',
  'MTF facility activated and terms accepted',
  'Sufficient initial margin available in cash or approved collateral',
  'Completed KYC and a valid PAN',
  'Understanding of interest costs and square-off rules',
];

// Risks specific to margin trading.
const RISKS = [
  {
    h: 'Interest Cost',
    p: "Interest accrues daily on the funded amount for as long as the position stays open. Hold too long and the interest can erode — or exceed — your gains.",
  },
  {
    h: 'Margin Calls',
    p: 'If the value of your pledged shares falls, the broker may issue a margin call requiring you to add funds or collateral to maintain the position.',
  },
  {
    h: 'Forced Square-Off',
    p: "If you don't meet a margin call in time, the broker can sell your pledged shares to recover the funded amount — sometimes at an unfavourable price.",
  },
  {
    h: 'Amplified Market Fall',
    p: 'Because you control a larger position than your own capital, a fall in the share price magnifies your loss relative to a normal cash purchase.',
  },
];

// General Questions — plain-text answers, shared with the FAQPage schema.
const FAQS = [
  {
    q: 'What is Margin Trading Facility (MTF)?',
    a: 'Margin Trading Facility, or MTF, lets you buy more shares than your available cash allows. You pay a part of the trade value as margin and the broker funds the rest, charging interest on the funded amount. The shares you buy are pledged as collateral until you square off.',
  },
  {
    q: 'How much extra buying power does MTF give?',
    a: 'MTF can give you buying power of up to around four times your available margin, depending on the stock, its applicable margin percentage and prevailing exchange and broker rules. Higher leverage applies to more liquid, approved securities.',
  },
  {
    q: 'How is interest charged on MTF?',
    a: 'Interest is charged only on the amount funded by the broker, calculated on a daily basis for as long as the position remains open. If you square off the same day or hold for a short period, the interest cost stays low; longer holds accumulate more interest.',
  },
  {
    q: 'Which shares are eligible for MTF?',
    a: 'Only securities on the exchange-approved MTF list are eligible. These are typically liquid stocks that meet SEBI and exchange norms. Each approved stock carries a margin percentage that determines how much you must fund yourself versus how much the broker can fund.',
  },
  {
    q: 'What happens if the stock price falls?',
    a: 'If your pledged shares lose value, the broker may issue a margin call asking you to add funds or collateral. If you do not meet the call in time, the broker can square off your position by selling the pledged shares to recover the funded amount.',
  },
  {
    q: 'How is MTF different from F&O?',
    a: 'MTF is delivery-based — you actually own the shares, funded partly by the broker, and can hold them subject to interest and square-off rules. F&O involves derivative contracts with expiry dates and no ownership of the underlying. MTF suits leveraged delivery positions; F&O suits directional and hedging strategies.',
  },
  {
    q: 'Are the charges transparent?',
    a: 'Yes. MTF costs comprise the daily interest on the funded amount, standard brokerage, and any pledge or unpledge charges levied by the depository. Shriram discloses the applicable rates upfront so you can assess the total cost before taking a position.',
  },
];

const site = Astro.site!.href;

const seo = {
  title: 'Margin Trading Facility (MTF) — Buy More With Margin Funding | Shriram Financial Services',
  description:
    'Understand Margin Trading Facility (MTF) in India — how margin funding works, interest and charges, eligible securities, MTF vs delivery vs F&O, and the risks — with Shriram.',
  path: '/products/mtf/',
  jsonLd: [
    faqPageSchema(FAQS.map((f) => ({ question: f.q, answer: f.a }))),
    breadcrumbSchema(
      [
        { name: 'Home', path: '/' },
        { name: 'Products', path: '/products/' },
        { name: 'Margin Trading Facility', path: '/products/mtf/' },
      ],
      site
    ),
    organizationSchema(site),
  ],
};
---

<BaseLayout seo={seo}>
  <!-- ===== Hero ===== -->
  <section class="hero" id="sec-hero" data-section="hero">
    <div class="hero-inner">
      <h1>Buy More Than Your Cash Allows With <span class="g">Margin Trading</span></h1>
      <p class="lead">Amplify your buying power with Margin Trading Facility — pay a part of the trade, let Shriram fund the rest, and pledge the shares as collateral, all with transparent charges.</p>
      <div class="cta"><a class="btn-gold" href="/demat/">Open Demat Account</a></div>
      <div class="hero-feats">
        <div class="feats">
          <div class="feat"><span class="tk" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span><span class="lb">&nbsp;SEBI-approved</span></div>
          <div class="feat"><span class="tk" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span><span class="lb">&nbsp;Up to 4x</span></div>
          <div class="feat"><span class="tk" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span><span class="lb">&nbsp;Transparent charges</span></div>
          <div class="feat"><span class="tk" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span><span class="lb">&nbsp;Pledge-backed</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== What Is MTF ===== -->
  <section class="section stack sec-light" id="sec-about" data-section="about" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">What Is Margin Trading Facility?</h2>
      <p class="sec-lead">Margin Trading Facility (MTF) lets you buy more shares than your available cash would normally allow. You pay a fraction of the total order value as margin, and the broker funds the remaining amount. The shares you purchase are pledged as collateral against that funding, and you pay interest on the funded portion for as long as you hold the position. MTF is a SEBI-regulated, delivery-based product — you actually own the shares, unlike in F&amp;O where you trade contracts.</p>
    </div>
    <div class="stack" style="gap:32px">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">Why Traders Use MTF</h3>
        <p class="sub-lead">Two things set MTF apart from a plain cash purchase — leverage and ownership.</p>
      </div>
      <div class="row-2">
        <div class="card" style="border-color:var(--color-border-card)">
          <h4 class="card-h">More Buying Power</h4>
          <p class="card-p">A limited amount of cash can command a larger position — often up to four times your margin — letting you act on a conviction without waiting to accumulate the full amount.</p>
        </div>
        <div class="card" style="border-color:var(--color-border-card)">
          <h4 class="card-h">You Still Own the Shares</h4>
          <p class="card-p">MTF is delivery-based, so the shares sit in your Demat account (pledged as collateral). You can hold them beyond a single session, subject to interest and margin rules.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== How MTF Works ===== -->
  <section class="section stack sec-tint" id="sec-how" data-section="how" style="gap:56px;align-items:center;justify-content:center">
    <div class="stack" style="gap:16px;width:100%">
      <h2 class="sec-title">How MTF Works</h2>
      <p class="sec-lead" style="color:var(--color-text-secondary)">From your first margin payment to the final square-off — five steps that define every MTF trade.</p>
    </div>
    <div class="stack" style="gap:32px;width:100%">
      <div class="steps">
        {STEPS.slice(0, 3).map((s, i) => (
          <>
            {i > 0 && <div class="step-div" />}
            <div class="step"><div class="num">{i + 1}</div><div class="st-body"><h4>{s.h}</h4><p>{s.p}</p></div></div>
          </>
        ))}
      </div>
      <div class="steps">
        {STEPS.slice(3).map((s, i) => (
          <>
            {i > 0 && <div class="step-div" />}
            <div class="step"><div class="num">{i + 4}</div><div class="st-body"><h4>{s.h}</h4><p>{s.p}</p></div></div>
          </>
        ))}
      </div>
    </div>
    <a class="btn-gold" href="/demat/" style="align-self:center">Open Demat Account</a>
  </section>

  <!-- ===== Interest & Charges ===== -->
  <section class="section stack sec-light" id="sec-charges" data-section="charges" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Interest &amp; Charges</h2>
      <p class="sec-lead">MTF costs are simple and disclosed upfront — interest on the funded amount, brokerage, and depository pledge charges.</p>
    </div>
    <div class="t-scroll"><div class="product-page_table t3">
      <div class="cell th"><p>Charge Type</p></div><div class="cell th"><p>Basis</p></div><div class="cell th"><p>How It Applies</p></div>
      <div class="cell tb"><p class="k">Interest on Funding</p></div><div class="cell tb"><p class="v">Per day on the funded amount</p></div><div class="cell tb"><p class="v">Charged daily only on the broker-funded portion while the position is open</p></div>
      <div class="cell tb"><p class="k">Brokerage</p></div><div class="cell tb"><p class="v">Per executed order</p></div><div class="cell tb"><p class="v">Standard delivery brokerage on the buy and sell legs</p></div>
      <div class="cell tb"><p class="k">Pledge Charges</p></div><div class="cell tb"><p class="v">Per pledge / unpledge request</p></div><div class="cell tb"><p class="v">Depository fee to pledge shares as collateral and release them later</p></div>
      <div class="cell tb"><p class="k">GST</p></div><div class="cell tb"><p class="v">18% on brokerage &amp; charges</p></div><div class="cell tb"><p class="v">Applied on brokerage, interest and other applicable service charges</p></div>
      <div class="cell tb"><p class="k">Statutory Levies</p></div><div class="cell tb"><p class="v">STT, stamp duty, exchange charges</p></div><div class="cell tb"><p class="v">Same as a normal delivery trade, on both legs per prevailing rates</p></div>
    </div></div>
    <a class="btn-gold" href="/demat/" style="align-self:center">Open Demat Account</a>
  </section>

  <!-- ===== Eligibility & Approved Securities ===== -->
  <section class="section stack sec-tint" id="sec-eligibility" data-section="eligibility" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Eligibility &amp; Approved Securities</h2>
      <p class="sec-lead" style="color:var(--color-text-secondary)">Not every account or every stock qualifies for MTF. Here is what you and the security both need to meet.</p>
    </div>
    <div class="row-2">
      <div class="card check-card">
        <h4 class="ch-title">Who Can Use MTF</h4>
        <div class="check-list">
          {ELIGIBLE.map((c, i) => (
            <>
              {i > 0 && <div class="check-sep" />}
              <div class="check-row"><span class="ck" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span><p class="tx">{c}</p></div>
            </>
          ))}
        </div>
      </div>
      <div class="card check-card">
        <h4 class="ch-title">Approved Securities</h4>
        <div class="check-list">
          {APPROVED.map((c, i) => (
            <>
              {i > 0 && <div class="check-sep" />}
              <div class="check-row"><span class="ck" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span><p class="tx">{c}</p></div>
            </>
          ))}
        </div>
      </div>
    </div>
    <a class="btn-gold" href="/demat/" style="align-self:center">Open Demat Account</a>
  </section>

  <!-- ===== MTF vs Delivery vs F&O ===== -->
  <section class="section stack sec-light" id="sec-compare" data-section="compare" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">MTF vs Delivery vs F&amp;O</h2>
      <p class="sec-lead">Three ways to take a position in the market, compared across the factors that matter most.</p>
    </div>
    <div class="t-scroll"><div class="product-page_table t4 bordered">
      <div class="cell th"><p>Feature</p></div><div class="cell th"><p>MTF</p></div><div class="cell th"><p>Delivery (Cash)</p></div><div class="cell th"><p>F&amp;O</p></div>
      <div class="cell tb"><p class="k">Ownership</p></div><div class="cell tb"><p class="v">You own the shares (pledged)</p></div><div class="cell tb"><p class="v">You fully own the shares</p></div><div class="cell tb"><p class="v">No ownership — contracts only</p></div>
      <div class="cell tb"><p class="k">Leverage</p></div><div class="cell tb"><p class="v">Up to ~4x via broker funding</p></div><div class="cell tb"><p class="v">None — pay full value</p></div><div class="cell tb"><p class="v">High, via margin</p></div>
      <div class="cell tb"><p class="k">Holding Period</p></div><div class="cell tb"><p class="v">Flexible, subject to interest</p></div><div class="cell tb"><p class="v">Unlimited</p></div><div class="cell tb"><p class="v">Until contract expiry</p></div>
      <div class="cell tb"><p class="k">Main Cost</p></div><div class="cell tb"><p class="v">Daily interest on funding</p></div><div class="cell tb"><p class="v">Brokerage only</p></div><div class="cell tb"><p class="v">Premium / margin + brokerage</p></div>
      <div class="cell tb"><p class="k">Key Risk</p></div><div class="cell tb"><p class="v">Interest cost &amp; forced square-off</p></div><div class="cell tb"><p class="v">Market price movement</p></div><div class="cell tb"><p class="v">Leverage, expiry &amp; time decay</p></div>
      <div class="cell tb"><p class="k">Best Suited For</p></div><div class="cell tb"><p class="v">Leveraged delivery views</p></div><div class="cell tb"><p class="v">Long-term investors</p></div><div class="cell tb"><p class="v">Hedging &amp; directional trading</p></div>
    </div></div>
    <a class="btn-gold" href="/demat/" style="align-self:center">Open Demat Account</a>
  </section>

  <!-- ===== Risks to Weigh ===== -->
  <section class="section stack sec-tint" id="sec-risks" data-section="risks" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Risks to Weigh</h2>
      <p class="sec-lead" style="color:var(--color-text-secondary)">Leverage magnifies both outcomes. Understand these risks before you fund a position with MTF.</p>
    </div>
    <div class="risks">
      {RISKS.map((r) => (
        <div class="risk"><h4>{r.h}</h4><p>{r.p}</p></div>
      ))}
    </div>
    <p class="sec-lead" style="color:var(--color-text-secondary)">Use MTF with discipline — keep an eye on interest accruing on the funded amount, respond to margin calls promptly, and size positions so a market fall never forces an unplanned square-off.</p>
  </section>

  <!-- ===== General Questions ===== -->
  <section class="faq-wrap sec-light" id="sec-faq" data-section="faq">
    <div class="faq-cols">
      <div class="faq-left">
        <h2 class="faq-title">General Questions</h2>
        <FaqAccordion faqs={FAQS} />
      </div>
      <div class="faq-side">
        <div class="usr"><img src="/assets/user.svg" alt="" /></div>
        <div class="side-in">
          <div class="side-tx">
            <h3>Need A Clearer Direction?</h3>
            <p>Let's get in touch on a 15-minute call where we can answer any questions you may have. Our advisor will explain how margin funding, interest and square-off rules apply to your trades.</p>
          </div>
          <a class="btn-gold" href="/support/">Book A Discovery Call</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Final CTA ===== -->
  <section class="cta-sec sec-tint" id="sec-final-cta" data-section="final-cta">
    <div class="cta-box">
      <div class="ct-tt">
        <h3>Trade With More Buying Power in Minutes</h3>
        <p class="ct-sub">Open your Demat account, activate MTF, and buy more than your cash allows — with transparent charges.</p>
      </div>
      <a class="btn-gold" href="/demat/">Open Demat Account</a>
    </div>
  </section>
</BaseLayout>

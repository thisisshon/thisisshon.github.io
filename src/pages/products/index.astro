---
/**
 * Product Suite / Product Listing — /products/
 * Nested page (depth ../../). Pixel parity with legacy products/index.html.
 *
 * Uses the shared .pgroup / .pcard-grid / .pcard components from global.css
 * (markup only). The "Six Financial Stages, One Orbit" dark band and the
 * "gateway" CTA band are page-local: their gradients and animations are
 * single-use literals (Tier-2 candidates), kept verbatim for exact parity.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import FaqAccordion from '../../components/sections/FaqAccordion.astro';
import { faqPageSchema } from '../../lib/seo';

// General Questions — legacy content verbatim, same order (first item open).
const FAQS = [
  {
    q: 'What is a Demat Account?',
    a: 'A Demat (dematerialised) account holds your shares and securities in electronic form, replacing physical certificates. It lets you buy, sell and hold equities, bonds, ETFs and mutual funds safely, with instant electronic settlement of trades.',
  },
  {
    q: 'What are the benefits of a Demat Account?',
    a: 'A Demat account removes the risks of physical certificates — theft, loss and forgery — and enables faster, paperless settlement. You get a single consolidated view of your holdings, easy access to corporate actions such as dividends and bonuses, and the ability to trade from anywhere.',
  },
  {
    q: 'What are the brokerage charges for options trading with Shriram Financial Services?',
    a: 'Brokerage charges for options trading are structured to be competitive and straightforward. Shriram Financial Services charges a flat fee of ₹20 per executed order for options trading. To understand and calculate the total cost — including brokerage, taxes and other fees — use the Brokerage Calculator, which estimates the net profit or loss on your trades after all applicable charges.',
  },
  {
    q: 'Are there any charges associated with the Demat Account?',
    a: 'Typical charges include a one-time account opening fee (often waived), an annual maintenance charge (AMC) and per-transaction debit or dematerialisation charges. Shriram keeps these transparent, so you can review the full schedule before you open your account.',
  },
  {
    q: 'What is Intraday brokerage and Option brokerage?',
    a: 'Intraday brokerage applies to positions bought and sold within the same trading day, while option brokerage applies to options contracts. Both are charged per executed order — you can estimate the exact cost of any trade with our Brokerage Calculator.',
  },
  {
    q: 'Can I have multiple Demat Accounts?',
    a: 'Yes. You may hold more than one Demat account across different depository participants, but you cannot open two accounts with the same DP under the same PAN. Your PAN links all accounts for tax and regulatory purposes.',
  },
  {
    q: 'Is a Demat Account mandatory for applying for an IPO?',
    a: 'Yes. To receive shares allotted in an IPO in electronic form you need a Demat account. You can apply via ASBA through your bank or broker, and any allotted shares are credited directly to your Demat account.',
  },
];

const seo = {
  title: 'Product Suite — Trade, Invest & Borrow',
  description:
    "Explore Shriram's complete product suite — equity, derivatives, commodities, mutual funds, ETFs, IPOs, bonds, NPS, fixed deposits and loans against securities — all in one place.",
  path: '/products/',
  jsonLd: [faqPageSchema(FAQS.map((f) => ({ question: f.q, answer: f.a })))],
};
---

<BaseLayout seo={seo}>
  <!-- ================= HERO ================= -->
  <section class="hero" id="sec-hero" data-section="hero">
    <div class="hero-inner">
      <h1>Our Complete <span class="g">Product Suite</span></h1>
      <p class="lead">Trade, invest or borrow across our comprehensive list of product offerings — all from one connected account.</p>
      <div class="cta"><a class="btn-gold" href="/open-demat-account/">Open Demat Account</a></div>
    </div>
  </section>

  <!-- ================= ALL PRODUCTS ================= -->
  <section class="section stack sec-light" id="sec-products" data-section="products" style="gap:56px">
    <h2 class="sec-title">All Products</h2>

    <!-- Group 1 — Trade -->
    <div class="pgroup" id="pg-trade">
      <div class="pgroup-head">
        <h3>Trade with speed and precision</h3>
        <p>Unlock seamless trading with cutting-edge tools and live market data.</p>
      </div>
      <div class="pcard-grid">
        <a class="pcard" href="/equity/">
          <div class="pcard-tx"><h4>Equity Trading Made Easy</h4><p>Execute trades in NSE &amp; BSE stocks with instant execution and expert analysis.</p></div>
          <span class="pcard-arr" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M5 12h13m0 0-5-5m5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path></svg></span>
        </a>
        <a class="pcard" href="#">
          <div class="pcard-tx"><h4>Derivatives</h4><p>Manage risks effectively while trading futures and options.</p></div>
          <span class="pcard-arr" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M5 12h13m0 0-5-5m5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path></svg></span>
        </a>
        <a class="pcard" href="#">
          <div class="pcard-tx"><h4>Invest in Commodities</h4><p>Expand your investments with Gold, Silver, Oil, and Agricultural Commodities.</p></div>
          <span class="pcard-arr" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M5 12h13m0 0-5-5m5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path></svg></span>
        </a>
        <a class="pcard" href="#">
          <div class="pcard-tx"><h4>Forex Trading Simplified</h4><p>Engage in forex trading with low spreads and up-to-the-minute insights.</p></div>
          <span class="pcard-arr" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M5 12h13m0 0-5-5m5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path></svg></span>
        </a>
        <a class="pcard" href="#">
          <div class="pcard-tx"><h4>Leverage Margin Trading Facilities</h4><p>Enhance your trading capacity with our Margin Trading Facility.</p></div>
          <span class="pcard-arr" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M5 12h13m0 0-5-5m5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path></svg></span>
        </a>
      </div>
    </div>

    <!-- Group 2 — Long-Term Investment -->
    <div class="pgroup" id="pg-invest">
      <div class="pgroup-head">
        <h3>Long-Term Investment Strategy</h3>
        <p>Access top-tier investment tools and personalized support for informed decisions.</p>
      </div>
      <div class="pcard-grid">
        <a class="pcard" href="#">
          <div class="pcard-tx"><h4>Invest in Mutual Funds</h4><p>Join expertly managed funds with no commission and flexible SIP options.</p></div>
          <span class="pcard-arr" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M5 12h13m0 0-5-5m5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path></svg></span>
        </a>
        <a class="pcard" href="#">
          <div class="pcard-tx"><h4>New Fund Offerings (NFO)</h4><p>Invest in diversified ETFs with minimal fees and quick access.</p></div>
          <span class="pcard-arr" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M5 12h13m0 0-5-5m5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path></svg></span>
        </a>
        <a class="pcard" href="#">
          <div class="pcard-tx"><h4>Exchange Traded Funds (ETFs)</h4><p>Trade ETFs with low costs and immediate liquidity.</p></div>
          <span class="pcard-arr" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M5 12h13m0 0-5-5m5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path></svg></span>
        </a>
        <a class="pcard" href="#">
          <div class="pcard-tx"><h4>Participate in IPOs</h4><p>Easily apply for new IPOs with our user-friendly online platform.</p></div>
          <span class="pcard-arr" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M5 12h13m0 0-5-5m5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path></svg></span>
        </a>
        <a class="pcard" href="#">
          <div class="pcard-tx"><h4>Bond Investments</h4><p>Invest in a variety of bonds with competitive returns.</p></div>
          <span class="pcard-arr" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M5 12h13m0 0-5-5m5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path></svg></span>
        </a>
        <a class="pcard" href="#">
          <div class="pcard-tx"><h4>Fixed Deposit</h4><p>Enjoy secure returns with fixed deposits from Shriram Finance.</p></div>
          <span class="pcard-arr" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M5 12h13m0 0-5-5m5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path></svg></span>
        </a>
        <a class="pcard" href="#">
          <div class="pcard-tx"><h4>National Pension Scheme (NPS)</h4><p>Secure your retirement with tax-efficient NPS contributions.</p></div>
          <span class="pcard-arr" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M5 12h13m0 0-5-5m5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path></svg></span>
        </a>
        <a class="pcard" href="#">
          <div class="pcard-tx"><h4>Global Market Access</h4><p>Invest in leading US stocks and International ETFs.</p></div>
          <span class="pcard-arr" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M5 12h13m0 0-5-5m5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path></svg></span>
        </a>
      </div>
    </div>

    <!-- Group 3 — Highlighted Financial Solutions -->
    <div class="pgroup" id="pg-loans">
      <div class="pgroup-head">
        <h3>Highlighted Financial Solutions</h3>
        <p>Achieve financial security with our flexible loan offerings.</p>
      </div>
      <div class="pcard-grid">
        <a class="pcard" href="#">
          <div class="pcard-tx"><h4>Loans Against Mutual Funds</h4><p>Enjoy quick access to funds while leveraging your mutual fund portfolio.</p></div>
          <span class="pcard-arr" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M5 12h13m0 0-5-5m5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path></svg></span>
        </a>
        <a class="pcard" href="#">
          <div class="pcard-tx"><h4>Loans Against Stocks</h4><p>Secure your financial future with our tailored stock-backed loans.</p></div>
          <span class="pcard-arr" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M5 12h13m0 0-5-5m5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path></svg></span>
        </a>
      </div>
    </div>
  </section>

  <!-- ================= ORBIT ================= -->
  <section class="orbit" id="sec-orbit" data-section="orbit">
    <div class="orbit-in">
      <div class="orbit-head">
        <h2 class="sec-title">Six Financial Stages, One Orbit.</h2>
        <p class="sec-lead">Every financial move you make — trading, building, borrowing, protecting — happens in one connected place. Tap any stage to explore.</p>
      </div>
      <div class="orbit-panel">
        <div class="orbit-list">
          <a class="orbit-row" href="#pg-trade" data-stage="trade">
            <div class="orbit-stage"><span class="num">01</span><span class="name">Trade</span></div>
            <div class="orbit-tags"><span class="tag">Equity</span><span class="div"></span><span class="tag">F&amp;O</span><span class="div"></span><span class="tag">Commodities</span></div>
          </a>
          <a class="orbit-row" href="#pg-invest" data-stage="invest">
            <div class="orbit-stage"><span class="num">02</span><span class="name">Invest</span></div>
            <div class="orbit-tags"><span class="tag">MF</span><span class="div"></span><span class="tag">IPO</span><span class="div"></span><span class="tag">Bonds</span><span class="div"></span><span class="tag">FD</span></div>
          </a>
          <a class="orbit-row" href="#pg-invest" data-stage="earn">
            <div class="orbit-stage"><span class="num">03</span><span class="name">Earn</span></div>
            <div class="orbit-tags"><span class="tag">Interest</span><span class="div"></span><span class="tag">Dividends</span></div>
          </a>
          <a class="orbit-row" href="#pg-invest" data-stage="grow">
            <div class="orbit-stage"><span class="num">04</span><span class="name">Grow</span></div>
            <div class="orbit-tags"><span class="tag">ETFs</span><span class="div"></span><span class="tag">NPS</span><span class="div"></span><span class="tag">SIPs</span></div>
          </a>
          <a class="orbit-row" href="#pg-loans" data-stage="borrow">
            <div class="orbit-stage"><span class="num">05</span><span class="name">Borrow</span></div>
            <div class="orbit-tags"><span class="tag">LAMF</span><span class="div"></span><span class="tag">LAS</span><span class="div"></span><span class="tag">Personal Loan</span></div>
          </a>
          <a class="orbit-row" href="#pg-loans" data-stage="protect">
            <div class="orbit-stage"><span class="num">06</span><span class="name">Protect</span></div>
            <div class="orbit-tags"><span class="tag">Insurance</span><span class="div"></span><span class="tag">Term Plans</span></div>
          </a>
        </div>
        <div class="orbit-viz" aria-hidden="true">
          <svg viewBox="0 0 840 448" fill="none" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <radialGradient id="orbitGlow" cx="50%" cy="50%" r="50%">
                <stop offset="0%" stop-color="#c79a38"></stop>
                <stop offset="45%" stop-color="#7d6a30"></stop>
                <stop offset="75%" stop-color="#454430"></stop>
                <stop offset="100%" stop-color="#2e3223"></stop>
              </radialGradient>
            </defs>
            <!-- breathing gold glow -->
            <ellipse class="orbit-glow" cx="420" cy="224" rx="200" ry="178" fill="url(#orbitGlow)"></ellipse>
            <!-- concentric dashed rings, drifting slowly -->
            <g class="orbit-rings" stroke-width="1">
              <circle cx="420" cy="224" r="120" stroke="#6b7352" stroke-dasharray="2 7"></circle>
              <circle cx="420" cy="224" r="170" stroke="#8b9173" stroke-dasharray="3 6"></circle>
              <circle cx="420" cy="224" r="208" stroke="#5c6545" stroke-dasharray="2 9"></circle>
            </g>
            <!-- stage nodes on the main ring -->
            <g fill="#b7bd9f">
              <circle class="nd" data-stage="trade" cx="335" cy="77" r="4"></circle>
              <circle class="nd" data-stage="grow" cx="505" cy="77" r="4"></circle>
              <circle class="nd" data-stage="earn" cx="250" cy="224" r="4"></circle>
              <circle class="nd" data-stage="borrow" cx="590" cy="224" r="4"></circle>
              <circle class="nd" data-stage="invest" cx="335" cy="371" r="4"></circle>
              <circle class="nd" data-stage="protect" cx="505" cy="371" r="4"></circle>
            </g>
            <!-- stage labels -->
            <g fill="#e9eae9" font-family="Outfit,sans-serif" font-size="20" font-weight="400">
              <text class="lb" data-stage="trade" x="315" y="70" text-anchor="end">Trade</text>
              <text class="lb" data-stage="grow" x="525" y="70" text-anchor="start">Grow</text>
              <text class="lb" data-stage="earn" x="230" y="230" text-anchor="end">Earn</text>
              <text class="lb" data-stage="borrow" x="610" y="230" text-anchor="start">Borrow</text>
              <text class="lb" data-stage="invest" x="315" y="384" text-anchor="end">Invest</text>
              <text class="lb" data-stage="protect" x="525" y="384" text-anchor="start">Protect</text>
            </g>
            <!-- centre -->
            <text x="420" y="214" text-anchor="middle" fill="#ffffff" font-family="Outfit,sans-serif" font-size="30" font-weight="500">Your</text>
            <text x="420" y="252" text-anchor="middle" fill="#ffffff" font-family="Outfit,sans-serif" font-size="30" font-weight="500">Wealth</text>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <!-- ================= GENERAL QUESTIONS ================= -->
  <section class="faq-wrap sec-tint" id="sec-faq" data-section="faq">
    <div class="faq-cols">
      <div class="faq-left">
        <h2 class="faq-title">General Questions</h2>
        <FaqAccordion faqs={FAQS} />
      </div>
      <div class="faq-side">
        <div class="usr"><img src="/assets/user.svg" alt="" /></div>
        <div class="side-in">
          <div class="side-tx">
            <h3>Need A Clearer Direction? </h3>
            <p>Let's get in touch on a 15-Minute call where we would be able to answer any questions you may have. Our Advisor will additionally help map your wealth mix and demonstrate what a dedicated advisor would do differently.</p>
          </div>
          <a class="btn-gold" href="#">Book A Discovery Call</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ================= GATEWAY CTA BAND ================= -->
  <section class="gateway" id="sec-gateway" data-section="gateway">
    <div class="gateway-in">
      <div class="gateway-tx">
        <h2>We are now your new gateway to the Stock Market!</h2>
        <p>Open a Demat account instantly and trade with confidence.</p>
      </div>
      <a class="btn-gold" href="/open-demat-account/">Open A Demat Account</a>
    </div>
  </section>
</BaseLayout>

<style>
  /* ===== products — page-specific only (product-card component lives in global.css §6) ===== */

  /* ===== Orbit feature section (dark) — "Six Financial Stages, One Orbit" ===== */
  /* Own single-use gradient — page-local LITERAL, Tier-2 candidate. */
  .orbit {
    padding: var(--section-y) var(--pad);
    background: radial-gradient(125% 210% at 100% -8%, #4f583b 0%, #363a2c 50%, #1d1d1d 100%);
  }
  .orbit-in {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }
  .orbit-head {
    display: flex;
    flex-direction: column;
    gap: 16px;
    max-width: 731px; /* page-local — Tier-2 candidate */
  }
  .orbit .sec-title {
    color: var(--color-gray-50); /* #f7f7f7 — standard 40px section-title scale, on dark */
  }
  .orbit .sec-lead {
    color: var(--color-sage-100); /* #c9cac7 */
  }

  /* one bordered panel: olive stage list (left) + orbit viz (right) */
  .orbit-panel {
    display: flex;
    align-items: stretch;
    border: 1px solid #4f583b; /* page-local — Tier-2 candidate (matches olive-600 #4f583b) */
    border-radius: 24px;
    overflow: hidden;
  }
  .orbit-list {
    flex: 0 0 48.5%; /* page-local — Tier-2 candidate */
    display: flex;
    flex-direction: column;
    background: #4f583b; /* page-local — Tier-2 candidate (matches olive-600) */
  }
  .orbit-row {
    flex: 1 0 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 24px;
    border-top: 1px solid #5c6545; /* page-local — Tier-2 candidate */
    transition: background 0.25s ease;
  }
  .orbit-row:first-child {
    border-top: 0;
  }
  .orbit-row:hover {
    background: #576142; /* quiet surface shift — page-local, Tier-2 candidate */
  }
  .orbit-stage {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .orbit-stage .num {
    font-weight: 400;
    font-size: 12px;
    color: var(--color-gold-400);
  }
  .orbit-stage .name {
    font-weight: 700;
    font-size: 16px;
    color: #f2eee3; /* page-local — Tier-2 candidate */
  }
  .orbit-tags {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 8px;
    flex-wrap: wrap;
  }
  .orbit-tags .tag {
    font-weight: 400;
    font-size: 16px;
    color: #f2eee3; /* page-local — Tier-2 candidate */
    padding: 8px;
  }
  .orbit-tags .div {
    width: 1px;
    height: 16px;
    background: #7d8564; /* page-local — Tier-2 candidate */
    flex: none;
  }
  .orbit-viz {
    flex: 1 1 auto;
    min-width: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }
  .orbit-viz svg {
    width: 100%;
    max-width: 560px;
    height: auto;
    display: block;
  }

  /* Subtle motion: the dashed rings drift, the glow breathes, and hovering /
     focusing a stage row lights its node + label in the viz. All neutralised
     under prefers-reduced-motion. 120s/7s durations are page-local literals. */
  .orbit-rings {
    transform-origin: 420px 224px;
    animation: orbit-spin 120s linear infinite;
  }
  .orbit-glow {
    transform-origin: 420px 224px;
    animation: orbit-breathe 7s ease-in-out infinite;
  }
  @keyframes orbit-spin {
    to {
      transform: rotate(360deg);
    }
  }
  @keyframes orbit-breathe {
    0%,
    100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.05);
    }
  }
  .orbit-viz .nd,
  .orbit-viz .lb {
    transition: fill 0.25s ease;
  }
  .orbit-viz .nd.lit,
  .orbit-viz .lb.lit {
    fill: var(--color-gold-400);
  }
  @media (prefers-reduced-motion: reduce) {
    .orbit-rings,
    .orbit-glow {
      animation: none;
    }
  }

  /* stage rows deep-link into All Products; keep anchor targets clear of the sticky nav */
  .pgroup {
    scroll-margin-top: 96px;
  }
  @media (prefers-reduced-motion: no-preference) {
    html {
      scroll-behavior: smooth;
    }
  }

  /* ===== Gateway CTA band (dark, full-width bar) — page-local, values EXACT ===== */
  .gateway {
    padding: 40px var(--pad);
    background: radial-gradient(140% 220% at 88% -30%, #3a3f30 0%, #23261c 46%, #1a1a13 100%);
  }
  .gateway-in {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
  }
  .gateway-tx {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .gateway-tx h2 {
    font-weight: 500;
    font-size: 32px;
    color: var(--color-white);
    line-height: 1.5;
  }
  .gateway-tx p {
    font-weight: 400;
    font-size: 16px;
    color: var(--color-sage-100); /* #c9cac7 */
    line-height: 1.5;
  }

  @media (max-width: 900px) {
    .orbit-panel {
      flex-direction: column;
    }
    .orbit-list {
      flex: none;
      width: 100%;
    }
    .orbit-viz {
      width: 100%;
      padding: 32px 24px;
    }
  }
  @media (max-width: 768px) {
    .orbit-head h2,
    .gateway-tx h2 {
      font-size: clamp(24px, 6.4vw, 32px);
    }
    .orbit-head p,
    .gateway-tx p {
      font-size: 14px;
    }
    .orbit-tags .tag {
      font-size: 14px;
    }
    .orbit-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }
    .orbit-tags {
      justify-content: flex-start;
    }
    .gateway-in {
      flex-direction: column;
      align-items: flex-start;
      gap: 24px;
    }
  }
</style>

<script>
  /* Orbit: hovering / focusing a stage row lights its node + label in the viz */
  document.querySelectorAll<HTMLElement>('.orbit-row[data-stage]').forEach((row) => {
    const stage = row.getAttribute('data-stage');
    const marks = document.querySelectorAll<SVGElement>(`.orbit-viz [data-stage="${stage}"]`);
    const on = () => marks.forEach((m) => m.classList.add('lit'));
    const off = () => marks.forEach((m) => m.classList.remove('lit'));
    row.addEventListener('mouseenter', on);
    row.addEventListener('mouseleave', off);
    row.addEventListener('focus', on);
    row.addEventListener('blur', off);
  });
</script>

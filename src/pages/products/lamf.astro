---
/**
 * Loan Against Mutual Funds (LAMF) — /products/lamf/
 * Long-form product page. Built entirely from the shared design-system
 * components in global.css (hero, .section/.sec-title, .card, .steps,
 * .product-page_table, .check-card, .risks, FaqAccordion, .cta-box).
 * The only page-scoped CSS is a generic responsive card grid (.lamf-cards),
 * token-bound. Nested route → BaseLayout / component imports at ../../ depth.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import FaqAccordion from '../../components/sections/FaqAccordion.astro';
import { faqPageSchema, breadcrumbSchema, organizationSchema } from '../../lib/seo';

// How a Loan Against Mutual Funds works — five steps.
const STEPS = [
  { h: 'Select Your Mutual Fund Holdings', p: 'Choose the equity or debt fund units you want to pledge from your demat or statement-of-account (SoA) folios.' },
  { h: 'Pledge Digitally via RTA / Depository', p: 'Mark a lien on the units online through the RTA (CAMS/KFintech) or your depository (NSDL/CDSL) — no physical paperwork.' },
  { h: 'Get a Sanctioned Overdraft Limit', p: 'A credit limit is set as a percentage of the current NAV of your pledged units, typically within a working day.' },
  { h: 'Withdraw Funds as Needed', p: 'Draw down against the limit whenever you need cash, in part or in full, straight to your linked bank account.' },
  { h: 'Pay Interest Only on What You Use', p: 'Interest accrues only on the amount actually utilised — repay and re-draw flexibly, while your units stay invested.' },
];

// LAMF vs redeeming vs personal loan.
const COMPARE = [
  { k: 'Stays Invested', l: 'Yes — units remain in your name and keep compounding', r: 'No — you sell and exit the market', p: 'Not applicable' },
  { k: 'Cost', l: 'Interest only on the amount used', r: 'No interest, but exit load / opportunity cost', p: 'Higher interest on the full sanctioned amount' },
  { k: 'Speed of Access', l: 'Quick — digital pledge, often same day', r: 'T+1 to T+3 for redemption proceeds', p: 'Days — full underwriting and approval' },
  { k: 'Tax Event', l: 'No sale, so no capital-gains tax triggered', r: 'Redemption triggers capital-gains tax', p: 'No sale, no tax event' },
  { k: 'Best Suited For', l: 'Short-term liquidity without breaking investments', r: 'When you no longer want to hold the units', p: 'Unsecured, one-off funding needs' },
];

// Risks to weigh with a Loan Against Mutual Funds.
const RISKS = [
  { h: 'Margin Call on Market Fall', p: "If markets fall and your pledged units' value drops below the required cover, the lender can ask you to top up funds or pledge more units at short notice." },
  { h: 'Interest Cost', p: 'Interest accrues on every rupee you utilise. If a drawdown stays outstanding for long, the cumulative interest can outweigh the convenience of not redeeming.' },
  { h: 'Pledged Units Are Locked', p: "You can't redeem, switch or transfer pledged units until the lien is released. This can limit your ability to rebalance or exit during volatile markets." },
  { h: 'Forced Sale Risk', p: 'If a margin call is not met, the lender is entitled to invoke the pledge and sell your units — potentially at an unfavourable price and triggering a capital-gains tax event.' },
];

// General Questions — plain-text answers, shared with the FAQPage schema.
const FAQS = [
  {
    q: 'What is a Loan Against Mutual Funds?',
    a: 'A Loan Against Mutual Funds (LAMF) is a secured overdraft where you pledge your mutual fund units as collateral to a lender and receive a credit limit against them. You continue to own the units and stay invested, while borrowing against their value and paying interest only on the amount you actually use.',
  },
  {
    q: 'How much loan can I get against my mutual funds?',
    a: 'The sanctioned limit is a percentage of the current NAV of your pledged units. For equity mutual funds the loan-to-value is typically around 50%, while for debt mutual funds it can be higher — often up to about 80% — because debt funds are less volatile.',
  },
  {
    q: 'Do I have to sell my mutual fund units to take this loan?',
    a: 'No. You only pledge the units — they remain in your name and continue to earn returns. Because there is no sale, no capital-gains tax is triggered, and the units keep compounding while you borrow against them.',
  },
  {
    q: 'How is the interest charged on a Loan Against Mutual Funds?',
    a: 'Interest is charged only on the amount you actually draw down, not on the full sanctioned limit. This works like an overdraft — if you use a smaller portion of the limit, you pay interest only on that portion for the days it stays outstanding.',
  },
  {
    q: 'What happens if the market falls after I pledge my units?',
    a: 'If the value of your pledged units falls below the required cover, the lender may issue a margin call asking you to repay part of the loan or pledge additional units. If the margin call is not met, the lender can invoke the pledge and sell units to recover dues.',
  },
  {
    q: 'Can I still redeem or switch my pledged units?',
    a: 'No. Once a lien is marked, the pledged units are locked and cannot be redeemed, switched or transferred until the loan is repaid and the lien is released. Any units not pledged remain fully available to you.',
  },
  {
    q: 'How quickly can I get the funds?',
    a: 'Because the pledge is done digitally through the RTA or depository, a Loan Against Mutual Funds can usually be sanctioned within a working day, and drawdowns are credited to your linked bank account soon after — far faster than an unsecured personal loan.',
  },
];

const site = Astro.site!.href;

const seo = {
  title: 'Loan Against Mutual Funds (LAMF) — Borrow Without Redeeming | Shriram Financial Services',
  description:
    'Pledge your mutual fund units for an instant overdraft limit — stay invested, pay interest only on what you use. Understand LAMF loan-to-value, interest, eligibility and risks with Shriram.',
  path: '/products/lamf/',
  jsonLd: [
    faqPageSchema(FAQS.map((f) => ({ question: f.q, answer: f.a }))),
    breadcrumbSchema(
      [
        { name: 'Home', path: '/' },
        { name: 'Products', path: '/products/' },
        { name: 'Loan Against Mutual Funds', path: '/products/lamf/' },
      ],
      site
    ),
    organizationSchema(site),
  ],
};
---

<BaseLayout seo={seo}>
  <!-- ===== Hero ===== -->
  <section class="hero" id="sec-hero" data-section="hero">
    <div class="hero-inner">
      <h1>Unlock Cash <span class="g">Without Redeeming</span> Your Mutual Funds</h1>
      <p class="lead">Pledge your mutual fund units for an instant overdraft limit — stay invested, keep compounding, and pay interest only on the amount you actually use.</p>
      <div class="cta"><a class="btn-gold" href="/demat/">Open Demat Account</a></div>
      <div class="hero-feats">
        <div class="feats">
          <div class="feat"><span class="tk" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span><span class="lb">&nbsp;Stay invested</span></div>
          <div class="feat"><span class="tk" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span><span class="lb">&nbsp;Overdraft on units</span></div>
          <div class="feat"><span class="tk" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span><span class="lb">&nbsp;Interest only on usage</span></div>
          <div class="feat"><span class="tk" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span><span class="lb">&nbsp;Quick digital pledge</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== What Is a Loan Against Mutual Funds ===== -->
  <section class="section stack sec-light" id="sec-about" data-section="about" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">What Is a Loan Against Mutual Funds?</h2>
      <p class="sec-lead">A Loan Against Mutual Funds (LAMF) is a secured line of credit that lets you borrow money by pledging your mutual fund units instead of selling them. You mark a lien on your units, the lender sanctions an overdraft limit against their current value, and you draw down cash whenever you need it — paying interest only on the amount you actually use. Your units stay in your name, continue to earn returns, and no capital-gains tax is triggered because nothing is sold.</p>
    </div>
    <div class="stack" style="gap:32px">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">Why Borrow Against Your Funds?</h3>
        <p class="sub-lead">The core reasons investors use a pledge instead of redeeming their holdings.</p>
      </div>
      <div class="row-2">
        <div class="card" style="border-color:var(--color-border-card)">
          <h4 class="card-h">Stay Invested and Keep Compounding</h4>
          <p class="card-p">Your units remain invested and continue to grow with the market. You meet a short-term cash need without breaking a long-term investment or resetting your compounding.</p>
        </div>
        <div class="card" style="border-color:var(--color-border-card)">
          <h4 class="card-h">Pay Interest Only on What You Use</h4>
          <p class="card-p">The sanctioned limit sits ready like an overdraft. Interest accrues only on the amount drawn, for the days it stays outstanding — not on the full limit.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== How LAMF Works ===== -->
  <section class="section stack sec-tint" id="sec-how" data-section="how" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">How a Loan Against Mutual Funds Works</h2>
      <p class="sec-lead" style="color:var(--color-text-secondary)">Five simple steps from selecting your holdings to drawing down funds — entirely digital.</p>
    </div>
    <div class="stack" style="gap:32px;width:100%">
      <div class="steps">
        {STEPS.slice(0, 3).map((s, i) => (
          <>
            {i > 0 && <div class="step-div" />}
            <div class="step"><div class="num">{i + 1}</div><div class="st-body"><h4>{s.h}</h4><p>{s.p}</p></div></div>
          </>
        ))}
      </div>
      <div class="steps">
        {STEPS.slice(3).map((s, i) => (
          <>
            {i > 0 && <div class="step-div" />}
            <div class="step"><div class="num">{i + 4}</div><div class="st-body"><h4>{s.h}</h4><p>{s.p}</p></div></div>
          </>
        ))}
      </div>
    </div>
    <a class="btn-gold" href="/demat/" style="align-self:center">Open Demat Account</a>
  </section>

  <!-- ===== Loan-to-Value & Interest ===== -->
  <section class="section stack sec-light" id="sec-ltv" data-section="ltv" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Loan-to-Value &amp; Interest</h2>
      <p class="sec-lead">How much you can borrow depends on the type of fund you pledge — debt funds command a higher loan-to-value than equity funds because they are less volatile. Indicative terms are shown below; final terms depend on the lender and your portfolio.</p>
    </div>
    <div class="t-scroll"><div class="product-page_table t3 bordered">
      <div class="cell th"><p>Parameter</p></div><div class="cell th"><p>Equity Mutual Funds</p></div><div class="cell th"><p>Debt Mutual Funds</p></div>
      <div class="cell tb"><p class="k">Loan-to-Value (LTV)</p></div><div class="cell tb"><p class="v">Up to ~50% of NAV</p></div><div class="cell tb"><p class="v">Up to ~80% of NAV</p></div>
      <div class="cell tb"><p class="k">Interest Rate (indicative)</p></div><div class="cell tb"><p class="v">~9% – 12% p.a.</p></div><div class="cell tb"><p class="v">~9% – 12% p.a.</p></div>
      <div class="cell tb"><p class="k">Interest Charged On</p></div><div class="cell tb"><p class="v">Amount utilised only</p></div><div class="cell tb"><p class="v">Amount utilised only</p></div>
      <div class="cell tb"><p class="k">Processing Fee</p></div><div class="cell tb"><p class="v">One-time, nominal</p></div><div class="cell tb"><p class="v">One-time, nominal</p></div>
      <div class="cell tb"><p class="k">Minimum Limit</p></div><div class="cell tb"><p class="v">From ₹25,000</p></div><div class="cell tb"><p class="v">From ₹25,000</p></div>
      <div class="cell tb"><p class="k">Maximum Limit</p></div><div class="cell tb"><p class="v">Up to ₹1 crore+</p></div><div class="cell tb"><p class="v">Up to ₹1 crore+</p></div>
    </div></div>
    <a class="btn-gold" href="/demat/" style="align-self:center">Open Demat Account</a>
  </section>

  <!-- ===== Eligibility & Documents ===== -->
  <section class="section stack sec-tint" id="sec-eligibility" data-section="eligibility" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Eligibility &amp; Documents</h2>
      <p class="sec-lead" style="color:var(--color-text-secondary)">What you need to qualify for a Loan Against Mutual Funds and complete the digital pledge.</p>
    </div>
    <div class="row-2">
      <div class="card check-card">
        <h4 class="ch-title">Eligibility Criteria</h4>
        <div class="check-list">
          <div class="check-row"><span class="ck" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span><p class="tx">Indian resident individual, 18+ years of age</p></div>
          <div class="check-sep"></div>
          <div class="check-row"><span class="ck" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span><p class="tx">Completed KYC with the RTA or depository</p></div>
          <div class="check-sep"></div>
          <div class="check-row"><span class="ck" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span><p class="tx">Mutual fund units held in your own name (demat or SoA folio)</p></div>
          <div class="check-sep"></div>
          <div class="check-row"><span class="ck" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span><p class="tx">Units in an approved, lien-markable scheme</p></div>
          <div class="check-sep"></div>
          <div class="check-row"><span class="ck" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span><p class="tx">Holdings meeting the lender's minimum pledge value</p></div>
        </div>
      </div>
      <div class="card check-card">
        <h4 class="ch-title">Documents Required</h4>
        <div class="check-list">
          <div class="check-row"><span class="ck" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span><p class="tx">PAN card (mandatory)</p></div>
          <div class="check-sep"></div>
          <div class="check-row"><span class="ck" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span><p class="tx">Aadhaar card for identity verification</p></div>
          <div class="check-sep"></div>
          <div class="check-row"><span class="ck" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span><p class="tx">Consolidated Account Statement (CAS) of your MF holdings</p></div>
          <div class="check-sep"></div>
          <div class="check-row"><span class="ck" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span><p class="tx">Cancelled cheque or bank statement of the linked account</p></div>
          <div class="check-sep"></div>
          <div class="check-row"><span class="ck" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span><p class="tx">Valid mobile number and email ID for OTP-based pledge</p></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== LAMF vs Redeeming vs Personal Loan ===== -->
  <section class="section stack sec-light" id="sec-compare" data-section="compare" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">LAMF vs Redeeming vs Personal Loan</h2>
      <p class="sec-lead">Three ways to raise cash — pledging your units, selling them, or taking an unsecured loan. Here is how they compare on the factors that matter most.</p>
    </div>
    <div class="t-scroll"><div class="product-page_table t4 bordered">
      <div class="cell th"><p>Factor</p></div><div class="cell th"><p>Loan Against MF</p></div><div class="cell th"><p>Redeeming Units</p></div><div class="cell th"><p>Personal Loan</p></div>
      {COMPARE.map((c) => (
        <>
          <div class="cell tb"><p class="k">{c.k}</p></div>
          <div class="cell tb"><p class="v">{c.l}</p></div>
          <div class="cell tb"><p class="v">{c.r}</p></div>
          <div class="cell tb"><p class="v">{c.p}</p></div>
        </>
      ))}
    </div></div>
    <a class="btn-gold" href="/demat/" style="align-self:center">Open Demat Account</a>
  </section>

  <!-- ===== Risks to Weigh ===== -->
  <section class="section stack sec-tint" id="sec-risks" data-section="risks" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Risks to Weigh</h2>
      <p class="sec-lead" style="color:var(--color-text-secondary)">A pledge is convenient, but it is still borrowing against a market-linked asset. Understand what can move against you before you draw down.</p>
    </div>
    <div class="risks">
      {RISKS.map((r) => (
        <div class="risk"><h4>{r.h}</h4><p>{r.p}</p></div>
      ))}
    </div>
  </section>

  <!-- ===== General Questions ===== -->
  <section class="faq-wrap sec-tint" id="sec-faq" data-section="faq">
    <div class="faq-cols">
      <div class="faq-left">
        <h2 class="faq-title">General Questions</h2>
        <FaqAccordion faqs={FAQS} />
      </div>
      <div class="faq-side">
        <div class="usr"><img src="/assets/user.svg" alt="" /></div>
        <div class="side-in">
          <div class="side-tx">
            <h3>Need A Clearer Direction?</h3>
            <p>Let's get in touch on a 15-minute call where we can answer any questions you may have. Our advisor will help you weigh a pledge against redeeming and show what a dedicated, research-led plan would do differently.</p>
          </div>
          <a class="btn-gold" href="/support/">Book A Discovery Call</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Final CTA ===== -->
  <section class="cta-sec sec-light" id="sec-final-cta" data-section="final-cta">
    <div class="cta-box">
      <div class="ct-tt">
        <h3>Borrow Against Your Funds Without Selling</h3>
        <p class="ct-sub">Open your Demat account in minutes and pledge your mutual fund units with zero paperwork.</p>
      </div>
      <a class="btn-gold" href="/demat/">Open Demat Account</a>
    </div>
  </section>
</BaseLayout>

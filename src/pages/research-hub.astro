---
/**
 * Research Centre - /research-hub
 *
 * Body content is the compliance-approved "Research Hub - Webpage Content" doc,
 * implemented word-for-word in the shared design system: the standardised olive
 * hero (rule 7), shared section / card / .appr research cards / FAQ / CTA
 * components, plus the page-local blocks (icon feature grid, dark access band,
 * alerts columns). Every value binds to a token (rule 9).
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/site/Breadcrumb.astro';
import FaqAccordion from '../components/sections/FaqAccordion.astro';
import { faqPageSchema } from '../lib/seo';

// SECTION 3 - "All-In-One Research Desk", six capability cards (doc verbatim).
const DESK = [
  { icon: 'calendar', title: 'Daily & weekly notes', body: 'A pre-market note is ready before the opening bell every trading day — so by the time the market opens, you already know the levels to watch and the trades worth considering.' },
  { icon: 'bars', title: 'Stock & sector coverage', body: 'From banking and IT to pharma and commodities, our analysts track key sectors quarterly and flag changes in outlook before they show up in price.' },
  { icon: 'candles', title: 'Technical levels, marked', body: 'Support, resistance, and targets are not approximate — they are charted, quantified, and updated so you know exactly what to watch before placing a trade.' },
  { icon: 'search', title: 'Fundamental deep dives', body: 'Margins, debt trends, and what management is actually saying — our analysts read through the filings so you understand why a stock is where it is, not just what price it is trading at.' },
  { icon: 'clock', title: 'Mutual fund flow tracking', body: 'Where SIP money, NFOs, and category flows are heading each month — because the direction of managed money often leads where price goes next.' },
  { icon: 'shield', title: 'One desk, three disciplines', body: 'Technical, fundamental, and mutual fund research sit inside a single platform. You do not need three subscriptions or three logins to build a complete picture.' },
];

// SECTION 4 - "Explore Our Research Types", three research streams (doc verbatim).
const TYPES = [
  {
    kicker: 'Technical Research', title: 'Charts, Levels & Trade Setups', href: '/technical-analysis',
    body: 'Our technical analysts read market structure, not headlines. Each report identifies high-probability trade setups using price action, volume patterns, and momentum — with defined entry levels, targets, and stop losses. Published daily for indices and high-volume stocks.',
    tags: ['Intraday calls', 'Swing trades', 'Index outlook', 'Option levels', 'Daily & weekly'],
  },
  {
    kicker: 'Fundamental Research', title: 'Business Analysis & Stock Ideas', href: '/fundamental-analysis',
    body: 'Our fundamental team looks past the quarterly noise to assess what a business is genuinely worth. Reports cover earnings quality, management track record, sector positioning, and valuation — giving you a long-term conviction, not just a short-term signal.',
    tags: ['Stock ideas', 'Sector notes', 'Quarterly results', 'Company profiles', 'Target price'],
  },
  {
    kicker: 'Mutual Fund Research', title: 'Scheme Analysis & Portfolio Guidance', href: '/mutual-fund-analysis',
    body: "Choosing a mutual fund should not depend on a distributor's incentive. Our analysts evaluate fund performance against peers and benchmarks, assess portfolio overlap, and track consistency of returns — so you invest in funds that suit your goal, not just the top-ranked list.",
    tags: ['Fund reviews', 'Category comparisons', 'SIP recommendations', 'NFO analysis', 'Portfolio overlap'],
  },
];

// SECTION 5 - "Why Shriram Financial Services Research?", three cards (doc verbatim).
const WHY = [
  { icon: 'globe', title: 'Multi-Asset Coverage', body: 'Equity, derivatives, debt, and mutual funds — tracked across asset classes and sectors so you get a complete view, not a fragment of one.' },
  { icon: 'target', title: 'Actionable Insights', body: 'Every note ends with a clear recommendation — buy, hold, reduce, or exit — and defines the price levels that trigger each. A view without a price is not useful to a trader. We do not publish those.' },
  { icon: 'users', title: 'Institutional-Grade Research', body: 'The kind of research that fund houses and proprietary trading desks rely on — company-level analysis, sector positioning, valuation models — is now part of your Shriram Financial Services account.' },
];

// SECTION 7 - "Market Alerts & Commentary", two columns each with a "how to"
// walk-through (doc verbatim).
const ALERTS = [
  {
    icon: 'bell', title: 'Market Alerts',
    body: 'By the time you read an analyst call an hour after it was published, the stock has usually already moved. Market Alerts push research calls to your phone the moment an analyst publishes — not a digest at the end of the day, but a live notification so you can look at the trade while it is still relevant. Alerts cover every research type — technical trade calls, fundamental buy and sell recommendations, and mutual fund updates. Turn them on once in the app settings.',
    howTitle: 'How to Get Research',
    steps: [
      'Login to your account on the Antara application.',
      'Navigate to Research section available in Dashboard.',
    ],
  },
  {
    icon: 'chat', title: 'Market Commentary',
    body: 'A market view written at 8:30 am can look outdated by 11 am. Something breaks in the US session, a large FII block goes through, a sector starts rotating — the picture changes. Our analyst desk publishes commentary three times every trading day — before the market opens, mid-session as trade develops, and at the end of day. Each update covers index direction, sector rotation, key support and resistance levels, FII and DII activity, and what to watch going into the next session.',
    howTitle: 'How to Check Market Commentary',
    steps: [
      'Login to your account on the Antara application.',
      'Navigate to News & Updates section available in Dashboard.',
    ],
  },
];

// SECTION 8 - Frequently Asked Questions (doc verbatim; first item open). The
// rendered header stays "General Questions" (project rule 13).
const FAQS = [
  {
    q: 'What is Shriram Research?',
    a: 'Shriram Research is the equity and commodity research division of Shriram Financial Services. Our analysts — registered with SEBI — publish technical analysis, fundamental stock reports, and sector-level mutual fund insights every trading day. The research is produced by qualified professionals, not algorithmically generated, and covers buy/sell recommendations with defined price targets and stop-loss levels.',
  },
  {
    q: 'What types of research reports are available?',
    a: 'We publish three categories of research: Technical Research (daily trade setups, intraday and swing trading calls for indices and stocks), Fundamental Research (company analysis, quarterly result reviews, sector notes with long-term investment recommendations), and Mutual Fund Research (scheme comparisons, SIP guidance, NFO evaluations, and portfolio overlap analysis). Market commentary is also published three times daily.',
  },
  {
    q: 'Do I need to login to read the reports?',
    a: 'To download the complete report, read in-depth analysis, and enable real-time research alerts, you will need to log in to your Antara account. If you do not have an account, you can open a demat account — the process is digital and takes very less time.',
  },
  {
    q: 'Is the research free for clients?',
    a: 'Yes. Research access is included as part of your Shriram Financial Services demat and trading account — there is no separate subscription fee. Once your account is active, you get full access to all published reports, market commentary, and research alerts through the Antara app and the website.',
  },
  {
    q: 'How often are reports published?',
    a: 'Technical research notes and market commentary are published every trading day. Fundamental research is published on an event-driven schedule — typically when quarterly results are announced, when a sector development warrants a view, or when an analyst changes recommendation on a covered stock. Mutual fund reviews are typically published monthly, with NFO analysis as and when new funds are launched.',
  },
];

const seo = {
  title: 'Stock Market Research Centre',
  description:
    'Access technical, fundamental and mutual fund research to make informed investing decisions with SEBI-registered Shriram Financial Services.',
  path: '/research-hub',
  jsonLd: [faqPageSchema(FAQS.map((f) => ({ question: f.q, answer: f.a })))],
};
---

<BaseLayout seo={seo} mainClass="rev-rise-scale">
  <!-- Inline icon set - every glyph is a real <svg> (rule 4), sized 16/20/24. -->
  <svg width="0" height="0" style="position:absolute" aria-hidden="true">
    <defs>
      <g id="ri-calendar"><rect x="4" y="5" width="16" height="15" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M4 9h16M8 3v4M16 3v4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></g>
      <g id="ri-bars"><path d="M5 20V11M12 20V4M19 20v-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></g>
      <g id="ri-candles"><path d="M8 3v3M8 15v6M16 3v6M16 18v3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><rect x="5.5" y="6" width="5" height="9" rx="1" stroke="currentColor" stroke-width="1.6"/><rect x="13.5" y="9" width="5" height="9" rx="1" stroke="currentColor" stroke-width="1.6"/></g>
      <g id="ri-search"><circle cx="11" cy="11" r="6" stroke="currentColor" stroke-width="1.6"/><path d="m20 20-4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></g>
      <g id="ri-clock"><circle cx="12" cy="12" r="8" stroke="currentColor" stroke-width="1.6"/><path d="M12 8v4l3 2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></g>
      <g id="ri-shield"><path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6l7-3Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="m9 12 2 2 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></g>
      <g id="ri-globe"><circle cx="12" cy="12" r="8.5" stroke="currentColor" stroke-width="1.6"/><path d="M3.5 12h17M12 3.5c2.5 2.4 3.8 5.4 3.8 8.5S14.5 18.1 12 20.5C9.5 18.1 8.2 15.1 8.2 12S9.5 5.9 12 3.5Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></g>
      <g id="ri-target"><circle cx="12" cy="12" r="8.5" stroke="currentColor" stroke-width="1.6"/><circle cx="12" cy="12" r="4.5" stroke="currentColor" stroke-width="1.6"/><circle cx="12" cy="12" r="1.2" fill="currentColor"/></g>
      <g id="ri-users"><circle cx="9" cy="8" r="3.2" stroke="currentColor" stroke-width="1.6"/><path d="M3.5 20c0-3.3 2.5-5.5 5.5-5.5s5.5 2.2 5.5 5.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><path d="M16 5.2A3.2 3.2 0 0 1 18 11m-.5 3.8c2.1.6 3.5 2.5 3.5 5.2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></g>
      <g id="ri-bell"><path d="M6 9a6 6 0 0 1 12 0c0 5 2 6 2 6H4s2-1 2-6Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="M10 19a2 2 0 0 0 4 0" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></g>
      <g id="ri-chat"><path d="M4 6a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H9l-4 4v-4H6a2 2 0 0 1-2-2V6Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="M8 9h8M8 12h5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></g>
    </defs>
  </svg>

  <!-- ================= SECTION 1 - HERO BANNER (standardised, rule 7) ================= -->
  <section class="hero" id="sec-hero" data-section="hero">
    <Breadcrumb trail={[{ name: 'Research Hub' }]} />
    <div class="hero-inner" data-enter>
      <h1>Shriram Financial Services <span class="g">Research Hub</span></h1>
      <p class="lead">Institutional-grade financial research — produced daily by certified analysts. Access the full reports by logging in or opening your demat account.</p>
      <div class="cta"><a class="btn-gold" href="/open-demat-account">Open Demat Account</a></div>
      <div class="hero-feats">
        <div class="feats">
          <div class="feat"><span class="tk" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span><span class="lb">&nbsp;100+ Reports published monthly</span></div>
          <div class="feat"><span class="tk" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span><span class="lb">&nbsp;Daily Market commentary, every session</span></div>
          <div class="feat"><span class="tk" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span><span class="lb">&nbsp;SEBI Registered Research Analysts</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================= SECTION 2 - WHAT IS RESEARCH & WHY DOES IT MATTER? ================= -->
  <section class="section stack sec-light" id="sec-what" data-section="what" style="gap:56px;justify-content:center" data-enter="2">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">What is Research &amp; Why Does It Matter?</h2>
      <p class="sec-lead">Ask most investors why they bought a particular stock and the honest answer usually involves a tip from someone, a headline they half-read, or a feeling that it was the right time. That works occasionally. It does not work reliably. What separates investors who build wealth over time from those who do not is usually access to better information — and more importantly, a method for using it.</p>
      <p class="sec-lead">That is what research does. At Shriram Financial Services, our analysts go through price charts, company financials, sector data, and economic indicators every day — not to tell you what the market will do, because nobody knows that, but to tell you whether a security is worth owning at today’s price and what it should be worth in six or twelve months.</p>
      <p class="sec-lead">Good research also gives you something harder to quantify — it keeps you out of bad situations. Panic selling on a rough day, buying a stock just because it has been going up, holding something that has stopped working because admitting a mistake feels worse than sitting on a loss — these are portfolio killers. Our reports are written to give you a clear view: buy here, target there, exit if this happens.</p>
      <p class="sec-lead">Shriram Financial Services Research covers three disciplines — technical, fundamental, and mutual fund — published by dedicated analyst teams every trading day. You do not need to piece together analysis from three different sources. It is all in one place, inside your trading account.</p>
    </div>
  </section>

  <!-- ================= SECTION 3 - ALL-IN-ONE RESEARCH DESK ================= -->
  <section class="section stack sec-tint" id="sec-desk" data-section="desk" style="gap:56px">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">All-In-One Research Desk</h2>
      <p class="sec-lead">Six reasons serious investors use our research every morning.</p>
    </div>
    <div class="feat-grid" data-reveal-row>
      {DESK.map((c) => (
        <article class="fcard">
          <span class="fic" aria-hidden="true"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><use href={`#ri-${c.icon}`} /></svg></span>
          <h3>{c.title}</h3>
          <p>{c.body}</p>
        </article>
      ))}
    </div>
  </section>

  <!-- ================= SECTION 4 - EXPLORE OUR RESEARCH TYPES ================= -->
  <section class="section stack sec-light" id="sec-types" data-section="types" style="gap:56px">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Explore Our Research Types</h2>
      <p class="sec-lead">Whether you trade intraday, invest for the long term, or build wealth steadily through SIPs — there is a dedicated research stream for you. Each type is produced by specialist analysts and published on a fixed schedule.</p>
    </div>
    <div class="approaches" data-reveal-row>
      {TYPES.map((t) => (
        <a class="appr" href={t.href}>
          <div class="appr-main">
            <p class="idx">{t.kicker}</p>
            <div class="appr-tt">
              <h4>{t.title}</h4>
              <p>{t.body}</p>
              <div class="rtags">
                {t.tags.map((tag) => <span class="rtag">{tag}</span>)}
              </div>
            </div>
            <div class="explore"><span>Explore&nbsp;</span><span aria-hidden="true"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 8h11M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span></div>
          </div>
        </a>
      ))}
    </div>
    <div style="display:flex"><a class="btn-gold" href="/open-demat-account">Open Demat Account</a></div>
  </section>

  <!-- ================= SECTION 5 - WHY SHRIRAM FINANCIAL SERVICES RESEARCH? ================= -->
  <section class="section stack sec-tint" id="sec-why" data-section="why" style="gap:56px">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Why Shriram Financial Services Research?</h2>
      <p class="sec-lead">Open any financial app in India right now and you will find market commentary — from analysts, influencers, news desks, and people on social media who started posting about stocks three months ago. Volume is not the problem. The problem is knowing which of it is worth reading before you place a trade.</p>
      <p class="sec-lead">Our curated Research services are from our Research Analyst Team (SEBI Registration No- INH200008705) and Every call is attributed to a specific analyst, every report has a timestamp, and when the view changes — because markets change — we update the recommendation and explain what shifted. You can see the track record. That accountability is something anonymous tips and algorithmic screeners cannot offer.</p>
    </div>
    <div class="feat-grid" data-reveal-row>
      {WHY.map((c) => (
        <article class="fcard">
          <span class="fic" aria-hidden="true"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><use href={`#ri-${c.icon}`} /></svg></span>
          <h3>{c.title}</h3>
          <p>{c.body}</p>
        </article>
      ))}
    </div>
  </section>

  <!-- ================= SECTION 6 - GET FULL ACCESS TO IN-DEPTH INSIGHTS - dark band ================= -->
  <section class="section stack sec-light" id="sec-access" data-section="access" style="gap:0;align-items:center;justify-content:center">
    <div class="access-band">
      <span class="access-ic" aria-hidden="true">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="5" y="11" width="14" height="9" rx="2" stroke="currentColor" stroke-width="1.6"></rect><path d="M8 11V8a4 4 0 0 1 8 0v3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path></svg>
      </span>
      <h2>Access Full Research Reports</h2>
      <p>Report titles and overviews are public. To read the complete analysis, download PDFs, and receive daily alerts, login or open your free demat account.</p>
      <div class="access-cta">
        <a class="btn-gold" href="/open-demat-account">Open Demat Account</a>
        <a class="btn-outline" href="#">Existing Client Login</a>
      </div>
    </div>
  </section>

  <!-- ================= SECTION 7 - MARKET ALERTS & COMMENTARY ================= -->
  <section class="section stack sec-tint" id="sec-alerts" data-section="alerts" style="gap:56px">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Market Alerts &amp; Commentary</h2>
      <p class="sec-lead">Staying informed between full reports is as important as reading them. The research desk keeps you connected to live market developments through two channels — instant alerts for calls and a structured three-times-daily commentary feed.</p>
    </div>
    <div class="row-2" data-reveal-row>
      {ALERTS.map((a) => (
        <div class="card">
          <div class="al-head">
            <span class="fic" aria-hidden="true"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><use href={`#ri-${a.icon}`} /></svg></span>
            <h3 class="card-h">{a.title}</h3>
          </div>
          <p class="card-p">{a.body}</p>
          <div class="how">
            <h4>{a.howTitle}</h4>
            <ol class="asteps">
              {a.steps.map((s, i) => (
                <li class="astep"><span class="anum">{i + 1}</span><span class="atx">{s}</span></li>
              ))}
            </ol>
          </div>
        </div>
      ))}
    </div>

    <!-- feature CTA bar - dark focus band -->
    <div class="get-access">
      <h3>To get access to this feature now:</h3>
      <div class="ga-cta">
        <a class="btn-gold" href="#">Login Now</a>
        <a class="btn-outline" href="/open-demat-account">Open Demat Account</a>
      </div>
    </div>
  </section>

  <!-- ================= SECTION 8 - FREQUENTLY ASKED QUESTIONS ================= -->
  <section class="faq-wrap sec-light" id="sec-faq" data-section="faq">
    <div class="faq-cols">
      <div class="faq-left">
        <h2 class="faq-title">Got Questions?</h2>
        <FaqAccordion faqs={FAQS} />
      </div>
      <div class="faq-side">
        <div class="usr"><img src="/assets/user.svg" alt="" /></div>
        <div class="side-in">
          <div class="side-tx">
            <h3>Need A Clearer Direction?</h3>
            <p>Let's get in touch on a 15-minute call where we can answer any questions you may have. Our advisor will help map your wealth mix and show what a dedicated research-led plan would do differently.</p>
          </div>
          <a class="btn-gold" href="/contact-us">Book A Discovery Call</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ===== Research Centre - page-local components only. Every value binds to a
     design token; shared hero/section/card/.approaches/FAQ/CTA come from
     global.css. The genuinely-new blocks are the icon feature grid (reused by
     the desk + why sections), the dark access band, and the alerts columns. */
  .section,
  .cta-sec {
    scroll-margin-top: 96px;
  }

  /* ===== Icon feature grid (DESK + WHY) ===== */
  .feat-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 32px; width: 100%; }
  .fcard {
    background: var(--color-surface-card); border: 1px solid var(--color-border-card);
    border-radius: 24px; padding: var(--container-pad);
    display: flex; flex-direction: column; gap: 16px;
    transition: border-color 0.22s ease;
  }
  @media (min-width: 1200px) and (hover: hover) {
    .fcard:hover { border-color: var(--color-sage-450); }
  }
  /* icon tile - 48px container (8px grid), warm gold tint + olive brand icon */
  .fic { width: 48px; height: 48px; flex: none; border-radius: 12px; background: var(--color-gold-100); color: var(--color-text-heading-dark); display: inline-flex; align-items: center; justify-content: center; }
  .fic svg { width: 24px; height: 24px; display: block; }
  .fcard h3 { font-weight: 500; font-size: 20px; color: var(--color-text-primary); }
  .fcard p { font-weight: 400; font-size: 16px; color: var(--color-text-muted); }

  /* ===== Research-type tag chips (inside the shared .appr cards) ===== */
  .rtags { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 4px; }
  .rtag {
    padding: 4px 12px; border-radius: 999px; font-weight: 500; font-size: 12px;
    color: var(--color-text-on-dark-lead); border: 1px solid var(--color-olive-700);
  }

  /* ===== Access band (Get Full Access) - centred dark focus band. The
     wireframe's saturated blue is remapped to the site's olive focus palette so
     the page stays inside one token set. Solid hex only. ===== */
  .access-band {
    width: 100%; border-radius: 24px; padding: 64px var(--container-pad);
    background: radial-gradient(125% 210% at 0% -8%, var(--color-olive-600) 0%, var(--color-olive-800) 50%, var(--color-charcoal-850) 100%);
    display: flex; flex-direction: column; align-items: center; text-align: center; gap: 16px;
  }
  .access-ic { width: 48px; height: 48px; flex: none; border-radius: 12px; background: var(--color-olive-800); color: var(--color-gold-400); display: inline-flex; align-items: center; justify-content: center; margin-bottom: 8px; }
  .access-band h2 { font-weight: 500; font-size: 40px; color: var(--color-white); }
  .access-band p { font-weight: 400; font-size: 16px; color: var(--color-text-on-dark-lead); max-width: 640px; }
  .access-cta { display: flex; gap: 16px; flex-wrap: wrap; justify-content: center; margin-top: 24px; }
  .access-cta .btn-gold { width: auto; min-width: var(--cta-w); padding: 8px 24px; }

  /* ===== Market alerts / commentary columns ===== */
  .row-2 .card { display: flex; flex-direction: column; gap: 16px; }
  .al-head { display: flex; align-items: center; gap: 16px; }
  /* nested "how to check" block - a hairline-bordered panel inside the card */
  .how {
    margin-top: 8px; padding: 24px; border-radius: 16px;
    background: var(--color-surface-section-tint); display: flex; flex-direction: column; gap: 8px;
  }
  .how h4 { font-weight: 500; font-size: 16px; color: var(--color-text-primary); }
  .asteps { list-style: none; margin: 8px 0 0; padding: 0; display: flex; flex-direction: column; gap: 16px; }
  .astep { display: flex; align-items: flex-start; gap: 16px; }
  .anum {

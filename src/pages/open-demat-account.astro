---
/**
 * Open a Demat Account - /open-demat-account
 * Lead-capture landing page. Two-column hero (persuasion + form card),
 * definition, benefit grid, eligibility checklist, documents, icon
 * timeline, FAQ, dark CTA. Pixel parity with legacy demat.html.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/site/Breadcrumb.astro';
import FaqAccordion from '../components/sections/FaqAccordion.astro';
import { faqPageSchema } from '../lib/seo';

const FAQS = [
  {
    q: 'What is a demat account?',
    a: 'It is an account that holds securities in electronic form. It can hold shares, ETFs, mutual funds, bonds and other eligible investments.',
  },
  {
    q: 'How long does it take to open a demat account online?',
    a: 'If your documents are ready, the form may take around 5 to 10 minutes. Activation depends on KYC and document checks. In many cases, account details are shared within 24 hours.',
  },
  {
    q: 'What documents do I need?',
    a: 'You will usually need your PAN card, Aadhaar card, Aadhaar-linked mobile number, bank proof and basic personal details. Income proof is needed only for F&O or derivatives.',
  },
  {
    q: 'Is PAN-Aadhaar linking required?',
    a: 'For resident individuals, PAN-Aadhaar linking is generally required for KYC where applicable. If your PAN is not linked, the application may be delayed or rejected.',
  },
  {
    q: 'What is a BSDA?',
    a: 'BSDA stands for Basic Services Demat Account. It is meant for eligible investors with smaller holdings. It may reduce annual maintenance charges.',
  },
  {
    q: 'Can I have more than one demat account?',
    a: 'Yes. You can have demat accounts with different brokers or depository participants. Each account must be linked to a valid PAN and completed KYC.',
  },
  {
    q: 'What are the charges for a demat account?',
    a: 'Charges vary by broker and account type. Check the tariff sheet before opening the account. Look for annual maintenance charges, transaction charges and other service fees.',
  },
  {
    q: 'What happens if my broker shuts down?',
    a: 'Your securities are held with the depository, not directly with the broker. You can usually transfer your holdings to another depository participant through the prescribed process.',
  },
  {
    q: 'Can NRIs open a demat account in India?',
    a: 'Yes. NRIs can open NRE or NRO demat accounts. FEMA, RBI and KYC requirements apply.',
  },
  {
    q: 'Can I open a demat account for a minor?',
    a: 'Yes. A minor can have a demat account. A parent or legal guardian must operate it. When the minor turns 18, the account must be updated.',
  },
  {
    q: 'Is nomination mandatory?',
    a: 'Investors are usually asked to add a nominee or record an opt-out choice. Adding a nominee is recommended. It can make transfer easier for the family.',
  },
];

const seo = {
  title:
    'Open A Demat Account',
  description:
    'Open a fully digital Demat and trading account in minutes with Shriram Financial Services. Zero paperwork, SEBI-regulated and secure.',
  path: '/open-demat-account',
  jsonLd: [faqPageSchema(FAQS.map((f) => ({ question: f.q, answer: f.a })))],
};
---

<BaseLayout seo={seo} mainClass="rev-rise-scale">
  <!-- ================= HERO ================= -->
  <section class="hero" id="sec-hero" data-section="hero">
    <Breadcrumb trail={[{ name: 'Open a Demat Account' }]} />
    <div class="hero-grid">
      <div class="hero-inner" data-enter>
        <h1>Open a <span class="g">Demat Account</span> in Minutes, 100% Online, Zero Paperwork</h1>
        <p class="lead">Hold stocks, bonds, ETFs, and mutual funds digitally with a Demat account.</p>
      </div>

      <!-- lead-capture card -->
      <form class="hero-form hero-aside" aria-label="Get started" onsubmit="return false;">
        <div class="hf-head">
          <h2>Let&rsquo;s Get Started</h2>
          <div class="hf-meta">
            <span>100% Paperless</span>
            <span class="dot" aria-hidden="true"></span>
            <span>Open Within Minutes</span>
            <span class="dot" aria-hidden="true"></span>
            <span>SEBI Regulated</span>
          </div>
        </div>
        <div class="hf-body">
          <div class="hf-field">
            <span class="hf-flag" aria-hidden="true"></span>
            <span class="hf-divider" aria-hidden="true"></span>
            <div class="hf-field-in">
              <label for="hf-mobile">Mobile Number</label>
              <input id="hf-mobile" name="mobile" type="tel" inputmode="numeric" autocomplete="tel-national" placeholder="+91 00000 00000" />
            </div>
          </div>
          <p class="hf-note">By continuing, I agree to receive the OTP and updates via SMS/WhatsApp</p>
          <div class="hf-actions">
            <button class="btn-gold" type="submit">Get Started</button>
            <p class="hf-login">Already a part of us? <a href="#">Login Here.</a></p>
          </div>
        </div>
      </form>
    </div>
  </section>

  <!-- ================= WHAT IS A DEMAT ACCOUNT? ================= -->
  <section class="section stack sec-light" id="sec-about" data-section="about" style="gap:56px" data-enter="2">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">What is a Demat Account?</h2>
      <div class="def-body">
        <p>A demat account is like a digital locker for your investments. It can hold shares, ETFs, bonds, mutual funds, government securities and other eligible securities. You do not need to keep paper certificates. Your holdings are stored electronically.</p>
        <p>In India, demat accounts are maintained through CDSL or NSDL. A SEBI-registered depository participant helps you open and manage the account.</p>
      </div>
    </div>
  </section>

  <!-- ================= WHY OPEN A DEMAT ACCOUNT? ================= -->
  <section class="section stack sec-tint" id="sec-why" data-section="why" style="gap:56px">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Why Open a Demat Account?</h2>
      <div class="def-body">
        <p>A demat account is essential if you want to invest in shares and many other market-linked securities in India. It makes buying and selling investments smooth, speeds up transactions, and helps you receive benefits like dividends, bonus shares, and stock splits directly into your account. It also keeps your investments organised, making them easier to track and manage.</p>
      </div>
    </div>
  </section>

  <!-- ================= BENEFITS OF A DEMAT ACCOUNT ================= -->
  <section class="section stack sec-light" id="sec-benefits" data-section="benefits" style="gap:56px">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Benefits of a Demat Account</h2>
      <p class="sec-lead">A demat account is useful because it keeps your investments in one place and makes them easier to track.</p>
    </div>
    <div class="cat-grid cat-grid-3" data-reveal-row>
      <div class="cat"><h4>No paper certificates</h4><p>Paper certificates can get lost or damaged. They can also be delayed. In a demat account, your holdings are stored electronically.</p></div>
      <div class="cat"><h4>Faster settlement</h4><p>Most equity trades in India follow a T+1 settlement cycle. This means settlement usually happens on the next working day after the trade date.</p></div>
      <div class="cat"><h4>Many investments in one account</h4><p>You can hold different eligible investments in one demat account. These may include shares, ETFs, bonds, mutual fund units and sovereign gold bonds.</p></div>
      <div class="cat"><h4>Needed for listed shares</h4><p>If you want to buy or sell listed shares in India, you generally need a demat account. It is usually linked to your trading account.</p></div>
      <div class="cat"><h4>Corporate benefits are updated</h4><p>Dividends, bonus shares and stock splits are updated in your account. This is done based on company, registrar and depository records.</p></div>
      <div class="cat"><h4>Pledging may be possible</h4><p>You may be able to pledge eligible securities for funding. This depends on the security, broker, lender and current rules.</p></div>
      <div class="cat"><h4>Nomination helps your family</h4><p>It is better to add a nominee while opening the account. Adding one can make it easier for your family to access the account, reducing delays and paperwork during a difficult time/uncertainty.</p></div>
    </div>
  </section>

  <!-- ================= DOCUMENTS REQUIRED ================= -->
  <section class="section stack sec-tint" id="sec-documents" data-section="documents" style="gap:56px">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Documents Required to Open a Demat Account</h2>
      <p class="sec-lead">The following are some of the usual documents that are required to open a demat account. However, please note that the documents may change based on your account type.</p>
    </div>
    <div class="t-scroll"><div class="product-page_table t3 bordered" style="min-width:640px">
      <div class="cell th"><p>Document</p></div><div class="cell th"><p>Why it is needed</p></div><div class="cell th"><p>Accepted format</p></div>
      <div class="cell tb"><p class="k">PAN card</p></div><div class="cell tb"><p class="v">Used for KYC and securities-market transactions.</p></div><div class="cell tb"><p class="v">Card details or a clear digital copy</p></div>
      <div class="cell tb"><p class="k">Aadhaar card</p></div><div class="cell tb"><p class="v">Used to verify your identity and address. It should be linked to your mobile number.</p></div><div class="cell tb"><p class="v">Digital copy or UIDAI-verified details</p></div>
      <div class="cell tb"><p class="k">Bank account proof</p></div><div class="cell tb"><p class="v">Used to link your bank account for payouts and transfers.</p></div><div class="cell tb"><p class="v">Cancelled cheque, passbook copy or recent bank statement (However, if your UPI verification or Penny-drop bank verification is successful during the online application, you often do not need to manually upload any physical documents)</p></div>
      <div class="cell tb"><p class="k">Photograph</p></div><div class="cell tb"><p class="v">May be needed for offline or non-Aadhaar applications.</p></div><div class="cell tb"><p class="v">JPEG, PNG or passport-size photo</p></div>
      <div class="cell tb"><p class="k">Income proof</p></div><div class="cell tb"><p class="v">Needed only if you want to activate F&amp;O or derivatives trading.</p></div><div class="cell tb"><p class="v">ITR, salary slip, Form 16 or recent bank statement</p></div>
    </div></div>
  </section>

  <!-- ================= HOW TO OPEN A DEMAT ACCOUNT ONLINE ================= -->
  <section class="section stack sec-light" id="sec-how" data-section="how" style="gap:56px">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">How to Open a Demat Account Online</h2>
      <p class="sec-lead">You can complete the application of a demat account on a phone or laptop. Keep your PAN, Aadhaar-linked mobile number and bank proof ready.</p>
    </div>
    <div class="steps" data-reveal-row>
      <div class="step"><div class="num">1</div><div class="st-body"><h4>Verify your mobile number</h4><p>Enter the mobile number linked with your Aadhaar. Use the OTP you receive to continue.</p></div></div>
      <div class="step-div"></div>
      <div class="step"><div class="num">2</div><div class="st-body"><h4>Complete PAN and Aadhaar KYC</h4><p>Enter your PAN details. Then verify your identity with the OTP sent to your Aadhaar-linked mobile number.</p></div></div>
      <div class="step-div"></div>
      <div class="step"><div class="num">3</div><div class="st-body"><h4>Add personal and bank details</h4><p>Fill in your name, date of birth, address, occupation, income range, IFSC code and bank account number. Check the details carefully. Small mistakes can delay approval.</p></div></div>
      <div class="step-div"></div>
      <div class="step"><div class="num">4</div><div class="st-body"><h4>Upload documents</h4><p>Upload your bank proof. This can be a cancelled cheque or recent bank statement. If you want F&amp;O or derivatives, upload income proof too. However, please note that if your UPI verification or Penny-drop bank verification is successful during the process, you often do not need to manually upload any physical documents.</p></div></div>
      <div class="step-div"></div>
      <div class="step"><div class="num">5</div><div class="st-body"><h4>Add nominee details</h4><p>Add your nominee&rsquo;s name, relationship and ID details. If you do not want a nominee, check if the platform allows you to opt out.</p></div></div>
      <div class="step-div"></div>
      <div class="step"><div class="num">6</div><div class="st-body"><h4>Sign online</h4><p>Read the application once. If the details are correct, complete the Aadhaar-based e-signature using the OTP.</p></div></div>
      <div class="step-div"></div>
      <div class="step"><div class="num">7</div><div class="st-body"><h4>Wait for activation</h4><p>After verification, your account details and login credentials are usually sent by email and SMS within 24 hours.</p></div></div>
    </div>
  </section>

  <!-- ================= AM I ELIGIBLE? ================= -->
  <section class="section stack sec-tint" id="sec-eligible" data-section="eligible" style="gap:56px">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Am I Eligible to Open a Demat Account?</h2>
      <p class="sec-lead">Answer these questions to understand which account type may suit you.</p>
    </div>
    <div class="cat-grid cat-grid-3" data-reveal-row>
      <div class="cat"><h4>Question 1: Who is the account for?</h4><p>Resident Indian; NRI; Minor under 18</p></div>
      <div class="cat"><h4>Question 2: Is your PAN linked with Aadhaar?</h4><p>Yes; No; Not sure</p></div>
      <div class="cat"><h4>Question 3: Do you have an active Indian bank account?</h4><p>Yes; No</p></div>
      <div class="cat"><h4>Question 4: Have you invested before?</h4><p>Yes; No</p></div>
      <div class="cat"><h4>Question 5: What will you use the account for?</h4><p>Long-term stock investing; Trading in shares and ETFs; IPO applications; Mutual funds; F&amp;O or derivatives trading</p></div>
    </div>
    <div class="stack" style="gap:16px">
      <h3 class="sub-title">Quick reference: who can open what</h3>
    </div>
    <div class="t-scroll"><div class="product-page_table t3 bordered" style="min-width:640px">
      <div class="cell th"><p>Applicant type</p></div><div class="cell th"><p>Account type</p></div><div class="cell th"><p>Main requirement</p></div>
      <div class="cell tb"><p class="k">Resident Indian aged 18 or above</p></div><div class="cell tb"><p class="v">Regular demat account or BSDA, if eligible</p></div><div class="cell tb"><p class="v">PAN, Aadhaar and completed KYC</p></div>
      <div class="cell tb"><p class="k">NRI: repatriable account</p></div><div class="cell tb"><p class="v">NRE demat account</p></div><div class="cell tb"><p class="v">NRE bank account and FEMA-related documents</p></div>
      <div class="cell tb"><p class="k">NRI: non-repatriable account</p></div><div class="cell tb"><p class="v">NRO demat account</p></div><div class="cell tb"><p class="v">NRO bank account and KYC documents</p></div>
      <div class="cell tb"><p class="k">Minor under 18</p></div><div class="cell tb"><p class="v">Minor demat account</p></div><div class="cell tb"><p class="v">Operated by parent or legal guardian</p></div>
      <div class="cell tb"><p class="k">Joint holders</p></div><div class="cell tb"><p class="v">Joint demat account</p></div><div class="cell tb"><p class="v">PAN and KYC for all holders</p></div>
    </div></div>
  </section>

  <!-- ===== General Questions ===== -->
  <section class="faq-wrap sec-light" id="sec-faq" data-section="faq">
    <div class="faq-cols">
      <div class="faq-left">
        <h2 class="faq-title">Got Questions?</h2>
        <p class="sec-lead">Here are simple answers to common questions.</p>
        <FaqAccordion faqs={FAQS} />
      </div>
      <div class="faq-side">
        <div class="usr"><img src="/assets/user.svg" alt="" /></div>
        <div class="side-in">
          <div class="side-tx">
            <h3>Need A Clearer Direction? </h3>
            <p>Let's get in touch on a 15-Minute call where we would be able to answer any questions you may have. Our Advisor will additionally help map your wealth mix and demonstrate what a dedicated advisor would do differently.</p>
          </div>
          <a class="btn-gold" href="#">Book A Discovery Call</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ===== Open Demat Account - page-specific styles. Values reuse shared tokens. ===== */
  .section,
  .cta-sec {
    scroll-margin-top: 96px;
  }

  /* ---------- hero: persuasion column + lead-capture form.
     Layout (.hero-grid / .hero-inner / .hero-aside width + mobile stacking) AND
     the two-column card centring are canonical in global.css - only the form's
     own look lives here. ---------- */
  .hero .cta {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
  }

  /* light "Let's Get Started" lead-capture card (width + flex come from .hero-aside) */
  .hero-form {
    background: var(--color-cream-350);
    border: 1px solid var(--color-tan-300);
    border-radius: 24px;
    padding: clamp(32px, 3.4vw, 48px);
    display: flex;
    flex-direction: column;
    gap: 40px;
  }
  .hf-head {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .hero-form h2 {
    font-weight: 500;
    font-size: clamp(26px, 2.4vw, 32px); /* page-local - Tier-2 candidate (26px off-scale min) */
    color: var(--color-olive-600);
  }
  .hf-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
  }
  .hf-meta span {
    font-weight: 500;
    font-size: 12px;
    color: var(--color-gray-650);
    white-space: nowrap;
  }
  .hf-meta .dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--color-gray-300);
    flex: none;
  }
  .hf-body {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  /* Input field (.hf-field / .hf-field-in) is the shared canonical component in
     global.css - see DESIGN-SYSTEM.md §4.15. Only the Demat phone-flag prefix
     decoration is page-specific. The flag's #ff9933/#138808 are illustration
     content (the India flag) - kept verbatim, not tokenised. */
  .hf-flag {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    flex: none;
    border: 1px solid var(--color-gray-200);
    background: linear-gradient(180deg, #ff9933 33%, #fff 33% 66%, #138808 66%);
  }
  .hf-divider {
    width: 1px;
    height: 24px;
    background: var(--color-gray-200);
    flex: none;
  }
  .hf-note {
    font-weight: 500;
    font-size: 12px;
    color: var(--color-charcoal-700);
  }
  .hf-actions {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .hero-form .btn-gold {
    width: 100%;
    height: 48px;
  }
  .hf-login {
    font-weight: 500;
    font-size: 12px;
    color: var(--color-charcoal-700);
  }
  .hf-login a {
    color: var(--color-link);
  }

  /* ---------- "What is a Demat account?" - vertical definition, full-width copy ---------- */
  .def-body {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .def-body p {
    font-weight: 400;
    font-size: 16px;
    color: var(--color-text-tertiary);
  }

  /* "Why open with Shriram?" uses the shared .encl-grid / .encl-cell (global.css). */

  /* "How Soon Can I Open A Trading Account?" now uses the shared <HowSoon /> component. */

  /* ---------- centered standalone section CTA ---------- */
  .cta-center {
    display: flex;
    justify-content: center;
  }

  /* ---------- final CTA (dark) ---------- */
  .cta-box.dark {
    background: var(--color-olive-950);
  }
  .cta-box.dark .ct-tt {
    color: var(--color-white);
  }
  .cta-box.dark h3 .g {
    color: var(--color-gold-400);
  }
  .cta-box.dark .ct-sub {
    color: var(--color-sage-200);
  }
  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    justify-content: center;
  }
  .cta-actions .btn-gold,
  .cta-actions .btn-ghost {
    transition: filter 0.2s ease, background 0.2s ease, border-color 0.2s ease;
  }
  @media (min-width: 1200px) and (hover: hover) {
    .cta-actions .btn-gold:hover {
    filter: brightness(0.96);
  }
  }
  @media (min-width: 1200px) and (hover: hover) {
    .cta-actions .btn-ghost:hover {
    background: var(--color-charcoal-650);
    border-color: var(--color-white);
  }
  }

  /* ---------- responsive (two-column hero stacking is canonical in global.css @980px) ---------- */
  @media (max-width: 768px) {
    .def-body p {
      font-size: 14px;
    }
  }
</style>

<script>
  /* ---- Demat page enhancement: digit-group the hero mobile field ----
     Scroll-reveal + back-to-top are owned by BaseLayout / shared CSS. */
  const mob = document.getElementById('hf-mobile') as HTMLInputElement | null;
  if (mob) {
    mob.addEventListener('input', () => {
      let d = mob.value.replace(/\D/g, '');
      if (d.slice(0, 2) === '91') {
        d = d.slice(2);
      }
      d = d.slice(0, 10);
      mob.value = d ? '+91 ' + (d.length > 5 ? d.slice(0, 5) + ' ' + d.slice(5) : d) : '';
    });
  }
</script>

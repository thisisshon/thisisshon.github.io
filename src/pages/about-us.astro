<script>
  /* ---- About page enhancements: scroll reveal (this page's OWN reveal system) ---- */
  (function () {
    'use strict';

    /* scroll reveal (transitions are neutralised under prefers-reduced-motion in global.css) */
    var reveals = Array.prototype.slice.call(document.querySelectorAll('.reveal'));
    if ('IntersectionObserver' in window) {
      var ro = new IntersectionObserver(
        function (entries, obs) {
          entries.forEach(function (e) {
            if (e.isIntersecting) {
              e.target.classList.add('in');
              obs.unobserve(e.target);
            }
          });
        },
        { rootMargin: '0px 0px -10% 0px', threshold: 0.08 }
      );
      reveals.forEach(function (el) {
        ro.observe(el);
      });
    } else {
      reveals.forEach(function (el) {
        el.classList.add('in');
      });
    }

    /* What We Do — equalise the first item of each column so the dividers and the
       second items line up across columns, whatever the text length. Columns that
       share a visual row are grouped by their row-band, so it works at 4 / 2 / 1
       columns; recomputed on resize and once web fonts have loaded. */
    var doGrid = document.querySelector('.do-grid');
    if (doGrid) {
      var firstItems = Array.prototype.slice.call(
        doGrid.querySelectorAll('.do-col > .do-item:first-of-type')
      );
      var alignDo = function () {
        firstItems.forEach(function (el) {
          el.style.minHeight = '';
        });
        var groups = {};
        firstItems.forEach(function (el) {
          var key = el.parentElement.offsetTop; // row-band: columns on the same row share this
          (groups[key] = groups[key] || []).push(el);
        });
        Object.keys(groups).forEach(function (k) {
          var g = groups[k],
            max = 0;
          g.forEach(function (el) {
            if (el.offsetHeight > max) {
              max = el.offsetHeight;
            }
          });
          g.forEach(function (el) {
            el.style.minHeight = max + 'px';
          });
        });
      };
      var rafId;
      window.addEventListener(
        'resize',
        function () {
          if (rafId) {
            cancelAnimationFrame(rafId);
          }
          rafId = requestAnimationFrame(alignDo);
        },
        { passive: true }
      );
      if (document.fonts && document.fonts.ready) {
        document.fonts.ready.then(alignDo);
      }
      alignDo();
    }
  })();
</script>

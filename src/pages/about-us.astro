---
/**
 * About Us — /about-us/
 * Company story, regulatory standing, mission/vision/values, parent groups,
 * services, milestones, leadership and offices. Pixel parity with legacy
 * about.html.
 *
 * Reveal note: this page keeps its OWN scroll-reveal system (html.js .reveal /
 * .reveal.in + the page reveal script) verbatim — it uses different class names
 * from the shared BaseLayout .js-reveal [data-reveal] system, so the two do not
 * collide. Preserved to keep this page's exact reveal behaviour.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/site/Breadcrumb.astro';

const seo = {
  title: 'About Us - Our Story & Mission',
  description:
    'Learn about Shriram Financial Services - a SEBI-registered, advisor-led investment platform backed by the trusted Shriram Group\'s legacy.',
  path: '/about-us/',
};
---

<BaseLayout seo={seo} mainClass="rev-rise-scale">
  <!-- ================= HERO ================= -->
  <section class="hero" id="sec-hero" data-section="hero">
    <Breadcrumb trail={[{ name: 'About Us' }]} />
    <div class="hero-inner" data-enter>
      <div class="hero-content">
        <h1>India's Trusted Financial Companion <span class="g">Since 2000</span></h1>
        <p class="lead">A Shriram Group company delivering personalised equity, mutual fund and insurance solutions to retail and HNI clients across 21 states.</p>
        <div class="cta">
          <a class="btn-gold" href="/open-demat-account/">Open A Demat Account</a>
        </div>
      </div>
      <div class="hero-stats">
        <div class="hstat"><span class="n">₹2.08L Cr</span><span class="l">Shriram Group AUM (Dec 2025)</span></div>
        <div class="hstat"><span class="n">12M+</span><span class="l">Group customer base</span></div>
        <div class="hstat"><span class="n">50+</span><span class="l">Years of Shriram Group legacy</span></div>
        <div class="hstat"><span class="n">21</span><span class="l">States pan-India</span></div>
      </div>
    </div>
  </section>

  <!-- ================= COMPANY OVERVIEW + REGULATORY ================= -->
  <section class="section stack sec-light" id="sec-overview" data-section="overview" style="gap:56px" data-enter="2">
    <div class="stack reveal" style="gap:16px">
      <h2 class="sec-title">Company Overview</h2>
      <p class="sec-lead">Shriram Financial Securities (formerly Way2Wealth Brokers Pvt. Ltd.) is a subsidiary of Shriram Credit Company Ltd and part of the Shriram Group — one of India's largest financial services conglomerates.</p>
      <p class="sec-lead ov-note">We provide a comprehensive range of wealth management and investment services to HNI, retail and institutional clients: equity, commodities, currency trading, PMS, mutual funds, AIF, IPO distribution and fixed income.</p>
    </div>
    <div class="stack reveal" style="gap:32px">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">Regulatory Standing</h3>
        <p class="sub-lead">Fully licensed and regulated by India's financial market authorities.</p>
      </div>
      <div class="reg-grid" data-reveal-row>
        <div class="reg-cell">
          <span class="reg-ico" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M12 3 5 6v5c0 4.4 3 8 7 9 4-1 7-4.6 7-9V6l-7-3Z" stroke="#2e3914" stroke-width="1.5" stroke-linejoin="round"/><path d="m9 12 2 2 4-4" stroke="#2e3914" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
          <h4 class="card-h">SEBI Stockbroker</h4>
          <p class="card-p">NSE (Cash &amp; F&amp;O), BSE (Cash &amp; F&amp;O), MCX and NCDEX member.</p>
          <span class="reg-no">INZ000157633</span>
        </div>
        <div class="reg-cell">
          <span class="reg-ico" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M12 3 5 6v5c0 4.4 3 8 7 9 4-1 7-4.6 7-9V6l-7-3Z" stroke="#2e3914" stroke-width="1.5" stroke-linejoin="round"/><path d="m9 12 2 2 4-4" stroke="#2e3914" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
          <h4 class="card-h">Research Analyst</h4>
          <p class="card-p">SEBI-registered in-house research team.</p>
          <span class="reg-no">INH200009624</span>
        </div>
        <div class="reg-cell">
          <span class="reg-ico" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M12 3 5 6v5c0 4.4 3 8 7 9 4-1 7-4.6 7-9V6l-7-3Z" stroke="#2e3914" stroke-width="1.5" stroke-linejoin="round"/><path d="m9 12 2 2 4-4" stroke="#2e3914" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
          <h4 class="card-h">MF Distributor</h4>
          <p class="card-p">AMFI-registered mutual fund distributor.</p>
          <span class="reg-no">ARN 29483</span>
        </div>
        <div class="reg-cell">
          <span class="reg-ico" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M12 3 5 6v5c0 4.4 3 8 7 9 4-1 7-4.6 7-9V6l-7-3Z" stroke="#2e3914" stroke-width="1.5" stroke-linejoin="round"/><path d="m9 12 2 2 4-4" stroke="#2e3914" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
          <h4 class="card-h">NPS Distributor</h4>
          <p class="card-p">PFRDA-registered NPS Point of Presence.</p>
        </div>
        <div class="reg-cell">
          <span class="reg-ico" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M12 3 5 6v5c0 4.4 3 8 7 9 4-1 7-4.6 7-9V6l-7-3Z" stroke="#2e3914" stroke-width="1.5" stroke-linejoin="round"/><path d="m9 12 2 2 4-4" stroke="#2e3914" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
          <h4 class="card-h">Depository Participant</h4>
          <p class="card-p">CDSL-registered depository participant for Demat accounts.</p>
        </div>
        <div class="reg-cell">
          <span class="reg-ico" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M12 3 5 6v5c0 4.4 3 8 7 9 4-1 7-4.6 7-9V6l-7-3Z" stroke="#2e3914" stroke-width="1.5" stroke-linejoin="round"/><path d="m9 12 2 2 4-4" stroke="#2e3914" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
          <h4 class="card-h">Insurance Broker</h4>
          <p class="card-p">IRDAI-registered broker for life and general insurance.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ================= MISSION / VISION / VALUES ================= -->
  <section class="section stack sec-tint" id="sec-mvv" data-section="mvv" style="gap:56px">
    <div class="stack reveal" style="gap:16px">
      <h2 class="sec-title">Mission, Vision &amp; Values</h2>
      <p class="sec-lead">The principles that guide every client interaction and business decision at Shriram Financial Securities.</p>
    </div>
    <div class="mvv reveal" data-reveal-row>
      <div class="mvv-card">
        <span class="mvv-ghost" aria-hidden="true">01</span>
        <span class="mvv-num">MISSION</span>
        <h3>Empower Every Investor</h3>
        <span class="mvv-rule" aria-hidden="true"></span>
        <p>To be the pre-eminent destination for personalised financial solutions that help every individual build and create lasting wealth.</p>
      </div>
      <div class="mvv-card">
        <span class="mvv-ghost" aria-hidden="true">02</span>
        <span class="mvv-num">VISION</span>
        <h3>Knowledge That Grows Wealth</h3>
        <span class="mvv-rule" aria-hidden="true"></span>
        <p>Knowledge combined with investor trust and involvement leads to wealth growth — and an investing experience clients genuinely enjoy.</p>
      </div>
      <div class="mvv-card">
        <span class="mvv-ghost" aria-hidden="true">03</span>
        <span class="mvv-num">VALUES</span>
        <h3>Empathy · Trust · Growth</h3>
        <span class="mvv-rule" aria-hidden="true"></span>
        <p>The three pillars behind every client relationship — and the standard we hold ourselves to in every interaction.</p>
      </div>
    </div>
  </section>

  <!-- ================= PARENT GROUPS ================= -->
  <section class="section stack sec-light" id="sec-group" data-section="group" style="gap:56px">
    <div class="stack reveal" style="gap:16px">
      <h2 class="sec-title">Our Parent Groups</h2>
      <p class="sec-lead">A securities business built on the scale, stability and reach of two established financial groups.</p>
    </div>
    <div class="stack" style="gap:40px">
      <div class="grp reveal">
        <div class="grp-left">
          <h3 class="sub-title">The Shriram Group</h3>
          <div class="grp-logo"><img src="/assets/shriram-group.svg" alt="Shriram Group" /></div>
        </div>
        <div class="grp-body">
          <p class="sec-lead">Founded in 1974 by Shri. R. Thyagarajan, the Shriram Group works with the philosophy of financially empowering the underserved. It manages assets of over ₹2.08 lakh crore across 4,050 branches in Consumer Finance, Vehicle Finance, Life &amp; General Insurance, Chit Funds, Asset Management and Stock Broking.</p>
          <div class="chips">
            <span class="chip">80,000+ Employees</span>
            <span class="chip">3,850+ Branches</span>
            <span class="chip">Pan-Indian Reach</span>
          </div>
        </div>
      </div>
      <div class="grp-div" aria-hidden="true"></div>
      <div class="grp reveal">
        <div class="grp-left">
          <h3 class="sub-title">The Sanlam Group</h3>
          <div class="grp-logo"><img src="/assets/sanlam-group.png" alt="Sanlam Group" /></div>
        </div>
        <div class="grp-body">
          <p class="sec-lead">Sanlam is a leading financial services group based in Cape Town, South Africa. Sanlam's association with the Shriram Group began in 2005 with the emergence of Shriram Life Insurance Company (SLIC), a part of the diversified Shriram Group.</p>
          <p class="sec-lead">Over the years, the relationship has deepened significantly, with Sanlam holding a key stake in the Shriram Group through its 100% subsidiary.</p>
          <div class="chips">
            <span class="chip">Founded 1918</span>
            <span class="chip">Listed on JSE</span>
            <span class="chip">Pan-African Reach</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================= WHAT WE DO ================= -->
  <section class="section stack sec-tint" id="sec-do" data-section="do" style="gap:56px">
    <div class="stack reveal" style="gap:16px">
      <h2 class="sec-title">What We Do</h2>
      <p class="sec-lead">A full-service financial securities firm offering broking, distribution, fund-based services and research.</p>
    </div>
    <div class="do-grid reveal" data-reveal-row>
      <div class="do-col">
        <h3 class="do-cat">Broking</h3>
        <a class="do-item" href="/equity/"><h4>Equity &amp; Derivatives</h4><p>NSE, BSE, MSEI trading with institutional empanelment and algo capabilities.</p></a>
        <div class="do-div"></div>
        <a class="do-item" href="#"><h4>Commodities &amp; Currency</h4><p>MCX, NCDEX commodity broking and currency futures trading.</p></a>
      </div>
      <div class="do-col">
        <h3 class="do-cat">Distribution</h3>
        <a class="do-item" href="#"><h4>Mutual Funds</h4><p>AMFI-registered distributor offering 3,000+ direct and regular funds with 0 commission.</p></a>
        <div class="do-div"></div>
        <a class="do-item" href="#"><h4>IPO &amp; Fixed Income</h4><p>Primary market IPO distribution and fixed income securities placement.</p></a>
      </div>
      <div class="do-col">
        <h3 class="do-cat">Fund-Based</h3>
        <a class="do-item" href="#"><h4>Loan Against Securities</h4><p>Overdraft facility against your equity and mutual fund portfolio.</p></a>
        <div class="do-div"></div>
        <a class="do-item" href="#"><h4>PMS &amp; AIF</h4><p>Portfolio Management Services and Alternative Investment Fund access for HNI clients.</p></a>
      </div>
      <div class="do-col">
        <h3 class="do-cat">Research</h3>
        <a class="do-item" href="#"><h4>Fundamental Analysis</h4><p>In-depth financial modelling and valuation reports by SEBI-registered analysts.</p></a>
        <div class="do-div"></div>
        <a class="do-item" href="#"><h4>Technical Analysis</h4><p>Chart patterns, indicators and trade setups for short-term and positional trading.</p></a>
      </div>
    </div>
  </section>

  <!-- ================= KEY MILESTONES ================= -->
  <section class="section stack sec-light" id="sec-milestones" data-section="milestones" style="gap:56px">
    <div class="stack reveal" style="gap:16px">
      <h2 class="sec-title">Key Milestones</h2>
      <p class="sec-lead">From a small web-trading startup in Bengaluru to a pan-India financial services brand.</p>
    </div>
    <div class="timeline reveal" data-reveal-row>
      <ol class="tl-col">
        <li class="tl-item"><span class="tl-year">2000</span><p class="tl-text">Incorporated as Sivan Web Trading Pvt. Ltd., Bengaluru. Rebranded as Way2Wealth Securities.</p></li>
        <li class="tl-item"><span class="tl-year">2008</span><p class="tl-text">Launched commodities business; 100th franchise outlet inaugurated.</p></li>
        <li class="tl-item"><span class="tl-year">2009</span><p class="tl-text">Launched single-screen multi-product online trading — among the first in India.</p></li>
        <li class="tl-item"><span class="tl-year">2011</span><p class="tl-text">Online trading for Karnataka Bank clients; acquired Techno Shares &amp; Stocks.</p></li>
      </ol>
      <ol class="tl-col">
        <li class="tl-item"><span class="tl-year">2012</span><p class="tl-text">Acquired Total Insurance Brokers Pvt. Ltd.; launched Mandi2Market.</p></li>
        <li class="tl-item"><span class="tl-year">2013</span><p class="tl-text">Ranked top-10 broking entity in retail segment by BSE.</p></li>
        <li class="tl-item"><span class="tl-year">2019</span><p class="tl-text">MCX Leading Broking House of the Year award.</p></li>
        <li class="tl-item now"><span class="tl-year">2026 <span class="tl-badge">Now</span></span><p class="tl-text">Rebranded as Shriram Financial Securities — a unified Shriram financial identity.</p></li>
      </ol>
    </div>
  </section>


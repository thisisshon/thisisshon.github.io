---
/**
 * Margin Trading Facility (MTF) - /mtf/
 * Long-form MTF product page. Built entirely from shared design-system
 * components in global.css (hero, .section/.sec-title, .card, .steps,
 * .product-page_table, .bullets, .cat-grid, FaqAccordion, .cta-box).
 * Content implemented verbatim from the compliance-approved MTF document.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/site/Breadcrumb.astro';
import FaqAccordion from '../components/sections/FaqAccordion.astro';
import { faqPageSchema, breadcrumbSchema, organizationSchema } from '../lib/seo';

// General Questions - doc content verbatim, same order (first item open).
const FAQS = [
  {
    q: 'What is Margin Trading Facility (MTF)?',
    a: 'MTF allows investors to buy shares by paying a margin, while the broker funds the balance. Interest is charged daily on the funded portion.',
  },
  {
    q: 'Is MTF legal in India?',
    a: 'Yes. MTF is a SEBI‑regulated facility offered by registered brokers on NSE and BSE. It is subject to strict compliance, investor protection norms, and transparent operational guidelines.',
  },
  {
    q: 'Which stocks are eligible for MTF?',
    a: 'Only SEBI/NSE/BSE‑approved “Group I” securities and select ETFs based on liquidity and market cap.',
  },
  {
    q: 'What is the minimum margin requirement?',
    a: 'Typically, 259–50% depending on the stock category, with haircuts applied as per SEBI rules.',
  },
  {
    q: 'How much leverage can I get under MTF?',
    a: 'Up to 4x buying power, subject to stock eligibility and broker policy.',
  },
  {
    q: 'How is MTF interest charged?',
    a: 'Daily on the broker‑funded portion, with annual rates ranging from 16% to 18%p.a.',
  },
  {
    q: 'Do I own the shares bought under MTF?',
    a: 'Yes. Shares are credited to your demat account and pledged as collateral; you remain entitled to dividends and corporate actions.',
  },
  {
    q: 'Can I hold MTF positions overnight or long‑term?',
    a: 'Yes. Unlike intraday trades, MTF allows unlimited holding as long as margin and interest are maintained.',
  },
  {
    q: 'What happens if I fail to meet a margin call?',
    a: 'Brokers may liquidate pledged shares to recover dues, potentially locking in losses.',
  },
  {
    q: 'How do I activate MTF with my broker?',
    a: 'Submit digital consent, pledge eligible stocks, and enable the MTF segment in your trading account - usually completed within minutes.',
  },
];

const site = Astro.site!.href;

const seo = {
  title: 'Margin Trading Facility (MTF)',
  description:
    'Get up to 4x buying power with Margin Trading Facility (MTF) from Shriram Financial Services - no overnight square-off, 500+ eligible stocks.',
  path: '/mtf/',
  jsonLd: [
    faqPageSchema(FAQS.map((f) => ({ question: f.q, answer: f.a }))),
    breadcrumbSchema(
      [
        { name: 'Home', path: '/' },
        { name: 'Products', path: '/products/' },
        { name: 'Margin Trading Facility', path: '/mtf/' },
      ],
      site
    ),
    organizationSchema(site),
  ],
};
---

<BaseLayout seo={seo} mainClass="rev-rise-scale">
  <!-- ===== Hero ===== -->
  <section class="hero" id="sec-hero" data-section="hero">
    <Breadcrumb trail={[{ name: 'Products', href: '/products/' }, { name: 'Margin Trading Facility' }]} />
    <div class="hero-inner" data-enter>
      <h1>Margin Trading Facility in India — Buy 4X More Stocks with Less Capital</h1>
      <p class="lead">Amplify your buying power up to 4x leverage with Shriram Financial Services trusted MTF platform. Trade approved NSE/BSE stocks with low margins, transparent interest rates, and secure settlement.</p>
      <div class="cta"><a class="btn-gold" href="/open-demat-account/">Open Demat Account / Activate MTF</a></div>
      <div class="hero-feats">
        <div class="feats">
          <div class="feat"><span class="tk" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span><span class="lb">&nbsp;SEBI Regulated</span></div>
          <div class="feat"><span class="tk" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span><span class="lb">&nbsp;NSE &amp; BSE Approved</span></div>
          <div class="feat"><span class="tk" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span><span class="lb">&nbsp;MTF Rates from 16%p.a.</span></div>
          <div class="feat"><span class="tk" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span><span class="lb">&nbsp;Up to 4x Buying Power</span></div>
          <div class="feat"><span class="tk" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span><span class="lb">&nbsp;100% Digital</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Margin Trading Facility: Trade with More Buying Power ===== -->
  <section class="section stack sec-light" id="sec-about" data-section="about" style="gap:56px;justify-content:center" data-enter="2">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Margin Trading Facility: Trade with More Buying Power</h2>
      <p class="sec-lead">Looking to Maximise Your Buying Power up to 4x? Margin Trading Facility (MTF) helps you take larger positions in the stock market by paying only a part of the total trade value upfront, while the remaining amount is funded by your broker. Unlike intraday trading, MTF lets you hold your shares for a longer period, giving you greater flexibility to manage your investments, with margins range starting from 30% of the approved equity shares. With Shriram Financial Services, you can trade using MTF through a seamless platform, competitive funding, powerful trading tools and advisory support to help you make the most of market opportunities.</p>
    </div>
    <div class="stack" style="gap:32px">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">MTF Vs Intraday Vs Futures</h3>
      </div>
      <div class="t-scroll"><div class="product-page_table t4 bordered" style="min-width:760px">
        <div class="cell th"><p>Feature</p></div><div class="cell th"><p>Margin Trading Facility (MTF)</p></div><div class="cell th"><p>Intraday Trading</p></div><div class="cell th"><p>Futures Contracts</p></div>
        <div class="cell tb"><p class="k">Definition</p></div><div class="cell tb"><p class="v">SEBI‑approved margin funding where broker finances part of stock purchase</p></div><div class="cell tb"><p class="v">Buying and selling shares within the same trading day</p></div><div class="cell tb"><p class="v">Derivative contracts to buy/sell assets at a future date</p></div>
        <div class="cell tb"><p class="k">Holding Period</p></div><div class="cell tb"><p class="v">Days, weeks, months (whatever is allowed by Broker) as long as margin is maintained.</p></div><div class="cell tb"><p class="v">Must be squared off before market close</p></div><div class="cell tb"><p class="v">Fixed expiry cycles (monthly/quarterly)</p></div>
        <div class="cell tb"><p class="k">Delivery of Shares</p></div><div class="cell tb"><p class="v">Yes, actual shares delivered and pledged as collateral</p></div><div class="cell tb"><p class="v">No delivery, only buy/sell within the day</p></div><div class="cell tb"><p class="v">No delivery, only contract settlement</p></div>
        <div class="cell tb"><p class="k">Leverage Available</p></div><div class="cell tb"><p class="v">Up to 4x buying power depending on broker &amp; stock eligibility</p></div><div class="cell tb"><p class="v">Limited leverage, usually 5x–10x intraday</p></div><div class="cell tb"><p class="v">High leverage depending on contract size</p></div>
        <div class="cell tb"><p class="k">Risk</p></div><div class="cell tb"><p class="v">Margin calls, interest costs, forced liquidation</p></div><div class="cell tb"><p class="v">High volatility, risk of intraday losses</p></div><div class="cell tb"><p class="v">Market risk, rollover costs, margin requirements</p></div>
        <div class="cell tb"><p class="k">Best Suited For</p></div><div class="cell tb"><p class="v">Long‑term investors seeking leverage with delivery</p></div><div class="cell tb"><p class="v">Traders looking for short‑term price moves</p></div><div class="cell tb"><p class="v">Hedgers/speculators managing future price risk</p></div>
      </div></div>
    </div>
  </section>

  <!-- ===== How MTF Works ===== -->
  <section class="section stack sec-tint" id="sec-how" data-section="how" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">How MTF Works</h2>
      <p class="sec-lead" style="color:var(--color-text-secondary)">With Margin Trading Facility (MTF), you can buy stocks by paying only a fraction of the total value upfront — Shriram Financial Services funds the remaining amount. You can hold your leveraged position for up to 360 days, giving you the flexibility to stay invested without paying the full cost immediately. Whenever you're ready, simply repay the funded amount to get the shares transferred directly to your demat account — a process known as Convert to Delivery (CTD).</p>
      <p class="sec-lead" style="color:var(--color-text-secondary)">Let's take an example for understanding how it works. Suppose you want to buy shares worth ₹1,00,000. With a 25% margin requirement, you pay ₹25,000. The broker funds ₹75,000. You hold the shares and pay interest only on the ₹75,000 financed amount.</p>
    </div>
    <div class="stack" style="gap:32px">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">True Cost of MTF</h3>
      </div>
      <div class="t-scroll"><div class="product-page_table t2 bordered" style="grid-template-columns:repeat(2,minmax(0,1fr));min-width:520px">
        <div class="cell th"><p>Variable</p></div><div class="cell th"><p>Value</p></div>
        <div class="cell tb"><p class="k">Total trade value</p></div><div class="cell tb"><p class="v">₹1,00,000</p></div>
        <div class="cell tb"><p class="k">Your margin (25%)</p></div><div class="cell tb"><p class="v">₹25,000</p></div>
        <div class="cell tb"><p class="k">Broker-funded amount (75%)</p></div><div class="cell tb"><p class="v">₹75,000</p></div>
        <div class="cell tb"><p class="k">MTF Interest Rate</p></div><div class="cell tb"><p class="v">16 %p.a. (illustrative)</p></div>
        <div class="cell tb"><p class="k">Holding period</p></div><div class="cell tb"><p class="v">90 days</p></div>
        <div class="cell tb"><p class="k">Daily interest on ₹75,000</p></div><div class="cell tb"><p class="v">₹75,000 × 16% ÷ 365 = ₹32.87/day</p></div>
        <div class="cell tb"><p class="k">Total interest for  90 days</p></div><div class="cell tb"><p class="v">₹2959</p></div>
        <div class="cell tb"><p class="k">Equivalent Personal Loan cost (at 18%)</p></div><div class="cell tb"><p class="v">₹75,000 × 18% ÷ 365 × 90 = ₹ 3329</p></div>
        <div class="cell tb"><p class="k">MTF saving vs unsecured borrowing</p></div><div class="cell tb"><p class="v">~₹370 for this 90-day trade</p></div>
      </div></div>
    </div>
    <div class="cta" style="justify-content:center"><a class="btn-gold" href="/open-demat-account/">Open Demat Account</a><a class="btn-ghost" href="/mtf/">Explore MTF</a></div>
  </section>

  <!-- ===== Key Benefits of MTF ===== -->
  <section class="section stack sec-light" id="sec-benefits" data-section="benefits" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Key Benefits of MTF – Why Use Leverage Trading?</h2>
      <p class="sec-lead">Margin Trading Facility (MTF) offers six core advantages for delivery-based equity investors. Unlike intraday trading, MTF lets you hold positions for extended periods — up to 90 days — while unlike futures, you gain actual ownership of the shares in your demat account. At its heart, MTF amplifies your buying power without sacrificing the benefits of delivery-based investing.</p>
    </div>
    <div class="cat-grid" data-reveal-row style="grid-template-columns:repeat(2,1fr)">
      <div class="cat"><h4>BUYING POWER 4X</h4><p>Up to 4X your Capital</p></div>
      <div class="cat"><h4>HOLIDING 90 days</h4><p>No Forced Overnight Exit</p></div>
      <div class="cat"><h4>SHARE OWNERSHIP YES</h4><p>Demat Credit + Dividends</p></div>
      <div class="cat"><h4>CAPITAL FREED 75%</h4><p>With 25% Margin example</p></div>
    </div>
    <ul class="bullets">
      <li>Amplified Buying Power - With up to 4x leverage, you can purchase more shares than your capital alone would allow, maximising portfolio exposure.</li>
      <li>More Holding Period - Unlike intraday trades, MTF positions can be held for days, weeks, or months, provided margin and interest are maintained.</li>
      <li>Delivery of Shares - You receive actual shares in your demat account, pledged as collateral, ensuring ownership rather than just speculative contracts.</li>
      <li>Portfolio Diversification - Access high‑value stocks with limited capital, enabling broader diversification across sectors.</li>
      <li>No Forced Square‑Off - Unlike intraday trading, there's no mandatory end‑of‑day closure, giving you flexibility to exit when market conditions suit you.</li>
      <li>Strategic Hedging - Investors can use MTF to hedge long‑term positions while maintaining liquidity for other opportunities.</li>
    </ul>
    <div class="cta" style="justify-content:center"><a class="btn-gold" href="/open-demat-account/">Open Demat Account Today</a><a class="btn-ghost" href="/mtf/">Explore MTF</a></div>
  </section>

  <!-- ===== Disadvantages of Margin Trading Facility ===== -->
  <section class="section stack sec-tint" id="sec-disadvantages" data-section="disadvantages" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Disadvantages of Margin Trading Facility</h2>
      <h3 class="sub-title">Disadvantages of MTF</h3>
      <p class="sec-lead" style="color:var(--color-text-secondary)">While Margin Trading Facility (MTF) offers leverage and flexibility, it also comes with certain drawbacks that investors must carefully consider before using it.</p>
    </div>
    <ul class="bullets">
      <li>Daily Interest Costs - Brokers charge daily interest on the funded portion. Over time, this can significantly reduce net returns, especially if positions are held for weeks or months.</li>
      <li>Margin Call Risk - If the value of pledged shares falls below the required margin, the broker issues a margin call. Failure to top up funds can lead to forced liquidation.</li>
      <li>Forced Liquidation - Brokers may sell pledged shares without investor consent to recover dues, potentially locking in losses.</li>
      <li>Limited Stock Eligibility - Only SEBI‑approved NSE/BSE stocks are eligible. This restricts opportunities compared to broader equity or futures markets.</li>
      <li>Leverage Amplifies Losses - Just as leverage magnifies gains, it also magnifies losses. A small decline in stock price can wipe out margin capital.</li>
      <li>Compliance &amp; Documentation - Investors must complete pledging formalities and adhere to SEBI regulations, which can feel complex compared to simple delivery trades.</li>
    </ul>
    <p class="sec-lead" style="color:var(--color-text-secondary)">Risk Disclaimer: Margin trading involves significant risk and is not suitable for all investors. Leverage can magnify losses as well as gains. Please read all risk disclosures before activating MTF.</p>
  </section>

  <!-- ===== MTF Interest Rate & Charges ===== -->
  <section class="section stack sec-light" id="sec-charges" data-section="charges" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">MTF Interest Rate &amp; Charges</h2>
      <p class="sec-lead">Margin Trading Facility (MTF) interest is charged daily on the broker‑funded portion of your trade. Annual rates in India typically range between 16% and 18% p.a., depending on the broker. Understanding the cost structure is essential before using leverage.</p>
    </div>
    <div class="stack" style="gap:32px">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">Quick-Reference: MTF Interest Rate Comparison</h3>
      </div>
      <div class="t-scroll"><div class="product-page_table t4 bordered" style="min-width:820px">
        <div class="cell th"><p>Fee Component</p></div><div class="cell th"><p>Rate / Amount</p></div><div class="cell th"><p>Frequency</p></div><div class="cell th"><p>Notes</p></div>
        <div class="cell tb"><p class="k">MTF Interest Rate</p></div><div class="cell tb"><p class="v">From  16% p.a.</p></div><div class="cell tb"><p class="v">Daily (on funded amount only)</p></div><div class="cell tb"><p class="v">Not charged on your own margin capital</p></div>
        <div class="cell tb"><p class="k">Effective Daily Rate (at 16%)</p></div><div class="cell tb"><p class="v">~₹0.44 per ₹1,000 funded</p></div><div class="cell tb"><p class="v">Per calendar day</p></div><div class="cell tb"><p class="v">Example: ₹75,000 funded × 30 days = ~₹986</p></div>
        <div class="cell tb"><p class="k">Processing / Pledge Charges</p></div><div class="cell tb"><p class="v">₹15/15 per pledge/unpledge</p></div><div class="cell tb"><p class="v">Per transaction</p></div><div class="cell tb"><p class="v">Charged on pledge activation and release</p></div>
        <div class="cell tb"><p class="k">Brokerage</p></div><div class="cell tb"><p class="v">Standard equity delivery rates</p></div><div class="cell tb"><p class="v">Per order</p></div><div class="cell tb"><p class="v">Same as regular delivery purchase</p></div>
        <div class="cell tb"><p class="k">Annual Maintenance Charge (AMC)</p></div><div class="cell tb"><p class="v">₹200 per annum</p></div><div class="cell tb"><p class="v">Annual</p></div><div class="cell tb"><p class="v"></p></div>
        <div class="cell tb"><p class="k">Margin Shortfall Penalty</p></div><div class="cell tb"><p class="v">As per SEBI/exchange norms</p></div><div class="cell tb"><p class="v">If triggered</p></div><div class="cell tb"><p class="v">Charged only when margin falls below threshold</p></div>
        <div class="cell tb"><p class="k">Foreclosure / Prepayment</p></div><div class="cell tb"><p class="v">Nil</p></div><div class="cell tb"><p class="v">N/A</p></div><div class="cell tb"><p class="v">No charges for early repayment</p></div>
        <div class="cell tb"><p class="k">STT (Securities Transaction Tax)</p></div><div class="cell tb"><p class="v">0.1% on sell side</p></div><div class="cell tb"><p class="v">Per trade</p></div><div class="cell tb"><p class="v">Same as normal delivery trades</p></div>
      </div></div>
    </div>
    <p class="sec-lead">Our MTF interest rates are among the most competitive in the market. Login to your account or contact support for your personalised MTF rate.</p>
    <div class="cta" style="justify-content:center"><a class="btn-gold" href="/mtf/">View MTF Charges</a><a class="btn-ghost" href="/open-demat-account/">Open Demat Account</a></div>
  </section>

  <!-- ===== MTF Eligible Stocks & Margin Requirements ===== -->
  <section class="section stack sec-tint" id="sec-eligible" data-section="eligible" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">MTF Eligible Stocks &amp; Margin Requirements</h2>
      <p class="sec-lead" style="color:var(--color-text-secondary)">Margin Trading Facility (MTF) is available only on SEBI‑approved NSE/BSE stocks that meet liquidity and compliance criteria. Brokers publish an updated list of eligible stocks along with margin requirements and haircut percentages.</p>
      <p class="sec-lead" style="color:var(--color-text-secondary)">The exact list of MTF-eligible stocks is updated periodically per SEBI/exchange guidelines. Log in to your account to view the complete, current MTF stock list with live margin requirements.</p>
    </div>
    <a class="btn-gold" href="/open-demat-account/" style="align-self:center">Open Demat Account</a>
  </section>

  <!-- ===== How to Activate MTF on Your Account ===== -->
  <section class="section stack sec-light" id="sec-activate" data-section="activate" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">How to Activate MTF on Your Account?</h2>
      <p class="sec-lead">Activating Margin Trading Facility (MTF) is a simple process, but it requires compliance with SEBI regulations and broker procedures. Once enabled, you can start leveraging your capital with up to 4x buying power.</p>
    </div>
    <div class="stack" style="gap:32px;width:100%">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">Step‑by‑Step Activation Process</h3>
      </div>
      <div class="steps" data-reveal-row>
        <div class="step"><div class="num">1</div><div class="st-body"><h4>Step 1 — Access Your Account</h4><p>Log in to your Shriram FS trading account via web platform or mobile app.</p></div></div>
        <div class="step-div"></div>
        <div class="step"><div class="num">2</div><div class="st-body"><h4>Step 2 — Submit MTF Consent</h4><p>Navigate to 'MTF / Margin Trading' section and submit the digital consent form as required by SEBI guidelines with OTP authorization (OTP will be sent on the mobile number &amp; Email registered with Shriram Financial services Pvt Ltd.)</p></div></div>
        <div class="step-div"></div>
        <div class="step"><div class="num">3</div><div class="st-body"><h4>Step 3 — Account Activation</h4><p>MTF segment is activated in your account by Shriram FS (usually within the same trading day for existing KYC-verified customers).</p></div></div>
      </div>
    </div>
    <div class="cta" style="justify-content:center"><a class="btn-gold" href="/open-demat-account/">Activate MTF Now</a><a class="btn-ghost" href="/open-demat-account/">Activate your MTF</a></div>
  </section>

  <!-- ===== Risks of Investing in Margin Trading Facility ===== -->
  <section class="section stack sec-tint" id="sec-risks" data-section="risks" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Risks of Investing in Margin Trading Facility</h2>
      <p class="sec-lead" style="color:var(--color-text-secondary)">Margin Trading Facility (MTF) offers leverage, but it also carries risks that every investor must understand before using it. SEBI regulations require brokers to disclose these risks clearly, and investors should evaluate them carefully.</p>
      <h3 class="sub-title">Key Risks of MTF</h3>
    </div>
    <ul class="bullets">
      <li>Daily Interest Burden - Interest is charged daily on the broker‑funded portion. Holding positions for weeks or months can significantly increase costs, reducing net returns.</li>
      <li>Margin Call Trigger - If the value of pledged shares falls below the required margin, the broker issues a margin call. Investors must add funds or collateral to maintain the position.</li>
      <li>Forced Liquidation - If margin calls are not met, brokers may liquidate pledged shares without investor consent, potentially locking in losses.</li>
      <li>Amplified Losses - Leverage magnifies both gains and losses. A small decline in stock price can wipe out margin capital.</li>
      <li>Margin Shortfall Penalty - Exchanges impose penalties if margin requirements are not met, adding to trading costs.</li>
      <li>Limited Stock Eligibility - Only SEBI‑approved NSE/BSE stocks are eligible, restricting opportunities compared to broader equity or futures markets.</li>
    </ul>
    <p class="sec-lead" style="color:var(--color-text-secondary)">Risk Disclaimer: Margin trading involves significant risk and is not suitable for all investors. Leverage can magnify losses as well as gains. Please read all risk disclosures before using MTF.</p>
  </section>

  <!-- ===== Why Choose Shriram Financial Services MTF ===== -->
  <section class="section stack sec-light" id="sec-why" data-section="why" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Why Choose Shriram Financial Services MTF?</h2>
      <p class="sec-lead">Empower your trades with transparent charges, flexible margins, and SEBI‑approved leverage — all designed for smarter, safer investing. Here is everything you get when you use MTF on our platform:</p>
    </div>
    <div class="t-scroll"><div class="product-page_table t3 bordered" style="min-width:680px">
      <div class="cell th"><p>Feature</p></div><div class="cell th"><p>Our MTF Offering</p></div><div class="cell th"><p>Notes</p></div>
      <div class="cell tb"><p class="k">MTF Interest Rate</p></div><div class="cell tb"><p class="v">Competitive</p></div><div class="cell tb"><p class="v">Personalised rates available for high‑volume traders</p></div>
      <div class="cell tb"><p class="k">Minimum Margin</p></div><div class="cell tb"><p class="v">As low as 25% (stock‑dependent)</p></div><div class="cell tb"><p class="v">Determined by exchange‑defined haircut percentages</p></div>
      <div class="cell tb"><p class="k">Maximum Leverage</p></div><div class="cell tb"><p class="v">Up to 4x buying power</p></div><div class="cell tb"><p class="v">Subject to stock eligibility and available margin</p></div>

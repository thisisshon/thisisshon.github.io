---
/**
 * Fixed Deposit Calculator — /fd-calculator/
 * Estimates FD maturity value and interest earned, with a selectable
 * compounding frequency. Built on the shared calculator UI in global.css;
 * page carries only content + its maths. (The FD *product* page lives at
 * /fixed-deposit/ — this is the calculator tool.)
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/site/Breadcrumb.astro';
import FaqAccordion from '../components/sections/FaqAccordion.astro';
import { faqPageSchema } from '../lib/seo';
import { otherCalculators, calcHref } from '../data/calculators';

const MORE = otherCalculators('fd');

const FAQS = [
  {
    q: 'How is fixed deposit maturity value calculated?',
    a: 'The calculator uses the compound-interest formula A = P × (1 + r/n)^(n·t), where P is your principal, r is the annual interest rate, n is the number of times interest is compounded per year and t is the tenure in years. Most banks compound FD interest quarterly, which is the default here — you can switch to monthly or yearly to match your bank.',
  },
  {
    q: 'Why does compounding frequency change my maturity amount?',
    a: 'The more often interest is compounded, the sooner earned interest itself starts earning interest. So for the same rate and tenure, monthly compounding yields slightly more than quarterly, which yields more than yearly. The difference is small over short tenures but grows with longer terms and larger deposits.',
  },
  {
    q: 'Is the interest on a fixed deposit taxable?',
    a: 'Yes. Interest earned on a fixed deposit is added to your income and taxed at your applicable slab rate, and banks deduct TDS once interest crosses the prescribed threshold in a financial year. This calculator shows gross interest before tax — your in-hand return will be lower after tax.',
  },
  {
    q: 'Can I withdraw my fixed deposit before maturity?',
    a: 'Most FDs allow premature withdrawal, but banks typically apply a penalty and pay interest at a lower rate for the period the deposit was actually held. If you may need the money sooner, consider a shorter tenure or a laddered set of deposits rather than breaking one large FD.',
  },
  {
    q: 'Does this calculator apply to cumulative or non-cumulative FDs?',
    a: 'It models a cumulative FD, where interest is reinvested and paid together with the principal at maturity. In a non-cumulative FD the interest is paid out periodically instead of compounding, so the maturity value equals your principal and the total interest received is lower.',
  },
];

const seo = {
  title: 'Fixed Deposit Calculator',
  description:
    'Calculate your fixed deposit maturity amount and interest earned instantly with the free FD calculator from Shriram Financial Services.',
  path: '/fd-calculator/',
  jsonLd: [faqPageSchema(FAQS.map((f) => ({ question: f.q, answer: f.a })))],
};
---

<BaseLayout seo={seo} mainClass="rev-rise-scale">
  <!-- ================= HERO ================= -->
  <section class="hero hero-compact" id="sec-hero" data-section="hero">
    <Breadcrumb trail={[{ name: 'Calculators', href: '/calculators/' }, { name: 'FD Calculator' }]} />
    <div class="hero-inner" data-enter>
      <h1>Estimate Your Returns With The <span class="g">Fixed Deposit Calculator</span></h1>
      <p class="lead">Work out exactly what your deposit will be worth at maturity — adjust the amount, interest rate, tenure and compounding frequency.</p>
    </div>
  </section>

  <!-- ===== FD Calculator ===== -->
  <section class="section stack sec-light" id="sec-calc" data-section="calc" style="gap:24px" data-enter="2">
    <h2 class="sec-title">Fixed Deposit Calculator</h2>
    <p class="calc-hint">Drag the sliders or type your own numbers — results update instantly. Switch the compounding frequency to match your bank.</p>

    <div class="calc-row">
      <!-- inputs -->
      <div class="card calc-panel">
        <div class="freq-toggle" role="group" aria-label="Compounding frequency">
          <button type="button" class="freq-btn" data-freq="12" aria-pressed="false">Monthly</button>
          <button type="button" class="freq-btn is-active" data-freq="4" aria-pressed="true">Quarterly</button>
          <button type="button" class="freq-btn" data-freq="1" aria-pressed="false">Yearly</button>
        </div>

        <div class="fields">
          <div class="field">
            <div class="field-top">
              <label for="amt">Total investment</label>
              <div class="field-val"><span class="pfx">₹</span><input id="amt" type="text" inputmode="numeric" value="1,00,000" aria-label="Deposit amount in rupees" /></div>
            </div>
            <input class="slider" id="amtR" type="range" min="1000" max="10000000" step="1000" value="100000" aria-label="Deposit amount" />
            <div class="slider-scale"><span>₹1,000</span><span>₹1,00,00,000</span></div>
          </div>

          <div class="field">
            <div class="field-top">
              <label for="rate">Rate of interest</label>
              <div class="field-val"><input id="rate" type="text" inputmode="decimal" value="7" aria-label="Annual interest rate in percent" /><span class="sfx">%</span></div>
            </div>
            <input class="slider" id="rateR" type="range" min="1" max="15" step="0.1" value="7" aria-label="Annual interest rate in percent" />
            <div class="slider-scale"><span>1%</span><span>15%</span></div>
          </div>

          <div class="field">
            <div class="field-top">
              <label for="dur">Time period</label>
              <div class="field-val"><input id="dur" type="text" inputmode="numeric" value="5" aria-label="Tenure in years" /><span class="sfx">Yr</span></div>
            </div>
            <input class="slider" id="durR" type="range" min="1" max="20" step="1" value="5" aria-label="Tenure in years" />
            <div class="slider-scale"><span>1 Yr</span><span>20 Yr</span></div>
          </div>
        </div>
      </div>

      <!-- results -->
      <div class="calc-results">
        <div class="bar-wrap">
          <div class="bar-top">
            <div class="bar-head">
              <span class="bar-cap">Maturity Value</span>
              <span class="bar-tot" id="d-tot">₹1,41,478</span>
            </div>
            <div class="stack-bar" role="img" aria-label="Maturity value split between invested amount and interest earned">
              <div class="seg seg-inv" id="seg-inv" style="width:71%"></div>
              <div class="seg seg-ret" id="seg-ret" style="width:29%"></div>
            </div>
          </div>

          <div class="res-cards" data-reveal-row>
            <div class="res-card">
              <div class="res-top"><span class="dot" style="background:var(--c-inv)"></span>Invested Amount</div>
              <div class="res-val" id="r-inv">₹1,00,000</div>
            </div>
            <div class="res-card">
              <div class="res-top"><span class="dot" style="background:var(--c-ret)"></span>Total Interest</div>
              <div class="res-val" id="r-ret">₹41,478</div>
            </div>
          </div>

          <div class="bar-div" role="presentation"></div>

          <p class="bar-note">Note: Interest is compounded at the selected frequency; figures are illustrative and gross of tax. TDS and your income-tax slab will reduce the in-hand return.</p>
        </div>

        <div class="ready-bar">
          <p class="ready-text">Lock in a <b id="cta-amt">₹1,00,000 fixed deposit</b> today</p>
          <a class="ready-btn" href="/open-demat-account/">Open Demat Account</a>
        </div>
      </div>
    </div>

    <p class="sr-only" id="sr-summary" aria-live="polite"></p>
  </section>

  <!-- ===== What Is An FD Calculator ===== -->
  <section class="section stack sec-tint" id="sec-what" data-section="what" style="gap:24px">
    <h2 class="sec-title">What Is A Fixed Deposit Calculator?</h2>
    <p class="sec-lead">A fixed deposit calculator is a free online tool that estimates the maturity value and total interest of an FD before you invest. By entering your deposit amount, the interest rate your bank offers, the tenure and how often interest is compounded, it projects exactly what your deposit will be worth at maturity. It takes the manual maths out of comparing offers, so you can pick the tenure and bank that suit your goals.</p>
  </section>

  <!-- ===== How An FD Calculator Helps You ===== -->
  <section class="section stack sec-light" id="sec-help" data-section="help" style="gap:24px">
    <h2 class="sec-title">How A Fixed Deposit Calculator Helps You</h2>
    <p class="sec-lead">Comparing FD offers by hand means recomputing compound interest for every rate and tenure. The calculator does it instantly:</p>
    <ul class="bullets">
      <li>Estimate your exact maturity amount and total interest before committing any money.</li>
      <li>Compare tenures and rates side by side to find the deposit that best fits your horizon.</li>
      <li>See how monthly, quarterly or yearly compounding changes your final return.</li>
      <li>Plan around your goals with a firm, guaranteed-style number rather than a rough guess.</li>
    </ul>
  </section>

  <!-- ===== How Does An FD Calculator Work ===== -->
  <section class="section stack sec-tint" id="sec-work" data-section="work" style="gap:24px">
    <h2 class="sec-title">How Does A Fixed Deposit Calculator Work?</h2>
    <p class="sec-lead">The calculator applies the compound-interest formula A = P × (1 + r/n)^(n·t), where P is your principal, r is the annual interest rate expressed as a decimal, n is the number of compounding periods per year and t is the tenure in years. It computes the maturity value A, then subtracts your principal to show the total interest earned. Because interest is reinvested each period, choosing a more frequent compounding schedule increases the final figure — the calculator lets you see that effect immediately.</p>
  </section>

  <!-- ===== Advantages Of An FD Calculator ===== -->
  <section class="section stack sec-light" id="sec-adv" data-section="adv" style="gap:24px">
    <h2 class="sec-title">Advantages Of A Fixed Deposit Calculator</h2>
    <p class="sec-lead">For a low-risk, predictable instrument like an FD, knowing your return in advance is half the value:</p>
    <ul class="bullets">
      <li>Precise, instant maturity and interest figures for any amount, rate and tenure.</li>
      <li>Completely free to use, with no sign-up required and results delivered in real time.</li>
      <li>Makes it easy to ladder deposits or compare cumulative options with confidence.</li>
      <li>Helps you balance FDs against market-linked options within your overall portfolio.</li>
    </ul>
  </section>

  <!-- ===== Explore More ===== -->
  <section class="section stack sec-tint" id="sec-explore" data-section="explore" style="gap:40px">
    <h2 class="sec-title">Explore More</h2>
    <div class="explore-grid" data-reveal-row>
      {
        MORE.map((c) => (
          <a class="xcard" href={calcHref(c.slug)}>
            <span class="xc-title">{c.title}</span>
            <span class="xc-desc">{c.desc}</span>
            <span class="xc-cta">Calculate Now <span class="arr" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 8h11M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span></span>
          </a>
        ))
      }
    </div>
  </section>

  <!-- ===== General Questions ===== -->
  <section class="faq-wrap sec-light" id="sec-faq" data-section="faq">
    <div class="faq-cols">
      <div class="faq-left">
        <h2 class="faq-title">General Questions</h2>
        <FaqAccordion faqs={FAQS} />
      </div>
      <div class="faq-side">
        <div class="usr"><img src="/assets/user.svg" alt="" /></div>
        <div class="side-in">
          <div class="side-tx">
            <h3>Need A Clearer Direction? </h3>
            <p>Let's get in touch on a 15-Minute call where we would be able to answer any questions you may have. Our Advisor will additionally help map your wealth mix and demonstrate what a dedicated advisor would do differently.</p>
          </div>
          <a class="btn-gold" href="#">Book A Discovery Call</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Fixed Deposit calculator — calculator UI is shared in global.css. Page-local:
     General Questions sits on --sec-light, so the accordion + helper side card
     need a defined edge. */
  .faq-acc { border: 1px solid var(--color-border-card); padding: 1px; }
  .faq-side { border: 1px solid var(--color-border-card); }
</style>

<script>
  // Fixed deposit calculator — compound interest with selectable frequency.
  const fmt = new Intl.NumberFormat('en-IN', { maximumFractionDigits: 0 });
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const amt = document.getElementById('amt') as HTMLInputElement;
  const amtR = document.getElementById('amtR') as HTMLInputElement;
  const rate = document.getElementById('rate') as HTMLInputElement;
  const rateR = document.getElementById('rateR') as HTMLInputElement;
  const dur = document.getElementById('dur') as HTMLInputElement;
  const durR = document.getElementById('durR') as HTMLInputElement;
  let freq = 4; // compounding periods per year — default quarterly

  const segInv = document.getElementById('seg-inv') as HTMLElement;
  const segRet = document.getElementById('seg-ret') as HTMLElement;
  let last = { inv: 0, ret: 0, tot: 0 };

  function digits(s: string) {
    return String(s).replace(/[^0-9.]/g, '');
  }
  function clamp(v: number, mn: number, mx: number) {
    return Math.max(mn, Math.min(mx, v));
  }
  function fillSlider(sl: HTMLInputElement) {
    const p = ((+sl.value - +sl.min) / (+sl.max - +sl.min)) * 100;
    sl.style.background =
      'linear-gradient(90deg, #4f583b 0%, #4f583b ' + p + '%, #f3f3f3 ' + p + '%, #f3f3f3 100%)';
  }
  function countTo(el: HTMLElement, from: number, to: number, fn: (n: number) => string) {
    if (reduce || from === to) {
      el.textContent = fn(to);
      return;
    }
    let t0: number | null = null;
    const d = 350;
    function tick(ts: number) {
      if (t0 === null) t0 = ts;
      const t = Math.min(1, (ts - t0) / d);
      const e = 1 - Math.pow(1 - t, 3);
      el.textContent = fn(from + (to - from) * e);
      if (t < 1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }

  function render(animate: boolean) {
    const amount = clamp(parseFloat(digits(amt.value)) || 0, +amtR.min, +amtR.max);
    const ratePct = clamp(parseFloat(digits(rate.value)) || 0, +rateR.min, +rateR.max);
    const years = clamp(parseFloat(digits(dur.value)) || 0, +durR.min, +durR.max);

    const i = ratePct / 100 / freq;
    const fv = amount * Math.pow(1 + i, freq * years);
    const invested = amount;
    const interest = fv - invested;
    const rupee = (v: number) => '₹' + fmt.format(Math.round(v));

    if (animate) {
      countTo(document.getElementById('r-inv') as HTMLElement, last.inv, invested, rupee);
      countTo(document.getElementById('r-ret') as HTMLElement, last.ret, interest, rupee);
      countTo(document.getElementById('d-tot') as HTMLElement, last.tot, fv, rupee);
    } else {
      (document.getElementById('r-inv') as HTMLElement).textContent = rupee(invested);
      (document.getElementById('r-ret') as HTMLElement).textContent = rupee(interest);
      (document.getElementById('d-tot') as HTMLElement).textContent = rupee(fv);
    }
    last = { inv: invested, ret: interest, tot: fv };

    const invPct = fv > 0 ? (invested / fv) * 100 : 0;
    segInv.style.width = invPct + '%';
    segRet.style.width = 100 - invPct + '%';

    (document.getElementById('cta-amt') as HTMLElement).textContent =
      '₹' + fmt.format(amount) + ' fixed deposit';
    (document.getElementById('sr-summary') as HTMLElement).textContent =
      'Maturity value ' + rupee(fv) + ' on ' + rupee(invested) + ' deposited for ' + years + ' years.';

    updateUrl(amount, ratePct, years);
    amtR.setAttribute('aria-valuetext', '₹' + fmt.format(amount));
    rateR.setAttribute('aria-valuetext', ratePct + ' percent');
    durR.setAttribute('aria-valuetext', years + ' years');
  }

  function updateUrl(amount: number, ratePct: number, years: number) {
    const q = '?amt=' + amount + '&rate=' + ratePct + '&dur=' + years + '&freq=' + freq;
    try {
      history.replaceState(null, '', q);
    } catch (e) {
      /* ignore */
    }
  }

  function pairNumberAndSlider(numEl: HTMLInputElement, slEl: HTMLInputElement, group: boolean) {
    slEl.addEventListener('input', function () {
      numEl.value = group ? fmt.format(+slEl.value) : slEl.value;
      fillSlider(slEl);
      render(false);
    });
    numEl.addEventListener('input', function () {
      const raw = parseFloat(digits(numEl.value)) || 0;
      if (group) numEl.value = raw ? fmt.format(raw) : '';
      slEl.value = String(clamp(raw, +slEl.min, +slEl.max));
      fillSlider(slEl);
      render(false);
    });
    numEl.addEventListener('change', function () {
      const v = clamp(parseFloat(digits(numEl.value)) || +slEl.min, +slEl.min, +slEl.max);
      numEl.value = group ? fmt.format(v) : String(v);
      slEl.value = String(v);
      fillSlider(slEl);
      render(true);
    });
  }
  pairNumberAndSlider(amt, amtR, true);
  pairNumberAndSlider(rate, rateR, false);
  pairNumberAndSlider(dur, durR, false);

  document.querySelectorAll('.freq-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      freq = parseInt(btn.getAttribute('data-freq') || '4', 10);
      document.querySelectorAll('.freq-btn').forEach(function (b) {
        const on = b === btn;
        b.classList.toggle('is-active', on);
        b.setAttribute('aria-pressed', on ? 'true' : 'false');
      });
      render(true);
    });
  });

  (function initFromUrl() {
    const p = new URLSearchParams(location.search);
    function setNum(el: HTMLInputElement, sl: HTMLInputElement, key: string, group: boolean) {
      if (!p.has(key)) return;
      const v = clamp(parseFloat(p.get(key) || '') || +sl.min, +sl.min, +sl.max);
      sl.value = String(v);
      el.value = group ? fmt.format(v) : String(v);
    }
    setNum(amt, amtR, 'amt', true);
    setNum(rate, rateR, 'rate', false);
    setNum(dur, durR, 'dur', false);
    if (p.has('freq')) {
      const f = parseInt(p.get('freq') || '', 10);
      if (f === 12 || f === 4 || f === 1) {
        freq = f;
        document.querySelectorAll('.freq-btn').forEach(function (b) {
          const on = parseInt(b.getAttribute('data-freq') || '', 10) === f;
          b.classList.toggle('is-active', on);
          b.setAttribute('aria-pressed', on ? 'true' : 'false');
        });
      }
    }
  })();

  [amtR, rateR, durR].forEach(fillSlider);
  render(true);
</script>

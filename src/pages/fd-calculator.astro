---
/**
 * Fixed Deposit Calculator - /fd-calculator/
 * Estimates FD maturity value and interest earned, with a selectable
 * compounding frequency. Built on the shared calculator UI in global.css;
 * page carries only content + its maths. (The FD *product* page lives at
 * /fixed-deposit/ - this is the calculator tool.)
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/site/Breadcrumb.astro';
import FaqAccordion from '../components/sections/FaqAccordion.astro';
import { faqPageSchema } from '../lib/seo';

// General-Questions FAQ - compliance doc content verbatim, same order.
const FAQS = [
  {
    q: 'What is a fixed deposit calculator?',
    a: 'A fixed deposit calculator is an online tool that estimates FD maturity value and interest earned using amount, rate, tenure and compounding frequency.',
  },
  {
    q: 'How is FD maturity calculated?',
    a: 'For cumulative FDs, interest is compounded. For short-tenure or payout FDs, simple interest may be used.',
  },
  {
    q: 'Is FD interest taxable?',
    a: 'Yes. FD interest is generally added to income and taxed as per the applicable income tax slab.',
  },
  {
    q: 'What is TDS on FD interest?',
    a: 'TDS may apply when annual interest crosses the prescribed threshold. The threshold and rate can change, so users should check current tax rules.',
  },
  {
    q: 'What is the difference between cumulative and non-cumulative FD?',
    a: 'Cumulative FDs pay interest at maturity. Non-cumulative FDs pay interest at regular intervals.',
  },
  {
    q: 'Can an FD be broken before maturity?',
    a: 'Yes, an FD can be broken before maturity, but  few issuers may charge a penalty or offer a lower effective rate.',
  },
  {
    q: 'What is a tax-saver FD?',
    a: 'A tax-saver FD has a 5-year lock-in and may provide deduction benefits under Section 80C, subject to rules.',
  },
  {
    q: 'Is FD safe?',
    a: 'FDs are considered low-risk, but users should check the issuer’s strength and deposit insurance limits.',
  },
  {
    q: 'What is DICGC insurance?',
    a: 'DICGC (Deposit Insurance and Credit Guarantee Corporation) insurance protects eligible bank deposits up to the prescribed limit per depositor per bank.',
  },
  {
    q: 'How does the calculator handle senior citizen rates?',
    a: 'Users can select Senior Citizen and apply the additional rate offered by the institution.',
  },
  {
    q: 'What is the minimum amount to open an FD?',
    a: 'Minimum amounts vary by issuers or platform. Many banks and NBFC allow FDs from small starting amounts i.e Rs. 1000.',
  },
  {
    q: 'Is FD better than RD?',
    a: 'FD suits lump sum investing. RD, on the other hand, suits regular monthly saving.',
  },
  {
    q: 'Can I take a loan against my FD?',
    a: 'Many banks allow loans against FDs. Please note that the limit and interest rate vary by bank.',
  },
  {
    q: 'What is FD laddering?',
    a: 'FD laddering means splitting money across FDs with different maturity dates for liquidity and rate flexibility.',
  },
  {
    q: 'What is the difference between NRE and NRO FD?',
    a: 'NRE (Non-Resident External) FDs are for overseas income. NRO (Non-Resident Ordinary) FDs are for income earned in India by NRIs.',
  },
  {
    q: 'Is NRE FD interest taxable in India?',
    a: 'NRE FD interest is generally tax-free in India, subject to eligibility and current rules.',
  },
];

const seo = {
  title: 'Fixed Deposit Calculator',
  description:
    'Calculate your fixed deposit maturity amount and interest earned instantly with the free FD calculator from Shriram Financial Services.',
  path: '/fd-calculator/',
  jsonLd: [faqPageSchema(FAQS.map((f) => ({ question: f.q, answer: f.a })))],
};
---

<BaseLayout seo={seo} mainClass="rev-rise-scale">
  <!-- ================= HERO ================= -->
  <section class="hero hero-compact" id="sec-hero" data-section="hero">
    <Breadcrumb trail={[{ name: 'Calculators', href: '/calculators/' }, { name: 'FD Calculator' }]} />
    <div class="hero-inner" data-enter>
      <h1>FD Calculator – Calculate Fixed Deposit Interest &amp; <span class="g">Maturity Amount Instantly</span></h1>
      <p class="lead">Estimate your FD returns in seconds and plan your savings with confidence.</p>
      <div class="cta"><a class="btn-gold" href="/open-demat-account/">Open FD Online Now</a><a class="btn-ghost" href="/fixed-deposit/">Compare FD Rates</a></div>
    </div>
  </section>

  <!-- ===== FD Calculator ===== -->
  <section class="section stack sec-light" id="sec-calc" data-section="calc" style="gap:24px" data-enter="2">
    <h2 class="sec-title">Fixed Deposit Calculator</h2>
    <p class="calc-hint">Drag the sliders or type your own numbers - results update instantly.</p>

    <div class="calc-row">
      <!-- inputs -->
      <div class="card calc-panel">
        <div class="fields">
          <div class="field">
            <div class="field-top">
              <label for="amt">Principal Amount</label>
              <div class="field-val"><span class="pfx">₹</span><input id="amt" type="text" inputmode="numeric" value="1,00,000" aria-label="Principal amount in rupees" /></div>
            </div>
            <input class="slider" id="amtR" type="range" min="1000" max="10000000" step="1000" value="100000" aria-label="Principal amount" />
            <div class="slider-scale"><span>₹1,000</span><span>₹1,00,00,000</span></div>
          </div>

          <div class="field">
            <div class="field-top">
              <label for="rate">Interest Rate (% p.a.)</label>
              <div class="field-val"><input id="rate" type="text" inputmode="decimal" value="7.5" aria-label="Annual interest rate in percent" /><span class="sfx">%</span></div>
            </div>
            <input class="slider" id="rateR" type="range" min="1" max="15" step="0.1" value="7.5" aria-label="Annual interest rate in percent" />
            <div class="slider-scale"><span>1%</span><span>15%</span></div>
          </div>

          <div class="field">
            <div class="field-top">
              <label for="dur">Tenure</label>
              <div class="field-val"><input id="dur" type="text" inputmode="numeric" value="3" aria-label="Tenure in years" /><span class="sfx">yrs</span></div>
            </div>
            <input class="slider" id="durR" type="range" min="1" max="10" step="1" value="3" aria-label="Tenure in years" />
            <div class="slider-scale"><span>1 yrs</span><span>10 yrs</span></div>
          </div>
        </div>
      </div>

      <!-- results -->
      <div class="calc-results">
        <div class="bar-wrap">
          <div class="bar-top">
            <div class="bar-head">
              <span class="bar-cap">Total Value</span>
              <span class="bar-tot" id="d-tot">₹1,24,899</span>
            </div>
            <div class="stack-bar" role="img" aria-label="Total value split between invested amount and estimated returns">
              <div class="seg seg-inv" id="seg-inv" style="width:80%"></div>
              <div class="seg seg-ret" id="seg-ret" style="width:20%"></div>
            </div>
          </div>

          <div class="res-cards" data-reveal-row>
            <div class="res-card">
              <div class="res-top"><span class="dot" style="background:var(--c-inv)"></span>Invested Amount</div>
              <div class="res-val" id="r-inv">₹1,00,000</div>
            </div>
            <div class="res-card">
              <div class="res-top"><span class="dot" style="background:var(--c-ret)"></span>Estimated Returns</div>
              <div class="res-val" id="r-ret">₹24,899</div>
            </div>
          </div>

          <div class="bar-div" role="presentation"></div>

          <p class="bar-note">Figures are illustrative and assume a constant rate over the full term; actual returns fluctuate and are not guaranteed.</p>
        </div>

        <div class="ready-bar">
          <p class="ready-text">Put your plan into action - <b>open a free Demat account</b></p>
          <a class="ready-btn" href="/open-demat-account/">Open Demat Account</a>
        </div>
      </div>
    </div>

    <p class="sr-only" id="sr-summary" aria-live="polite"></p>
  </section>

  <!-- ===== What Is an FD Calculator? ===== -->
  <section class="section stack sec-tint" id="sec-what" data-section="what" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">What Is an FD Calculator?</h2>
      <p class="sec-lead">An FD Calculator is a free online tool that calculates the maturity amount and interest earned on a fixed deposit. It helps remove manual errors and makes it easier to compare FD options before investing.</p>
      <p class="sec-lead">Key benefits of an FD calculator:</p>
    </div>
    <ul class="bullets">
      <li>Know your maturity value instantly.</li>
      <li>Compare cumulative and non-cumulative FD returns.</li>
      <li>Estimate tax deducted at source, where applicable.</li>
      <li>Check the benefit of senior citizen rates.</li>
      <li>Use it free, with no login required.</li>
    </ul>
  </section>

  <!-- ===== How Does the FD Calculator Work? ===== -->
  <section class="section stack sec-light" id="sec-work" data-section="work" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">How Does the FD Calculator Work?</h2>
      <p class="sec-lead">The calculator uses either compound interest or simple interest, depending on the FD type and tenure.</p>
    </div>
    <div class="t-scroll"><div class="product-page_table t3 bordered" style="grid-template-columns:repeat(3,minmax(0,1fr));min-width:640px">
      <div class="cell th"><p>Mode</p></div><div class="cell th"><p>Formula</p></div><div class="cell th"><p>Best Used For</p></div>
      <div class="cell tb"><p class="k">Compound Interest</p></div><div class="cell tb"><p class="v">A = P × (1 + r/n)^(n×t)</p></div><div class="cell tb"><p class="v">Cumulative FDs where interest is reinvested.</p></div>
      <div class="cell tb"><p class="k">Simple Interest</p></div><div class="cell tb"><p class="v">SI = P × r × t / 100</p></div><div class="cell tb"><p class="v">Short-tenure or payout-based calculations.</p></div>
    </div></div>
    <div class="t-scroll"><div class="product-page_table t2 bordered" style="grid-template-columns:repeat(2,minmax(0,1fr))">
      <div class="cell th"><p>Symbol</p></div><div class="cell th"><p>Meaning</p></div>
      <div class="cell tb"><p class="k">A</p></div><div class="cell tb"><p class="v">Maturity amount</p></div>
      <div class="cell tb"><p class="k">P</p></div><div class="cell tb"><p class="v">Principal amount</p></div>
      <div class="cell tb"><p class="k">r</p></div><div class="cell tb"><p class="v">Annual interest rate</p></div>
      <div class="cell tb"><p class="k">n</p></div><div class="cell tb"><p class="v">Compounding frequency</p></div>
      <div class="cell tb"><p class="k">t</p></div><div class="cell tb"><p class="v">Tenure in years</p></div>
    </div></div>
    <p class="sec-lead">Worked example Investment: ₹5,00,000 at 7% for 3 years. Quarterly compounding: maturity is about ₹6,15,720 and interest is about ₹1,15,720. Simple interest: interest is ₹1,05,000 and total value is ₹6,05,000.</p>
  </section>

  <!-- ===== FD Interest Rate Scenarios ===== -->
  <section class="section stack sec-tint" id="sec-scenarios" data-section="scenarios" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">FD Interest Rate Scenarios</h2>
      <p class="sec-lead">Use these examples as quick reference points. Actual returns may differ by bank, tenure, payout option and compounding rule.</p>
    </div>
    <div class="t-scroll"><div class="product-page_table t6 bordered" style="grid-template-columns:repeat(6,minmax(0,1fr));min-width:760px">
      <div class="cell th"><p>Principal</p></div><div class="cell th"><p>Rate</p></div><div class="cell th"><p>Tenure</p></div><div class="cell th"><p>Maturity</p></div><div class="cell th"><p>Interest Earned</p></div><div class="cell th"><p>Monthly Interest*</p></div>
      <div class="cell tb"><p class="k">₹1,00,000</p></div><div class="cell tb"><p class="v">6.50%</p></div><div class="cell tb"><p class="v">1 year</p></div><div class="cell tb"><p class="v">₹1,06,660</p></div><div class="cell tb"><p class="v">₹6,660</p></div><div class="cell tb"><p class="v">₹542</p></div>
      <div class="cell tb"><p class="k">₹1,00,000</p></div><div class="cell tb"><p class="v">7.00%</p></div><div class="cell tb"><p class="v">3 years</p></div><div class="cell tb"><p class="v">₹1,23,144</p></div><div class="cell tb"><p class="v">₹23,144</p></div><div class="cell tb"><p class="v">₹583</p></div>
      <div class="cell tb"><p class="k">₹5,00,000</p></div><div class="cell tb"><p class="v">7.00%</p></div><div class="cell tb"><p class="v">3 years</p></div><div class="cell tb"><p class="v">₹6,15,720</p></div><div class="cell tb"><p class="v">₹1,15,720</p></div><div class="cell tb"><p class="v">₹2,917</p></div>
      <div class="cell tb"><p class="k">₹5,00,000</p></div><div class="cell tb"><p class="v">7.50%</p></div><div class="cell tb"><p class="v">5 years</p></div><div class="cell tb"><p class="v">₹7,24,974</p></div><div class="cell tb"><p class="v">₹2,24,974</p></div><div class="cell tb"><p class="v">₹3,125</p></div>
      <div class="cell tb"><p class="k">₹10,00,000</p></div><div class="cell tb"><p class="v">7.00%</p></div><div class="cell tb"><p class="v">5 years</p></div><div class="cell tb"><p class="v">₹14,14,778</p></div><div class="cell tb"><p class="v">₹4,14,778</p></div><div class="cell tb"><p class="v">₹5,833</p></div>
      <div class="cell tb"><p class="k">₹10,00,000</p></div><div class="cell tb"><p class="v">7.50%</p></div><div class="cell tb"><p class="v">5 years</p></div><div class="cell tb"><p class="v">₹14,49,948</p></div><div class="cell tb"><p class="v">₹4,49,948</p></div><div class="cell tb"><p class="v">₹6,250</p></div>
      <div class="cell tb"><p class="k">₹25,00,000</p></div><div class="cell tb"><p class="v">7.00%</p></div><div class="cell tb"><p class="v">3 years</p></div><div class="cell tb"><p class="v">₹30,78,598</p></div><div class="cell tb"><p class="v">₹5,78,598</p></div><div class="cell tb"><p class="v">₹14,583</p></div>
      <div class="cell tb"><p class="k">₹50,00,000</p></div><div class="cell tb"><p class="v">7.25%</p></div><div class="cell tb"><p class="v">5 years</p></div><div class="cell tb"><p class="v">₹71,61,303</p></div><div class="cell tb"><p class="v">₹21,61,303</p></div><div class="cell tb"><p class="v">₹30,208</p></div>
    </div></div>
    <p class="sec-lead">*Disclaimer: The numbers used in this table are illustrative examples only. Actual returns may differ based on the bank’s FD terms, interest rate, tenure, compounding method, and payout option.</p>
  </section>

  <!-- ===== How to Use the FD Calculator ===== -->
  <section class="section stack sec-light" id="sec-how-to-use" data-section="how-to-use" style="gap:56px;align-items:center;justify-content:center">
    <div class="stack" style="gap:16px;width:100%">
      <h2 class="sec-title">How to Use the FD Calculator</h2>
      <p class="sec-lead">Use the FD Calculator to quickly estimate your maturity amount and interest earned by entering your investment amount, interest rate, tenure, and payout preferences.</p>
    </div>
    <div class="steps" data-reveal-row>
      <div class="step">
        <div class="num">1</div>
        <div class="st-body"><h4>Step 1</h4><p>Enter the amount you want to invest.</p></div>
      </div>
      <div class="step-div"></div>
      <div class="step">
        <div class="num">2</div>
        <div class="st-body"><h4>Step 2</h4><p>Add the annual interest rate offered by your chosen bank or NBFC.</p></div>
      </div>
      <div class="step-div"></div>
      <div class="step">
        <div class="num">3</div>
        <div class="st-body"><h4>Step 3</h4><p>Select the tenure in years and months.</p></div>
      </div>
      <div class="step-div"></div>
      <div class="step">
        <div class="num">4</div>
        <div class="st-body"><h4>Step 4</h4><p>Choose the compounding frequency or simple interest option.</p></div>
      </div>
      <div class="step-div"></div>
      <div class="step">
        <div class="num">5</div>
        <div class="st-body"><h4>Select Regular or Senior Citizen and view results instantly.</h4></div>
      </div>
    </div>
  </section>

  <!-- ===== Cumulative vs Non-Cumulative FD ===== -->
  <section class="section stack sec-tint" id="sec-cumulative" data-section="cumulative" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Cumulative vs Non-Cumulative FD</h2>
      <p class="sec-lead">Understand the difference between cumulative and non-cumulative FDs to choose whether you want higher maturity returns or regular interest payouts.</p>
    </div>
    <div class="t-scroll"><div class="product-page_table t3 bordered" style="grid-template-columns:repeat(3,minmax(0,1fr));min-width:640px">
      <div class="cell th"><p>Parameter</p></div><div class="cell th"><p>Cumulative FD</p></div><div class="cell th"><p>Non-Cumulative FD</p></div>
      <div class="cell tb"><p class="k">Interest payout</p></div><div class="cell tb"><p class="v">Paid at maturity</p></div><div class="cell tb"><p class="v">Paid monthly, quarterly or annually</p></div>
      <div class="cell tb"><p class="k">Return potential</p></div><div class="cell tb"><p class="v">Higher, due to compounding</p></div><div class="cell tb"><p class="v">Lower, as interest is not reinvested</p></div>
      <div class="cell tb"><p class="k">Best for</p></div><div class="cell tb"><p class="v">Long-term goals</p></div><div class="cell tb"><p class="v">Regular income needs</p></div>
      <div class="cell tb"><p class="k">Suitable users</p></div><div class="cell tb"><p class="v">Salaried investors and goal planners</p></div><div class="cell tb"><p class="v">Retirees and income-focused investors</p></div>
      <div class="cell tb"><p class="k">TDS point</p></div><div class="cell tb"><p class="v">Usually on annual accrual</p></div><div class="cell tb"><p class="v">Usually when interest is credited</p></div>
      <div class="cell tb"><p class="k">Example</p></div><div class="cell tb"><p class="v">₹5 lakh at 7% for 5 years grows to about ₹7.07 lakh maturity.</p></div><div class="cell tb"><p class="v">₹5 lakh at 7% gives about ₹2,917 per month payout till tenure.</p></div>
    </div></div>
    <p class="sec-lead">Quick tip: Choose a cumulative FD if regular income is not needed. Choose a non-cumulative FD if predictable cash flow is the priority.</p>
  </section>

  <!-- ===== FD Laddering Strategy ===== -->
  <section class="section stack sec-light" id="sec-laddering" data-section="laddering" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">FD Laddering Strategy</h2>
      <p class="sec-lead">FD laddering means splitting one large deposit into smaller FDs with different maturity dates. It gives regular liquidity and reduces the risk of locking all money at one rate.</p>
    </div>
    <div class="t-scroll"><div class="product-page_table t6 bordered" style="grid-template-columns:repeat(6,minmax(0,1fr));min-width:760px">
      <div class="cell th"><p>Tranche</p></div><div class="cell th"><p>Amount</p></div><div class="cell th"><p>Tenure</p></div><div class="cell th"><p>Illustrative Rate</p></div><div class="cell th"><p>Maturity Value</p></div><div class="cell th"><p>Matures In</p></div>
      <div class="cell tb"><p class="k">FD 1</p></div><div class="cell tb"><p class="v">₹2,00,000</p></div><div class="cell tb"><p class="v">1 year</p></div><div class="cell tb"><p class="v">6.80%</p></div><div class="cell tb"><p class="v">₹2,13,951</p></div><div class="cell tb"><p class="v">Year 1</p></div>
      <div class="cell tb"><p class="k">FD 2</p></div><div class="cell tb"><p class="v">₹2,00,000</p></div><div class="cell tb"><p class="v">2 years</p></div><div class="cell tb"><p class="v">7.00%</p></div><div class="cell tb"><p class="v">₹2,29,776</p></div><div class="cell tb"><p class="v">Year 2</p></div>
      <div class="cell tb"><p class="k">FD 3</p></div><div class="cell tb"><p class="v">₹2,00,000</p></div><div class="cell tb"><p class="v">3 years</p></div><div class="cell tb"><p class="v">7.20%</p></div><div class="cell tb"><p class="v">₹2,47,744</p></div><div class="cell tb"><p class="v">Year 3</p></div>
      <div class="cell tb"><p class="k">FD 4</p></div><div class="cell tb"><p class="v">₹2,00,000</p></div><div class="cell tb"><p class="v">4 years</p></div><div class="cell tb"><p class="v">7.30%</p></div><div class="cell tb"><p class="v">₹2,67,116</p></div><div class="cell tb"><p class="v">Year 4</p></div>
      <div class="cell tb"><p class="k">FD 5</p></div><div class="cell tb"><p class="v">₹2,00,000</p></div><div class="cell tb"><p class="v">5 years</p></div><div class="cell tb"><p class="v">7.50%</p></div><div class="cell tb"><p class="v">₹2,89,990</p></div><div class="cell tb"><p class="v">Year 5</p></div>
    </div></div>
    <ul class="bullets">
      <li>One FD can mature every year.</li>
      <li>Maturing amounts can be reinvested at new rates.</li>
      <li>The investor avoids locking the full amount into one tenure.</li>
      <li>This strategy is useful for retirees and conservative investors.</li>
    </ul>
  </section>

  <!-- ===== How to Avoid Common Mistakes While Selecting FDs ===== -->
  <section class="section stack sec-tint" id="sec-mistakes" data-section="mistakes" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">How to Avoid Common Mistakes While Selecting FDs</h2>
      <p class="sec-lead">While selecting FDs, we can avoid mistakes by reviewing rates, penalties, tax forms, deposit limits, and real returns before investing or renewing a fixed deposit.</p>
    </div>
    <div class="t-scroll"><div class="product-page_table t2 bordered" style="grid-template-columns:repeat(2,minmax(0,1fr))">
      <div class="cell th"><p>Mistake</p></div><div class="cell th"><p>Simple Fix</p></div>
      <div class="cell tb"><p class="k">Auto-renewing without checking rates</p></div><div class="cell tb"><p class="v">Compare rates before renewal.</p></div>
      <div class="cell tb"><p class="k">Breaking an FD early without checking penalty</p></div><div class="cell tb"><p class="v">Check the premature withdrawal rule first.</p></div>
      <div class="cell tb"><p class="k">Ignoring Form 15G or 15H</p></div><div class="cell tb"><p class="v">Submit the right form if eligible.</p></div>
      <div class="cell tb"><p class="k">Putting all money into one large FD</p></div><div class="cell tb"><p class="v">Split deposits by goal, tenure or bank.</p></div>
      <div class="cell tb"><p class="k">Choosing an NBFC FD only for a higher rate</p></div><div class="cell tb"><p class="v">Check credit rating and risk.</p></div>
      <div class="cell tb"><p class="k">Ignoring real returns</p></div><div class="cell tb"><p class="v">Review post-tax and inflation-adjusted return.</p></div>
    </div></div>
  </section>

  <!-- ===== General Questions ===== -->
  <section class="faq-wrap sec-light" id="sec-faq" data-section="faq">
    <div class="faq-cols">
      <div class="faq-left">
        <h2 class="faq-title">General Questions</h2>
        <FaqAccordion faqs={FAQS} />
      </div>
      <div class="faq-side">
        <div class="usr"><img src="/assets/user.svg" alt="" /></div>
        <div class="side-in">
          <div class="side-tx">
            <h3>Need A Clearer Direction? </h3>

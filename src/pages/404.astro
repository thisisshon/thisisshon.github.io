---
/**
 * 404 — also ProofKit's universal /<page>/review router.
 *
 * ⚠ PART OF THE PROOFKIT PACKAGE. This file is site-level only because static
 * hosting forces it to be (see below), but it belongs to the isolated ProofKit
 * tool, not the main site. It is therefore EXEMPT from the main-site design
 * system (BaseLayout/tokens/one-font/8px-grid rules) and is excluded from
 * site-wide guideline audits — it carries ProofKit's own chrome/fonts/colours
 * by design. Do not "fix" it to the main design system.
 *
 * On a static host every /<page>/review has no file, so GitHub Pages (and astro
 * preview) serve 404.html. This catches that: if the path ends in /review it arms
 * auto-review and bounces to the real page (/<page>), where the on-page overlay
 * opens the ProofKit login then review mode. Any page works with NO per-page stub.
 * A genuine 404 (no /review) shows the friendly message below. The redirect runs in
 * <head> before paint, so valid /<page>/review never flashes this page.
 * (This one file is necessarily site-level — it's the only way to catch arbitrary
 * /<page>/review paths on static hosting.)
 */
import { PROOFKIT_ENABLED } from '../plugins/proofkit/config';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Not found</title>
    {PROOFKIT_ENABLED && (
      <script is:inline>
        (() => {
          var path = location.pathname.replace(/\/+$/, '');
          var m = path.match(/^(.*)\/review$/);
          if (m) {
            try { sessionStorage.setItem('pkAutoReview', '1'); } catch (e) {}
            location.replace(m[1] || '/');
          }
        })();
      </script>
    )}
    <style>
      * { box-sizing: border-box; }
      body { margin: 0; }
      .pk404 { min-height: 100vh; display: flex; flex-direction: column; align-items: center;
        justify-content: center; text-align: center; background: #181818; color: #fff; padding: 48px 20px;
        font: 400 15px/1.6 Inter, system-ui, -apple-system, sans-serif; }
      .pk404-brand { display: flex; align-items: center; gap: 8px; margin-bottom: 28px;
        font: 600 12px/1 Inter, system-ui, sans-serif; text-transform: uppercase; letter-spacing: 1.1px; }
      .pk404-mark { width: 9px; height: 9px; background: #da291c; display: inline-block; }
      .pk404-title { font: 500 40px/1.1 Inter, system-ui, sans-serif; letter-spacing: -1px; margin: 0; }
      .pk404-sub { max-width: 460px; color: #969696; margin: 16px 0 32px; }
      .pk404-sub code { background: #303030; color: #fff; padding: 2px 6px; border-radius: 3px;
        font-size: 13px; font-family: ui-monospace, Menlo, monospace; }
      .pk404-btn { display: inline-flex; align-items: center; height: 48px; padding: 0 32px; background: #da291c;
        color: #fff; text-decoration: none; font: 700 14px/1 Inter, system-ui, sans-serif;
        text-transform: uppercase; letter-spacing: 1.4px; }
    </style>
  </head>
  <body>
    <main class="pk404">
      <div class="pk404-brand"><span class="pk404-mark"></span>ProoofKit</div>
      <h1 class="pk404-title">Well, this is awkward.</h1>
      <p class="pk404-sub">
        There's no page here. If you were trying to <strong>review</strong> one, open the page
        first, then pop <code>/review</code> onto the end of its address — e.g. <code>/equity/review</code>.
      </p>
      <a class="pk404-btn" href="/">Take me home</a>
    </main>
  </body>
</html>

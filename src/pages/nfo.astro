---
/**
 * NFO - /nfo/
 * Long-form New Fund Offer guide. Content is the compliance-approved doc,
 * rendered with the shared design-system components in global.css (hero,
 * .section/.sec-title, .card, .product-page_table, .cat-grid, .check-card,
 * .steps, FaqAccordion, .cta-box). Nested route → imports at ../ depth.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/site/Breadcrumb.astro';
import FaqAccordion from '../components/sections/FaqAccordion.astro';
import { faqPageSchema, breadcrumbSchema, organizationSchema } from '../lib/seo';

// NFO vs IPO - the parallel comparison table.
const NFO_IPO_ROWS = [
  { k: 'What is being offered', n: 'Units of a new mutual fund scheme', i: 'Shares of a company' },
  { k: 'Offer price', n: 'Typically ₹10 per unit', i: 'Determined by price band' },
  { k: 'Who issues it', n: 'Asset Management Company (AMC)', i: 'The company going public' },
  { k: 'Duration', n: 'Maximum 30 days (SEBI mandated)', i: 'Typically 3–5 business days' },
  { k: 'What you own post-subscription', n: 'Units in a pooled fund', i: 'Direct equity shares' },
];

// The NFO Process - step by step.
const PROCESS = [
  { h: 'SEBI Approval', p: 'The AMC files a Scheme Information Document (SID) with SEBI and receives approval to launch the NFO.' },
  { h: 'NFO Opens', p: 'The subscription window opens. Investors can apply through the AMC website, registered platforms, distributors, or directly at AMC branches.' },
  { h: 'Subscription Period', p: 'Investors subscribe at ₹10 per unit. The AMC collects the pooled corpus.' },
  { h: 'NFO Closes', p: 'At the end of the window (maximum 30 days for most fund types), the fund closes to fresh subscriptions.' },
  { h: 'Allotment', p: 'Units are allotted to investors based on the amount invested at the offer price.' },
  { h: 'Fund Deployment', p: "The fund manager begins deploying the corpus as per the scheme's investment mandate." },
  { h: 'NAV-Based Transactions', p: 'For open-ended funds, the scheme opens for regular purchase and redemption at the prevailing Net Asset Value (NAV).' },
];

// Key Features of a New Fund Offer - i to iv.
const FEATURES = [
  { h: 'Offering Price', p: 'NFOs are typically launched at ₹10 per unit, a SEBI-standardised price, ensuring equal entry for all investors. This should not be mistaken for the fund being undervalued. What truly matters are the fund’s mandate, AMC credibility, and market opportunity.' },
  { h: 'Limited Subscription Window', p: 'NFOs are open for a maximum of 30 days as mandated by SEBI, requiring investors to assess, decide, and act within a defined timeframe.' },
  { h: 'Investment Mandate and Benchmark', p: 'The mandate outlines the fund’s objective, asset allocation, sector focus, and risk approach, while the benchmark indicates how performance will be measured. Investors should ensure alignment with their horizon, risk appetite, and portfolio strategy before subscribing.' },
  { h: 'Lock-in Period for Close-ended Funds', p: 'Close-ended NFOs carry a mandatory lock-in of 3 to 5 years with no direct AMC redemption. Units are listed on NSE/BSE as an alternate exit, though liquidity may be limited. ELSS funds carry a 3-year lock-in per SIP instalment.' },
];

// Types of NFOs - four primary types.
const TYPE_ROWS = [
  {
    k: 'Open-ended NFOs',
    structure: 'No fixed maturity date; units available for purchase and redemption at prevailing NAV on any business day post offer period',
    lockin: 'No lock-in; exit loads may apply for early redemptions',
    highlight: 'Maximum flexibility for investors',
  },
  {
    k: 'Close-ended NFOs',
    structure: 'Fixed tenure of typically 3 to 5 years; no direct AMC redemption during the period',
    lockin: 'Locked in until maturity; units listed on NSE/BSE as an alternate exit route',
    highlight: 'Structured exit with exchange listing',
  },
  {
    k: 'ELSS NFOs',
    structure: 'Open-ended equity fund structure; investments qualify for tax deductions under Section 80C',
    lockin: 'Mandatory 3-year lock-in per investment instalment',
    highlight: 'Tax savings of up to ₹1.5 lakh annually under Section 80C',
  },
  {
    k: 'Sectoral / Thematic NFOs',
    structure: 'Typically open-ended; concentrated portfolio targeting specific industries or investment themes',
    lockin: 'No lock-in period',
    highlight: 'Suited for investors with strong sectoral conviction and higher risk appetite',
  },
];

// How to Invest in NFO - the online process.
const INVEST_STEPS = [
  { h: 'Download and Register on the app', p: 'Download Shriram Financial Services’ “Purse+” app and get registered.' },
  { h: 'Complete KYC', p: 'Complete the KYC formalities as per the instructions shared in the app.' },
  { h: 'Post MF registration open the Purse+ App and Navigate to NFO Section', p: "Move to the mutual fund module on the home screen and select the dedicated 'New Fund Offers' to view all active, regulatory-approved subscription windows." },
  { h: 'Review Allotment Confirmation', p: 'Upon successful transaction validation, your capital remains securely parked until the official closing date. The AMC will process unit generation within 5 business days of the subscription window ending, sending an official Statement of Account (SoA) directly to your registered digital destination.' },
];

// Benefits and Risks of an NFO.
const BENEFIT_RISK_ROWS = [
  { cat: 'Benefit', aspect: 'Attractive Entry Price at ₹10', details: "NFOs are launched at a standard entry price of ₹10 per unit, making them accessible to investors. However, investment decisions should go beyond entry price and focus on the scheme's objective, portfolio strategy, and long-term potential." },
  { cat: '', aspect: 'Diversification Opportunities', details: "NFOs, especially thematic and sectoral ones, often introduce fund categories or asset allocation strategies not yet present in an AMC's portfolio. This adds meaningful diversification by spreading capital across fresh growth drivers that complement existing core holdings." },
  { cat: 'Risk', aspect: 'No Historical Performance', details: 'NFOs carry no performance track record. Unlike existing mutual funds where 3-year, 5-year, and 10-year returns, rolling returns, and Sharpe ratios can be analysed, an NFO has zero history — making evaluation largely dependent on AMC reputation and fund manager credentials.' },
  { cat: '', aspect: 'Lock-in and Liquidity Risks', details: 'Close-ended NFOs lock in capital until maturity, restricting withdrawals even during emergencies. Open-ended NFOs, while more flexible, may carry exit loads on redemptions made within the first year, adding a short-term liquidity consideration for investors.' },
];

// How to Evaluate an NFO Before Investing.
const EVALUATE = [
  { h: 'AMC Reputation and Fund Manager', p: "Opt for an AMC with strong research capabilities, sound processes, and experienced fund managers. A credible fund house and proven investment team inspire greater confidence in a new scheme's strategy and execution." },
  { h: 'Investment Objective and Theme', p: "Review the NFO's investment objective and Scheme Information Document (SID) to assess whether the fund targets growth, income, tax saving, or a combination. Prioritise schemes aligned with your long-term goals and avoid NFOs driven by short-term market trends." },
  { h: 'Expense Ratio and Fees', p: "Even a marginal difference in the annual expense ratio can meaningfully impact long-term returns. Compare the NFO's costs across Direct and Regular plans against similar funds, as lower fees allow more capital to compound over time." },
  { h: 'Asset Allocation Strategy', p: "Examine the fund's allocation across equity, debt, and cash in the SID, as this determines risk, return potential, and how adaptable the fund is across market conditions." },
];

// How are NFO Gains Taxed in India.
const TAX_ROWS = [
  { k: 'Equity-oriented NFO', st: 'Less than 12 months', lt: '12 months or more', rate: '12.5% (above ₹1.25 lakh)' },
  { k: 'Debt-oriented NFO', st: 'Less than 36 months', lt: '36 months or more', rate: 'Taxed as per income slab' },
  { k: 'ELSS NFO', st: '3-year mandatory lock-in', lt: 'Post 3 years = Long-term', rate: '12.5% (above ₹1.25 lakh)' },
];

// Got Questions? - the first 6 FAQs from the compliance doc (display cap; the
// remainder was stripped and can be restored from the doc if needed). Feeds both
// the accordion and the FAQPage JSON-LD, so markup and schema cannot drift.
const FAQS = [
  {
    q: 'What is an NFO in mutual funds?',
    a: 'An NFO, or New Fund Offer, is the initial subscription period during which a newly launched mutual fund scheme is offered to investors for the first time by an AMC. NFOs are usually offered at a face value of ₹10 per unit. The fund starts investing according to its stated objective, once the subscription window closes.',
  },
  {
    q: 'Is NFO the same as IPO?',
    a: 'No. An IPO is issued by a company to raise capital by offering shares to the public, while an NFO is launched by a mutual fund house to introduce a new mutual fund scheme.',
  },
  {
    q: 'What is the minimum investment in an NFO?',
    a: 'Most NFOs allow a minimum investment of ₹500 to ₹5,000 for lump sum and ₹500 per instalment for SIP. Check the specific Scheme Information Document for exact amounts.',
  },
  {
    q: 'Is NFO better than existing mutual funds?',
    a: 'Not necessarily. Existing funds with a proven track record are often safer for most investors. NFOs may be suitable when they offer a genuinely new category or theme not available in existing funds.',
  },
  {
    q: 'Can I invest in an NFO via SIP?',
    a: 'Some open-ended NFOs allow SIP registrations during the subscription period. However, most close-ended NFOs are available only as lump sum investments.',
  },
  {
    q: 'What happens after the NFO subscription window closes?',
    a: 'For open-ended funds, the fund reopens for continuous purchase/redemption at the prevailing NAV after allotment. For close-ended funds, units are listed on stock exchanges, and direct AMC transactions are not possible until maturity.',
  },
];

const site = Astro.site!.href;

const seo = {
  title: 'New Fund Offer (NFO) Investing',
  description:
    'Get first-mover advantage on newly launched mutual fund schemes at initial NAV pricing. Explore active NFOs with Shriram Financial Services.',
  path: '/nfo/',
  jsonLd: [
    faqPageSchema(FAQS.map((f) => ({ question: f.q, answer: f.a }))),
    breadcrumbSchema(
      [
        { name: 'Home', path: '/' },
        { name: 'Products', path: '/products/' },
        { name: 'NFO', path: '/nfo/' },
      ],
      site
    ),
    organizationSchema(site),
  ],
};
---

<BaseLayout seo={seo} mainClass="rev-rise-scale">
  <!-- ===== Hero ===== -->
  <section class="hero" id="sec-hero" data-section="hero">
    <Breadcrumb trail={[{ name: 'Products', href: '/products/' }, { name: 'NFO' }]} />
    <div class="hero-inner" data-enter>
      <h1>Explore the Latest NFOs and Discover Tomorrow's Investment Opportunities.</h1>
      <p class="lead">Whether you are a first-time investor curious about what an NFO is, or a seasoned market participant evaluating the next NFO mutual fund opportunity, this guide covers everything you need to know.</p>
      <div class="cta"><a class="btn-gold" href="/open-demat-account/">Start Investing</a></div>
    </div>
  </section>

  <!-- ===== New Fund Offer: Discover the Latest Mutual Fund Launches ===== -->
  <section class="section stack sec-light" id="sec-about" data-section="about" style="gap:56px;justify-content:center" data-enter="2">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">New Fund Offer: Discover the Latest Mutual Fund Launches</h2>
      <p class="sec-lead">Every New Fund Offer (NFO) introduces a fresh investment strategy or market opportunity, giving investors more ways to diversify their portfolios. Evaluating the fund objective, investment approach, and long-term potential is essential before investing. Through Shriram Financial Services, you can explore active NFOs, review scheme details, and complete your investment journey online</p>
    </div>

    <div class="stack" style="gap:32px">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">How NFO Works?</h3>
        <p class="sub-lead">Understanding how an NFO works becomes clearer when viewed alongside a familiar concept — the Initial Public Offering (IPO) in equities.</p>
      </div>
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">NFO vs. IPO — The Parallel:</h3>
      </div>
      <div class="t-scroll"><div class="product-page_table t3 bordered">
        <div class="cell th"><p>Dimension</p></div><div class="cell th"><p>NFO (Mutual Fund)</p></div><div class="cell th"><p>IPO (Equity)</p></div>
        {NFO_IPO_ROWS.map((r) => (
          <>
            <div class="cell tb"><p class="k">{r.k}</p></div>
            <div class="cell tb"><p class="v">{r.n}</p></div>
            <div class="cell tb"><p class="v">{r.i}</p></div>
          </>
        ))}
      </div></div>
    </div>

    <div class="stack" style="gap:32px">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">The NFO Process — Step by Step:</h3>
      </div>
      <div class="steps" data-reveal-row>
        {PROCESS.slice(0, 4).map((s, i) => (
          <>
            {i > 0 && <div class="step-div" />}
            <div class="step"><div class="num">{i + 1}</div><div class="st-body"><h4>{s.h}</h4><p>{s.p}</p></div></div>
          </>
        ))}
      </div>
      <div class="steps" data-reveal-row>
        {PROCESS.slice(4).map((s, i) => (
          <>
            {i > 0 && <div class="step-div" />}
            <div class="step"><div class="num">{i + 5}</div><div class="st-body"><h4>{s.h}</h4><p>{s.p}</p></div></div>
          </>
        ))}
      </div>
      <p class="sec-lead">Unlike IPOs, NFO prices don't fluctuate during the subscription period — all investors get in at the same fixed price. At the same time, an NFO's ₹10 offer price does not imply the fund is inherently "cheap." The actual value lies in the quality of the investment strategy and execution.</p>
    </div>
  </section>

  <!-- ===== Key Features of a New Fund Offer ===== -->
  <section class="section stack sec-tint" id="sec-features" data-section="features" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Key Features of a New Fund Offer</h2>
      <p class="sec-lead" style="color:var(--color-text-secondary)">NFOs have several distinctive features that set them apart from regular mutual fund investments. Here's what every investor should know before subscribing:</p>
    </div>
    <div class="cat-grid" data-reveal-row>
      {FEATURES.map((c) => (
        <div class="cat"><h4>{c.h}</h4><p>{c.p}</p></div>
      ))}
    </div>
  </section>

  <!-- ===== Types of NFOs ===== -->
  <section class="section stack sec-light" id="sec-types" data-section="types" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Types of NFOs</h2>
      <p class="sec-lead">Not all NFOs are alike. The Indian mutual fund landscape offers multiple categories of NFOs, each with distinct structures, investment horizons, and suitability profiles. Understanding the types of NFO available allows investors to identify the right fit for their financial goals.</p>
      <p class="sec-lead">The four primary NFO types are:</p>
    </div>
    <div class="t-scroll"><div class="product-page_table t4 bordered" style="min-width:720px">
      <div class="cell th"><p>NFO Type</p></div><div class="cell th"><p>Structure</p></div><div class="cell th"><p>Lock-in Period</p></div><div class="cell th"><p>Key Highlight</p></div>
      {TYPE_ROWS.map((r) => (
        <>
          <div class="cell tb"><p class="k">{r.k}</p></div>
          <div class="cell tb"><p class="v">{r.structure}</p></div>
          <div class="cell tb"><p class="v">{r.lockin}</p></div>
          <div class="cell tb"><p class="v">{r.highlight}</p></div>
        </>
      ))}
    </div></div>
    <p class="sec-lead">Each type carries its own risk-reward equation, liquidity profile, and tax treatment. A thorough understanding of each is essential before you decide which type suits your investment thesis.</p>
    <a class="btn-gold" href="/open-demat-account/" style="align-self:center">Start Investing</a>
  </section>

  <!-- ===== How to Invest in NFO? ===== -->
  <section class="section stack sec-tint" id="sec-invest" data-section="invest" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">How to Invest in NFO?</h2>
      <p class="sec-lead" style="color:var(--color-text-secondary)">Investing in a New Fund Offer has never been more accessible. With multiple channels available, the process is designed to be straightforward for KYC-compliant investors. Shriram Financial Services makes this process seamless, here's how you can invest:</p>
    </div>
    <div class="stack" style="gap:32px;width:100%">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">Online Process</h3>
      </div>
      <div class="steps" data-reveal-row>
        {INVEST_STEPS.slice(0, 2).map((s, i) => (
          <>
            {i > 0 && <div class="step-div" />}
            <div class="step"><div class="num">{i + 1}</div><div class="st-body"><h4>{s.h}</h4><p>{s.p}</p></div></div>
          </>
        ))}
      </div>
      <div class="steps" data-reveal-row>
        {INVEST_STEPS.slice(2).map((s, i) => (
          <>
            {i > 0 && <div class="step-div" />}
            <div class="step"><div class="num">{i + 3}</div><div class="st-body"><h4>{s.h}</h4><p>{s.p}</p></div></div>
          </>
        ))}
      </div>
    </div>
    <a class="btn-gold" href="/open-demat-account/" style="align-self:center">Start Investing</a>
  </section>

  <!-- ===== What are the Benefits and Risks of an NFO? ===== -->
  <section class="section stack sec-light" id="sec-benefits-risks" data-section="benefits-risks" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">What are the Benefits and Risks of an NFO?</h2>
      <p class="sec-lead">Every investment opportunity carries both potential rewards and inherent risks. NFOs are no exception. A balanced understanding of NFO benefits and risks helps investors approach these opportunities with clarity and appropriate expectations.</p>
    </div>
    <div class="t-scroll"><div class="product-page_table t3 bordered" style="min-width:720px">
      <div class="cell th"><p>Category</p></div><div class="cell th"><p>Aspect</p></div><div class="cell th"><p>Details</p></div>
      {BENEFIT_RISK_ROWS.map((r) => (
        <>
          <div class="cell tb"><p class="k">{r.cat}</p></div>
          <div class="cell tb"><p class="v">{r.aspect}</p></div>
          <div class="cell tb"><p class="v">{r.details}</p></div>
        </>
      ))}
    </div></div>
  </section>

  <!-- ===== How to Evaluate an NFO Before Investing? ===== -->
  <section class="section stack sec-tint" id="sec-evaluate" data-section="evaluate" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">How to Evaluate an NFO Before Investing?</h2>
      <p class="sec-lead" style="color:var(--color-text-secondary)">Knowing how to evaluate an NFO before investing is an important skill an NFO investor can develop. Without historical NAV data to lean on, the evaluation framework must be built from first principles. Here is the structured approach we recommend.</p>
    </div>
    <div class="cat-grid" data-reveal-row>
      {EVALUATE.map((c) => (
        <div class="cat"><h4>{c.h}</h4><p>{c.p}</p></div>
      ))}
    </div>
  </section>

  <!-- ===== How are NFO Gains Taxed in India? ===== -->
  <section class="section stack sec-light" id="sec-tax" data-section="tax" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">How are NFO Gains Taxed in India?</h2>
      <p class="sec-lead">Understanding the tax implications of your NFO investment is essential for accurate return projections and efficient post-tax wealth creation. The NFO tax treatment framework is primarily governed by the Income Tax Act, 1961, and follows the same rules applicable to the underlying mutual fund category.</p>
    </div>
    <div class="stack" style="gap:32px">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">The tax treatment of NFO gains depends on two factors:</h3>
      </div>
      <div class="card check-card">
        <div class="check-list">
          <div class="check-row"><span class="ck" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span><p class="tx">Fund Category: Is it an equity-oriented fund (≥65% in equities) or a debt/non-equity fund?</p></div>
          <div class="check-sep"></div>
          <div class="check-row"><span class="ck" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path></svg></span><p class="tx">Holding Period: How long have you held the units from the date of allotment?</p></div>
        </div>
      </div>
    </div>
    <div class="t-scroll"><div class="product-page_table t4 bordered" style="min-width:720px">
      <div class="cell th"><p>Fund Type</p></div><div class="cell th"><p>Short-term Holding</p></div><div class="cell th"><p>Long-term Holding</p></div><div class="cell th"><p>LTCG Tax Rate</p></div>
      {TAX_ROWS.map((r) => (
        <>
          <div class="cell tb"><p class="k">{r.k}</p></div>
          <div class="cell tb"><p class="v">{r.st}</p></div>
          <div class="cell tb"><p class="v">{r.lt}</p></div>
          <div class="cell tb"><p class="v">{r.rate}</p></div>
        </>
      ))}
    </div></div>
    <p class="sec-lead">Note: Tax rates are subject to change. Always refer to the latest provisions of the Income Tax Act and consult a qualified tax adviser for personalised guidance.</p>
  </section>

  <!-- ===== Got Questions? (General Questions) ===== -->
  <section class="faq-wrap sec-tint" id="sec-faq" data-section="faq">
    <div class="faq-cols">
      <div class="faq-left">
        <h2 class="faq-title">Got Questions?</h2>
        <FaqAccordion faqs={FAQS} />
      </div>
      <div class="faq-side">
        <div class="usr"><img src="/assets/user.svg" alt="" /></div>
        <div class="side-in">
          <div class="side-tx">
            <h3>Need A Clearer Direction?</h3>
            <p>Let's get in touch on a 15-minute call where we can answer any questions you may have. Our advisor will help map your wealth mix and show what a dedicated, research-led plan would do differently.</p>
          </div>
          <a class="btn-gold" href="/contact-us/">Book A Discovery Call</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

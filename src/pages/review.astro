---
/**
 * /review — ProofKit reviewer entry for the HOMEPAGE. A redirect stub, not a page:
 * it arms auto-review and bounces to `/`, where the on-page overlay opens the
 * ProofKit login and then review mode, and rewrites the address bar back to /review.
 * Gated on PROOFKIT_ENABLED. Every OTHER page uses /<page>/review, routed by 404.astro.
 * All the logic lives in the package (src/plugins/proofkit/); this is a thin seam.
 */
import { PROOFKIT_ENABLED } from '../plugins/proofkit/config';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Proofkit</title>
    {PROOFKIT_ENABLED && (
      <script is:inline>
        try { sessionStorage.setItem('pkAutoReview', '1'); } catch (e) {}
        location.replace('/');
      </script>
    )}
  </head>
  <body></body>
</html>

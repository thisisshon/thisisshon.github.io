---
/**
 * FD — /fixed-deposit/
 * Long-form Fixed Deposit guide. Built entirely from the shared design-system
 * components in global.css (hero, .section/.sec-title, .card, .cat-grid,
 * .product-page_table, .risks, FaqAccordion, .cta-box). The only page-scoped
 * CSS is a generic responsive card grid (.fd-cards), token-bound.
 * Nested route → BaseLayout / component imports at ../../ depth.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import FaqAccordion from '../components/sections/FaqAccordion.astro';
import { faqPageSchema, breadcrumbSchema, organizationSchema } from '../lib/seo';

// Types of fixed deposit — payout / structure differences.
const TYPES = [
  {
    h: 'Cumulative FD',
    p: 'Interest is compounded and paid together with the principal at maturity. Best suited to investors who want their money to grow rather than draw a regular payout.',
  },
  {
    h: 'Non-Cumulative FD',
    p: 'Interest is paid out at regular intervals — monthly, quarterly, half-yearly or annually — making it useful for those who need a steady income stream.',
  },
  {
    h: 'Tax-Saver FD',
    p: 'A 5-year lock-in deposit that qualifies for a deduction of up to ₹1.5 lakh under Section 80C. Premature withdrawal is not permitted during the lock-in.',
  },
  {
    h: 'Senior Citizen FD',
    p: 'Offered to investors aged 60 and above, typically with an additional interest rate of 0.25%–0.75% over the standard published rates.',
  },
  {
    h: 'Bank FD',
    p: 'Opened with a scheduled bank and covered by DICGC deposit insurance up to ₹5 lakh per depositor per bank, making it among the safest FD options.',
  },
  {
    h: 'Corporate / Company FD',
    p: 'Issued by companies and NBFCs, often at higher rates than bank FDs — but they are not DICGC-insured, so check the issuer’s credit rating first.',
  },
];

// Things to consider / risks with FDs.
const RISKS = [
  {
    h: 'Premature Withdrawal Penalty',
    p: 'Breaking an FD before maturity usually attracts a penalty of 0.5%–1% on the applicable interest rate, reducing your effective return.',
  },
  {
    h: 'Reinvestment Risk',
    p: 'When an FD matures in a low-rate environment, you may have to reinvest the proceeds at a lower interest rate than you originally earned.',
  },
  {
    h: 'Inflation Risk',
    p: 'If the FD rate is lower than inflation, the real (inflation-adjusted) value of your returns can erode over the deposit tenure.',
  },
  {
    h: 'DICGC Cover Limit',
    p: 'Bank deposits are insured only up to ₹5 lakh per depositor per bank. Corporate FDs carry no such cover and depend on the issuer’s creditworthiness.',
  },
];

// General Questions — plain-text answers, shared with the FAQPage schema.
const FAQS = [
  {
    q: 'What is a Fixed Deposit?',
    a: 'A Fixed Deposit (FD) is an investment where you place a lump sum with a bank or company for a fixed tenure at an assured rate of interest. The rate is locked in at the time of booking, so your returns are predictable regardless of how market interest rates move afterwards.',
  },
  {
    q: 'What is the difference between a cumulative and non-cumulative FD?',
    a: 'In a cumulative FD, interest is compounded and paid out along with the principal at maturity, so the corpus grows. In a non-cumulative FD, interest is paid out at regular intervals — monthly, quarterly, half-yearly or annually — which suits investors who want a steady income.',
  },
  {
    q: 'How is FD interest taxed?',
    a: 'Interest earned on a fixed deposit is added to your total income and taxed at your applicable income-tax slab rate. There is no special or concessional rate for FD interest — it is treated as “income from other sources”.',
  },
  {
    q: 'When is TDS deducted on FD interest?',
    a: 'Banks deduct TDS at 10% once the interest across your deposits with that bank exceeds ₹40,000 in a financial year (₹50,000 for senior citizens). If your total income is below the taxable limit, you can submit Form 15G (or Form 15H for senior citizens) to avoid TDS.',
  },
  {
    q: 'Do FDs offer any tax benefit?',
    a: 'Yes — a 5-year Tax-Saver FD qualifies for a deduction of up to ₹1.5 lakh under Section 80C. Note that the interest it earns is still taxable, and the deposit carries a 5-year lock-in with no premature withdrawal.',
  },
  {
    q: 'Do senior citizens get higher FD rates?',
    a: 'Yes. Most banks and companies offer senior citizens (aged 60 and above) an additional interest rate of roughly 0.25% to 0.75% over the standard published rates, across most tenures.',
  },
  {
    q: 'Are fixed deposits safe?',
    a: 'Bank FDs are among the safest investments — deposits are insured by DICGC up to ₹5 lakh per depositor per bank. Corporate or company FDs may offer higher rates but are not DICGC-insured, so their safety depends on the issuer’s credit rating and financial strength.',
  },
];

const site = Astro.site!.href;

const seo = {
  title: 'Fixed Deposit (FD) — A Guide to FD Investments in India',
  description:
    'Understand fixed deposits in India — cumulative vs non-cumulative, tax-saver and senior-citizen FDs, interest rates by tenure, taxation and TDS, FD vs debt funds, and key risks — with Shriram.',
  path: '/fixed-deposit/',
  jsonLd: [
    faqPageSchema(FAQS.map((f) => ({ question: f.q, answer: f.a }))),
    breadcrumbSchema(
      [
        { name: 'Home', path: '/' },
        { name: 'Products', path: '/products/' },
        { name: 'Fixed Deposit', path: '/fixed-deposit/' },
      ],
      site
    ),
    organizationSchema(site),
  ],
};
---

<BaseLayout seo={seo}>
  <!-- ===== Hero ===== -->
  <section class="hero" id="sec-hero" data-section="hero">
    <div class="hero-inner">
      <h1>Grow Your Savings Safely With a <span class="g">Fixed Deposit</span></h1>
      <p class="lead">Lock in a lump sum for a fixed tenure at an assured rate of interest — with predictable, market-independent returns, flexible payouts and DICGC-insured bank deposits.</p>
      <div class="cta"><a class="btn-gold" href="/open-demat-account/">Open Account</a></div>
      <div class="hero-feats">
        <div class="feats">
          <div class="feat"><span class="tk" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span><span class="lb">&nbsp;Assured returns</span></div>
          <div class="feat"><span class="tk" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span><span class="lb">&nbsp;Senior-citizen rates</span></div>
          <div class="feat"><span class="tk" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span><span class="lb">&nbsp;DICGC insured</span></div>
          <div class="feat"><span class="tk" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4.5 10.5 8 14l7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span><span class="lb">&nbsp;Flexible tenure</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== What Is a Fixed Deposit ===== -->
  <section class="section stack sec-light" id="sec-about" data-section="about" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">What Is a Fixed Deposit?</h2>
      <p class="sec-lead">A Fixed Deposit is a low-risk investment in which you place a lump sum with a bank or company for a fixed tenure at an assured rate of interest. The rate is locked in when you book the deposit, so your returns stay predictable regardless of how market interest rates move afterwards. In return for committing your money for a set period, you earn a higher rate than an ordinary savings account — and with bank FDs, your deposit is insured by DICGC up to ₹5 lakh per depositor per bank.</p>
    </div>
  </section>

  <!-- ===== Types of FDs ===== -->
  <section class="section stack sec-tint" id="sec-types" data-section="types" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Types of Fixed Deposits</h2>
      <p class="sec-lead" style="color:var(--color-text-secondary)">FDs come in several variants that differ by payout structure, tenure, tax treatment and issuer. Choosing the right one depends on your income needs and goals.</p>
    </div>
    <div class="fd-cards">
      {TYPES.map((t) => (
        <div class="card"><h4 class="card-h">{t.h}</h4><p class="card-p">{t.p}</p></div>
      ))}
    </div>
    <a class="btn-gold" href="/open-demat-account/" style="align-self:center">Open Account</a>
  </section>

  <!-- ===== Interest Rates & Tenure ===== -->
  <section class="section stack sec-light" id="sec-rates" data-section="rates" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Interest Rates &amp; Tenure</h2>
      <p class="sec-lead">FD rates generally rise with tenure, and senior citizens earn a bonus over the standard rate. The rates below are indicative — actual rates vary by issuer and change periodically.</p>
    </div>
    <div class="t-scroll"><div class="product-page_table t3 bordered">
      <div class="cell th"><p>Tenure Band</p></div><div class="cell th"><p>Indicative Rate (General)</p></div><div class="cell th"><p>Senior Citizen Rate</p></div>
      <div class="cell tb"><p class="k">7 days – 6 months</p></div><div class="cell tb"><p class="v">3.00% – 5.50%</p></div><div class="cell tb"><p class="v">3.50% – 6.00%</p></div>
      <div class="cell tb"><p class="k">6 months – 1 year</p></div><div class="cell tb"><p class="v">5.50% – 6.75%</p></div><div class="cell tb"><p class="v">6.00% – 7.25%</p></div>
      <div class="cell tb"><p class="k">1 – 3 years</p></div><div class="cell tb"><p class="v">6.75% – 7.25%</p></div><div class="cell tb"><p class="v">7.25% – 7.75%</p></div>
      <div class="cell tb"><p class="k">3 – 5 years</p></div><div class="cell tb"><p class="v">6.75% – 7.00%</p></div><div class="cell tb"><p class="v">7.25% – 7.50%</p></div>
      <div class="cell tb"><p class="k">5 years &amp; above</p></div><div class="cell tb"><p class="v">6.50% – 7.00%</p></div><div class="cell tb"><p class="v">7.00% – 7.50%</p></div>
    </div></div>
    <a class="btn-gold" href="/open-demat-account/" style="align-self:center">Open Account</a>
  </section>

  <!-- ===== Taxation ===== -->
  <section class="section stack sec-tint" id="sec-tax" data-section="tax" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Taxation of Fixed Deposits</h2>
      <p class="sec-lead" style="color:var(--color-text-secondary)">FD interest is fully taxable as income. Understanding TDS thresholds and the forms available can help you plan and avoid over-deduction.</p>
    </div>
    <div class="t-scroll"><div class="product-page_table t3">
      <div class="cell th"><p>Aspect</p></div><div class="cell th"><p>How It Works</p></div><div class="cell th"><p>Key Point</p></div>
      <div class="cell tb"><p class="k">Interest Taxation</p></div><div class="cell tb"><p class="v">Added to income under “income from other sources”</p></div><div class="cell tb"><p class="v">Taxed at your applicable slab rate</p></div>
      <div class="cell tb"><p class="k">TDS Threshold</p></div><div class="cell tb"><p class="v">10% TDS once interest crosses the annual limit at a bank</p></div><div class="cell tb"><p class="v">₹40,000 general / ₹50,000 for senior citizens</p></div>
      <div class="cell tb"><p class="k">Form 15G / 15H</p></div><div class="cell tb"><p class="v">Self-declaration to avoid TDS when income is below the taxable limit</p></div><div class="cell tb"><p class="v">15G for general, 15H for senior citizens</p></div>
      <div class="cell tb"><p class="k">Section 80C</p></div><div class="cell tb"><p class="v">Applies only to 5-year Tax-Saver FDs</p></div><div class="cell tb"><p class="v">Deduction up to ₹1.5 lakh; interest still taxable</p></div>
    </div></div>
    <a class="btn-gold" href="/open-demat-account/" style="align-self:center">Open Account</a>
  </section>

  <!-- ===== FD vs Other Options ===== -->
  <section class="section stack sec-light" id="sec-compare" data-section="compare" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">FD vs Other Options</h2>
      <p class="sec-lead">See how a fixed deposit compares with a debt mutual fund and a savings account across the factors that matter most.</p>
    </div>
    <div class="t-scroll"><div class="product-page_table t4 bordered">
      <div class="cell th"><p>Feature</p></div><div class="cell th"><p>Fixed Deposit</p></div><div class="cell th"><p>Debt Mutual Fund</p></div><div class="cell th"><p>Savings Account</p></div>
      <div class="cell tb"><p class="k">Returns</p></div><div class="cell tb"><p class="v">Assured, fixed at booking</p></div><div class="cell tb"><p class="v">Market-linked, not guaranteed</p></div><div class="cell tb"><p class="v">Low, variable</p></div>
      <div class="cell tb"><p class="k">Risk</p></div><div class="cell tb"><p class="v">Very low (DICGC-insured banks)</p></div><div class="cell tb"><p class="v">Low to moderate (rate &amp; credit risk)</p></div><div class="cell tb"><p class="v">Very low</p></div>
      <div class="cell tb"><p class="k">Liquidity</p></div><div class="cell tb"><p class="v">Locked; penalty on early exit</p></div><div class="cell tb"><p class="v">Redeem anytime (T+1 to T+3)</p></div><div class="cell tb"><p class="v">Instant, fully liquid</p></div>
      <div class="cell tb"><p class="k">Taxation</p></div><div class="cell tb"><p class="v">Interest taxed at slab rate</p></div><div class="cell tb"><p class="v">Gains taxed at slab rate (post-2023)</p></div><div class="cell tb"><p class="v">Interest taxed at slab rate</p></div>
    </div></div>
    <a class="btn-gold" href="/open-demat-account/" style="align-self:center">Open Account</a>
  </section>

  <!-- ===== Things to Consider / Risks ===== -->
  <section class="section stack sec-tint" id="sec-risks" data-section="risks" style="gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Things to Consider</h2>
      <p class="sec-lead" style="color:var(--color-text-secondary)">Fixed deposits are safe, but they are not risk-free. Weigh these factors before you commit your money for a fixed term.</p>
    </div>
    <div class="risks">
      {RISKS.map((r) => (
        <div class="risk"><h4>{r.h}</h4><p>{r.p}</p></div>
      ))}
    </div>
    <p class="sec-lead" style="color:var(--color-text-secondary)">Used well, an FD is a dependable anchor for the low-risk part of a portfolio — pair it with the right tenure, ladder your deposits to manage reinvestment risk, and keep bank deposits within the DICGC cover where safety is the priority.</p>
  </section>

  <!-- ===== General Questions ===== -->
  <section class="faq-wrap sec-tint" id="sec-faq" data-section="faq">
    <div class="faq-cols">
      <div class="faq-left">
        <h2 class="faq-title">General Questions</h2>
        <FaqAccordion faqs={FAQS} />
      </div>
      <div class="faq-side">
        <div class="usr"><img src="/assets/user.svg" alt="" /></div>
        <div class="side-in">
          <div class="side-tx">
            <h3>Need A Clearer Direction?</h3>
            <p>Let's get in touch on a 15-minute call where we can answer any questions you may have. Our advisor will help map your wealth mix and show what a dedicated, research-led plan would do differently.</p>
          </div>
          <a class="btn-gold" href="/contact-us/">Book A Discovery Call</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Final CTA ===== -->
  <section class="cta-sec sec-light" id="sec-final-cta" data-section="final-cta">
    <div class="cta-box">
      <div class="ct-tt">
        <h3>Start Earning Assured Returns Today</h3>
        <p class="ct-sub">Open your account in minutes and book a fixed deposit with zero paperwork.</p>
      </div>
      <a class="btn-gold" href="/open-demat-account/">Open Account</a>
    </div>
  </section>
</BaseLayout>

<style>
  /* ===== fd — page-specific only ===== */

  /* Generic responsive card grid for the FD-types card set (the shared .row-2 is
     2-up and .cat-grid's border math is tuned for its own cell count; this handles
     arbitrary counts). Values are on the 8px grid. */
  .fd-cards {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 24px;
    align-items: stretch;
  }
  .fd-cards .card {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  @media (max-width: 1024px) {
    .fd-cards {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  @media (max-width: 560px) {
    .fd-cards {
      grid-template-columns: 1fr;
    }
  }
</style>

    }
  }
  .product-box-4 {
    margin-top: 40px;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr)); /* mweb: 2-col grid (4 at ≥1280) */
    gap: 16px;
  }
  /* Scroll reveal — the section header + each card fade/rise in as the grid
     enters view (the page-local observer below adds .revealed, staggered per
     card by the inline transition-delay). Gated on .js-reveal so no-JS /
     reduced-motion (BaseLayout omits .js-reveal there) paints them visible with
     no flash; the shared reveal easing keeps it consistent with the rest of the
     site. Starting the cards hidden also masks the on-load transition settle. */
  :global(.js-reveal) .product-box-3,
  :global(.js-reveal) .product-card-reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease, transform 0.6s var(--ease-reveal);
    will-change: opacity, transform;
  }
  :global(.js-reveal) .product-box-3.revealed,
  :global(.js-reveal) .product-card-reveal.revealed {
    opacity: 1;
    transform: none;
  }
  .product-box-5 {
    height: 20px;
    width: 20px;
    flex-shrink: 0;
  }
  /* Left-aligned column, vertically centred in BOTH states (justify-content
     center) so nothing snaps. At rest: icon + a 40px gap + copy, centred as one
     group; the CTA is collapsed (max-height:0) so it takes no space. On hover
     the CTA grows into flow (max-height + margin animate) with a matching 40px
     gap, so the centred group grows and re-centres each frame — icon + copy
     glide up while the CTA slides in, staying equidistant throughout. */
  .product-box-6 {
    position: relative;
    z-index: 10;
    display: flex;
    height: 100%;
    flex-direction: column;
    justify-content: center;
  }
  /* Title + subheading grouped, sitting 40px below the icon. */
  .product-copy {
    display: flex;
    flex-direction: column;
    margin-top: 40px;
    transition: margin-top var(--pc-dur) var(--pc-ease);
  }
  @media (min-width: 1024px) and (hover: hover) {
    .product-link-2:hover .product-copy {
      margin-top: 32px; /* 8px tighter to the icon on hover */
    }
  }
  .product-subtitle {
    color: var(--color-white);
  }
  .product-text-2 {
    color: #ffffff80; /* Tier-2: rule-5 (alpha) — parity-preserved (over dark card) */
  }
  @media (min-width: 1024px) and (hover: hover) {
    .product-link-2:hover .product-text-2 {
      color: #ffffffb3; /* Tier-2: rule-5 (alpha) — parity-preserved */
    }
  }

  /* Products — Figma "Product Card v7" Smart-Animate (node 904:9490).
     Idle: charcoal card. Hover: the charcoal overlay CONDENSES into the
     top-right arrow point, revealing the olive card; a gold circle + arrow
     scale in, the icon enlarges + brightens, content rises, "View More" fades
     in. One 0.9s slow ease-out on every layer together. */
  .product-link-2 {
    --pc-dur: 0.9s;
    --pc-ease: cubic-bezier(0.22, 1, 0.36, 1);
    --pc-delay: 0s;
    position: relative;
    display: flex;
    height: 284px;
    flex-direction: column;
    overflow: hidden;
    border-radius: 24px;
    padding: 32px;
    background-color: #2e3914; /* --color-olive-900 (revealed base) */
  }
  @media (min-width: 1024px) and (hover: hover) {
    .product-link-2:hover {
      --pc-delay: 0.1s;
      background-color: #2e3914; /* --color-olive-900 */
      z-index: 10;
    }
  }
  .product-link-2::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    background-color: #2b2c2b; /* charcoal overlay — page-local literal (Tier-2) */
    clip-path: circle(150% at calc(100% - 60px) 60px);
    transition: clip-path var(--pc-dur) var(--pc-ease);
  }
  @media (min-width: 1024px) and (hover: hover) {
    .product-link-2:hover::before {
      clip-path: circle(0% at calc(100% - 60px) 60px);
    }
  }
  /* icon scales from its left edge — grows rightward, not from centre */
  .product-img {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    object-fit: contain;
    color: #d7d7cd; /* page-local literal (Tier-2) */
    transform-origin: left center;
    transition: transform var(--pc-dur) var(--pc-ease), color var(--pc-dur) var(--pc-ease);
  }
  .product-img [stroke] {
    stroke: currentColor;
    transition: stroke-width var(--pc-dur) var(--pc-ease);
  }
  @media (min-width: 1024px) and (hover: hover) {
    .product-link-2:hover .product-img {
      transform: scale(1.2); /* 40px → 48px */
      color: var(--color-white);
    }
    .product-link-2:hover .product-img [stroke] {
      stroke-width: 3; /* 2.5 + 0.5 on hover */
    }
  }
  .product-subtitle {
    font-size: 16px;
    font-weight: 700;
  }
  .product-text-2 {
    margin-top: 8px;
    font-size: 14px;
  }
  /* View More: in flow but collapsed (max-height:0) at rest. On hover it grows
     into place — max-height + margin-top + opacity all animate together, so the
     CTA slides in and pushes the container's centred content upward smoothly. */
  .product-label {
    display: block;
    overflow: hidden;
    margin-top: 0;
    max-height: 0;
    font-size: 12px;
    font-weight: 500;
    color: #fffc; /* Tier-2: rule-5 (alpha) — parity-preserved (#ffffffcc) */
    opacity: 0;
    transform: translateY(8px);
    transition: opacity var(--pc-dur) var(--pc-ease), transform var(--pc-dur) var(--pc-ease),
      max-height var(--pc-dur) var(--pc-ease), margin-top var(--pc-dur) var(--pc-ease);
  }
  @media (min-width: 1024px) and (hover: hover) {
    .product-link-2:hover .product-label {
      margin-top: 40px;
      max-height: 24px;
      opacity: 1;
      transform: translateY(0);
    }
  }
  .product-card-circle {
    position: absolute;
    top: 20px;
    right: 20px;
    width: 64px;
    height: 64px;
    border-radius: 50%;
    z-index: 5;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    background-color: #f3b83f; /* --color-gold-400 */
    opacity: 0;
    transform: scale(0.375); /* 24px at rest → 64px on hover */
    transition: opacity var(--pc-dur) var(--pc-ease), transform var(--pc-dur) var(--pc-ease);
  }
  @media (min-width: 1024px) and (hover: hover) {
    .product-link-2:hover .product-card-circle {
      opacity: 1;
      transform: scale(1);
    }
  }
  /* arrow points right (→) while hidden, then rotates up to aim at the
     top-right corner (↗) as it reveals */
  .product-card-circle svg {
    width: 26px; /* Tier-2: off-scale icon (parity) */
    height: 26px;
    color: #202318; /* --color-charcoal-825 */
    stroke: #202318;
    transform: rotate(45deg);
    transition: transform var(--pc-dur) var(--pc-ease);
  }
  @media (min-width: 1024px) and (hover: hover) {
    .product-link-2:hover .product-card-circle svg {
      transform: rotate(0deg);
    }
  }
  /* Figma trigger: Mouse enter · 100ms delay — hover-IN only (0s at rest) */
  .product-link-2::before,
  .product-img,
  .product-card-circle,
  .product-card-circle svg,
  .product-label {
    transition-delay: var(--pc-delay);
  }
  @media (prefers-reduced-motion: reduce) {
    .product-link-2::before,
    .product-img,
    .product-card-circle,
    .product-card-circle svg,
    .product-label {
      transition: none;
    }
  }
  /* mweb: static 2-col cards. The card sizes to content instead of the fixed
     284px hover-expansion height, its padding tightens to fit two columns, and
     "View More" shows by default. Placed after the base rules so it wins on
     mobile; desktop (≥1024) keeps the hover behaviour untouched. */
  @media (max-width: 1023px) {
    .product-link-2 {
      height: auto;
      padding: 16px; /* was 32px — proportional reduction so two columns fit */
    }
    .product-label {
      margin-top: 16px;
      max-height: 24px;
      opacity: 1;
      transform: none;
    }
    /* Dark grey card container: 16px sides / 24px top+bottom internal padding. */
    .product-box-2 {
      padding: 24px 16px;
    }
    @media (min-width: 1024px) and (hover: hover) {
      /* Remove the hover animation entirely on mweb — hold every layer at its
       resting value even while :hover matches (it does in a desktop browser at
       mobile width, which is why the animation still fired). No animation, no
       state change; the card is fully static. */
    .product-link-2:hover::before {
      clip-path: circle(150% at calc(100% - 60px) 60px);
    }
    }
    @media (min-width: 1024px) and (hover: hover) {
      .product-link-2:hover .product-card-circle {
      opacity: 0;
      transform: scale(0.375);
    }
    }
    @media (min-width: 1024px) and (hover: hover) {
      .product-link-2:hover .product-card-circle svg {
      transform: rotate(45deg);
    }
    }
    @media (min-width: 1024px) and (hover: hover) {
      .product-link-2:hover .product-img {
      transform: none;
      color: #d7d7cd;
    }
    }
    @media (min-width: 1024px) and (hover: hover) {
      .product-link-2:hover .product-img [stroke] {
      stroke-width: 2.5;
    }
    }
    @media (min-width: 1024px) and (hover: hover) {
      .product-link-2:hover .product-copy {
      margin-top: 40px;
    }
    }
    @media (min-width: 1024px) and (hover: hover) {
      .product-link-2:hover .product-label {
      margin-top: 16px;
    }
    }
    @media (min-width: 1024px) and (hover: hover) {
      .product-link-2:hover .product-text-2 {
      color: #ffffff80; /* Tier-2: rule-5 (alpha) — parity-preserved (over dark card) */
    }
    }
  }


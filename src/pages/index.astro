  .differ-fade-top .pb3 { -webkit-mask-image: linear-gradient(to bottom, #000 0%, #000 12%, transparent 44%);  mask-image: linear-gradient(to bottom, #000 0%, #000 12%, transparent 44%); }
  .differ-fade-top .pb4 { -webkit-mask-image: linear-gradient(to bottom, #000 0%, #000 6%,  transparent 24%);  mask-image: linear-gradient(to bottom, #000 0%, #000 6%,  transparent 24%); }
  /* bottom band: mirrored — 0% = section bottom edge */
  .differ-fade-bottom .pb1 { -webkit-mask-image: linear-gradient(to top, #000 0%, #000 40%, transparent 100%); mask-image: linear-gradient(to top, #000 0%, #000 40%, transparent 100%); }
  .differ-fade-bottom .pb2 { -webkit-mask-image: linear-gradient(to top, #000 0%, #000 22%, transparent 68%);  mask-image: linear-gradient(to top, #000 0%, #000 22%, transparent 68%); }
  .differ-fade-bottom .pb3 { -webkit-mask-image: linear-gradient(to top, #000 0%, #000 12%, transparent 44%);  mask-image: linear-gradient(to top, #000 0%, #000 12%, transparent 44%); }
  .differ-fade-bottom .pb4 { -webkit-mask-image: linear-gradient(to top, #000 0%, #000 6%,  transparent 24%);  mask-image: linear-gradient(to top, #000 0%, #000 6%,  transparent 24%); }
  /* Dark tint painted ON TOP of the blur (::after paints above the .pb layers) so
     content dissolves into the panel's dark edge instead of blurring into a light
     halo. Ramps from the panel's dark (#1d1d1d) at the edge to transparent inward,

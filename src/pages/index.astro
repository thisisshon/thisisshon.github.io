  /* Full-width progressive-blur bands over the whole panel, top & bottom (rule-5
     sanctioned backdrop-filter). Each band stacks 4 layers of increasing blur, each
     masked opaque AT the section edge and fading inward — the heaviest blur reaches
     only the thin edge strip, the lightest spans the band. Because every layer is
     opaque at the edge and only the LIGHTEST blur fades out over sharp content, the
     blur ramps up smoothly toward the edge with no sharp-through-blur halo. */
  .differ-fade {
    pointer-events: none;
    position: absolute;
    left: 0;
    right: 0;
    z-index: 20;
    height: 240px;
  }
  .differ-fade-top { top: 0; }

<script>
  /* Homepage-unique behaviour (homepage-port-spec Decision 6). Ported verbatim
     from the legacy inline module + head scripts. DROPPED: the nav hamburger /
     mega-overlay open/close scripts (shared now via Header.astro / MegaNav.astro).

     RE-ADDED (Decision 1): a minimal scroll listener toggling .header-hidden on
     <html> — the pinned "Why Shriram" fill effect keys off that class. This is
     NOT a nav re-implementation; the shared Header owns nav auto-hide, but its
     class toggles on the nav element, not <html>, so the fill needs this. */
  (function () {
    var last = window.pageYOffset || 0,
      threshold = 80,
      delta = 6;
    window.addEventListener(
      'scroll',
      function () {
        var y = window.pageYOffset || 0;
        if (Math.abs(y - last) < delta) return;
        var hide = y > last && y > threshold;
        document.documentElement.classList.toggle('header-hidden', hide);
        last = y <= 0 ? 0 : y;
      },
      { passive: true }
    );
  })();

  /* Hero "Get Started" — AES-GCM-encrypt the mobile number into the signup URL;
     falls back to the plain signup URL on any failure. Verbatim from legacy. */
  const g = document.getElementById('hero-mobile') as HTMLInputElement | null,
    h = document.getElementById('hero-get-started') as HTMLAnchorElement | null;
  if (g && h) {
    const e = 'https://signup.way2wealth.com/way2wealth/individual_new',
      t = 'ShriramSFS2026Way2WealthAESKey01',
      n = e,
      l = (window.crypto && window.crypto.subtle) || null,
      v = (c: ArrayBuffer) =>
        btoa(String.fromCharCode(...new Uint8Array(c)))
          .replace(/\+/g, '-')
          .replace(/\//g, '_')
          .replace(/=+$/, ''),
      S = async (c: Record<string, unknown>) => {
        const a = new TextEncoder(),
          d = await l!.importKey('raw', a.encode(t), 'AES-GCM', !1, ['encrypt']),
          s = crypto.getRandomValues(new Uint8Array(12)),
          u = await l!.encrypt({ name: 'AES-GCM', iv: s, tagLength: 128 }, d, a.encode(JSON.stringify(c))),
          y = new Uint8Array(s.length + u.byteLength);
        return y.set(s, 0), y.set(new Uint8Array(u), s.length), v(y.buffer);
      };
    h.addEventListener('click', async (c) => {
      c.preventDefault();
      const a = (g.value || '').replace(/\D/g, '').slice(-10);
      if (a.length !== 10 || !l) {
        window.location.href = n;
        return;
      }
      try {
        const d = await S({ mobile_number: a });
        window.location.href = e + '?enc_details=' + d + '&utm_source=' + encodeURIComponent('sfs');
      } catch {
        window.location.href = n;
      }
    });
  }

  /* Hero video — fade the wash + start playback once the video can play.
     Verbatim from legacy. */
  const r = document.getElementById('hero-video') as HTMLVideoElement | null,
    w = document.querySelector('.hero-wave') as HTMLElement | null;
  if (r) {
    const e = () => {
        r.style.opacity = '0.2';
        w && (w.style.opacity = '0');
      },
      t = () => {
        r.play().catch(() => {});
      };
    r.readyState >= 3
      ? (e(), t())
      : (r.addEventListener('canplay', () => { e(); t(); }, { once: true }),
        r.addEventListener('loadeddata', () => { e(); t(); }, { once: true }),
        setTimeout(() => { e(); t(); }, 1500));
  }

  /* "Why Shriram" scroll-pin — map page scroll through the tall wrapper onto the
     card rail's scrollTop, and drift the collage upward. Verbatim from legacy. */
  const f = document.getElementById('differ-pin-wrap'),
    i = document.getElementById('differ-scroll'),
    m = document.getElementById('differ-collage') as HTMLElement | null;
  if (f && i) {
    const e = () => {
      /* mweb: no pin/parallax — reset the rail + collage and bail (CSS lists the
         cards as a static vertical stack below 1024px). */
      if (window.innerWidth < 1024) {
        i.scrollTop = 0;
        if (m) m.style.transform = '';
        return;
      }
      const tRect = f.getBoundingClientRect(),
        o = f.offsetHeight - window.innerHeight;
      if (o <= 0) return;
      const n = Math.min(1, Math.max(0, -tRect.top / o));
      i.scrollTop = n * (i.scrollHeight - i.clientHeight);
      m && (m.style.transform = `translateY(${(-n * 23).toFixed(2)}%)`);
    };
    window.addEventListener('scroll', e, { passive: true });
    window.addEventListener('resize', e, { passive: true });
    e();
  }

  /* Product-card reveal-on-scroll — add .revealed as each card enters, then
     clear its stagger delay. Verbatim from legacy. */
  const p = document.querySelectorAll('.product-box-3, .product-card-reveal');
  if (p.length) {
    const e = new IntersectionObserver(
      (t) => {
        t.forEach((o) => {
          if (o.isIntersecting) {
            const n = o.target as HTMLElement;
            n.classList.add('revealed');
            e.unobserve(n);
            setTimeout(() => {
              n.style.transitionDelay = '0ms';
            }, 950);
          }
        });
      },
      { threshold: 0.12 }
    );
    p.forEach((t) => e.observe(t));
  }

  /* FAQ — single-open <details> accordion. Verbatim from legacy. */
  const E = document.getElementById('faq-accord');
  E?.querySelectorAll('details').forEach((el) => {
    el.addEventListener('toggle', () => {
      el.open &&
        E.querySelectorAll('details').forEach((tt) => {
          tt !== el && tt.removeAttribute('open');
        });
    });
  });
</script>

---
/**
 * Proofkit Dashboard - the /reviewdash admin view.
 *
 * Client-rendered admin view of every ticket across the site: where each sits
 * on its page, who raised it, when, its real-time status (TBI → In Progress →
 * Deployed live; Reopen bounces it back), threaded replies, the iteration
 * timeline, the Master Log, and the AI change-prompt per entry. Reads the
 * Cloudflare Worker (WORKER_URL) when set, else the localStorage demo store.
 * Builder drives status + deletes here (admin side); the on-page overlay is add-only.
 *
 * Rendered by the src/pages/reviewdash.astro route shim, gated on PROOFKIT_ENABLED
 * (./config.ts). Keeps its own admin-password gate so hitting /reviewdash
 * directly still requires the password.
 *
 * THIN ADAPTER: all logic + styles live in the framework-neutral core
 * (./core/dashboard.js + ./core/dashboard.css, standalone entry ./core/dashboard.html).
 * This file only mounts the shell, bridges the build-time Worker URL, and loads the core.
 */
import { WORKER_URL } from './config';
import './core/design/tokens.css';       // colour + theme system (single source of truth)
import './core/design/components.css';   // reusable component classes (incl. the toggle)
import './core/dashboard.css';           // admin-dashboard-specific styles
---

{/* Bridge the build-time Worker URL to the framework-neutral core (window global). */}
<script is:inline set:html={`window.PROOFKIT_WORKER_URL=${JSON.stringify(WORKER_URL)}`}></script>

<section class="rvd">
  {/* Gated-off stub — a clean "no access" state instead of a blank/broken app.
      Hidden at build; dashboard.js reveals it (and hides .rvd-app) if a signed-in
      identity is parked off via TEAM_ENABLED / isTeamEnabled (Builder/admin is
      always enabled, so this is defence-in-depth). Self-contained + token-styled. */}
  <div class="rvd-blocked" id="rvd-blocked" hidden>
    <div style="max-width:420px;text-align:center;color:var(--pk-body)">
      <h1 style="margin:0 0 8px;font:700 22px/1.3 var(--pk-font,Outfit);color:var(--pk-ink)">Review access unavailable</h1>
      <p style="margin:0 0 20px;font:400 14px/1.5 var(--pk-font,Outfit)">This team’s review access isn’t currently available.</p>
      <a class="rvd-btn rvd-btn-primary" href="/">Go to site</a>
    </div>
  </div>

  <div class="rvd-app" data-enter>
    <!-- Brand top bar -->
    <header class="rvd-top">
      <div class="rvd-brand">
        <span class="rvd-mark" aria-hidden="true"></span>
        <span class="rvd-word">Proofkit</span>
        <span class="rvd-tag">Content Review | <span class="rvd-tag-brand">Shriram FS</span></span>
      </div>
      <div class="rvd-actions">
        <a class="rvd-btn rvd-btn-primary" href="/">Go to site</a>
        <button id="rvd-refresh" class="rvd-btn" type="button">
          <span class="rvd-refresh-ico">
            <svg class="ico-sync" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12a9 9 0 1 1-2.64-6.36"/><path d="M21 3v6h-6"/></svg>
            <svg class="ico-check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
          </span>
          <span class="rvd-refresh-label">Refresh</span>
        </button>
      </div>
    </header>

    <!-- Headline -->
    <div class="rvd-headband">
      <div class="rvd-headband-row">
        <h1 class="rvd-h1">Admin Console</h1>
        <span class="rvd-headtoggle" data-pk-toggle></span>
      </div>
      <p class="rvd-lead">Every ticket raised across the site, directed to you as Builder. Open a
        pin to see it in context on the live page; Start, Mark Complete (deploy live) or Reopen
        each ticket as you action it.</p>
    </div>

    <!-- Stat tiles -->
    <div class="rvd-bar">
      <div class="rvd-counts" id="rvd-counts"></div>
    </div>

    <div class="rvd-shell">
      <aside class="rvd-side">
        <button class="rvd-nav is-active" data-view="dash">Team Queue</button>
        <button class="rvd-nav" data-view="notifs">Notifications<span class="rvd-navbadge rvd-navbadge-alert" id="rvd-badge-notifs" hidden>0</span></button>
        <button class="rvd-nav" data-view="entries">Master Log</button>
        <button class="rvd-nav" data-view="insights">Insights</button>
        <div class="rvd-teamview">
          <span class="rvd-teamview-label">Team dashboards</span>
          <div id="rvd-teamview-mount"></div>
        </div>
      </aside>

      <div class="rvd-content">
        <!-- Dashboard View: all current info -->
        <div id="rvd-view-dash">
          <div class="rvd-toolbar" id="rvd-toolbar">
            <input id="rvd-search" class="rvd-search" type="search" placeholder="Search comments, pages, reviewers…" autocomplete="off" spellcheck="false" />
            <div id="rvd-sort-mount"></div>
            <span class="rvd-toolbar-sp"></span>
            <button id="rvd-saveview" class="rvd-selectall" type="button">Save view</button>
            <button id="rvd-selectall" class="rvd-selectall" type="button">Select</button>
            <div id="rvd-copy-mount"></div>
          </div>
          <!-- Saved "Team views" (Feature 11): quick-select filter chips, shared per key -->
          <div class="rvd-views" id="rvd-views" hidden></div>
          <div class="rvd-tabs" id="rvd-tabs" role="tablist">
            <button class="rvd-tab is-active" data-tab="all">All</button>
            <button class="rvd-tab" data-tab="page">By Page</button>
          </div>
          <div class="rvd-teamchips" id="rvd-teamchips"></div>
          <div id="rvd-list"></div>
        </div>

        <!-- Notifications: fired as tickets move through the status machine, newest first -->
        <div id="rvd-view-notifs" hidden></div>

        <!-- Master Log: tabular log (one row per ticket chain) + per-entry detail drill-in -->
        <div id="rvd-view-entries" hidden>
          <div id="rvd-entries"></div>
        </div>

        <!-- Insights (Feature 12): admin-only aggregate metrics + date-range picker -->
        <div id="rvd-view-insights" hidden></div>

        <p id="rvd-empty" class="rvd-empty" hidden>No comments yet.</p>
      </div>
    </div>

    <!-- bulk-select action bar (shows when ≥1 ticket is selected) -->
    <div class="rvd-bulk" id="rvd-bulk" hidden>
      <span class="rvd-bulk-n" id="rvd-bulk-n">0 selected</span>
      <button class="rvd-bulk-a" type="button" data-act="all">Select all</button>
      <button class="rvd-bulk-a" type="button" data-act="start">Start</button>
      <button class="rvd-bulk-a" type="button" data-act="complete">Mark Complete</button>
      <button class="rvd-bulk-a" type="button" data-act="reopen">Reopen</button>
      <button class="rvd-bulk-a" type="button" data-act="copy">Copy prompts</button>
      <button class="rvd-bulk-a danger" type="button" data-act="delete">Delete</button>
      <button class="rvd-bulk-x" type="button" id="rvd-bulk-clear" aria-label="Clear selection">×</button>
    </div>
  </div>
</section>

{/* All behaviour lives in the framework-neutral core (bundled + deferred). */}
<script>import './core/dashboard.js';</script>

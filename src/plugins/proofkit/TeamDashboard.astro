---
/**
 * Proofkit Team Dashboard — the /teamdash per-team view.
 *
 * A client-rendered, READ-ONLY window a single team gets onto its OWN review
 * items. The team signs in with its team key; the Cloudflare Worker returns
 * ONLY that team's comments (server-side isolation, masked to the team-visible
 * status) plus that team's notifications. No admin actions, no delete, no AI
 * prompt, no other team's data — a lighter sibling of the admin Dashboard.
 *
 * Statuses are framed for the team (the deploy BUCKET is never exposed):
 *   masked 'open' → "Pending"   ·  'completed' → "Done"   ·  'closed' → "Closed".
 *
 * Rendered by the src/pages/teamdash.astro route shim, gated on PROOFKIT_ENABLED
 * (./config.ts). Reads the Worker (WORKER_URL) when set, else the localStorage
 * demo store (masking client-side). Scoped under .tmd so it never clashes with
 * the admin .rvd styles.
 *
 * THIN ADAPTER: all logic + styles live in the framework-neutral core
 * (./core/teamdash.js + ./core/teamdash.css, standalone entry ./core/teamdash.html).
 * This file only mounts the shell, bridges the build-time Worker URL, and loads the core.
 */
import { WORKER_URL } from './config';
import './core/design/tokens.css';       // colour + theme system (single source of truth)
import './core/design/components.css';   // reusable component classes
import './core/teamdash.css';            // team-dashboard-specific styles
---

{/* Bridge the build-time Worker URL to the framework-neutral core (window global). */}
<script is:inline set:html={`window.PROOFKIT_WORKER_URL=${JSON.stringify(WORKER_URL)}`}></script>

<section class="tmd">
  <div class="tmd-app" data-enter>
    <!-- Brand top bar -->
    <header class="tmd-top">
      <div class="tmd-brand">
        <svg class="tmd-mark" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M4 5a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H9l-4 4V5Z" fill="#da291c"/>
          <circle cx="12" cy="9.5" r="1.6" fill="#fff"/>
        </svg>
        <span class="tmd-word">ProofKit</span>
        <span class="tmd-tag">Team Review</span>
      </div>
      <div class="tmd-actions">
        <span class="tmd-you" id="tmd-you" hidden>
          <span class="tmd-you-lbl">Your Team</span>
          <span id="tmd-you-chip"></span>
        </span>
        <a class="tmd-btn tmd-btn-primary" href="/">Go to site</a>
        <button id="tmd-refresh" class="tmd-btn" type="button">
          <span class="tmd-refresh-ico">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12a9 9 0 1 1-2.64-6.36"/><path d="M21 3v6h-6"/></svg>
          </span>
          <span class="tmd-refresh-label">Refresh</span>
        </button>
      </div>
    </header>

    <!-- Headline -->
    <div class="tmd-headband">
      <h1 class="tmd-h1">Your Reviews</h1>
      <p class="tmd-lead">Every comment your team has left across the site, and where each
        one stands. Pending items are still being actioned; Done items are live.</p>
    </div>

    <!-- Stat tiles -->
    <div class="tmd-bar">
      <div class="tmd-counts" id="tmd-counts"></div>
    </div>

    <div class="tmd-shell">
      <aside class="tmd-side">
        <button class="tmd-nav is-active" data-view="comments">My Comments</button>
        <button class="tmd-nav" data-view="notifs">
          Notifications
          <span class="tmd-navbadge" id="tmd-navbadge" hidden>0</span>
        </button>
      </aside>

      <div class="tmd-content">
        <!-- My Comments -->
        <div id="tmd-view-comments">
          <div class="tmd-filters" id="tmd-filters" role="tablist">
            <button class="tmd-filter is-active" data-filter="all">All</button>
            <button class="tmd-filter" data-filter="pending">Pending</button>
            <button class="tmd-filter" data-filter="done">Done</button>
            <button class="tmd-filter" data-filter="closed">Closed</button>
            <span class="tmd-filter-sp"></span>
            <button class="tmd-bypage" id="tmd-bypage" type="button">By Page</button>
          </div>
          <div id="tmd-list"></div>
        </div>

        <!-- Notifications -->
        <div id="tmd-view-notifs" hidden>
          <div class="tmd-noteshead">
            <h2>Notifications</h2>
            <button class="tmd-markall" id="tmd-markall" type="button" disabled>Mark all read</button>
          </div>
          <div id="tmd-notes"></div>
        </div>

        <p id="tmd-empty" class="tmd-empty" hidden>Nothing here yet.</p>
      </div>
    </div>
  </div>
</section>

{/* All behaviour lives in the framework-neutral core (bundled + deferred). */}
<script>import './core/teamdash.js';</script>

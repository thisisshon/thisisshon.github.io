---
/**
 * Proofkit Team Dashboard — the /teamdash per-team view.
 *
 * A client-rendered window a single team (Content in Phase 1) gets onto its OWN
 * tickets. The team signs in with its team key; the Cloudflare Worker returns
 * ONLY that team's tickets (server-side isolation) plus its notifications. No
 * other team's data — a lighter sibling of the admin Dashboard.
 *
 * Statuses are the shared real-time state machine, framed for the raiser:
 *   to_be_initiated → "With builder – TBI" · in_progress → "With builder – in
 *   progress" · deployed_live → "Deployed live" · reopened → "Reopened" (bounced
 *   back by Builder with a reason — Content clarifies and Resubmits for another pass).
 *
 * Rendered by the src/pages/teamdash.astro route shim, gated on PROOFKIT_ENABLED
 * (./config.ts). Reads the Worker (WORKER_URL) when set, else the localStorage
 * demo store (masking client-side). Scoped under .tmd so it never clashes with
 * the admin .rvd styles.
 *
 * THIN ADAPTER: all logic + styles live in the framework-neutral core
 * (./core/teamdash.js + ./core/teamdash.css, standalone entry ./core/teamdash.html).
 * This file only mounts the shell, bridges the build-time Worker URL, and loads the core.
 */
import { WORKER_URL } from './config';
import './core/design/tokens.css';       // colour + theme system (single source of truth)
import './core/design/components.css';   // reusable component classes
import './core/teamdash.css';            // team-dashboard-specific styles
---

{/* Bridge the build-time Worker URL to the framework-neutral core (window global). */}
<script is:inline set:html={`window.PROOFKIT_WORKER_URL=${JSON.stringify(WORKER_URL)}`}></script>

<section class="tmd">
  {/* Gated-off team stub — a clean "no access" state instead of a blank/broken app.
      Hidden at build; teamdash.js reveals it (and hides .tmd-app) when the signed-in
      team is parked off via TEAM_ENABLED / isTeamEnabled (../config → ./core/config.js).
      Self-contained + token-styled so it needs nothing from teamdash.css. */}
  <div class="tmd-blocked" id="tmd-blocked" hidden>
    <div style="max-width:420px;text-align:center;color:var(--pk-body)">
      <h1 style="margin:0 0 8px;font:700 22px/1.3 var(--pk-font,Outfit);color:var(--pk-ink)">Review access unavailable</h1>
      <p style="margin:0 0 20px;font:400 14px/1.5 var(--pk-font,Outfit)">This team’s review access isn’t currently available.</p>
      <a class="tmd-btn tmd-btn-primary" href="/">Go to site</a>
    </div>
  </div>

  <div class="tmd-app" data-enter>
    <!-- Brand top bar -->
    <header class="tmd-top">
      <div class="tmd-brand">
        <span class="tmd-mark" aria-hidden="true"></span>
        <span class="tmd-word">Proofkit</span>
        <span class="tmd-tag">Content Review | <span class="tmd-tag-brand">Shriram FS</span><span class="tmd-tag-team" id="tmd-tag-team"></span></span>
      </div>
      <div class="tmd-actions">
        <a class="tmd-btn tmd-btn-primary" href="/">Go to site</a>
        <button id="tmd-refresh" class="tmd-btn" type="button">
          <span class="tmd-refresh-ico">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12a9 9 0 1 1-2.64-6.36"/><path d="M21 3v6h-6"/></svg>
          </span>
          <span class="tmd-refresh-label">Refresh</span>
        </button>
      </div>
    </header>

    <!-- Headline -->
    <div class="tmd-headband">
      <div class="tmd-headband-row">
        <h1 class="tmd-h1">Team</h1>
        <span class="tmd-headtoggle" data-pk-toggle></span>
      </div>
      <p class="tmd-lead">Everything your team submitted to Builder. Track each ticket's live
        status in Completed — With builder (TBI / in progress) or Deployed live. When Builder
        reopens one, it moves to Active with the reason, ready to clarify and resubmit.</p>
    </div>

    <!-- Stat tiles -->
    <div class="tmd-bar">
      <div class="tmd-counts" id="tmd-counts"></div>
    </div>

    <div class="tmd-shell">
      <aside class="tmd-side">
        <button class="tmd-nav" data-view="delivery" hidden>Active<span class="tmd-navbadge" id="tmd-badge-delivery" hidden>0</span></button>
        <button class="tmd-nav is-active" data-view="comments">Completed</button>
        <button class="tmd-nav" data-view="notifs">
          Notifications
          <span class="tmd-navbadge" id="tmd-navbadge" hidden>0</span>
        </button>
      </aside>

      <div class="tmd-content">
        <!-- Shared control bar — Search · Sort · By Page · primary — same position on ALL three tabs -->
        <div id="tmd-controls">
          <div class="tmd-toolbar">
            <input id="tmd-search" class="tmd-search" type="search" placeholder="Search comments, pages, reviewers…" autocomplete="off" spellcheck="false" />
            <div id="tmd-sort-mount"></div>
            <button class="tmd-tbtn" id="tmd-bypage" type="button">By Page</button>
            <button class="tmd-tbtn" id="tmd-saveview" type="button">Save view</button>
            <span class="tmd-toolbar-sp"></span>
            <button class="tmd-tbtn tmd-tbtn--primary" id="tmd-primary" type="button">Clear filters</button>
          </div>
          <!-- Saved "Team views" quick-select chips (Feature 11) — shared per team key -->
          <div class="tmd-views" id="tmd-views" hidden></div>
          <!-- Status filter tabs — Completed tab only -->
          <div class="tmd-filters" id="tmd-filters" role="tablist">
            <button class="tmd-filter is-active" data-filter="all">All</button>
            <button class="tmd-filter" data-filter="to_be_initiated">TBI</button>
            <button class="tmd-filter" data-filter="in_progress">In Progress</button>
            <button class="tmd-filter" data-filter="deployed_live">Deployed live</button>
          </div>
          <div class="tmd-teamchips" id="tmd-teamchips" hidden></div>
          <p class="tmd-viewnote" id="tmd-viewnote" hidden></p>
        </div>

        <!-- Completed: everything submitted, with its live status -->
        <div id="tmd-view-comments"><div id="tmd-list"></div></div>
        <!-- Active: tickets Builder reopened, awaiting clarify + resubmit -->
        <div id="tmd-view-delivery" hidden></div>
        <!-- Notifications -->
        <div id="tmd-view-notifs" hidden><div id="tmd-notes"></div></div>

        <p id="tmd-empty" class="tmd-empty" hidden>Nothing here yet.</p>
      </div>
    </div>

    <!-- Faded provision to elevate: clears the team session and opens the admin door. -->
    <footer class="tmd-foot">
      <a id="tmd-upgrade" class="tmd-upgrade" href="/reviewdash?login=builder">Upgrade access to admin</a>
    </footer>
  </div>
</section>

{/* All behaviour lives in the framework-neutral core (bundled + deferred). */}
<script>import './core/teamdash.js';</script>

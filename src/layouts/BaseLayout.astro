---
/**
 * BaseLayout - the one layout every page uses.
 *
 * Renders the complete <head> (templated SEO: title / description / canonical /
 * OG / Twitter / JSON-LD), the shared site chrome (Header + MegaNav + Footer)
 * and the page content in between. Pages supply content + an `seo` object -
 * nothing else. Head boilerplate is never hand-copied between pages.
 */
import '../styles/global.css';
import Header from '../components/site/Header.astro';
import Footer from '../components/site/Footer.astro';
import MegaNav from '../components/site/MegaNav.astro';
import ProofkitOverlay from '../plugins/proofkit/Overlay.astro';
import { PROOFKIT_ENABLED } from '../plugins/proofkit/config';
import { fullTitle, type SEO } from '../lib/seo';

interface Props {
  seo: SEO;
  /**
   * 'site' (default) renders the shared Footer (+ back-to-top).
   * 'custom' skips it - the page supplies its own via the default slot.
   * Only the homepage uses 'custom': its legacy footer is VISIBLY different
   * (Tier-2 unification pending sign-off - see docs/legacy-style-audit.md §E2).
   */
  footer?: 'site' | 'custom';
  /** Optional class on <main> - e.g. opt a page into a reveal-motion variant. */
  mainClass?: string;
  /**
   * `true` (default) renders the shared site chrome (skip-link + Header + MegaNav).
   * `false` omits it for full-bleed tool pages that own their chrome - e.g. the
   * Proofkit /reviewdash dashboard.
   */
  chrome?: boolean;
}

const { seo, footer = 'site', mainClass, chrome = true } = Astro.props;
const site = Astro.site!.href;
const canonical = new URL(seo.path, site).href;
const title = fullTitle(seo.title);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <script is:inline>document.documentElement.className += ' js';</script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={seo.description} />
    <link rel="canonical" href={canonical} />
    {/* Site-wide noindex - the site is not ready to be indexed yet. Remove this
        line (and restore `seo.noindex` gating below) before launch. */}
    <meta name="robots" content="noindex, nofollow" />
    <meta name="theme-color" content="#1d1d1d" />

    <!-- Open Graph -->
    <meta property="og:type" content={seo.ogType ?? 'website'} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Shriram Financial Services" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Icons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- Font: Outfit - the site's single typeface -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Variable font (continuous 300-800 wght axis) so weight changes can be
         animated - e.g. the FAQ title's 500->600 on open. -->
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@300..800&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD -->
    {
      seo.jsonLd?.map((block) => (
        <script type="application/ld+json" set:html={JSON.stringify(block)} />
      ))
    }

    <slot name="head" />
  </head>
  <body>
    {chrome && <a href="#main" class="skip-link">Skip to content</a>}

    {chrome && <Header />}

    <main id="main" class={mainClass}>
      <slot />
    </main>

    {footer === 'site' && <Footer />}
    {chrome && <MegaNav />}

    <slot name="body-end" />

    {/* Proofkit review overlay - dormant unless ?review=1, and only when the
        tool is switched on (PROOFKIT_ENABLED in the plugin's config.ts).
        See src/plugins/proofkit/README.md. */}
    {PROOFKIT_ENABLED && <ProofkitOverlay />}

    <script>
      // Scroll reveal (progressive enhancement) - parity with legacy app.js.
      // Gated on .js-reveal so the hidden state never applies without JS;
      // skipped under prefers-reduced-motion / missing IntersectionObserver.
      const reduce = window.matchMedia?.('(prefers-reduced-motion: reduce)').matches;
      if (!reduce && 'IntersectionObserver' in window) {
        const SELECTOR = [
          '.hero-inner > *', '.calc-hero > *',
          '.section > *', '.faq-cols', '.cta-box',
          'footer .foot-main > *', 'footer .foot-bottom',
        ].join(',');

        const blocks = Array.from(document.querySelectorAll<HTMLElement>(SELECTOR)).filter(
          // skip sr-only, and anything inside a [data-enter] section (that whole
          // section eases in on load as one block - don't also reveal its children)
          (el) => !el.classList.contains('sr-only') && !el.closest('[data-enter]')
        );
        // Rows opt in via [data-reveal-row]; their children stagger left-to-right
        // via CSS (nth-child). We only add .is-visible to the row here.
        const rows = Array.from(document.querySelectorAll<HTMLElement>('[data-reveal-row]'));

        if (blocks.length || rows.length) {
          document.documentElement.classList.add('js-reveal');

          const io = new IntersectionObserver(
            (entries) => {
              entries.forEach((e) => {
                if (e.isIntersecting) {
                  e.target.classList.add('is-visible');
                  io.unobserve(e.target);
                }
              });
            },
            { rootMargin: '0px 0px -8% 0px', threshold: 0.06 }
          );

          if (blocks.length) {
            blocks.forEach((el) => el.setAttribute('data-reveal', ''));

            // gentle stagger between blocks that share a parent
            blocks.forEach((el) => {
              const sibs = Array.from(el.parentNode!.children).filter((c) =>
                c.hasAttribute('data-reveal')
              );
              const i = sibs.indexOf(el);
              if (i > 0) el.style.transitionDelay = `${Math.min(i * 70, 280)}ms`;
            });

            blocks.forEach((el) => io.observe(el));
          }

          rows.forEach((el) => io.observe(el));

          // Buttons that fall OUTSIDE every reveal block (standalone section CTAs
          // in custom bands, hero form submits) would otherwise pop in statically
          // while the containers around them fade. Give any such button its own
          // reveal so every button eases in along with its surrounding content.
          // Skip chrome (nav/mobile-menu pills), the footer, and buttons already
          // covered by a reveal block/row/[data-enter] (they fade WITH their box -
          // this must run AFTER the blocks above are tagged with data-reveal).
          const loneButtons = Array.from(
            document.querySelectorAll<HTMLElement>('.btn, .hero-link, .hero-link-2')
          ).filter(
            (el) =>
              !el.classList.contains('nav-cta') &&
              !el.classList.contains('mm-cta') &&
              !el.closest('[data-reveal], [data-reveal-row], [data-enter]') &&
              !el.closest('footer, .mobile-menu')
          );
          loneButtons.forEach((el) => {
            el.setAttribute('data-reveal', '');
            io.observe(el);
          });
        }
      }
    </script>
  </body>
</html>

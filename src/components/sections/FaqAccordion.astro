---
/**
 * FaqAccordion - the "General Questions" accordion (single-open, accessible).
 *
 * Renders the .faq-acc item list; pages compose the surrounding
 * .faq-wrap / .faq-cols / .faq-side themselves (the side card varies).
 * Questions are real <button>s; ARIA wiring matches legacy app.js.
 *
 * Pass the same entries to `faqPageSchema()` (src/lib/seo.ts) for the
 * page's FAQPage JSON-LD so markup and schema never drift.
 */
export interface FaqEntry {
  q: string;
  a: string;
}

interface Props {
  faqs: FaqEntry[];
  /** Index of the initially-open item (legacy default: the first). */
  openIndex?: number;
}

const { faqs, openIndex = 0 } = Astro.props;
---

<div class="faq-acc">
  {
    faqs.map((f, i) => (
      <div class={i === openIndex ? 'faq-item open' : 'faq-item'}>
        <button class="faq-q" type="button">
          <span class="qt">{f.q}</span>
          <span class="faq-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none">
              <line class="v" x1="12" y1="5" x2="12" y2="19" stroke="#404040" stroke-width="2" stroke-linecap="round" />
              <line x1="5" y1="12" x2="19" y2="12" stroke="#404040" stroke-width="2" stroke-linecap="round" />
            </svg>
          </span>
        </button>
        <div class="qa-wrap">
          <div class="qa">
            <p set:html={f.a} />
          </div>
        </div>
      </div>
    ))
  }
</div>

<script>
  // Single-open accessible accordion - behaviour parity with legacy app.js.
  // Runs once per page (Astro dedupes component scripts) over every .faq-acc.
  document.querySelectorAll<HTMLElement>('.faq-acc').forEach((acc, accIndex) => {
    const items = Array.from(acc.querySelectorAll<HTMLElement>('.faq-item'));
    items.forEach((item, i) => {
      const btn = item.querySelector<HTMLButtonElement>('.faq-q');
      const panel = item.querySelector<HTMLElement>('.qa-wrap');
      if (!btn || !panel) return;

      // wire ARIA relationships
      const qid = `faq-q-${accIndex}-${i}`;
      const pid = `faq-a-${accIndex}-${i}`;
      btn.id = qid;
      panel.id = pid;
      btn.setAttribute('aria-controls', pid);
      btn.setAttribute('aria-expanded', item.classList.contains('open') ? 'true' : 'false');
      panel.setAttribute('role', 'region');
      panel.setAttribute('aria-labelledby', qid);

      btn.addEventListener('click', () => {
        const willOpen = !item.classList.contains('open');
        items.forEach((other) => {
          other.classList.remove('open');
          other.querySelector('.faq-q')?.setAttribute('aria-expanded', 'false');
        });
        if (willOpen) {
          item.classList.add('open');
          btn.setAttribute('aria-expanded', 'true');
        }
      });
    });
  });
</script>

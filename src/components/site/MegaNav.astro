---
/**
 * MegaNav - the full-page navigation overlay (desktop).
 *
 * Opened by the panel-backed header links; a dark sidebar lists the four
 * sections, the cream content pane shows the active section's link columns.
 * Markup parity with the legacy app.js-injected `#nav-panel`, but rendered
 * statically from src/data/navigation.ts so every link is crawlable.
 */
import { megaNavSections } from '../../data/navigation';
---

<div id="nav-panel" role="dialog" aria-modal="true" aria-label="Site navigation">
  <!-- Left sidebar: dark olive gradient + all nav items -->
  <div id="nps-sidebar">
    <button id="nps-go-back" aria-label="Go back to main navigation">
      <svg
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M15 18l-6-6 6-6"></path>
      </svg>
      Go Back
    </button>
    <nav class="nps-nav" aria-label="Panel navigation">
      {
        megaNavSections.map((s) => (
          <button class="nps-item" data-for={s.id}>
            {s.label}
          </button>
        ))
      }
    </nav>
  </div>

  <!-- Right content: cream/white, section-specific -->
  <div id="nps-content">
    <div id="nps-scroll-area">
      {
        megaNavSections.map((s) => (
          <div class="nps-section" data-section={s.id}>
            <h2 class="nps-heading">{s.heading}</h2>
            <div class="nps-grid">
              {s.columns.map((col, i) => (
                <>
                  {/* Products keeps its wide two-list "Trade And Invest" block +
                      divider + Featured column, exactly like the legacy panel. */}
                  {col.linkGroups.length > 1 ? (
                    <div class="nps-trade-block">
                      {col.title && <p class="nps-col-title">{col.title}</p>}
                      <div class="nps-trade-cols">
                        {col.linkGroups.map((group) => (
                          <div class="nps-col-items">
                            {group.map((link) => (
                              <a href={link.href}>{link.label}</a>
                            ))}
                          </div>
                        ))}
                      </div>
                    </div>
                  ) : (
                    <div class="nps-col">
                      {col.title && <p class="nps-col-title">{col.title}</p>}
                      <div class="nps-col-items">
                        {col.linkGroups[0]!.map((link) => (
                          <a href={link.href}>{link.label}</a>
                        ))}
                      </div>
                    </div>
                  )}
                  {i < s.columns.length - 1 && <div class="nps-divider" aria-hidden="true" />}
                </>
              ))}
            </div>
            {
              s.viewAll && (
                <div class="nps-view-all">
                  <a href={s.viewAll.href}>{s.viewAll.label}</a>
                </div>
              )
            }
          </div>
        ))
      }
    </div>
  </div>
</div>

<script>
  // Overlay open/close + section switching. Behaviour parity with legacy app.js.
  const panel = document.getElementById('nav-panel');
  if (panel) {
    let active: HTMLElement | null = null;

    const openPanel = (name: string, trig?: HTMLElement) => {
      panel.setAttribute('data-open', '');
      panel.setAttribute('data-panel', name);
      if (active && active !== trig) active.setAttribute('aria-expanded', 'false');
      if (trig) {
        trig.setAttribute('aria-expanded', 'true');
        active = trig;
      }
      document.body.style.overflow = 'hidden';
    };

    const closePanel = () => {
      panel.removeAttribute('data-open');
      panel.removeAttribute('data-panel');
      document.body.style.overflow = '';
      if (active) {
        active.setAttribute('aria-expanded', 'false');
        active = null;
      }
    };

    // Header links that carry data-panel open their overlay section
    // (the "View All …" links inside the overlay do the navigating).
    document.querySelectorAll<HTMLElement>('.nav .nav-link[data-panel]').forEach((link) => {
      const section = link.getAttribute('data-panel')!;
      link.addEventListener('click', (e) => {
        e.preventDefault();
        if (panel.hasAttribute('data-open') && panel.getAttribute('data-panel') === section) {
          closePanel();
        } else {
          openPanel(section, link);
        }
      });
    });

    // Sidebar items switch the visible section.
    panel.querySelectorAll<HTMLElement>('.nps-item').forEach((it) => {
      it.addEventListener('click', () => {
        const name = it.getAttribute('data-for')!;
        panel.setAttribute('data-panel', name);
        if (active) active.setAttribute('aria-expanded', 'false');
        const trig = document.querySelector<HTMLElement>(`.nav .nav-link[data-panel="${name}"]`);
        if (trig) {
          trig.setAttribute('aria-expanded', 'true');
          active = trig;
        }
      });
    });

    panel.querySelector('#nps-go-back')?.addEventListener('click', closePanel);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && panel.hasAttribute('data-open')) closePanel();
    });
    panel.querySelectorAll('a').forEach((a) => a.addEventListener('click', closePanel));
  }
</script>

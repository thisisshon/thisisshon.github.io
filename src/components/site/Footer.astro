---
/**
 * Footer - sitewide dark footer (V4).
 * Brand + contact block, five link columns, regulatory/BSE compliance
 * bands and a copyright bar; all content from navigation.ts.
 */
import { footerBrand, footerColumns, footerCompliance, footerLegal } from '../../data/navigation';
---

<footer>
  <div class="foot-main">
    <div class="foot-brand">
      <a class="fb-logo" href="/" aria-label="Shriram Financial Services - home">
        <div class="logo-box">
          <div class="logo-crop">
            <img src="/assets/logo.svg" alt="Shriram Financial Services" width="128" height="52" />
          </div>
        </div>
      </a>
      <p class="fb-desc">{footerBrand.description}</p>
      <address class="fb-contact">
        <span class="fb-row">
          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path
              d="M12 21s-7-5.2-7-11a7 7 0 1 1 14 0c0 5.8-7 11-7 11Z"
              stroke="currentColor"
              stroke-width="1.7"
              stroke-linejoin="round"></path>
            <circle cx="12" cy="10" r="2.6" stroke="currentColor" stroke-width="1.7"></circle>
          </svg>
          <span>{footerBrand.addressLines[0]}<br />{footerBrand.addressLines[1]}</span>
        </span>
        <a class="fb-row" href={`tel:${footerBrand.phone.replace(/\s/g, '')}`}>
          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path
              d="M6.6 3.8 4.9 5.5a2 2 0 0 0-.5 2c.7 2.4 2.1 4.7 4 6.6 1.9 1.9 4.2 3.3 6.6 4a2 2 0 0 0 2-.5l1.7-1.7a1.4 1.4 0 0 0-.2-2.1l-2.3-1.6a1.4 1.4 0 0 0-1.7.1l-.9.8a12.3 12.3 0 0 1-4.2-4.2l.8-.9a1.4 1.4 0 0 0 .1-1.7L8.7 4a1.4 1.4 0 0 0-2.1-.2Z"
              stroke="currentColor"
              stroke-width="1.7"
              stroke-linejoin="round"></path>
          </svg>
          <span>{footerBrand.phone}</span>
        </a>
        <a class="fb-row" href={`mailto:${footerBrand.email}`}>
          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <rect x="3.5" y="5.5" width="17" height="13" rx="2" stroke="currentColor" stroke-width="1.7"
            ></rect>
            <path d="m4.5 7 7.5 5.6L19.5 7" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"
            ></path>
          </svg>
          <span>{footerBrand.email}</span>
        </a>
      </address>
      <div class="socials">
        <a href="#" aria-label="X">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path
              d="M17.53 3h3.2l-7 8 8.23 10h-6.44l-5.05-6.6L3.9 21H.7l7.49-8.56L.3 3h6.6l4.56 6.03L17.53 3Zm-1.12 16.1h1.77L7.68 4.8H5.78l10.63 14.3Z"
            ></path>
          </svg>
        </a>
        <a href="#" aria-label="Facebook">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path
              d="M13.5 21v-8h2.7l.4-3.1h-3.1V7.9c0-.9.25-1.5 1.55-1.5H17V3.6c-.3-.04-1.3-.13-2.46-.13-2.43 0-4.09 1.48-4.09 4.2v2.34H7.7V13h2.75v8h3.05Z"
            ></path>
          </svg>
        </a>
        <a href="#" aria-label="LinkedIn">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path
              d="M6.94 8.5H4V20h2.94V8.5ZM5.47 3.9a1.7 1.7 0 1 0 0 3.4 1.7 1.7 0 0 0 0-3.4ZM20 20h-2.94v-6.2c0-1.48-.53-2.49-1.85-2.49-1.01 0-1.61.68-1.88 1.34-.1.24-.12.57-.12.9V20H10.3s.04-10.3 0-11.5h2.94v1.63c.39-.6 1.09-1.46 2.65-1.46 1.94 0 3.4 1.27 3.4 4V20Z"
            ></path>
          </svg>
        </a>
        <a href="#" aria-label="YouTube">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path
              d="M21.58 7.2a2.8 2.8 0 0 0-1.97-1.98C17.88 4.75 12 4.75 12 4.75s-5.88 0-7.61.47A2.8 2.8 0 0 0 2.42 7.2 29.3 29.3 0 0 0 1.95 12c0 1.62.16 3.23.47 4.8a2.8 2.8 0 0 0 1.97 1.98c1.73.47 7.61.47 7.61.47s5.88 0 7.61-.47a2.8 2.8 0 0 0 1.97-1.98c.31-1.57.47-3.18.47-4.8 0-1.62-.16-3.23-.47-4.8ZM9.94 15.02V8.98L15.09 12l-5.15 3.02Z"
            ></path>
          </svg>
        </a>
      </div>
    </div>
    <nav class="foot-cols" aria-label="Footer">
      {
        footerColumns.map((col) => (
          <div class:list={['foot-col', { 'foot-col-wide': col.wide }]}>
            <h5>{col.title}</h5>
            <ul>
              {col.links.map((link) => (
                <li>
                  {link.href.startsWith('http') ? (
                    <a href={link.href} target="_blank" rel="noopener">
                      {link.label}
                    </a>
                  ) : (
                    <a href={link.href}>{link.label}</a>
                  )}
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </nav>
  </div>

  <div class="foot-legal">
    {
      footerCompliance.map((band) => (
        <div class="foot-note">
          <h5>{band.title}</h5>
          {band.paragraphs.map((p) => (
            <p>
              {p.strong && <strong>{p.strong}</strong>}
              {p.text}
            </p>
          ))}
        </div>
      ))
    }
  </div>

  <div class="foot-bottom">
    <span class="copy">{footerLegal.copyright}</span>
    <span class="foot-reg"><span class="reg-dot" aria-hidden="true"></span>{footerLegal.registration}</span>
  </div>
</footer>

<button class="to-top" aria-label="Back to top">
  <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
    <path
      d="M12 19V6M6 11l6-6 6 6"
      stroke="currentColor"
      stroke-width="1.8"
      stroke-linecap="round"
      stroke-linejoin="round"
    ></path>
  </svg>
</button>

<script>
  // Back-to-top: appears after 600px of scroll (was duplicated per page).
  const tt = document.querySelector<HTMLButtonElement>('.to-top');
  if (tt) {
    window.addEventListener(
      'scroll',
      () => tt.classList.toggle('show', window.pageYOffset > 600),
      { passive: true }
    );
    tt.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
  }
</script>

---
/**
 * Header - sticky site header (auto-hides on scroll down, reappears on
 * scroll up) with the primary nav, Login + CTA actions and the hamburger
 * that opens the mobile menu. Markup parity with the legacy `.nav` header.
 *
 * Panel-backed primary links (Products / Research Centre / Calculators /
 * Support) open the MegaNav overlay; behaviour is wired in the script at
 * the bottom. All link content comes from src/data/navigation.ts.
 */
import { primaryNav, headerActions } from '../../data/navigation';
import MobileMenu from './MobileMenu.astro';
---

<header class="nav">
  <div class="nav-left">
    <a href="/" class="nav-logo-link" aria-label="Shriram Financial Services - home">
      <div class="logo-box">
        <div class="logo-crop">
          <img src="/assets/logo.png" alt="Shriram Financial Services" />
        </div>
      </div>
    </a>
    <nav class="nav-links" aria-label="Primary">
      {
        primaryNav.map((item) => (
          <a
            class="nav-link"
            href={item.href}
            data-panel={item.panel}
            aria-haspopup={item.panel ? 'dialog' : undefined}
            aria-expanded={item.panel ? 'false' : undefined}
          >
            <span>{item.label}</span>
            {item.panel && (
              <svg class="chev" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path
                  d="M3.5 5.25 7 8.75l3.5-3.5"
                  stroke="#333333"
                  stroke-width="1.2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            )}
          </a>
        ))
      }
    </nav>
  </div>
  <div class="nav-right">
    <div class="nav-actions">
      <div class="login-wrap">
        <button class="login" type="button" aria-haspopup="true" aria-expanded="false" aria-controls="login-menu">
          <span>{headerActions.login.label}</span>
          <svg class="login-chev" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path
              d="M4 6 8 10l4-4"
              stroke="#2f7ef4"
              stroke-width="1.3"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </button>
        <div class="login-menu" id="login-menu" role="menu">
          <span class="login-item login-item--soon" role="menuitem" aria-disabled="true">Explore Antara</span>
          <a class="login-item" role="menuitem" href="https://antara.way2wealth.com/login">Antara Web Login</a>
          <span class="login-item login-item--soon" role="menuitem" aria-disabled="true">Back Office</span>
        </div>
      </div>
      <a class="btn-dark" href={headerActions.cta.href}>{headerActions.cta.label}</a>
    </div>
  </div>
  <button class="nav-toggle" aria-label="Open menu" aria-expanded="false">
    <span></span><span></span><span></span>
  </button>
</header>

<MobileMenu />

<script>
  // Mobile nav (hamburger) + sticky auto-hide header.
  // Behaviour parity with legacy app.js.
  const nav = document.querySelector<HTMLElement>('.nav');
  if (nav) {
    const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
    const menu = document.querySelector<HTMLElement>('.mobile-menu');

    const closeMenu = () => {
      if (!menu) return;
      nav.classList.remove('open');
      menu.classList.remove('open');
      toggle?.setAttribute('aria-expanded', 'false');
      document.documentElement.style.overflow = ''; // release background scroll lock
    };

    if (toggle && menu) {
      toggle.addEventListener('click', () => {
        const open = nav.classList.toggle('open');
        menu.classList.toggle('open', open);
        toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
        // Lock background scroll on the root (not <body>): locking <body> turns it into
        // the scroll container and breaks the sticky header, which then scrolls up and
        // leaves a gap above the fixed menu.
        document.documentElement.style.overflow = open ? 'hidden' : '';
      });
      menu.querySelectorAll('a').forEach((a) => a.addEventListener('click', closeMenu));
    }

    // Sticky header: hides on scroll down, reappears on scroll up.
    let last = window.pageYOffset;
    const THRESHOLD = 80;
    const DELTA = 6;
    window.addEventListener(
      'scroll',
      () => {
        if (nav.classList.contains('open')) return; // keep header put while the menu is open
        const y = window.pageYOffset;
        if (Math.abs(y - last) < DELTA) return; // ignore tiny jitters
        if (y > last && y > THRESHOLD) {
          nav.classList.add('nav--hidden'); // scrolling down
          closeMenu();
        } else {
          nav.classList.remove('nav--hidden'); // scrolling up / near top
        }
        last = y <= 0 ? 0 : y;
      },
      { passive: true }
    );
  }

  // Login dropdown: toggle on click, close on outside click / Escape.
  const loginWrap = document.querySelector<HTMLElement>('.login-wrap');
  const loginBtn = loginWrap?.querySelector<HTMLButtonElement>('.login');
  if (loginWrap && loginBtn) {
    const setOpen = (open: boolean) => {
      loginWrap.classList.toggle('open', open);
      loginBtn.setAttribute('aria-expanded', open ? 'true' : 'false');
    };
    loginBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      setOpen(!loginWrap.classList.contains('open'));
    });
    document.addEventListener('click', (e) => {
      if (!loginWrap.contains(e.target as Node)) setOpen(false);
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') setOpen(false);
    });
  }
</script>

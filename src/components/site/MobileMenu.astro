---
/**
 * MobileMenu - the hamburger menu panel (mWeb).
 *
 * Panel-backed items (Products / Research Centre / Calculators / Support)
 * expand their links inline as accordion groups; plain items navigate.
 * In the legacy site these groups were cloned from the overlay at runtime -
 * here they are server-rendered from the same navigation data, so the links
 * are crawlable and there is no cloning script.
 */
import { primaryNav, headerActions, megaNavSections } from '../../data/navigation';

const sectionById = new Map(megaNavSections.map((s) => [s.id, s]));

/** Flatten a section's links in overlay order, then its View-All link. */
function sectionLinks(id: string) {
  const s = sectionById.get(id as any);
  if (!s) return [];
  const links = s.columns.flatMap((col) => col.linkGroups.flat());
  return s.viewAll ? [...links, { ...s.viewAll, cta: true }] : links;
}
---

<div class="mobile-menu">
  <div class="mm-inner">
    {
      primaryNav.map((item) =>
        item.panel ? (
          <div class="mm-group">
            <button
              type="button"
              class="mm-acc"
              aria-expanded="false"
              aria-controls={`mm-sub-${item.panel}`}
            >
              <span>{item.label}</span>
              <svg class="mm-chev" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path
                  d="M4 6l4 4 4-4"
                  stroke="currentColor"
                  stroke-width="1.4"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </button>
            <div class="mm-sub" id={`mm-sub-${item.panel}`}>
              <div class="mm-sub-in">
                {sectionLinks(item.panel).map((link) => (
                  <a
                    href={link.href}
                    class={'cta' in link && link.cta ? 'mm-sublink mm-sub-cta' : 'mm-sublink'}
                  >
                    {link.label}
                  </a>
                ))}
              </div>
            </div>
          </div>
        ) : (
          <a class="mlink" href={item.href}>
            {item.label}
          </a>
        )
      )
    }
    <div class="mm-actions">
      <a class="login" href={headerActions.login.href}>{headerActions.login.label}</a>
      <a class="btn-dark" href={headerActions.cta.href}>{headerActions.cta.label}</a>
    </div>
  </div>
</div>

<script>
  // Accordion behaviour for the panel-backed groups.
  document.querySelectorAll<HTMLElement>('.mm-group').forEach((group) => {
    const btn = group.querySelector<HTMLButtonElement>('.mm-acc');
    btn?.addEventListener('click', () => {
      const open = group.classList.toggle('open');
      btn.setAttribute('aria-expanded', open ? 'true' : 'false');
    });
  });
</script>
